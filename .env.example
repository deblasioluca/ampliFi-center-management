# ============================================================
# ampliFi Center Management — Environment Configuration
# Copy to .env and customise for your deployment.
# ============================================================

# --- Application ---
APP_NAME="ampliFi Cleanup"
APP_ENV=dev
DEBUG=true

# --- Ports (configurable per deployment target) ---
BACKEND_PORT=8180
FRONTEND_PORT=4321
BACKEND_URL=http://127.0.0.1:${BACKEND_PORT:-8180}
POSTGRES_PORT=5433
REDIS_PORT=6380
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8125
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101

# --- Database (PostgreSQL) ---
POSTGRES_USER=amplifi
POSTGRES_PASSWORD=amplifi
POSTGRES_DB=amplifi_cleanup
DATABASE_URL=postgresql+psycopg2://amplifi:amplifi@localhost:${POSTGRES_PORT:-5433}/amplifi_cleanup
DATABASE_ASYNC_URL=postgresql+asyncpg://amplifi:amplifi@localhost:${POSTGRES_PORT:-5433}/amplifi_cleanup
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:${REDIS_PORT:-6380}/0

# --- CORS (production only — dev allows all origins) ---
# CORS_ALLOWED_ORIGINS=http://localhost:4321,https://app.example.com

# --- Auth ---
APP_SECRET_KEY=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_PROVIDER=local

# --- Auth: EntraID (v2 — enable via AUTH_PROVIDER=entraid) ---
ENTRAID_CLIENT_ID=
ENTRAID_TENANT_ID=
ENTRAID_CLIENT_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=${MAILHOG_SMTP_PORT:-1025}
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=amplifi@example.com
SMTP_TLS=false

# --- LLM: Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=

# --- LLM: SAP BTP Generative AI Hub ---
BTP_GENAI_SERVICE_URL=
BTP_GENAI_CLIENT_ID=
BTP_GENAI_CLIENT_SECRET=
BTP_GENAI_XSUAA_URL=

# --- LLM cost caps ---
LLM_DAILY_COST_CAP_USD=250.0
LLM_CHAT_DAILY_COST_CAP_USD=50.0

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=storage
S3_ENDPOINT=http://localhost:${MINIO_API_PORT:-9100}
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=amplifi-cleanup

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:${REDIS_PORT:-6380}/1
CELERY_RESULT_BACKEND=redis://localhost:${REDIS_PORT:-6380}/2

# --- Feature flags ---
FEATURE_MDG_API=false
FEATURE_DATASPHERE=false
FEATURE_ENTRAID=false

# --- SAP System (example) ---
# SAP_S4H_BASE_URL=https://20.103.171.238:44300
# SAP_S4H_CLIENT=100
# SAP_S4H_USER=macan
# SAP_S4H_PASSWORD=
# SAP_S4H_VERIFY_SSL=false

# --- Network Proxy (optional — required if your server uses a proxy for internet) ---
# If your server goes through a corporate proxy for outbound HTTPS, set these.
# The Makefile reads them for: pip install, npm install, git pull.
# HTTPS_PROXY=http://proxy-host:port
# HTTP_PROXY=http://proxy-host:port
# NO_PROXY=localhost,127.0.0.1
