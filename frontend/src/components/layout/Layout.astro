---
import '../../styles/global.css';

interface Props {
  title: string;
  requireAuth?: boolean;
  adminOnly?: boolean;
  requiredRole?: string;
}

const { title, requireAuth = false, adminOnly = false, requiredRole } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ampliFi Cost & Profit Center Clean-Up" />
    <title>{title} | ampliFi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:text-amplifi-600 focus:px-4 focus:py-2 focus:rounded focus:shadow-lg">Skip to main content</a>

    <!-- Top Navigation Bar -->
    <nav class="bg-navy-900 text-white shadow-lg sticky top-0 z-50" aria-label="Main navigation">
      <div class="max-w-screen-2xl mx-auto px-4">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center space-x-6">
            <a href="/" class="flex items-center space-x-2 font-semibold text-lg">
              <img src="/ubs-logo.svg" alt="UBS" class="h-6" />
              <span><span style="color:#E60000">a</span>mplif<span style="color:#E60000">i</span> Center Management</span>
            </a>
            <div class="w-px h-8 bg-white/20"></div>

            <!-- Navigation grouped by role -->
            <div class="hidden md:flex items-center space-x-1" id="main-nav">
              <!-- Everyone -->
              <a href="/" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors">Dashboard</a>
              <a href="/tasks" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors">My Tasks</a>
              <a href="/review" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors" id="nav-review">My Reviews</a>

              <!-- Data Manager + Admin -->
              <div class="w-px h-5 bg-white/20 mx-1" id="nav-sep-dm"></div>
              <a href="/data" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors" id="nav-data">Data</a>
              <a href="/cockpit" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors" id="nav-cockpit">Waves & Analysis</a>

              <!-- Admin only -->
              <div class="w-px h-5 bg-white/20 mx-1" id="nav-sep-admin"></div>
              <a href="/admin" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors" id="nav-admin">System</a>

              <!-- Activity (everyone) -->
              <div class="w-px h-5 bg-white/20 mx-1"></div>
              <a href="/activity" class="nav-link px-3 py-1.5 rounded text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors relative" id="nav-activity">Activity<span id="activity-badge" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-[10px] rounded-full w-4 h-4 flex items-center justify-center"></span></a>
            </div>
          </div>

          <div class="flex items-center space-x-4">
            <div id="user-menu" class="text-sm text-gray-300"></div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Sub-navigation (page-specific) -->
    <slot name="subnav" />

    <!-- Main Content -->
    <main id="main-content" class="flex-1 max-w-screen-2xl mx-auto w-full px-4 py-6" role="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto" role="contentinfo">
      <div class="max-w-screen-2xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between text-xs text-gray-400">
          <span>ampliFi Center Management</span>
          <span>&copy; {new Date().getFullYear()}</span>
        </div>
      </div>
    </footer>

    <!-- Auth redirect -->
    {requireAuth && (
      <script is:inline>
        if (!localStorage.getItem('amplifi_token')) {
          window.location.href = '/login';
        }
      </script>
    )}

    <!-- Admin-only redirect -->
    {adminOnly && (
      <script is:inline>
        try {
          var userData = JSON.parse(localStorage.getItem('amplifi_user') || '{}');
          if (userData.role !== 'admin') {
            window.location.href = '/';
          }
        } catch(e) { window.location.href = '/login'; }
      </script>
    )}

    <!-- Role-based nav visibility + active link highlighting -->
    <script is:inline>
      (function() {
        var token = localStorage.getItem('amplifi_token');
        var userMenu = document.getElementById('user-menu');
        var role = 'viewer';
        try {
          var userData = JSON.parse(localStorage.getItem('amplifi_user') || '{}');
          role = userData.role || 'viewer';
        } catch(e) {}

        // User menu
        if (token && userMenu) {
          try {
            var ud = JSON.parse(localStorage.getItem('amplifi_user') || '{}');
            var name = ud.display_name || ud.username || 'User';
            var roleLabel = {
              'admin': 'System Admin',
              'data_manager': 'Data Manager',
              'reviewer': 'Reviewer',
              'viewer': 'Viewer'
            }[role] || role;
            userMenu.innerHTML = '<span class="text-gray-400">' + name + '</span>' +
              ' <span class="text-xs bg-white/10 px-2 py-0.5 rounded ml-1">' + roleLabel + '</span>' +
              ' <button id="logout-btn" class="ml-3 text-gray-400 hover:text-white text-xs">Logout</button>';
            document.getElementById('logout-btn').addEventListener('click', function() {
              localStorage.removeItem('amplifi_token');
              localStorage.removeItem('amplifi_user');
              window.location.href = '/login';
            });
          } catch(e) {}
        } else if (userMenu) {
          userMenu.innerHTML = '<a href="/login" class="text-gray-300 hover:text-white text-sm">Login</a>';
        }

        // Role-based nav visibility
        // admin sees everything; data_manager sees Data + Cockpit; reviewer sees Reviews
        var isAdmin = (role === 'admin');
        var isDataMgr = (role === 'data_manager' || role === 'analyst' || isAdmin);
        var isReviewer = (role === 'reviewer' || isDataMgr);

        // Data Manager items
        var dmItems = ['nav-data', 'nav-cockpit', 'nav-sep-dm'];
        if (!isDataMgr) {
          dmItems.forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.style.display = 'none';
          });
        }
        // Admin items
        var adminItems = ['nav-admin', 'nav-sep-admin'];
        if (!isAdmin) {
          adminItems.forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.style.display = 'none';
          });
        }
        // Review link: show for reviewers and data managers
        if (!isReviewer) {
          var revEl = document.getElementById('nav-review');
          if (revEl) revEl.style.display = 'none';
        }

        // Active nav link highlighting
        var path = window.location.pathname;
        document.querySelectorAll('#main-nav .nav-link').forEach(function(link) {
          var linkPath = new URL(link.href).pathname;
          var isHome = linkPath === '/';
          if (isHome && path === '/') {
            link.classList.add('bg-white/10', 'text-white');
            link.classList.remove('text-gray-300');
          } else if (!isHome && path.startsWith(linkPath)) {
            link.classList.add('bg-white/10', 'text-white');
            link.classList.remove('text-gray-300');
          }
        });

        // Activity badge — check unread count
        if (token) {
          fetch('/api/activity/unread-count', {
            headers: { Authorization: 'Bearer ' + token }
          }).then(function(r) { return r.json(); }).then(function(d) {
            if (d.count > 0) {
              var badge = document.getElementById('activity-badge');
              if (badge) {
                badge.textContent = d.count > 9 ? '9+' : d.count;
                badge.classList.remove('hidden');
              }
            }
          }).catch(function() {});
        }
      })();
    </script>
  </body>
</html>
