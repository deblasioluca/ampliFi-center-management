---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Data Quality Dashboard" requireAuth={true} requiredRole="data_manager">
  <div class="mb-4">
    <a href="/cockpit" class="text-sm text-amplifi-600 hover:underline">&larr; Back to Cockpit</a>
    <h2 class="text-xl font-bold mt-2">Data Quality Dashboard</h2>
    <p class="text-sm text-gray-500 mt-1">Overview of data completeness, consistency, and quality metrics</p>
  </div>

  <!-- Summary KPIs -->
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3 mb-6" id="dq-kpis">
    <div class="card text-center py-3">
      <div class="text-xs text-gray-500">Completeness Score</div>
      <div class="text-2xl font-bold text-green-600" id="kpi-completeness">--</div>
    </div>
    <div class="card text-center py-3">
      <div class="text-xs text-gray-500">Missing Names</div>
      <div class="text-2xl font-bold text-amber-600" id="kpi-missing-names">--</div>
    </div>
    <div class="card text-center py-3">
      <div class="text-xs text-gray-500">Orphan CCs</div>
      <div class="text-2xl font-bold text-red-600" id="kpi-orphans">--</div>
    </div>
    <div class="card text-center py-3">
      <div class="text-xs text-gray-500">Duplicate Names</div>
      <div class="text-2xl font-bold text-purple-600" id="kpi-duplicates">--</div>
    </div>
    <div class="card text-center py-3">
      <div class="text-xs text-gray-500">No Balances</div>
      <div class="text-2xl font-bold text-gray-600" id="kpi-no-balance">--</div>
    </div>
    <div class="card text-center py-3">
      <div class="text-xs text-gray-500">Total CCs</div>
      <div class="text-2xl font-bold text-amplifi-600" id="kpi-total">--</div>
    </div>
  </div>

  <!-- Missing fields breakdown -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Field Completeness</h3>
      <div id="field-completeness" class="space-y-2 text-sm">Loading...</div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Entity Distribution</h3>
      <div id="entity-distribution" class="space-y-2 text-sm">Loading...</div>
    </div>
  </div>

  <!-- Upload DQ Issues (from VERAK validation etc.) -->
  <div class="card mb-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold">Upload Data Quality Issues</h3>
      <div class="flex gap-2 items-center">
        <select id="dq-status-filter" class="input text-xs w-28" onchange="loadDqIssues()">
          <option value="open">Open</option>
          <option value="">All</option>
          <option value="resolved">Resolved</option>
          <option value="auto_fixed">Auto-Fixed</option>
          <option value="suppressed">Suppressed</option>
        </select>
      </div>
    </div>
    <div id="dq-summary-row" class="flex gap-3 mb-3 text-xs"></div>
    <div id="dq-issues-table" class="text-sm">Loading...</div>
  </div>

  <!-- Issues list -->
  <div class="card">
    <h3 class="text-sm font-semibold mb-3">Data Issues</h3>
    <div id="issues-list" class="text-sm">Loading...</div>
  </div>
</Layout>

<script>
  var token = localStorage.getItem('amplifi_token');
  if (!token) window.location.href = '/login';
  var headers = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

  function pctBar(pct, color) {
    return '<div class="flex items-center gap-2"><div class="flex-1 bg-gray-100 rounded-full h-2"><div class="h-2 rounded-full ' + color + '" style="width:' + pct + '%"></div></div><span class="text-xs font-mono w-10 text-right">' + pct + '%</span></div>';
  }

  async function loadQuality() {
    try {
      // Fetch all cost centers
      var ccResp = await fetch('/api/legacy/cost-centers?size=500', { headers: headers });
      var ccData = await ccResp.json();
      var ccs = ccData.items || [];
      var total = ccs.length;
      document.getElementById('kpi-total').textContent = total;

      // Compute quality metrics
      var missingNames = 0, noEntity = 0, noResponsible = 0, inactive = 0, noBalance = 0;
      var entityDist = {};

      ccs.forEach(function(cc) {
        if (!cc.txtsh && !cc.txtmi) missingNames++;
        if (!cc.ccode) noEntity++;
        if (!cc.responsible) noResponsible++;
        if (!cc.is_active) inactive++;
        var ent = cc.ccode || 'UNKNOWN';
        entityDist[ent] = (entityDist[ent] || 0) + 1;
      });

      document.getElementById('kpi-missing-names').textContent = missingNames;
      document.getElementById('kpi-orphans').textContent = noEntity;

      // Completeness = % of CCs with all key fields populated
      var complete = ccs.filter(function(cc) {
        return cc.txtsh && cc.ccode && cc.responsible;
      }).length;
      var pct = total ? Math.round(complete / total * 100) : 0;
      document.getElementById('kpi-completeness').textContent = pct + '%';

      // Field completeness bars
      var fields = [
        { label: 'Short Name (txtsh)', val: ccs.filter(function(c) { return c.txtsh; }).length },
        { label: 'Company Code', val: ccs.filter(function(c) { return c.ccode; }).length },
        { label: 'Responsible', val: ccs.filter(function(c) { return c.responsible; }).length },
        { label: 'CO Area', val: ccs.filter(function(c) { return c.coarea; }).length },
        { label: 'Category', val: ccs.filter(function(c) { return c.category; }).length },
      ];
      var fcHtml = '';
      fields.forEach(function(f) {
        var p = total ? Math.round(f.val / total * 100) : 0;
        var color = p >= 90 ? 'bg-green-400' : p >= 70 ? 'bg-amber-400' : 'bg-red-400';
        fcHtml += '<div><div class="flex justify-between text-xs text-gray-600 mb-0.5"><span>' + f.label + '</span><span>' + f.val + '/' + total + '</span></div>' + pctBar(p, color) + '</div>';
      });
      document.getElementById('field-completeness').innerHTML = fcHtml;

      // Entity distribution
      var entHtml = '';
      var entries = Object.entries(entityDist).sort(function(a, b) { return b[1] - a[1]; });
      entries.slice(0, 15).forEach(function(e) {
        var p = Math.round(e[1] / total * 100);
        entHtml += '<div class="flex items-center gap-2 text-xs"><span class="font-mono w-16">' + e[0] + '</span><div class="flex-1 bg-gray-100 rounded-full h-2"><div class="h-2 rounded-full bg-amplifi-400" style="width:' + p + '%"></div></div><span class="w-12 text-right">' + e[1] + '</span></div>';
      });
      document.getElementById('entity-distribution').innerHTML = entHtml || '<span class="text-gray-400">No entities</span>';

      // Duplicate check
      try {
        var dupResp = await fetch('/api/legacy/data/duplicate-check?threshold=0.90&limit=50', { method: 'POST', headers: headers });
        var dupData = await dupResp.json();
        document.getElementById('kpi-duplicates').textContent = dupData.total || 0;
      } catch(e) {
        document.getElementById('kpi-duplicates').textContent = '?';
      }

      // Issues
      var issues = [];
      if (missingNames > 0) issues.push({ severity: 'warning', text: missingNames + ' cost centers have no name (txtsh/txtmi empty)' });
      if (noEntity > 0) issues.push({ severity: 'error', text: noEntity + ' cost centers have no company code' });
      if (noResponsible > 0) issues.push({ severity: 'info', text: noResponsible + ' cost centers have no responsible person assigned' });
      if (inactive > 0) issues.push({ severity: 'info', text: inactive + ' cost centers are flagged as inactive' });

      var issHtml = '';
      if (!issues.length) {
        issHtml = '<span class="text-green-600 font-medium">No issues detected!</span>';
      } else {
        issues.forEach(function(iss) {
          var icon = iss.severity === 'error' ? 'text-red-500' : iss.severity === 'warning' ? 'text-amber-500' : 'text-blue-500';
          var dot = '<span class="inline-block w-2 h-2 rounded-full mr-2 ' + icon.replace('text-', 'bg-') + '"></span>';
          issHtml += '<div class="py-1.5 border-b border-gray-100 flex items-center">' + dot + iss.text + '</div>';
        });
      }
      document.getElementById('issues-list').innerHTML = issHtml;
      document.getElementById('kpi-no-balance').textContent = '—';

    } catch(e) {
      document.getElementById('issues-list').textContent = 'Error loading data: ' + e.message;
    }
  }

  loadQuality();

  // DQ Issues from upload validation
  async function loadDqIssues() {
    var container = document.getElementById('dq-issues-table');
    var summaryRow = document.getElementById('dq-summary-row');
    var status = document.getElementById('dq-status-filter').value;
    try {
      // Summary
      var sumRes = await fetch('/api/dq/issues/summary?scope=cleanup', { headers: headers });
      if (sumRes.ok) {
        var sum = await sumRes.json();
        summaryRow.innerHTML =
          '<span class="px-2 py-1 rounded bg-red-100 text-red-700">' + (sum.total_open || 0) + ' Open</span>' +
          '<span class="px-2 py-1 rounded bg-green-100 text-green-700">' + (sum.by_status.resolved || 0) + ' Resolved</span>' +
          '<span class="px-2 py-1 rounded bg-blue-100 text-blue-700">' + (sum.by_status.auto_fixed || 0) + ' Auto-Fixed</span>' +
          '<span class="px-2 py-1 rounded bg-gray-100 text-gray-600">' + (sum.by_status.suppressed || 0) + ' Suppressed</span>';
      }

      // List issues
      var url = '/api/dq/issues?scope=cleanup&size=50';
      if (status) url += '&status=' + status;
      var res = await fetch(url, { headers: headers });
      if (!res.ok) throw new Error('Failed to load DQ issues');
      var data = await res.json();
      if (!data.items.length) {
        container.innerHTML = '<div class="text-gray-400 py-3">No issues found.</div>';
        return;
      }
      var html = '<table class="w-full text-xs"><thead><tr class="text-left text-gray-500 border-b">';
      html += '<th class="py-1.5 pr-2">Center</th><th class="py-1.5 pr-2">Field</th><th class="py-1.5 pr-2">Rule</th>';
      html += '<th class="py-1.5 pr-2">Current Value</th><th class="py-1.5 pr-2">Suggested</th>';
      html += '<th class="py-1.5 pr-2">Status</th><th class="py-1.5">Actions</th>';
      html += '</tr></thead><tbody>';
      data.items.forEach(function(iss) {
        var sevClass = iss.severity === 'error' ? 'text-red-600' : iss.severity === 'warning' ? 'text-amber-600' : 'text-blue-600';
        var statusBadge = iss.status === 'open' ? '<span class="bg-red-100 text-red-700 px-1.5 py-0.5 rounded">' + iss.status + '</span>' :
          iss.status === 'resolved' ? '<span class="bg-green-100 text-green-700 px-1.5 py-0.5 rounded">' + iss.status + '</span>' :
          iss.status === 'auto_fixed' ? '<span class="bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">auto-fix</span>' :
          '<span class="bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded">' + iss.status + '</span>';
        html += '<tr class="border-b border-gray-50 hover:bg-gray-50">';
        html += '<td class="py-1.5 pr-2 font-mono">' + (iss.cctr || iss.pctr || iss.object_id) + '</td>';
        html += '<td class="py-1.5 pr-2">' + iss.field_name + '</td>';
        html += '<td class="py-1.5 pr-2 ' + sevClass + '">' + iss.rule_code + '</td>';
        html += '<td class="py-1.5 pr-2"><code class="bg-gray-100 px-1 rounded text-xs">' + (iss.current_value || '-') + '</code></td>';
        html += '<td class="py-1.5 pr-2">' + (iss.suggested_value ? '<code class="bg-green-50 px-1 rounded text-xs">' + iss.suggested_value + '</code>' : '-') + '</td>';
        html += '<td class="py-1.5 pr-2">' + statusBadge + '</td>';
        html += '<td class="py-1.5">';
        if (iss.status === 'open') {
          html += '<button onclick="resolveDqAdmin(' + iss.id + ')" class="text-xs text-amplifi-600 hover:underline mr-2">Resolve</button>';
          html += '<button onclick="suppressDqAdmin(' + iss.id + ')" class="text-xs text-gray-500 hover:underline">Suppress</button>';
        } else if (iss.resolved_value) {
          html += '<span class="text-xs text-gray-400">' + iss.resolved_value + '</span>';
        }
        html += '</td></tr>';
      });
      html += '</tbody></table>';
      container.innerHTML = html;
    } catch(e) {
      container.innerHTML = '<div class="text-red-500">Error: ' + e.message + '</div>';
    }
  }

  window.resolveDqAdmin = async function(issueId) {
    var empGpn = prompt('Enter employee GPN to assign:');
    if (!empGpn) return;
    try {
      // Search for the employee
      var searchRes = await fetch('/api/employees?search=' + encodeURIComponent(empGpn) + '&size=5', { headers: headers });
      var searchData = await searchRes.json();
      if (!searchData.items.length) { alert('Employee not found: ' + empGpn); return; }
      var emp = searchData.items[0];
      var res = await fetch('/api/dq/issues/' + issueId + '/resolve', {
        method: 'POST', headers: headers,
        body: JSON.stringify({ employee_id: emp.id, action: 'resolve' })
      });
      if (!res.ok) throw new Error('Failed to resolve');
      loadDqIssues();
    } catch(e) { alert('Error: ' + e.message); }
  };

  window.suppressDqAdmin = async function(issueId) {
    if (!confirm('Suppress this issue?')) return;
    try {
      var res = await fetch('/api/dq/issues/' + issueId + '/resolve', {
        method: 'POST', headers: headers,
        body: JSON.stringify({ action: 'suppress' })
      });
      if (!res.ok) throw new Error('Failed to suppress');
      loadDqIssues();
    } catch(e) { alert('Error: ' + e.message); }
  };

  loadDqIssues();
</script>
