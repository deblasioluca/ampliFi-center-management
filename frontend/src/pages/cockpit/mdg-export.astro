---
import Layout from '../../components/layout/Layout.astro';
---
<Layout title="MDG Export">
  <div class="max-w-4xl mx-auto p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">MDG Export</h1>
    <p class="text-gray-600 mb-6">
      Generate Master Data Governance export files for signed-off waves.
      These files can be imported into SAP MDG for creating target cost centers.
    </p>

    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Select Wave</h3>
      <select id="sel-wave" class="border rounded px-3 py-2 w-full mb-4">
        <option value="">Select a signed-off wave...</option>
      </select>

      <div id="wave-info" class="hidden bg-gray-50 rounded p-4 mb-4 text-sm">
        <div class="grid grid-cols-2 gap-4">
          <div><span class="text-gray-500">Status:</span> <span id="info-status" class="font-medium"></span></div>
          <div><span class="text-gray-500">Total proposals:</span> <span id="info-proposals" class="font-medium"></span></div>
          <div><span class="text-gray-500">RETIRE:</span> <span id="info-retire" class="font-medium text-red-600"></span></div>
          <div><span class="text-gray-500">MERGE_MAP:</span> <span id="info-merge" class="font-medium text-amber-600"></span></div>
        </div>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">Export Format</h3>
      <div class="flex gap-4 mb-4">
        <label class="flex items-center gap-2">
          <input type="radio" name="format" value="csv" checked class="w-4 h-4"> CSV
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="format" value="xlsx" class="w-4 h-4"> Excel (XLSX)
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="format" value="json" class="w-4 h-4"> JSON
        </label>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">Include</h3>
      <div class="space-y-2 mb-6">
        <label class="flex items-center gap-2">
          <input type="checkbox" checked class="w-4 h-4" id="incl-retire"> RETIRE decisions (decommission list)
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" checked class="w-4 h-4" id="incl-merge"> MERGE_MAP decisions (mapping table)
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" checked class="w-4 h-4" id="incl-redesign"> REDESIGN decisions (new target centers)
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" class="w-4 h-4" id="incl-keep"> KEEP decisions (no-change confirmation)
        </label>
      </div>

      <button id="btn-export" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 disabled:opacity-50" disabled>
        Generate Export File
      </button>
    </div>

    <!-- Export History -->
    <div class="bg-white rounded-lg shadow p-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Recent Exports</h3>
      <div id="export-history" class="text-sm text-gray-500">No previous exports</div>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('token') || localStorage.getItem('auth_token') || sessionStorage.getItem('auth_token');
    const headers = { Authorization: `Bearer ${token}` };

    async function loadWaves() {
      try {
        const resp = await fetch('/api/waves?size=100', { headers });
        const data = await resp.json();
        const sel = document.getElementById('sel-wave');
        (data.items || []).forEach(w => {
          const opt = document.createElement('option');
          opt.value = w.id;
          opt.textContent = `${w.name} (${w.status})`;
          sel.appendChild(opt);
        });
      } catch (e) { console.error('Failed to load waves:', e); }
    }

    document.getElementById('sel-wave')?.addEventListener('change', async function () {
      const waveId = this.value;
      const infoEl = document.getElementById('wave-info');
      const btn = document.getElementById('btn-export');
      if (!waveId) { infoEl?.classList.add('hidden'); btn.disabled = true; return; }

      try {
        const resp = await fetch(`/api/waves/${waveId}`, { headers });
        const wave = await resp.json();
        document.getElementById('info-status').textContent = wave.status;
        document.getElementById('info-proposals').textContent = wave.kpis?.total_centers || '0';
        document.getElementById('info-retire').textContent = wave.kpis?.retire || '0';
        document.getElementById('info-merge').textContent = wave.kpis?.merge_map || '0';
        infoEl?.classList.remove('hidden');
        btn.disabled = false;
      } catch (e) { console.error(e); }
    });

    document.getElementById('btn-export')?.addEventListener('click', async function () {
      const waveId = document.getElementById('sel-wave').value;
      if (!waveId) return;

      const format = document.querySelector('input[name="format"]:checked')?.value || 'csv';
      const outcomes = [];
      if (document.getElementById('incl-retire').checked) outcomes.push('RETIRE');
      if (document.getElementById('incl-merge').checked) outcomes.push('MERGE_MAP');
      if (document.getElementById('incl-redesign').checked) outcomes.push('REDESIGN');
      if (document.getElementById('incl-keep').checked) outcomes.push('KEEP');

      this.disabled = true;
      this.textContent = 'Generating...';

      try {
        const params = new URLSearchParams({ format, outcomes: outcomes.join(',') });
        const resp = await fetch(`/api/waves/${waveId}/mdg-export?${params}`, { headers });
        if (!resp.ok) throw new Error(await resp.text());

        const blob = await resp.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `mdg_export_wave_${waveId}.${format}`;
        a.click();
        URL.revokeObjectURL(url);

        alert('Export downloaded successfully.');
      } catch (e) {
        alert('Export failed: ' + e.message);
      } finally {
        this.disabled = false;
        this.textContent = 'Generate Export File';
      }
    });

    loadWaves();
  </script>
</Layout>
