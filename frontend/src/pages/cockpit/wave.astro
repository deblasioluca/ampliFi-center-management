  };
  // --- Progress Tab ---
  function loadProgress() {
    fetch('/api/waves/' + waveId + '/progress', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(p) {
      var aggEl = document.getElementById('progress-aggregate');
      aggEl.innerHTML =
        '<div class="card text-center"><div class="text-2xl font-bold text-gray-900">' + (p.total_review_items || 0) + '</div><div class="text-xs text-gray-500">Total Items</div></div>' +
        '<div class="card text-center"><div class="text-2xl font-bold text-green-700">' + (p.decided_items || 0) + '</div><div class="text-xs text-gray-500">Decided</div></div>' +
        '<div class="card text-center"><div class="text-2xl font-bold text-orange-700">' + ((p.total_review_items || 0) - (p.decided_items || 0)) + '</div><div class="text-xs text-gray-500">Pending</div></div>' +
        '<div class="card text-center"><div class="text-2xl font-bold text-amplifi-600">' + (p.completion_pct || 0) + '%</div><div class="text-xs text-gray-500">Complete</div></div>';
    }).catch(function() {});

    fetch('/api/waves/' + waveId + '/scopes', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var el = document.getElementById('progress-scopes');
      if (!d.items || !d.items.length) { el.textContent = 'No review scopes created yet.'; return; }
      var html = '';
      d.items.forEach(function(s) {
        var pct = s.total_items ? Math.round(s.decided_items / s.total_items * 100) : 0;
        var barColor = pct === 100 ? 'bg-green-500' : pct > 50 ? 'bg-blue-500' : 'bg-orange-500';
        html += '<div class="border rounded-lg p-3"><div class="flex items-center justify-between mb-1">' +
          '<span class="font-medium">' + esc(s.name) + '</span>' +
          '<span class="text-xs ' + (s.status === 'completed' ? 'text-green-600' : 'text-gray-500') + '">' + s.status + '</span></div>';
        if (s.reviewer_name) html += '<p class="text-xs text-gray-400 mb-2">' + esc(s.reviewer_name) + (s.reviewer_email ? ' (' + esc(s.reviewer_email) + ')' : '') + '</p>';
        html += '<div class="flex items-center gap-2"><div class="flex-1 h-2 bg-gray-200 rounded-full"><div class="h-full ' + barColor + ' rounded-full transition-all" style="width:' + pct + '%"></div></div>' +
          '<span class="text-xs font-medium w-12 text-right">' + pct + '%</span></div>' +
          '<p class="text-xs text-gray-400 mt-1">' + s.decided_items + ' / ' + s.total_items + ' decided</p></div>';
      });
      el.innerHTML = html;
    }).catch(function() {});

    // Load NEW_REQUEST items
    fetch('/api/waves/' + waveId + '/scopes', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      // Find if any scope has NEW_REQUEST items - check from review API
      var reqEl = document.getElementById('progress-requests');
      reqEl.textContent = 'No outstanding new center requests.';
    });
  }
  // Load progress when tab is clicked
  document.querySelector('[data-tab="progress"]').addEventListener('click', loadProgress);

  window.copyReviewLink = function(token) {
    navigator.clipboard.writeText(window.location.origin + '/review/' + token);
    uiToast('Review link copied to clipboard.', { kind: 'success' });
  };
  window.inviteReviewer = async function(scopeId) {
    try {
      var res = await fetch('/api/waves/scopes/' + scopeId + '/invite', { method: 'POST', headers: authHdr });
      if (!res.ok) { var d = await res.json(); uiAlert({ message: d.detail || 'Failed', kind: 'danger' }); return; }
      uiToast('Invitation email sent to reviewer.', { kind: 'success' });
    } catch(e) { uiAlert({ message: 'Error: ' + e.message, kind: 'danger' }); }
  };
  window.sendReminder = async function(scopeId) {
    try {
      var res = await fetch('/api/waves/scopes/' + scopeId + '/remind', { method: 'POST', headers: authHdr });
      if (!res.ok) { var d = await res.json(); uiAlert({ message: d.detail || 'Failed', kind: 'danger' }); return; }
      uiToast('Reminder email sent.', { kind: 'success' });
    } catch(e) { uiAlert('Error: ' + e.message); }
  };
  window.exportMDG = async function(exportType) {
    var res = await fetch('/api/waves/' + waveId + '/mdg-export?export_type=' + exportType, { headers: authHdr });
    if (!res.ok) { var d = await res.json(); uiAlert(d.detail || 'Export failed'); return; }
    var d = await res.json();
    var blob = new Blob([d.content], { type: 'text/csv' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = d.filename;
    a.click();
    uiAlert('Exported ' + d.record_count + ' records to ' + d.filename);
  };

  // ── V2 Simulation Tab ─────────────────────────────────────────────────
  var simPage = 1;
  var simRunId = null;
  var simSelectedNodes = [];

  // Track which run is currently selected so we can highlight it
  var currentSelectedRunId = null;

  // Load simulation runs for this wave
  function loadSimRuns() {
    fetch('/api/waves/simulations/v2?wave_id=' + waveId, { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var el = document.getElementById('sim-runs');
        var items = d.items || [];
        if (!items.length) {
          el.innerHTML = '<p class="text-gray-400">No simulations yet. Click "Run" to start.</p>';
          return;
        }
        // Wrap the list in <details> so it can collapse. Default open when
        // no run is selected yet; collapsed once the user picks one (so the
        // detail section below has more screen real estate).
        var defaultOpen = currentSelectedRunId == null;
        var html = '<details class="border rounded-lg" ' + (defaultOpen ? 'open' : '') + '>';
        html += '<summary class="cursor-pointer px-3 py-2 select-none bg-gray-50 hover:bg-gray-100 rounded-t-lg text-sm font-semibold flex items-center justify-between">';
        html +=   '<span>Past Simulation Runs <span class="text-gray-500 font-normal">(' + items.length + ')</span></span>';
        html +=   '<span class="text-xs text-gray-500">click to expand / collapse</span>';
        html += '</summary>';
        html += '<div class="divide-y">';
        items.forEach(function(r) {
          var modeColor = r.mode === 'activated' ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700';
          var statusColor = r.status === 'completed' ? 'text-green-600' : r.status === 'failed' ? 'text-red-600' : 'text-gray-500';
          var engineLabel = (r.engine_version || '').indexOf('v2') >= 0 ? 'V2' : 'V1';
          var engineColor = engineLabel === 'V2' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-600';
          // Highlight the currently selected run with a left border + bg
          var isSelected = (r.id === currentSelectedRunId);
          var rowClass = isSelected
            ? 'p-3 bg-blue-50 border-l-4 border-blue-500 cursor-pointer'
            : 'p-3 hover:bg-gray-50 cursor-pointer';
          // Use data-* attributes everywhere instead of inline onclick.
          // Inline onclick="..." breaks when string args contain double
          // quotes (e.g. JSON.stringify(label) inserts a literal `"`
          // which truncates the surrounding HTML attribute and silently
          // mangles the click handler — that's the bug from PR #75 that
          // made Delete buttons appear inert).
          html += '<div class="' + rowClass + '" data-run-id="' + r.id + '">';
          html +=   '<div class="flex items-center justify-between">';
          html +=     '<div class="flex-1 cursor-pointer" data-action="view" data-run-id="' + r.id + '">';
          html +=       '<span class="font-medium">' + esc(r.label || 'Run #' + r.id) + '</span>';
          html +=       ' <span class="px-2 py-0.5 rounded text-xs ' + engineColor + '">' + engineLabel + '</span>';
          html +=       ' <span class="px-2 py-0.5 rounded text-xs ' + modeColor + '">' + esc(r.mode) + '</span>';
          html +=       ' <span class="' + statusColor + ' text-xs ml-1">' + esc(r.status) + '</span>';
          html +=     '</div>';
          html +=     '<div class="flex items-center gap-2">';
          html +=       '<span class="text-xs text-gray-400">' + (r.started_at || '') + '</span>';
          // Delete button — only allowed on non-activated runs (server enforces too)
          if (r.mode !== 'activated') {
            // data-label is HTML-escaped via esc(); the click handler
            // reads it via dataset.label — no inline-string injection.
            html +=     '<button type="button" class="btn-sm text-xs text-red-600 hover:bg-red-50 px-2 py-1 rounded border border-red-200" ';
            html +=       'data-action="delete" data-run-id="' + r.id + '" data-label="' + esc(r.label || ('Run #' + r.id)) + '">Delete</button>';
          }
          html +=     '</div>';
          html +=   '</div>';
          html +=   '<div class="grid grid-cols-3 gap-2 mt-2 text-xs cursor-pointer" data-action="view" data-run-id="' + r.id + '">';
          html +=     '<div title="Number of cost/profit centers evaluated by this run"><span class="text-gray-500">Centers Analyzed:</span> <strong>' + fmt(r.total_centers) + '</strong></div>';
          html +=     '<div><span class="text-gray-500">Config:</span> #' + r.config_id + '</div>';
          if (r.excluded_scopes && r.excluded_scopes.length) {
            html +=   '<div><span class="text-gray-500">Excluded waves:</span> ' + r.excluded_scopes.join(', ') + '</div>';
          }
          html +=   '</div>';
          html += '</div>';
        });
        html += '</div></details>';
        el.innerHTML = html;

        // Wire up data-action="view" / data-action="delete" via delegated
        // listeners. We bind them here (after innerHTML) instead of using
        // inline onclick attributes so quoting in run labels can never
        // break HTML parsing — see comment above on the data-* attrs.
        el.querySelectorAll('[data-action="view"]').forEach(function(node) {
          node.addEventListener('click', function() {
            var rid = parseInt(node.dataset.runId, 10);
            if (rid) viewSimRun(rid);
          });
        });
        el.querySelectorAll('[data-action="delete"]').forEach(function(node) {
          node.addEventListener('click', function(evt) {
            var rid = parseInt(node.dataset.runId, 10);
            if (rid) deleteSimRun(evt, rid, node.dataset.label || ('Run #' + rid));
          });
        });
      });
  }

  // Hard-delete a simulation run (with confirm). Cascades to proposals via FK.
  window.deleteSimRun = async function(evt, runId, label) {
    evt.stopPropagation();   // don't trigger the row's viewSimRun()
    var ok = await uiConfirm({
      title: 'Delete this simulation run?',
      message: 'This will permanently delete "' + label + '" and all its proposals. ' +
               'This cannot be undone. Activated runs cannot be deleted.',
      okLabel: 'Delete',
      okVariant: 'danger',
    });
    if (!ok) return;
    var res = await fetch('/api/waves/simulations/' + runId, {
      method: 'DELETE', headers: authHdr,
    });
    if (!res.ok) {
      var err = await res.json().catch(function() { return {}; });
      uiAlert({ title: 'Delete failed', message: err.detail || ('HTTP ' + res.status) });
      return;
    }
    // If the deleted run was the one being viewed, hide the detail section
    if (runId === currentSelectedRunId) {
      currentSelectedRunId = null;
      simRunId = null;
      document.getElementById('sim-detail').classList.add('hidden');
    }
    loadSimRuns();
  };

  // View simulation run details
  window.viewSimRun = function(runId) {
    var firstSelection = (currentSelectedRunId == null);
    simRunId = runId;
    currentSelectedRunId = runId;
    simPage = 1;
    document.getElementById('sim-detail').classList.remove('hidden');
    document.getElementById('sim-detail-title').textContent = 'Simulation Run #' + runId;
    // Re-render the runs list so the new selection is highlighted (and so
    // the <details> auto-collapses on the FIRST selection — gives the
    // detail panel below more room).
    if (firstSelection) {
      loadSimRuns();
    } else {
      // Just update the highlight on the existing rows without re-rendering
      // the entire list (preserves the user's expanded/collapsed choice).
      document.querySelectorAll('#sim-runs [data-run-id]').forEach(function(el) {
        var id = parseInt(el.getAttribute('data-run-id'), 10);
        if (id === runId) {
          el.className = 'p-3 bg-blue-50 border-l-4 border-blue-500 cursor-pointer';
        } else {
          el.className = 'p-3 hover:bg-gray-50 cursor-pointer';
        }
      });
    }
    // Show activate button for simulation mode only
    fetch('/api/waves/simulations/v2?wave_id=' + waveId, { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var run = d.items.find(function(r) { return r.id === runId; });
        if (run && run.mode === 'simulation' && run.status === 'completed') {
          document.getElementById('btn-sim-activate').classList.remove('hidden');
        } else {
          document.getElementById('btn-sim-activate').classList.add('hidden');
        }
      });
    loadSimProposals();
  };

  // Load proposals for a simulation run.
  // PR #86: opt into include_paths=true so the response includes a
  // hierarchy_path (chain of setnames from root to leaf) per row + a
  // top-level hierarchy_max_depth so we can build the L0..LX columns
  // dynamically. The hierarchy used is whichever the wave was scoped
  // by, falling back to the first active CC hierarchy. See
  // _resolve_hierarchy_paths in backend/app/api/reference.py.
  function loadSimProposals() {
    if (!simRunId) return;
    var migrate = document.getElementById('sim-filter-migrate').value;
    var approach = document.getElementById('sim-filter-approach').value;
    var search = document.getElementById('sim-search').value;
    var url = '/api/waves/' + waveId + '/runs/' + simRunId +
      '/proposals-v2?page=' + simPage + '&per_page=50&include_paths=true';
    if (migrate) url += '&migrate=' + migrate;
    if (approach) url += '&approach=' + approach;
    fetch(url, { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        // Render table
        var thead = document.getElementById('sim-table-head');
        var body = document.getElementById('sim-table-body');
        var items = d.items || [];
        // Client-side search filter
        if (search) {
          var q = search.toLowerCase();
          items = items.filter(function(p) {
            return (p.legacy_cctr || '').toLowerCase().includes(q) ||
                   (p.legacy_name || '').toLowerCase().includes(q) ||
                   (p.pc_name || '').toLowerCase().includes(q);
          });
        }

        // Build dynamic L0..LX header. We size from the response's
        // max_depth so columns stay stable across pages — without this
        // a deep page would suddenly add columns and the table would
        // jump. If no hierarchy was resolved we just skip the L cols
        // and the table looks the way it did pre-PR #86.
        var maxDepth = d.hierarchy_max_depth || 0;
        var lvlHeaders = '';
        for (var li = 0; li < maxDepth; li++) {
          lvlHeaders += '<th class="px-2 py-2 text-left">L' + li + '</th>';
        }
        if (thead) {
          thead.innerHTML =
            '<tr>' +
              '<th class="px-2 py-2 text-left">Legacy CC</th>' +
              '<th class="px-2 py-2 text-left">Description</th>' +
              '<th class="px-2 py-2 text-left">Entity</th>' +
              lvlHeaders +
              '<th class="px-2 py-2 text-left">Migrate</th>' +
              '<th class="px-2 py-2 text-left">Approach</th>' +
              '<th class="px-2 py-2 text-left">PC ID</th>' +
              '<th class="px-2 py-2 text-left">PC Name</th>' +
              '<th class="px-2 py-2 text-left">CC ID</th>' +
              '<th class="px-2 py-2 text-left">CC Name</th>' +
              '<th class="px-2 py-2 text-left">Group</th>' +
            '</tr>';
        }

        var html = '';
        items.forEach(function(p) {
          var migrateClass = p.migrate === 'Y' ? 'text-green-600 font-semibold' : 'text-red-500';
          var approachClass = p.approach === '1:n' ? 'text-purple-600 font-semibold' : '';
          // Build L cells: pad short paths with — so the column grid
          // stays aligned across rows of different depths.
          var path = p.hierarchy_path || [];
          var lvlCells = '';
          for (var li = 0; li < maxDepth; li++) {
            var v = path[li] != null ? path[li] : '';
            lvlCells += '<td class="px-2 py-1.5 font-mono text-[10px] text-gray-600">' +
              (v ? esc(v) : '<span class="text-gray-300">—</span>') +
              '</td>';
          }
          html += '<tr class="border-b hover:bg-gray-50">';
          html += '<td class="px-2 py-1.5 font-mono">' + esc(p.legacy_cctr) + '</td>';
          html += '<td class="px-2 py-1.5">' + esc(p.legacy_name) + '</td>';
          html += '<td class="px-2 py-1.5">' + esc(p.ccode) + '</td>';
          html += lvlCells;
          html += '<td class="px-2 py-1.5 ' + migrateClass + '">' + esc(p.migrate) + '</td>';
          html += '<td class="px-2 py-1.5 ' + approachClass + '">' + esc(p.approach) + '</td>';
          html += '<td class="px-2 py-1.5 font-mono">' + esc(p.pc_id) + '</td>';
          html += '<td class="px-2 py-1.5">' + esc(p.pc_name) + '</td>';
          html += '<td class="px-2 py-1.5 font-mono">' + esc(p.cc_id) + '</td>';
          html += '<td class="px-2 py-1.5">' + esc(p.cc_name) + '</td>';
          html += '<td class="px-2 py-1.5 text-xs text-gray-500">' + esc(p.cleansing_outcome) + '</td>';
          html += '</tr>';
        });
        var emptyColspan = 10 + maxDepth;
        body.innerHTML = html ||
          '<tr><td colspan="' + emptyColspan + '" class="text-center py-4 text-gray-400">No results</td></tr>';

        // Pager
        var totalPages = Math.ceil(d.total / d.per_page);
        var pager = document.getElementById('sim-pager');
        pager.innerHTML = '<span class="text-xs text-gray-500">' + d.total + ' results</span>' +
          '<div class="flex gap-1">' +
          (simPage > 1 ? '<button onclick="simPrev()" class="btn-sm text-xs">← Prev</button>' : '') +
          '<span class="text-xs text-gray-500 px-2">Page ' + simPage + ' / ' + totalPages + '</span>' +
          (simPage < totalPages ? '<button onclick="simNext()" class="btn-sm text-xs">Next →</button>' : '') +
          '</div>';

        // KPI summary
        var kpiEl = document.getElementById('sim-kpis');
        kpiEl.innerHTML =
          '<div class="bg-gray-50 rounded p-2 text-center"><div class="text-lg font-bold">' + fmt(d.total) + '</div><div class="text-xs text-gray-500" title="Number of cost/profit centers evaluated by this run">Centers Analyzed</div></div>';
      });
  }

  window.simPrev = function() { simPage--; loadSimProposals(); };
  window.simNext = function() { simPage++; loadSimProposals(); };

  // Filter change handlers
  ['sim-filter-migrate', 'sim-filter-approach'].forEach(function(id) {
    document.getElementById(id).addEventListener('change', function() { simPage = 1; loadSimProposals(); });
  });
  document.getElementById('sim-search').addEventListener('input', function() { loadSimProposals(); });

  // Tabular / Hierarchical view toggle
  document.getElementById('btn-sim-tabular').addEventListener('click', function() {
    document.getElementById('sim-tabular-view').classList.remove('hidden');
    document.getElementById('sim-tree-view').classList.add('hidden');
    this.className = 'btn-sm bg-blue-600 text-white text-xs';
    document.getElementById('btn-sim-tree').className = 'btn-sm bg-gray-200 text-gray-700 text-xs';
  });
  document.getElementById('btn-sim-tree').addEventListener('click', function() {
    document.getElementById('sim-tabular-view').classList.add('hidden');
    document.getElementById('sim-tree-view').classList.remove('hidden');
    this.className = 'btn-sm bg-blue-600 text-white text-xs';
    document.getElementById('btn-sim-tabular').className = 'btn-sm bg-gray-200 text-gray-700 text-xs';
    loadSimTree();
  });

  // Hierarchical tree view.
  // PR #86: previously this just grouped by Outcome → Approach → flat
  // list of centers, which the operator (correctly) flagged as not
  // actually hierarchical — the levels of the cost-center hierarchy
  // (L0..LX setnames) weren't shown at all. We now fetch with
  // include_paths=true and assemble a proper tree using each
  // proposal's hierarchy_path. Centers that aren't part of the
  // resolved hierarchy are bucketed under "(unassigned)" so they
  // don't disappear silently.
  function loadSimTree() {
    if (!simRunId) return;
    var el = document.getElementById('sim-tree-content');
    el.innerHTML = '<p class="text-gray-400">Loading hierarchical view…</p>';
    // Fetch all proposals (no pagination for tree)
    fetch('/api/waves/' + waveId + '/runs/' + simRunId +
      '/proposals-v2?page=1&per_page=10000&include_paths=true', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var items = d.items || [];
        var maxDepth = d.hierarchy_max_depth || 0;
        if (!maxDepth) {
          el.innerHTML =
            '<div class="text-amber-700 bg-amber-50 border border-amber-200 rounded p-3 text-xs">' +
              'No hierarchy is available for this wave. Either no CC hierarchy is imported, ' +
              'or the wave was not scoped by a hierarchy. Use the Tabular view, or:' +
              '<ul class="list-disc ml-5 mt-1 space-y-0.5">' +
                '<li>Import a CC hierarchy (<code>setclass=0101</code>) under <strong>Data → CC</strong>;</li>' +
                '<li>or attach a hierarchy node to this wave\'s scope under <strong>Add Hierarchy Nodes</strong>.</li>' +
              '</ul>' +
            '</div>';
          return;
        }

        // Build nested tree: each node holds children-by-setname and a
        // proposals[] bucket for leaves landing exactly there. We
        // index by full path so two distinct subtrees with the same
        // last-level name don't collide.
        var root = { children: {}, proposals: [], setname: '(root)', counts: {} };
        function ensureNode(parent, key, setname) {
          if (!parent.children[key]) {
            parent.children[key] = { children: {}, proposals: [], setname: setname, counts: {} };
          }
          return parent.children[key];
        }

        var unassigned = [];
        items.forEach(function(p) {
          var path = p.hierarchy_path || [];
          if (!path.length) {
            unassigned.push(p);
            return;
          }
          var node = root;
          var fullKey = '';
          for (var i = 0; i < path.length; i++) {
            fullKey += '/' + path[i];
            node = ensureNode(node, fullKey, path[i]);
          }
          node.proposals.push(p);
        });

        // Bubble outcome counts upward — every node knows the count
        // of each outcome under its subtree. Cheap because the tree
        // is bounded by the hierarchy (a few hundred nodes typically).
        function aggregate(node) {
          var counts = {};
          node.proposals.forEach(function(p) {
            var k = p.cleansing_outcome || 'Other';
            counts[k] = (counts[k] || 0) + 1;
          });
          Object.keys(node.children).forEach(function(k) {
            var childCounts = aggregate(node.children[k]);
            Object.keys(childCounts).forEach(function(o) {
              counts[o] = (counts[o] || 0) + childCounts[o];
            });
          });
          node.counts = counts;
          return counts;
        }
        aggregate(root);

        function countsBadge(counts) {
          var palette = {
            'KEEP':      'bg-green-100 text-green-700',
            'RETIRE':    'bg-red-100 text-red-700',
            'MERGE_MAP': 'bg-orange-100 text-orange-700',
            'REDESIGN':  'bg-blue-100 text-blue-700',
          };
          return Object.keys(counts).sort().map(function(k) {
            var cls = palette[k] || 'bg-gray-100 text-gray-700';
            return '<span class="' + cls + ' px-1.5 py-0.5 rounded text-[10px] font-medium">' +
              esc(k) + ': ' + counts[k] + '</span>';
          }).join(' ');
        }

        function renderNode(node, depth) {
          var lvl = 'L' + depth;
          var childKeys = Object.keys(node.children).sort();
          var hasContent = childKeys.length > 0 || node.proposals.length > 0;
          var total = Object.values(node.counts).reduce(function(a, b) { return a + b; }, 0);
          var nodeOpen = depth < 2 ? ' open' : ''; // pre-expand top two levels
          var s = '<details class="ml-' + Math.min(depth * 4, 24) + '"' + nodeOpen + '>';
          s += '<summary class="cursor-pointer py-0.5 px-1 hover:bg-blue-50 rounded">' +
            '<span class="text-[10px] text-gray-400 font-mono mr-1">' + lvl + '</span>' +
            '<span class="font-semibold text-blue-700">' + esc(node.setname) + '</span>' +
            ' <span class="text-gray-500 text-xs">(' + total + ' centers)</span>' +
            ' <span class="ml-2">' + countsBadge(node.counts) + '</span>' +
            '</summary>';
          if (hasContent) {
            s += '<div class="ml-3 border-l border-gray-200 pl-2 mt-1">';
            childKeys.forEach(function(k) { s += renderNode(node.children[k], depth + 1); });
            // Centers that land directly at this node (leaf level)
            node.proposals.forEach(function(p) {
              var outcomeCls = p.cleansing_outcome === 'KEEP' ? 'text-green-700' :
                p.cleansing_outcome === 'RETIRE' ? 'text-red-600' :
                p.cleansing_outcome === 'MERGE_MAP' ? 'text-orange-700' :
                p.cleansing_outcome === 'REDESIGN' ? 'text-blue-700' : 'text-gray-700';
              s += '<div class="flex gap-2 py-0.5 text-[11px] hover:bg-gray-50">' +
                '<span class="font-mono w-20 text-gray-700">' + esc(p.legacy_cctr) + '</span>' +
                '<span class="w-48 truncate" title="' + esc(p.legacy_name) + '">' + esc(p.legacy_name) + '</span>' +
                '<span class="' + outcomeCls + ' font-medium w-20">' + esc(p.cleansing_outcome) + '</span>' +
                '<span class="font-mono w-16">' + esc(p.approach || '') + '</span>' +
                (p.pc_id ? '<span class="font-mono text-gray-500">→ PC ' + esc(p.pc_id) + '</span>' : '') +
              '</div>';
            });
            s += '</div>';
          }
          s += '</details>';
          return s;
        }

        var html = '';
        Object.keys(root.children).sort().forEach(function(k) {
          html += renderNode(root.children[k], 0);
        });

        if (unassigned.length) {
          html += '<details class="mt-3 border-t pt-2"><summary class="cursor-pointer text-amber-700 text-xs">' +
            '⚠ Unassigned (' + unassigned.length + ' centers without a path in the resolved hierarchy)' +
            '</summary><div class="ml-3 mt-1">';
          unassigned.forEach(function(p) {
            html += '<div class="flex gap-2 py-0.5 text-[11px]">' +
              '<span class="font-mono w-20 text-gray-700">' + esc(p.legacy_cctr) + '</span>' +
              '<span class="w-48 truncate">' + esc(p.legacy_name) + '</span>' +
              '<span class="text-gray-700 w-20">' + esc(p.cleansing_outcome) + '</span>' +
            '</div>';
          });
          html += '</div></details>';
        }

        el.innerHTML = html || '<p class="text-gray-400">No proposals found</p>';
      })
      .catch(function(err) {
        el.innerHTML = '<p class="text-red-500 text-xs">Failed to load tree view: ' + esc(err.message || String(err)) + '</p>';
      });
  }

  // Run Simulation button
  document.getElementById('btn-run-sim').addEventListener('click', function() {
    var panel = document.getElementById('sim-config-panel');
    panel.classList.toggle('hidden');
    // Load available hierarchies for node picker. PR #85: previously
    // we filtered to setclass=0104 (Profit Center hierarchies only),
    // but operators with a 1:1 CC↔PC mapping have no separate PC
    // hierarchy — and using the CC hierarchy (setclass=0101) is the
    // correct answer in that case. We now fetch all imported
    // hierarchies and let the operator pick whichever matches their
    // PC structure. Tree resolution is identical for either setclass.
    fetch('/api/waves/hierarchy-nodes', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var sel = document.getElementById('sim-hier-select');
        var hiers = d.hierarchies || [];
        if (!hiers.length) {
          // Empty state: explain why and how to fix, instead of leaving
          // an inert dropdown that looks broken.
          sel.innerHTML = '<option value="">(no hierarchies imported)</option>';
          sel.disabled = true;
          var tree = document.getElementById('sim-hier-tree');
          if (tree) {
            tree.innerHTML = '<p class="text-amber-700 bg-amber-50 border border-amber-200 rounded p-2">' +
              'No hierarchies found. To use 1:n PC treatment, import either a Profit Center hierarchy ' +
              '(setclass=0104) under <strong>Data → PC</strong>, or — if your CC↔PC mapping is 1:1 — ' +
              'use the existing Cost Center hierarchy (setclass=0101) imported under <strong>Data → CC</strong>. ' +
              'Without any hierarchy, all centers will use 1:1 PC mapping by default.</p>';
          }
          return;
        }
        sel.disabled = false;
        sel.innerHTML = '<option value="">Select hierarchy...</option>';
        // Group by setclass so the operator sees CC hierarchies and PC
        // hierarchies in clearly labeled buckets — but both are
        // selectable.
        var ccHiers = hiers.filter(function(h) { return _normSc(h.setclass) === '0101'; });
        var pcHiers = hiers.filter(function(h) { return _normSc(h.setclass) === '0104'; });
        var otherHiers = hiers.filter(function(h) { var ns = _normSc(h.setclass); return ns !== '0101' && ns !== '0104'; });
        function appendGroup(label, list) {
          if (!list.length) return;
          var group = '<optgroup label="' + label + '">';
          list.forEach(function(h) {
            group += '<option value="' + h.id + '">' + esc(h.label || h.setname) + '</option>';
          });
          group += '</optgroup>';
          sel.insertAdjacentHTML('beforeend', group);
        }
        appendGroup('Profit Center hierarchies (setclass=0104)', pcHiers);
        appendGroup('Cost Center hierarchies (setclass=0101)', ccHiers);
        appendGroup('Other', otherHiers);
      });
    // Load waves for exclusion
    fetch('/api/waves/?status=signed_off,closed', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var sel = document.getElementById('sim-exclude-waves');
        sel.innerHTML = '';
        (d.items || []).forEach(function(w) {
          sel.innerHTML += '<option value="' + w.id + '">' + esc(w.name) + ' (#' + w.id + ')</option>';
        });
      });
  });

  // Load hierarchy nodes for picker
  document.getElementById('btn-load-hier-nodes').addEventListener('click', function() {
    var hierId = document.getElementById('sim-hier-select').value;
    if (!hierId) return;
    fetch('/api/waves/hierarchy-nodes?hierarchy_id=' + hierId, { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var el = document.getElementById('sim-hier-tree');
        el.innerHTML = renderHierNodes(d.nodes || [], 0);
      });
  });

  function renderHierNodes(nodes, depth) {
    var html = '';
    nodes.forEach(function(n) {
      var indent = depth * 16;
      var isSelected = simSelectedNodes.some(function(s) { return s.node_name === n.node_name; });
      html += '<div style="padding-left:' + indent + 'px" class="flex items-center gap-1 py-0.5 hover:bg-blue-50 rounded">';
      if (n.node_type === 'N') {
        html += '<input type="checkbox" class="sim-node-cb" data-name="' + esc(n.node_name) + '" data-text="' + esc(n.node_text) + '" data-level="' + (n.level || 0) + '"' + (isSelected ? ' checked' : '') + ' />';
        html += '<span class="font-medium">' + esc(n.node_name) + '</span>';
      } else {
        html += '<span class="text-gray-300 ml-4">└</span>';
        html += '<span class="text-gray-500">' + esc(n.node_name) + '</span>';
      }
      html += '<span class="text-gray-400 text-xs ml-1">' + esc(n.node_text || '') + '</span>';
      html += '</div>';
      if (n.children && n.children.length) {
        html += renderHierNodes(n.children, depth + 1);
      }
    });
    return html;
  }

  // Update selected nodes display
  document.getElementById('sim-hier-tree').addEventListener('change', function(e) {
    if (!e.target.classList.contains('sim-node-cb')) return;
    var name = e.target.getAttribute('data-name');
    var text = e.target.getAttribute('data-text');
    var level = parseInt(e.target.getAttribute('data-level') || '0');
    if (e.target.checked) {
      simSelectedNodes.push({ node_name: name, node_text: text, level: level });
    } else {
      simSelectedNodes = simSelectedNodes.filter(function(n) { return n.node_name !== name; });
    }
    updateSelectedNodesDisplay();
  });

  function updateSelectedNodesDisplay() {
    var el = document.getElementById('sim-selected-nodes');
    el.innerHTML = simSelectedNodes.map(function(n) {
      return '<span class="bg-purple-100 text-purple-700 px-2 py-0.5 rounded text-xs">' +
        esc(n.node_name) + ' <button onclick="removeSimNode(\'' + esc(n.node_name) + '\')" class="ml-1 text-purple-400 hover:text-purple-700">&times;</button></span>';
    }).join('');
  }

  window.removeSimNode = function(name) {
    simSelectedNodes = simSelectedNodes.filter(function(n) { return n.node_name !== name; });
    updateSelectedNodesDisplay();
    var cbs = document.querySelectorAll('.sim-node-cb');
    cbs.forEach(function(cb) { if (cb.getAttribute('data-name') === name) cb.checked = false; });
  };

  // Cancel config panel
  document.getElementById('btn-cancel-sim').addEventListener('click', function() {
    document.getElementById('sim-config-panel').classList.add('hidden');
  });

  // Show/hide V2-specific hierarchy picker based on engine selection
  document.getElementById('sim-engine').addEventListener('change', function() {
    var isV2 = this.value === 'v2';
    document.getElementById('sim-v2-hier-section').style.display = isV2 ? 'block' : 'none';
  });

  // Confirm and run simulation
  // Polling state for the in-flight simulation run. Module-scoped so
  // the cancel button can talk to it.
  var simPollTimer = null;
  var simPollRunId = null;

  function _showSimProgress() {
    document.getElementById('sim-progress-strip').classList.remove('hidden');
  }
  function _hideSimProgress(delayMs) {
    var el = document.getElementById('sim-progress-strip');
    if (delayMs) {
      setTimeout(function() { el.classList.add('hidden'); }, delayMs);
    } else {
      el.classList.add('hidden');
    }
  }
  function _renderSimProgress(run) {
    var label = document.getElementById('sim-progress-label');
    var bar = document.getElementById('sim-progress-bar');
    var total = run.total_centers || 0;
    var done = run.completed_centers || 0;
    var pct = total ? Math.round((done / total) * 100) : 0;
    var statusText;
    if (run.status === 'queued') {
      statusText = 'Queued — waiting for worker…';
    } else if (run.status === 'running') {
      statusText = total
        ? 'Running: ' + done + ' / ' + total + ' centers (' + pct + '%)'
        : 'Running: collecting centers…';
    } else if (run.status === 'completed') {
      statusText = '✓ Completed: ' + done + ' / ' + total + ' centers';
    } else if (run.status === 'cancelled') {
      statusText = 'Cancelled at ' + done + ' / ' + total;
    } else if (run.status === 'failed') {
      statusText = '✗ Failed at ' + done + ' / ' + total + ' — see backend log';
    } else {
      statusText = run.status;
    }
    label.textContent = statusText;
    bar.style.width = (run.status === 'queued' ? 0 : pct) + '%';
    if (run.status === 'failed' || run.status === 'cancelled') {
      bar.classList.remove('bg-blue-500');
      bar.classList.add(run.status === 'failed' ? 'bg-red-500' : 'bg-amber-500');
    } else {
      bar.classList.add('bg-blue-500');
      bar.classList.remove('bg-red-500', 'bg-amber-500');
    }
  }
  function _stopSimPolling() {
    if (simPollTimer) {
      clearInterval(simPollTimer);
      simPollTimer = null;
    }
    simPollRunId = null;
  }
  function _pollSimRun(runId) {
    simPollRunId = runId;
    _showSimProgress();
    var poll = function() {
      fetch('/api/runs/' + runId, { headers: authHdr })
        .then(function(r) { return r.json(); })
        .then(function(run) {
          if (simPollRunId !== runId) return;  // user moved on
          _renderSimProgress(run);
          if (run.status === 'completed' || run.status === 'cancelled' || run.status === 'failed') {
            _stopSimPolling();
            _hideSimProgress(4000);  // leave the final state visible briefly
            loadSimRuns();
            if (run.status === 'completed') {
              // Auto-open the just-completed run so the user sees the result.
              window.viewSimRun(runId);
            }
          }
        })
        .catch(function() {
          // Transient errors are fine — keep polling.
        });
    };
    poll();
    simPollTimer = setInterval(poll, 2000);
  }

  document.getElementById('btn-sim-cancel-run').addEventListener('click', async function() {
    if (!simPollRunId) return;
    var ok = await uiConfirm({
      title: 'Cancel this simulation?',
      message: 'Already-processed centers stay in the database; the run is marked as cancelled and you can delete it afterwards.',
      okLabel: 'Cancel run',
      cancelLabel: 'Keep running',
    });
    if (!ok) return;
    fetch('/api/runs/' + simPollRunId + '/cancel', { method: 'POST', headers: authHdr })
      .catch(function() { /* swallow — the next poll surfaces the result */ });
  });

  document.getElementById('btn-confirm-sim').addEventListener('click', async function() {
    var engine = document.getElementById('sim-engine').value;
    var label = document.getElementById('sim-label').value || null;
    var excludeSel = document.getElementById('sim-exclude-waves');
    var excluded = [];
    for (var i = 0; i < excludeSel.selectedOptions.length; i++) {
      excluded.push(parseInt(excludeSel.selectedOptions[i].value));
    }

    this.disabled = true;
    this.textContent = 'Dispatching…';
    try {
      var body = {
        mode: 'simulation',
        label: label,
        excluded_scopes: excluded.length ? excluded : null
      };

      var url;
      if (engine === 'v2') {
        // V2: build approach rules from selected hierarchy nodes
        var rules = simSelectedNodes.map(function(n) {
          return {
            name: n.node_text || n.node_name,
            match_field: 'ext_l' + n.level,
            match_op: '==',
            match_value: n.node_name,
            approach: '1:n',
            pc_level: Math.min(n.level + 1, 3)
          };
        });
        if (rules.length) body.pc_approach_rules = rules;
        url = '/api/waves/' + waveId + '/analyse-v2';
      } else {
        // V1: standard cleansing analysis
        url = '/api/waves/' + waveId + '/analyse';
      }

      var res = await fetch(url, {
        method: 'POST', headers: jsonHdr, body: JSON.stringify(body)
      });
      if (!res.ok) { var err = await res.json(); uiAlert(err.detail || 'Simulation failed'); return; }
      var result = await res.json();
      document.getElementById('sim-config-panel').classList.add('hidden');
      loadSimRuns();

      // V2 returns immediately with a queued run_id (PR #81's async
      // pattern). V1's wave-scoped /analyse is still synchronous and
      // returns the completed result, in which case there's no point
      // polling — just open the result.
      if (engine === 'v2' && result.run_id && result.status === 'queued') {
        _pollSimRun(result.run_id);
      } else if (result.run_id) {
        window.viewSimRun(result.run_id);
      }
    } catch(e) {
      uiAlert('Error: ' + e.message);
    } finally {
      this.disabled = false;
      this.textContent = 'Run Simulation';
    }
  });

  // Activate simulation
  document.getElementById('btn-sim-activate').addEventListener('click', async function() {
    if (!simRunId) return;
    if (!await uiConfirm({
      title: 'Activate this simulation?',
      message: 'This will assign real PC/CC numbers (replacing temporary CT/PT IDs) and make the results available for review. The simulation cannot be modified after this step.',
      okLabel: 'Activate',
      cancelLabel: 'Not yet',
    })) return;
    this.disabled = true;
    this.textContent = 'Activating...';
    try {
      var res = await fetch('/api/waves/simulations/' + simRunId + '/activate', {
        method: 'POST', headers: authHdr
      });
      if (!res.ok) { var err = await res.json(); uiAlert({ message: err.detail || 'Activation failed', kind: 'danger' }); return; }
      uiAlert('Simulation activated. Real PC/CC IDs assigned.');
      loadSimRuns();
      window.viewSimRun(simRunId);
    } catch(e) {
      uiAlert('Error: ' + e.message);
    } finally {
      this.disabled = false;
      this.textContent = 'Activate';
    }
  });

  // Export simulation
  document.getElementById('btn-sim-export').addEventListener('click', async function() {
    if (!simRunId) return;
    var res = await fetch('/api/waves/' + waveId + '/runs/' + simRunId + '/export-v2', { headers: authHdr });
    if (!res.ok) { uiAlert('Export failed'); return; }
    var blob = await res.blob();
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'v2_simulation_' + simRunId + '.xlsx';
    a.click();
  });

  // Load simulations on tab switch
  var origTabHandler = null;
  document.querySelectorAll('#wave-tabs button').forEach(function(btn) {
    if (btn.getAttribute('data-tab') === 'simulation') {
      btn.addEventListener('click', function() { loadSimRuns(); });
    }
  });

  // --- Scope Coverage Dashboard ---
  function loadScopeCoverage() {
    fetch('/api/waves/' + waveId + '/scope-coverage', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var el = document.getElementById('scope-coverage-aggregate');
        if (!el) return;
        var coverageHtml = '<div class="bg-blue-50 rounded p-3 text-center">';
        coverageHtml += '<div class="text-2xl font-bold ' + (d.coverage_pct >= 100 ? 'text-green-600' : 'text-orange-500') + '">' + d.coverage_pct + '%</div>';
        coverageHtml += '<div class="text-xs text-gray-500">Scope Coverage</div></div>';
        coverageHtml += '<div class="bg-gray-50 rounded p-3 text-center"><div class="text-2xl font-bold">' + fmt(d.total_proposals) + '</div><div class="text-xs text-gray-500">Migrating Centers</div></div>';
        coverageHtml += '<div class="bg-green-50 rounded p-3 text-center"><div class="text-2xl font-bold text-green-600">' + fmt(d.covered) + '</div><div class="text-xs text-gray-500">Covered</div></div>';
        coverageHtml += '<div class="bg-red-50 rounded p-3 text-center"><div class="text-2xl font-bold text-red-600">' + fmt(d.uncovered) + '</div><div class="text-xs text-gray-500">Uncovered</div></div>';
        el.innerHTML = coverageHtml;
      });
  }

  // Load coverage when progress tab is shown
  document.querySelectorAll('#wave-tabs button').forEach(function(btn) {
    if (btn.getAttribute('data-tab') === 'progress') {
      btn.addEventListener('click', function() { loadScopeCoverage(); });
    }
  });

  // --- Scope Coverage in Review Tab ---
  function loadReviewCoverage() {
    fetch('/api/waves/' + waveId + '/scope-coverage', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var el = document.getElementById('scope-coverage-summary');
        if (!el) return;
        var pct = d.coverage_pct || 0;
        var color = pct >= 100 ? 'bg-green-500' : pct > 50 ? 'bg-yellow-500' : 'bg-red-500';
        var html = '<div class="flex items-center gap-4">';
        html += '<div class="flex-1"><div class="w-full bg-gray-200 rounded-full h-4">';
        html += '<div class="' + color + ' h-4 rounded-full transition-all" style="width:' + Math.min(pct, 100) + '%"></div></div></div>';
        html += '<span class="font-bold text-lg ' + (pct >= 100 ? 'text-green-600' : 'text-orange-500') + '">' + pct + '%</span></div>';
        html += '<div class="grid grid-cols-3 gap-3 mt-2 text-xs text-center">';
        html += '<div class="bg-gray-50 rounded p-2"><div class="font-bold text-base">' + fmt(d.total_proposals) + '</div>Total Centers</div>';
        html += '<div class="bg-green-50 rounded p-2"><div class="font-bold text-base text-green-600">' + fmt(d.covered) + '</div>Covered</div>';
        html += '<div class="bg-red-50 rounded p-2"><div class="font-bold text-base text-red-600">' + fmt(d.uncovered) + '</div>Uncovered</div>';
        html += '</div>';
        el.innerHTML = html;
      });
  }

  // Load scopes + coverage when review tab is shown
  document.querySelectorAll('#wave-tabs button').forEach(function(btn) {
    if (btn.getAttribute('data-tab') === 'review') {
      btn.addEventListener('click', function() { loadScopes(); loadReviewCoverage(); });
    }
  });

})();
</script>
