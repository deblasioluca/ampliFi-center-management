---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Wave Detail" requireAuth={true} requiredRole="data_manager">
  <div id="wave-header" class="mb-6">Loading wave...</div>

  <!-- Wave Progress Pipeline -->
  <div id="wave-pipeline" class="mb-6 hidden">
    <div class="bg-white border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Wave Progress</span>
        <span id="wave-status-badge" class="px-3 py-1 rounded-full text-xs font-medium"></span>
      </div>
      <div class="flex items-center gap-0" id="pipeline-steps">
        <!-- Steps injected by JS -->
      </div>
      <div class="mt-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="h-2 flex-1 bg-gray-200 rounded-full overflow-hidden" style="width:120px">
            <div id="progress-bar" class="h-full bg-amplifi-500 transition-all" style="width:0%"></div>
          </div>
          <p id="progress-text" class="text-xs text-gray-500"></p>
        </div>
        <div id="wave-actions" class="flex gap-2"></div>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white border-b border-gray-200 rounded-t-lg mb-0">
    <div class="flex space-x-0" id="wave-tabs">
      <button class="tab-active px-4 py-3" data-tab="scope">Scope</button>
      <button class="tab px-4 py-3" data-tab="simulation">Decision Tree</button>
      <button class="tab px-4 py-3" data-tab="proposals">Proposals</button>
      <button class="tab px-4 py-3" data-tab="review">Review Scopes</button>
      <button class="tab px-4 py-3" data-tab="progress">Progress</button>
    </div>
  </div>

  <div class="card rounded-t-none border-t-0">
    <!-- Scope Tab -->
    <div id="tab-scope">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Wave Scope</h3>
        <div class="flex gap-2">
          <button id="btn-add-entities" class="btn-amplifi text-sm">+ Add Entities</button>
          <button id="btn-add-hier" class="btn-secondary text-sm">+ Add Hierarchy Nodes</button>
        </div>
      </div>
      <p class="text-xs text-gray-500 mb-3">Define scope by selecting entities (company codes) and/or hierarchy nodes. Only cost centers matching the selected scope will be included in the analysis.</p>
      <h4 class="text-sm font-medium text-gray-700 mb-2">Entities in Scope</h4>
      <div id="scope-entities" class="text-sm mb-4">Loading...</div>
      <h4 class="text-sm font-medium text-gray-700 mb-2">Hierarchy Nodes in Scope</h4>
      <div id="scope-hier-nodes" class="text-sm">
        <p class="text-xs text-gray-400">No hierarchy nodes selected. Click "+ Add Hierarchy Nodes" to narrow scope by hierarchy.</p>
      </div>
    </div>

    <!-- Analysis Tab — hidden, kept for backward JS compatibility.
         The Analysis tab and Simulation tab were doing essentially the same
         thing (both create AnalysisRun rows in 'simulation' mode by default).
         The Decision Tree tab below is now the single entry point. The DOM
         here is kept so the existing analysis-related JS (loadRuns, runAnalysis,
         loadConfigVersions, proposeRun) continues to work without modification.
         The Tab BUTTON for it has been removed from the tab strip above. -->
    <div id="tab-analysis" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Analysis Runs</h3>
        <div class="flex items-center gap-2">
          <select id="analysis-engine" class="input text-sm" style="width:200px">
            <option value="v1">V1 — Standard Cleansing</option>
            <option value="v2">V2 — CEMA Migration</option>
          </select>
          <select id="analysis-config-version" class="input text-sm" style="width:220px">
            <option value="">Default config</option>
          </select>
          <a id="link-compare-runs" href="#" class="btn-secondary text-sm hidden">Compare Runs</a>
          <button id="btn-run-analysis" class="btn-amplifi text-sm">Run Analysis</button>
        </div>
      </div>
      <div id="analysis-runs" class="text-sm">Loading...</div>
    </div>

    <!-- Decision Tree Tab (was: 'Simulation' — consolidated UX) -->
    <div id="tab-simulation" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Decision Tree</h3>
        <div class="flex gap-2">
          <button id="btn-run-sim" class="btn-amplifi text-sm">Run</button>
        </div>
      </div>
      <p class="text-xs text-gray-500 mb-4">Run the decision tree on this wave's scope. Default mode is <strong>Simulation</strong> — non-destructive, versioned, can be compared. Use the <strong>Activate</strong> button on a completed simulation to commit its proposals.</p>

      <!-- Simulation Config Panel -->
      <div id="sim-config-panel" class="border rounded-lg p-4 mb-4 bg-gray-50 hidden">
        <h4 class="text-sm font-semibold mb-3">Simulation Configuration</h4>
        <div class="grid grid-cols-3 gap-4 mb-3">
          <div>
            <label class="block text-xs font-medium mb-1">Engine</label>
            <select id="sim-engine" class="input text-sm">
              <option value="v2">V2 — CEMA Migration</option>
              <option value="v1">V1 — Standard Cleansing</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium mb-1">Label (optional)</label>
            <input id="sim-label" class="input text-sm" placeholder="e.g. Baseline Q2 2026" />
          </div>
          <div>
            <label class="block text-xs font-medium mb-1">Exclude Waves (completed)</label>
            <select id="sim-exclude-waves" class="input text-sm" multiple></select>
          </div>
        </div>
        <div class="mb-3" id="sim-v2-hier-section">
          <label class="block text-xs font-semibold mb-2">PC Approach — Hierarchy Node Selection (V2 only)</label>
          <details class="bg-blue-50 border border-blue-200 rounded mb-2 text-xs">
            <summary class="cursor-pointer px-3 py-1.5 font-medium text-blue-900 select-none">
              ℹ️ What does PC Approach do?
            </summary>
            <div class="px-3 pb-2 pt-1 text-blue-900 space-y-1.5 leading-relaxed">
              <p>
                The V2 CEMA migration engine decides for each cost center
                whether to map its postings to a single profit center
                (<strong>1:1</strong>, the default and cleanest case) or to
                multiple profit centers based on a split key
                (<strong>1:n</strong>, used for shared services and group
                functions where one cost center logically serves many
                business units).
              </p>
              <p>
                Pick one or more <strong>nodes</strong> from a Profit Center
                hierarchy below to flag every CC under those nodes as 1:n.
                Common picks: <em>Group Functions</em>, <em>Asset
                Management</em>, <em>Corporate Real Estate</em>. Centers
                outside the selected nodes default to 1:1.
              </p>
              <p>
                If the dropdown below is empty, you don't have any
                hierarchies imported yet — go to <em>Data → PC</em> and
                import one with <code>setclass = 0104</code>, or use an
                existing Cost Center hierarchy (<code>setclass = 0101</code>)
                if your CC↔PC mapping is 1:1 — both setclasses are
                selectable here.
              </p>
            </div>
          </details>
          <p class="text-xs text-gray-500 mb-2">Select hierarchy nodes for 1:n PC treatment (e.g., Group Functions, Asset Management). All other centers default to 1:1.</p>
          <div class="flex gap-2 mb-2">
            <select id="sim-hier-select" class="input text-sm w-64">
              <option value="">Select hierarchy...</option>
            </select>
            <button id="btn-load-hier-nodes" class="btn-secondary text-xs">Load Nodes</button>
          </div>
          <div id="sim-hier-tree" class="max-h-48 overflow-y-auto border rounded p-2 text-xs bg-white">
            <p class="text-gray-400">Select a hierarchy and click Load Nodes</p>
          </div>
          <div id="sim-selected-nodes" class="flex flex-wrap gap-1 mt-2"></div>
        </div>
        <div class="flex justify-end gap-2">
          <button id="btn-cancel-sim" class="btn-secondary text-sm">Cancel</button>
          <button id="btn-confirm-sim" class="btn-amplifi text-sm">Run Simulation</button>
        </div>
      </div>

      <!-- Progress strip for in-flight V2 (and V1) simulations.
           Shown while a queued/running run is active, hidden when
           terminal. Mirrors the strip used on the global Analytics
           Dashboard so both flows feel consistent. -->
      <div id="sim-progress-strip" class="hidden mb-3 px-3 py-2 bg-blue-50 border border-blue-200 rounded">
        <div class="flex items-center justify-between mb-1">
          <span id="sim-progress-label" class="text-xs font-medium text-blue-900">Queued…</span>
          <button id="btn-sim-cancel-run" class="text-xs text-amber-700 hover:underline" type="button">Cancel</button>
        </div>
        <div class="h-1.5 bg-blue-100 rounded overflow-hidden">
          <div id="sim-progress-bar" class="h-full bg-blue-500 transition-all" style="width: 0%"></div>
        </div>
      </div>

      <!-- Simulation Results List -->
      <div id="sim-runs" class="space-y-3 text-sm">Loading simulations...</div>

      <!-- Simulation Detail View (tabular + hierarchical toggle) -->
      <div id="sim-detail" class="hidden mt-4">
        <div class="flex items-center justify-between mb-3">
          <h4 id="sim-detail-title" class="text-sm font-semibold">Simulation Results</h4>
          <div class="flex gap-2">
            <button id="btn-sim-tabular" class="btn-sm bg-blue-600 text-white text-xs">Tabular</button>
            <button id="btn-sim-tree" class="btn-sm bg-gray-200 text-gray-700 text-xs">Hierarchical</button>
            <button id="btn-sim-export" class="btn-secondary text-xs">Export Excel</button>
            <button id="btn-sim-activate" class="btn-amplifi text-xs hidden">Activate</button>
          </div>
        </div>

        <!-- KPI Summary -->
        <div id="sim-kpis" class="grid grid-cols-6 gap-3 mb-4"></div>

        <!-- Filters -->
        <div class="flex gap-2 mb-3">
          <select id="sim-filter-migrate" class="input text-xs w-28">
            <option value="">All</option>
            <option value="Y">Migrate</option>
            <option value="N">Retire</option>
          </select>
          <select id="sim-filter-approach" class="input text-xs w-28">
            <option value="">All Approaches</option>
            <option value="1:1">1:1</option>
            <option value="1:n">1:n</option>
          </select>
          <input id="sim-search" class="input text-xs w-48" placeholder="Search center..." />
        </div>

        <!-- Tabular View -->
        <div id="sim-tabular-view">
          <div class="overflow-x-auto">
            <table class="w-full text-xs">
              <thead id="sim-table-head" class="bg-gray-50 sticky top-0">
                <tr>
                  <th class="px-2 py-2 text-left">Legacy CC</th>
                  <th class="px-2 py-2 text-left">Description</th>
                  <th class="px-2 py-2 text-left">Entity</th>
                  <th class="px-2 py-2 text-left">Migrate</th>
                  <th class="px-2 py-2 text-left">Approach</th>
                  <th class="px-2 py-2 text-left">PC ID</th>
                  <th class="px-2 py-2 text-left">PC Name</th>
                  <th class="px-2 py-2 text-left">CC ID</th>
                  <th class="px-2 py-2 text-left">CC Name</th>
                  <th class="px-2 py-2 text-left">Group</th>
                </tr>
              </thead>
              <tbody id="sim-table-body"></tbody>
            </table>
          </div>
          <div id="sim-pager" class="flex items-center justify-between mt-3"></div>
        </div>

        <!-- Hierarchical View -->
        <div id="sim-tree-view" class="hidden">
          <div id="sim-tree-content" class="border rounded p-3 max-h-96 overflow-y-auto text-xs"></div>
        </div>
      </div>
    </div>

    <!-- Proposals Tab -->
    <div id="tab-proposals" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Center Proposals</h3>
        <div class="flex gap-2">
          <select id="filter-outcome" class="input text-sm w-36">
            <option value="">All Outcomes</option>
            <option value="KEEP">KEEP</option>
            <option value="RETIRE">RETIRE</option>
            <option value="MERGE_MAP">MERGE_MAP</option>
            <option value="REDESIGN">REDESIGN</option>
          </select>
          <select id="filter-target" class="input text-sm w-36">
            <option value="">All Targets</option>
            <option value="CC">CC</option>
            <option value="PC">PC</option>
            <option value="CC_AND_PC">CC+PC</option>
            <option value="PC_ONLY">PC Only</option>
            <option value="WBS_REAL">WBS Real</option>
            <option value="WBS_STAT">WBS Stat</option>
            <option value="NONE">None</option>
          </select>
        </div>
      </div>
      <div id="proposals-kpis" class="grid grid-cols-4 gap-4 mb-4"></div>
      <div id="proposals-table" class="text-sm">Loading...</div>
      <div id="proposals-pager" class="flex items-center justify-between mt-3 text-sm"></div>
    </div>

    <!-- Review Tab -->
    <div id="tab-review" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Review Scopes</h3>
        <button id="btn-create-scope" class="btn-amplifi text-sm">+ Create Scope</button>
      </div>
      <div id="review-scopes" class="text-sm">Loading...</div>

      <!-- Scope Coverage Summary -->
      <div class="mt-6 border-t pt-4">
        <h4 class="text-sm font-semibold mb-2">Scope Coverage</h4>
        <p class="text-xs text-gray-500 mb-3">Shows whether all in-scope centers have an assigned reviewer.</p>
        <div id="scope-coverage-summary" class="text-sm">Loading...</div>
      </div>
    </div>

    <!-- Progress Tab -->
    <div id="tab-progress" class="hidden">
      <h3 class="text-base font-semibold mb-4">Review Progress Dashboard</h3>
      <p class="text-xs text-gray-500 mb-4">Monitor the overall review progress across all scopes. When all scopes are complete, the wave can be signed off.</p>
      <div id="progress-aggregate" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6"></div>
      <div id="scope-coverage-aggregate" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6"></div>
      <h4 class="text-sm font-medium text-gray-700 mb-2">Per-Scope Progress</h4>
      <div id="progress-scopes" class="space-y-3 text-sm">Loading...</div>
      <h4 class="text-sm font-medium text-gray-700 mt-6 mb-2">Outstanding New Center Requests</h4>
      <div id="progress-requests" class="text-sm">Loading...</div>
    </div>
  </div>

  <!-- Why Panel Overlay -->
  <div id="why-overlay" class="hidden fixed inset-0 bg-black/50 z-40 flex items-start justify-center pt-20">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
      <h2 class="text-lg font-semibold mb-4">Why Panel</h2>
      <div id="why-content" class="text-sm"></div>
      <div class="flex justify-end mt-4">
        <button onclick="document.getElementById('why-overlay').classList.add('hidden')" class="btn-secondary">Close</button>
      </div>
    </div>
  </div>



  <!-- Add Entities Modal -->
  <div id="entities-overlay" class="hidden fixed inset-0 bg-black/50 z-40 flex items-start justify-center pt-16">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
      <h2 class="text-lg font-semibold mb-3">Add Entities to Wave</h2>
      <div class="flex items-center gap-2 mb-3">
        <input id="entity-search" class="input text-sm flex-1" placeholder="Search by code or name..." />
        <button id="btn-entity-all" class="btn-secondary text-xs whitespace-nowrap">Select All</button>
        <button id="btn-entity-none" class="btn-secondary text-xs whitespace-nowrap">Deselect All</button>
      </div>
      <div class="flex items-center justify-between mb-2">
        <span id="entity-count" class="text-xs text-gray-500">0 entities</span>
        <span id="entity-selected-count" class="text-xs font-medium text-blue-600">0 selected</span>
      </div>
      <div id="available-entities" class="max-h-72 overflow-y-auto text-sm border rounded p-1">Loading...</div>
      <div class="flex justify-end gap-2 mt-4">
        <button onclick="document.getElementById('entities-overlay').classList.add('hidden')" class="btn-secondary">Cancel</button>
        <button id="btn-confirm-add" class="btn-amplifi">Add Selected</button>
      </div>
    </div>
  </div>

  <!-- Add Hierarchy Nodes Modal -->
  <div id="hier-overlay" class="hidden fixed inset-0 bg-black/50 z-40 flex items-start justify-center pt-20">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
      <h2 class="text-lg font-semibold mb-4">Add Hierarchy Nodes to Scope</h2>
      <div class="mb-3">
        <label class="block text-xs font-medium mb-1">Select Hierarchy</label>
        <select id="hier-select" class="input text-sm">
          <option value="">Loading hierarchies...</option>
        </select>
      </div>
      <div id="hier-nodes-list" class="max-h-64 overflow-y-auto border rounded p-2 text-xs space-y-1">
        <p class="text-gray-400">Select a hierarchy to see its nodes</p>
      </div>
      <div class="flex justify-end gap-2 pt-3">
        <button type="button" onclick="document.getElementById('hier-overlay').classList.add('hidden')" class="btn-secondary">Cancel</button>
        <button type="button" id="btn-save-hier-scope" class="btn-amplifi">Add Selected</button>
      </div>
    </div>
  </div>

  <!-- Create Scope Modal -->
  <div id="scope-overlay" class="hidden fixed inset-0 bg-black/50 z-40 flex items-start justify-center pt-20">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
      <h2 class="text-lg font-semibold mb-4">Create Review Scope</h2>
      <p class="text-xs text-gray-500 mb-3">Define a scope and assign a reviewer.</p>
      <form id="scope-form" class="space-y-3">
        <div><label class="block text-xs font-medium mb-1">Scope Name</label><input id="sf-name" class="input text-sm" required /></div>
        <div><label class="block text-xs font-medium mb-1">Scope Type</label>
          <select id="sf-type" class="input text-sm">
            <option value="entity">By Entity</option>
            <option value="hierarchy_node">By Hierarchy Node</option>
            <option value="list">By CC List</option>
          </select>
          <p id="sf-type-help" class="text-[11px] text-gray-500 mt-1"></p>
        </div>
        <div id="sf-entity-wrap">
          <label class="block text-xs font-medium mb-1">Entity Filter <span class="text-gray-400 font-normal">(restricted to wave entities)</span></label>
          <div id="sf-entity-picker"></div>
        </div>
        <div id="sf-hier-wrap" class="hidden">
          <label class="block text-xs font-medium mb-1">Hierarchy Node</label>
          <div class="flex gap-2">
            <select id="sf-hier-id" class="input text-sm flex-1">
              <option value="">-- Pick a hierarchy --</option>
            </select>
            <select id="sf-hier-node" class="input text-sm flex-1" disabled>
              <option value="">-- Pick a hierarchy first --</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium mb-1">Reviewer</label>
          <div class="relative">
            <input type="text" id="sf-reviewer-search" class="input text-sm w-full" placeholder="Search user by name or email..." autocomplete="off" />
            <input type="hidden" id="sf-reviewer-name" />
            <input type="hidden" id="sf-reviewer-email" />
            <input type="hidden" id="sf-reviewer-uid" />
            <div id="sf-reviewer-results" class="hidden absolute z-10 w-full bg-white border rounded-b shadow-lg max-h-48 overflow-y-auto text-xs"></div>
          </div>
          <p class="text-[11px] text-gray-400 mt-1">Optional — you can also assign a reviewer later.</p>
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" onclick="document.getElementById('scope-overlay').classList.add('hidden')" class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-amplifi">Create</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Assign Reviewer Modal -->
  <div id="assign-reviewer-overlay" class="hidden fixed inset-0 bg-black/50 z-40 flex items-start justify-center pt-20">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md p-6">
      <h2 class="text-lg font-semibold mb-4">Assign Reviewer</h2>
      <p class="text-xs text-gray-500 mb-3">Search for a registered user to assign as the reviewer for this scope.</p>
      <form id="assign-reviewer-form" class="space-y-3">
        <div class="relative">
          <label class="block text-xs font-medium mb-1">Reviewer</label>
          <input type="text" id="ar-search" class="input text-sm w-full" placeholder="Search user by name or email..." autocomplete="off" />
          <input type="hidden" id="ar-name" />
          <input type="hidden" id="ar-email" />
          <input type="hidden" id="ar-uid" />
          <div id="ar-results" class="hidden absolute z-10 w-full bg-white border rounded-b shadow-lg max-h-48 overflow-y-auto text-xs"></div>
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" onclick="document.getElementById('assign-reviewer-overlay').classList.add('hidden')" class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-amplifi">Assign</button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script src="/ui-prompts.js" is:inline></script>
<script src="/entity-picker.js" is:inline></script>
<script src="/employee-picker.js" is:inline></script>
<script is:inline>
(function() {
  var token = localStorage.getItem('amplifi_token');
  var authHdr = { 'Authorization': 'Bearer ' + token };
  var jsonHdr = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };
  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }
  function escAttr(t) { return esc(t).replace(/"/g, '&quot;'); }
  function fmt(n) { return (n || 0).toLocaleString(); }
  var _SC_MAP = { CC: '0101', PC: '0104', ENT: '0106', ENTITY: '0106' };
  function _normSc(raw) { if (!raw) return ''; var u = String(raw).trim().toUpperCase(); return _SC_MAP[u] || u; }

  var params = new URLSearchParams(window.location.search);
  var waveId = params.get('id');
  if (!waveId) { document.getElementById('wave-header').textContent = 'No wave ID provided. Go to Cockpit.'; return; }

  var allTabs = ['scope','simulation','proposals','review','progress'];
  var activeTab = 'scope';

  function getEnabledTabs() {
    if (!wave) return allTabs;
    var step = statusToStep(wave.status, wave.entity_count || 0);
    // step 0: defining wave -> only scope
    // step 1: defining scope -> scope, simulation
    // step 2: running analysis -> scope, simulation
    // step 3+: all tabs
    if (step <= 0) return ['scope'];
    if (step <= 2) return ['scope', 'simulation'];
    return allTabs;
  }

  function updateTabStates() {
    var enabled = getEnabledTabs();
    document.querySelectorAll('#wave-tabs button').forEach(function(btn) {
      var tab = btn.getAttribute('data-tab');
      var isEnabled = enabled.indexOf(tab) >= 0;
      btn.disabled = !isEnabled;
      if (!isEnabled) {
        btn.className = 'tab px-4 py-3 opacity-40 cursor-not-allowed';
      } else if (tab === activeTab) {
        btn.className = 'tab-active px-4 py-3';
      } else {
        btn.className = 'tab px-4 py-3';
      }
    });
  }

  function switchTab(tab) {
    var enabled = getEnabledTabs();
    if (enabled.indexOf(tab) < 0) return;
    activeTab = tab;
    document.querySelectorAll('#wave-tabs button').forEach(function(b) {
      var t = b.getAttribute('data-tab');
      b.className = t === tab ? 'tab-active px-4 py-3' : (enabled.indexOf(t) < 0 ? 'tab px-4 py-3 opacity-40 cursor-not-allowed' : 'tab px-4 py-3');
    });
    allTabs.forEach(function(t) {
      var el = document.getElementById('tab-' + t);
      if (el) el.classList.toggle('hidden', t !== tab);
    });
  }

  document.querySelectorAll('#wave-tabs button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (this.disabled) return;
      switchTab(this.getAttribute('data-tab'));
    });
  });

  var wave = null;
  var preferredRunId = null;
  var statusColors = {
    draft: 'bg-gray-100 text-gray-700', analysing: 'bg-blue-100 text-blue-700',
    proposed: 'bg-purple-100 text-purple-700', locked: 'bg-yellow-100 text-yellow-700',
    in_review: 'bg-orange-100 text-orange-700', signed_off: 'bg-green-100 text-green-700',
    closed: 'bg-gray-200 text-gray-600', cancelled: 'bg-red-100 text-red-700',
  };

  // --- Wave Progress Pipeline ---
  var PIPELINE_STEPS = [
    { key: 'defining',   label: 'Defining Wave' },
    { key: 'scope',      label: 'Defining Scope' },
    { key: 'analysis',   label: 'Running Analysis' },
    { key: 'confirmed',  label: 'Confirmed Analysis' },
    { key: 'rev_start',  label: 'Review Started' },
    { key: 'rev_progress', label: 'Review In Progress' },
    { key: 'rev_done',   label: 'Review Completed' },
  ];

  function statusToStep(status, entityCount) {
    if (status === 'cancelled') return -1;
    if (status === 'closed' || status === 'signed_off') return 6;
    if (status === 'in_review') return 5;
    if (status === 'locked') return 4;
    if (status === 'proposed') return 3;
    if (status === 'analysing') return 2;
    if (status === 'draft' && entityCount > 0) return 1;
    return 0;
  }

  function renderPipeline(currentStep, reviewPct) {
    var el = document.getElementById('pipeline-steps');
    var html = '';
    PIPELINE_STEPS.forEach(function(step, idx) {
      var isDone = idx < currentStep;
      var isCurrent = idx === currentStep;
      var isFuture = idx > currentStep;

      var bg = isDone ? 'bg-green-500' : isCurrent ? 'bg-blue-600' : 'bg-gray-200';
      var textCol = isDone ? 'text-green-700' : isCurrent ? 'text-blue-700 font-semibold' : 'text-gray-400';
      var circleCol = isDone ? 'bg-green-500 text-white' : isCurrent ? 'bg-blue-600 text-white ring-2 ring-blue-300' : 'bg-gray-200 text-gray-400';
      var icon = isDone ? '&#10003;' : (idx + 1);

      html += '<div class="flex flex-col items-center flex-1 relative">';
      // connector line (left half)
      if (idx > 0) {
        var leftBg = isDone ? 'bg-green-500' : isCurrent ? 'bg-blue-400' : 'bg-gray-200';
        html += '<div class="absolute top-3 right-1/2 w-full h-0.5 ' + leftBg + '" style="z-index:0"></div>';
      }
      // circle
      html += '<div class="relative z-10 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold ' + circleCol + '">' + icon + '</div>';
      // label
      html += '<span class="text-[10px] mt-1 text-center leading-tight ' + textCol + '">' + step.label + '</span>';
      // review % annotation
      if (idx === 5 && isCurrent && reviewPct != null) {
        html += '<span class="text-[9px] text-blue-600 font-semibold mt-0.5">' + reviewPct + '% reviewed</span>';
      } else if (idx === 6 && isDone) {
        html += '<span class="text-[9px] text-green-600 font-semibold mt-0.5">100%</span>';
      }
      html += '</div>';
    });
    el.innerHTML = html;
  }

  function loadWave() {
    fetch('/api/waves/' + waveId, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(w) {
      wave = w;
      // Render header in the standard cockpit-subpage pattern: small
      // back link top-left, page title below it, no right-side back
      // button (the wave's right side already has wave-status / actions).
      document.getElementById('wave-header').innerHTML =
        '<a href="/cockpit" class="text-sm text-amplifi-600 hover:underline">\u2190 Back to Cockpit</a>' +
        '<div class="mt-2">' +
          '<h1 class="text-2xl font-bold text-gray-900">' + esc(w.name) + '</h1>' +
          '<p class="text-sm text-gray-500 mt-1">Code: ' + esc(w.code) +
            (w.is_full_scope ? ' (Full Scope)' : '') + ' | ' + w.entity_count + ' entities</p>' +
        '</div>';

      var badge = document.getElementById('wave-status-badge');
      badge.textContent = w.status.toUpperCase().replace('_', ' ');
      badge.className = 'px-3 py-1 rounded-full text-xs font-medium ' + (statusColors[w.status] || 'bg-gray-100');
      document.getElementById('wave-pipeline').classList.remove('hidden');

      // Render pipeline (review % loaded separately below)
      var currentStep = statusToStep(w.status, w.entity_count || 0);
      renderPipeline(currentStep, null);

      // Actions based on state
      var actions = '';
      if (w.status === 'draft' || w.status === 'analysing') actions += '<button onclick="runAnalysis()" class="btn-sm bg-blue-600 text-white">Run Analysis</button>';
      if (w.status === 'proposed') actions += '<button onclick="lockWave()" class="btn-sm bg-yellow-600 text-white">Lock Proposal</button>';
      if (w.status === 'proposed' || w.status === 'locked' || w.status === 'in_review') actions += '<button onclick="document.getElementById(\'scope-overlay\').classList.remove(\'hidden\')" class="btn-sm bg-orange-600 text-white">Create Scope / Invite Reviewers</button>';
      if (w.status === 'in_review') actions += '<button onclick="signoffWave()" class="btn-sm bg-green-600 text-white">Sign Off</button>';
      if (w.status === 'signed_off') {
        actions += '<button onclick="exportMDG(\'cost_center\')" class="btn-sm bg-teal-600 text-white">Export CC (MDG)</button>';
        actions += '<button onclick="exportMDG(\'profit_center\')" class="btn-sm bg-teal-600 text-white">Export PC (MDG)</button>';
        actions += '<button onclick="exportMDG(\'retire\')" class="btn-sm bg-red-600 text-white">Export Retire List</button>';
        actions += '<button onclick="closeWave()" class="btn-sm bg-gray-600 text-white">Close Wave</button>';
      }
      if (w.status === 'locked') actions += '<button onclick="unlockWave()" class="btn-sm text-yellow-700 border border-yellow-300">Unlock</button>';
      if (['draft','analysing','proposed'].includes(w.status)) actions += '<button onclick="cancelWave()" class="btn-sm text-red-600">Cancel</button>';
      document.getElementById('wave-actions').innerHTML = actions;

      preferredRunId = (w.config || {}).preferred_run_id;
      if (typeof loadHierScope === 'function') loadHierScope();
      updateTabStates();
    });

    // Load progress + update pipeline review %
    fetch('/api/waves/' + waveId + '/progress', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(p) {
      var pct = p.completion_pct || 0;
      document.getElementById('progress-bar').style.width = pct + '%';
      document.getElementById('progress-text').textContent = p.decided_items + '/' + p.total_review_items + ' items reviewed (' + pct + '%)';
      // Use the status from progress (may have been auto-corrected)
      var effectiveStatus = p.status || (wave && wave.status) || 'draft';
      if (wave && wave.status !== effectiveStatus) {
        wave.status = effectiveStatus;
        // Re-render badge + actions for the corrected status
        var badge = document.getElementById('wave-status-badge');
        badge.textContent = effectiveStatus.toUpperCase().replace('_', ' ');
        badge.className = 'px-3 py-1 rounded-full text-xs font-medium ' + (statusColors[effectiveStatus] || 'bg-gray-100');
        var actions = '';
        if (effectiveStatus === 'in_review') {
          actions += '<button onclick="document.getElementById(\'scope-overlay\').classList.remove(\'hidden\')" class="btn-sm bg-orange-600 text-white">Create Scope / Invite Reviewers</button>';
          actions += '<button onclick="signoffWave()" class="btn-sm bg-green-600 text-white">Sign Off</button>';
        }
        if (effectiveStatus === 'signed_off') {
          actions += '<button onclick="exportMDG(\'cost_center\')" class="btn-sm bg-teal-600 text-white">Export CC (MDG)</button>';
          actions += '<button onclick="exportMDG(\'profit_center\')" class="btn-sm bg-teal-600 text-white">Export PC (MDG)</button>';
          actions += '<button onclick="exportMDG(\'retire\')" class="btn-sm bg-red-600 text-white">Export Retire List</button>';
          actions += '<button onclick="closeWave()" class="btn-sm bg-gray-600 text-white">Close Wave</button>';
        }
        document.getElementById('wave-actions').innerHTML = actions;
      }
      var currentStep = statusToStep(effectiveStatus, (wave && wave.entity_count) || 0);
      renderPipeline(currentStep, pct);
    }).catch(function() {});
  }
  loadWave();

  // --- Scope ---
  function loadScope() {
    fetch('/api/waves/' + waveId + '/entities', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var el = document.getElementById('scope-entities');
      if (!d.items || !d.items.length) { el.textContent = 'No entities in scope. Click + Add Entities.'; return; }
      var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
        '<th class="py-2 px-2 text-left">Code</th><th class="py-2 px-2 text-left">Name</th>' +
        '<th class="py-2 px-2 text-left">Region</th><th class="py-2 px-2 text-right">Cost Centers</th></tr></thead><tbody>';
      d.items.forEach(function(e) {
        html += '<tr class="border-b hover:bg-gray-50"><td class="py-1.5 px-2 font-mono font-medium">' + esc(e.ccode) + '</td>' +
          '<td class="py-1.5 px-2">' + esc(e.name) + '</td><td class="py-1.5 px-2">' + esc(e.region) + '</td>' +
          '<td class="py-1.5 px-2 text-right">' + fmt(e.cost_centers) + '</td></tr>';
      });
      el.innerHTML = html + '</tbody></table>';
    });
  }
  loadScope();

  var allEntities = [];
  function updateEntityCounts() {
    var visible = document.querySelectorAll('.entity-row:not(.hidden)');
    var selected = document.querySelectorAll('.entity-cb:checked');
    document.getElementById('entity-count').textContent = allEntities.length + ' entities' + (visible.length < allEntities.length ? ' (' + visible.length + ' shown)' : '');
    document.getElementById('entity-selected-count').textContent = selected.length + ' selected';
  }

  function filterEntities() {
    var q = (document.getElementById('entity-search').value || '').toLowerCase();
    document.querySelectorAll('.entity-row').forEach(function(row) {
      var text = row.getAttribute('data-search') || '';
      row.classList.toggle('hidden', q && text.indexOf(q) < 0);
    });
    updateEntityCounts();
  }

  document.getElementById('btn-add-entities').addEventListener('click', function() {
    document.getElementById('entities-overlay').classList.remove('hidden');
    document.getElementById('entity-search').value = '';
    fetch('/api/entities?size=1000', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      allEntities = d.items || [];
      var html = '';
      allEntities.forEach(function(e) {
        var searchText = ((e.ccode || '') + ' ' + (e.name || '') + ' ' + (e.country || '') + ' ' + (e.region || '')).toLowerCase();
        html += '<label class="entity-row flex items-center gap-2 py-1 hover:bg-gray-50 px-2 rounded cursor-pointer" data-search="' + escAttr(searchText) + '">' +
          '<input type="checkbox" value="' + escAttr(e.ccode) + '" class="entity-cb" />' +
          '<span class="font-mono text-xs w-12 shrink-0">' + esc(e.ccode) + '</span>' +
          '<span class="text-sm truncate">' + esc(e.name) + '</span>' +
          (e.region ? '<span class="text-xs text-gray-400 ml-auto shrink-0">' + esc(e.region) + '</span>' : '') +
          '</label>';
      });
      document.getElementById('available-entities').innerHTML = html || '<p class="text-gray-400 p-2">No entities available.</p>';
      updateEntityCounts();
      // Bind checkbox change events
      document.querySelectorAll('.entity-cb').forEach(function(cb) {
        cb.addEventListener('change', updateEntityCounts);
      });
    });
  });

  document.getElementById('entity-search').addEventListener('input', filterEntities);

  document.getElementById('btn-entity-all').addEventListener('click', function() {
    document.querySelectorAll('.entity-row:not(.hidden) .entity-cb').forEach(function(cb) { cb.checked = true; });
    updateEntityCounts();
  });

  document.getElementById('btn-entity-none').addEventListener('click', function() {
    document.querySelectorAll('.entity-cb').forEach(function(cb) { cb.checked = false; });
    updateEntityCounts();
  });

  document.getElementById('btn-confirm-add').addEventListener('click', async function() {
    var cbs = document.querySelectorAll('.entity-cb:checked');
    var ccodes = []; cbs.forEach(function(cb) { ccodes.push(cb.value); });
    if (!ccodes.length) { uiAlert('No entities selected.'); return; }
    await fetch('/api/waves/' + waveId + '/entities', {
      method: 'POST', headers: jsonHdr, body: JSON.stringify({ ccodes: ccodes })
    });
    document.getElementById('entities-overlay').classList.add('hidden');
    loadScope(); loadWave();
  });

  // --- Hierarchy Scope Picker ---
  // Selection state lives on the server now (PR #85 — WaveHierarchyScope
  // table, surfaced via /api/waves/{id}/hierarchy-scopes). The client
  // doesn't track a parallel selectedHierNodes array anymore — that was
  // the source of the bug where adding from the modal looked OK but
  // didn't survive a page reload.
  document.getElementById('btn-add-hier').addEventListener('click', function() {
    document.getElementById('hier-overlay').classList.remove('hidden');
    var hierSel = document.getElementById('hier-select');
    hierSel.innerHTML = '<option value="">Loading...</option>';
    fetch('/api/legacy/hierarchies?size=100', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var opts = '<option value="">-- Select hierarchy --</option>';
      (d.items || []).forEach(function(h) {
        opts += '<option value="' + h.id + '">' + esc(h.setname) + ' (' + esc(h.description || '') + ')</option>';
      });
      hierSel.innerHTML = opts;
    });
  });

  document.getElementById('hier-select').addEventListener('change', function() {
    var hierId = this.value;
    var el = document.getElementById('hier-nodes-list');
    if (!hierId) { el.innerHTML = '<p class="text-gray-400">Select a hierarchy</p>'; return; }
    el.innerHTML = 'Loading nodes...';
    fetch('/api/legacy/hierarchies/' + hierId + '/nodes?size=500', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      if (!d.items || !d.items.length) { el.innerHTML = '<p class="text-gray-400">No nodes in this hierarchy.</p>'; return; }
      var html = '';
      (d.items || []).forEach(function(n) {
        var indent = (n.level || 0) * 16;
        html += '<label class="flex items-center gap-2 py-1 hover:bg-gray-50 px-2 rounded" style="padding-left:' + (8 + indent) + 'px">' +
          '<input type="checkbox" class="hier-node-cb" value="' + esc(n.setname) + '" data-hier="' + esc(d.hierarchy_id || '') + '" />' +
          '<span class="font-mono text-xs">' + esc(n.setname) + '</span>' +
          (n.description ? ' <span class="text-gray-500">' + esc(n.description) + '</span>' : '') +
          '</label>';
      });
      el.innerHTML = html;
    });
  });

  // Add selected hierarchy nodes via the proper API (PR #85).
  // Previously this PATCH'ed wave.config.hierarchy_scope but
  // WaveUpdate's Pydantic model doesn't accept `config`, so the
  // payload was silently dropped — the UI looked like it worked but
  // nothing was persisted, and on the next page load the chips
  // disappeared. The new endpoint writes WaveHierarchyScope rows
  // which the analysis pipeline (V1 _scope_query and V2) now reads
  // when building the cost-center filter.
  document.getElementById('btn-save-hier-scope').addEventListener('click', async function() {
    var cbs = document.querySelectorAll('.hier-node-cb:checked');
    if (!cbs.length) {
      document.getElementById('hier-overlay').classList.add('hidden');
      return;
    }
    // Each checkbox has both the setname (value) and the hierarchy_id
    // (data-hier) so the wave can scope by nodes from multiple
    // hierarchies if needed.
    var failures = [];
    for (var i = 0; i < cbs.length; i++) {
      var cb = cbs[i];
      var hierId = parseInt(cb.getAttribute('data-hier'), 10);
      var setname = cb.value;
      if (!hierId || !setname) continue;
      try {
        var r = await fetch('/api/waves/' + waveId + '/hierarchy-scopes', {
          method: 'POST', headers: jsonHdr,
          body: JSON.stringify({ hierarchy_id: hierId, node_setname: setname }),
        });
        if (!r.ok) {
          var d = await r.json().catch(function(){return {};});
          failures.push(setname + ': ' + (d.detail || 'HTTP ' + r.status));
        }
      } catch (e) {
        failures.push(setname + ': ' + e.message);
      }
    }
    if (failures.length) {
      uiAlert({ message: 'Some nodes could not be added:\n' + failures.join('\n'), kind: 'danger' });
    }
    document.getElementById('hier-overlay').classList.add('hidden');
    loadHierScope();
  });

  // Load the wave's hierarchy scopes from the server and render them
  // as chips with × buttons. Each × calls the DELETE endpoint and
  // re-renders. Replaces the previous client-only state — chips now
  // survive a page reload because they reflect real DB rows.
  function loadHierScope() {
    var el = document.getElementById('scope-hier-nodes');
    fetch('/api/waves/' + waveId + '/hierarchy-scopes', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var items = (data && data.items) || [];
        if (!items.length) {
          el.innerHTML = '<span class="text-xs text-gray-400 italic">No hierarchy nodes in scope.</span>';
          return;
        }
        var chips = items.map(function(it) {
          return '<span class="inline-flex items-center gap-1 bg-blue-50 text-blue-700 px-2 py-1 rounded text-xs font-mono">' +
            esc(it.node_setname) +
            ' <button data-scope-id="' + it.id + '" data-setname="' + esc(it.node_setname) + '" ' +
              'class="hier-scope-remove text-blue-500 hover:text-red-600 ml-1" title="Remove from scope">×</button>' +
            '</span>';
        }).join(' ');
        el.innerHTML = '<div class="flex flex-wrap gap-2">' + chips + '</div>';
        el.querySelectorAll('.hier-scope-remove').forEach(function(btn) {
          btn.addEventListener('click', async function() {
            var sid = btn.getAttribute('data-scope-id');
            var sname = btn.getAttribute('data-setname');
            if (!confirm('Remove "' + sname + '" from the wave scope?')) return;
            var r = await fetch('/api/waves/' + waveId + '/hierarchy-scopes/' + sid, {
              method: 'DELETE', headers: authHdr,
            });
            if (!r.ok) {
              var d = await r.json().catch(function(){return {};});
              uiAlert({ message: d.detail || 'Failed to remove', kind: 'danger' });
              return;
            }
            loadHierScope();
          });
        });
      })
      .catch(function() {
        el.innerHTML = '<span class="text-xs text-red-500">Failed to load hierarchy scope.</span>';
      });
  }

  // --- Analysis ---
  function loadRuns() {
    fetch('/api/waves/' + waveId + '/runs', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var el = document.getElementById('analysis-runs');
      if (!d.items || !d.items.length) { el.textContent = 'No analysis runs yet. Click "Run Analysis" to start.'; return; }
      var html = '<div class="space-y-3">';
      d.items.forEach(function(r) {
        var isPreferred = r.id === preferredRunId;
        var statusColor = r.status === 'completed' ? 'text-green-600' : r.status === 'running' ? 'text-blue-600' : 'text-gray-500';
        html += '<div class="border rounded-lg p-4 ' + (isPreferred ? 'border-purple-300 bg-purple-50' : '') + '">' +
          '<div class="flex items-center justify-between"><div>' +
          '<span class="font-semibold">Run #' + r.id + '</span>' +
          (isPreferred ? ' <span class="bg-purple-200 text-purple-800 px-2 py-0.5 rounded text-xs ml-2">Preferred</span>' : '') +
          ' <span class="' + statusColor + ' text-xs ml-2">' + r.status + '</span>' +
          '</div><div class="flex gap-2">';
        if (r.status === 'completed') {
          html += '<a href="/cockpit/run?id=' + r.id + '&wave=' + waveId + '" class="btn-sm bg-gray-600 text-white text-xs">View Details</a>';
          if (!isPreferred) {
            html += '<button onclick="proposeRun(' + r.id + ')" class="btn-sm bg-purple-600 text-white text-xs">Set as Preferred</button>';
          }
        }
        html += '</div></div>';
        if (r.kpis) {
          html += '<div class="grid grid-cols-4 gap-2 mt-2 text-xs">' +
            '<div><span class="text-gray-500">Total:</span> <strong>' + fmt(r.kpis.total_centers) + '</strong></div>' +
            '<div><span class="text-green-600">KEEP:</span> <strong>' + fmt(r.kpis.keep) + '</strong></div>' +
            '<div><span class="text-red-600">RETIRE:</span> <strong>' + fmt(r.kpis.retire) + '</strong></div>' +
            '<div><span class="text-orange-600">MERGE:</span> <strong>' + fmt(r.kpis.merge_map) + '</strong></div>' +
            '</div>';
        }
        if (r.started_at) html += '<p class="text-xs text-gray-400 mt-1">Started: ' + r.started_at + '</p>';
        html += '</div>';
      });
      el.innerHTML = html + '</div>';
      // Show compare link if 2+ runs
      var compareLink = document.getElementById('link-compare-runs');
      if (d.items.length >= 2) {
        compareLink.href = '/cockpit/compare?wave=' + waveId;
        compareLink.classList.remove('hidden');
      } else {
        compareLink.classList.add('hidden');
      }
    });
  }
  loadRuns();

  // Load config versions when engine changes
  function loadConfigVersions() {
    var cfgSel = document.getElementById('analysis-config-version');
    cfgSel.innerHTML = '<option value="">Default config</option>';
    fetch('/api/configs', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var items = Array.isArray(data) ? data : (data.items || []);
        items.forEach(function(c) {
          cfgSel.innerHTML += '<option value="' + c.id + '">' + esc(c.code) + ' v' + c.version + ' — ' + esc(c.name) + '</option>';
        });
      })
      .catch(function() {});
  }
  loadConfigVersions();
  document.getElementById('analysis-engine').addEventListener('change', loadConfigVersions);

  window.runAnalysis = async function() {
    var engine = document.getElementById('analysis-engine').value;
    var configId = document.getElementById('analysis-config-version').value;
    document.getElementById('btn-run-analysis').disabled = true;
    document.getElementById('btn-run-analysis').textContent = 'Running...';
    try {
      var url = engine === 'v2'
        ? '/api/waves/' + waveId + '/analyse-v2'
        : '/api/waves/' + waveId + '/analyse';
      var body = {};
      if (configId) body.config_id = parseInt(configId, 10);
      var res = await fetch(url, {
        method: 'POST',
        headers: jsonHdr,
        body: Object.keys(body).length ? JSON.stringify(body) : undefined
      });
      var d = await res.json();
      if (!res.ok) throw new Error(d.detail || 'Analysis failed');
      loadRuns(); loadWave();
    } catch(e) { uiAlert('Error: ' + e.message); }
    document.getElementById('btn-run-analysis').disabled = false;
    document.getElementById('btn-run-analysis').textContent = 'Run Analysis';
  };
  document.getElementById('btn-run-analysis').addEventListener('click', runAnalysis);

  window.proposeRun = async function(runId) {
    var res = await fetch('/api/waves/' + waveId + '/propose/' + runId, { method: 'POST', headers: authHdr });
    if (!res.ok) { var d = await res.json(); uiAlert(d.detail); return; }
    loadRuns(); loadWave();
  };

  // --- Proposals ---
  window.loadProposals = function(page) {
    page = page || 1;
    if (!preferredRunId) {
      // Find latest completed run
      fetch('/api/waves/' + waveId + '/runs', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
        var completed = (d.items || []).filter(function(r) { return r.status === 'completed'; });
        if (completed.length) { preferredRunId = completed[0].id; loadProposals(page); }
        else { document.getElementById('proposals-table').textContent = 'No completed analysis runs.'; }
      });
      return;
    }
    var outcome = document.getElementById('filter-outcome').value;
    var target = document.getElementById('filter-target').value;
    var url = '/api/runs/' + preferredRunId + '/proposals?page=' + page + '&size=50';
    if (outcome) url += '&outcome=' + outcome;
    if (target) url += '&target=' + target;

    fetch(url, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      // KPIs
      fetch('/api/runs/' + preferredRunId, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(run) {
        if (run.kpis) {
          document.getElementById('proposals-kpis').innerHTML =
            '<div class="bg-green-50 p-3 rounded text-center"><div class="text-lg font-bold text-green-700">' + fmt(run.kpis.keep) + '</div><div class="text-xs text-green-600">KEEP</div></div>' +
            '<div class="bg-red-50 p-3 rounded text-center"><div class="text-lg font-bold text-red-700">' + fmt(run.kpis.retire) + '</div><div class="text-xs text-red-600">RETIRE</div></div>' +
            '<div class="bg-orange-50 p-3 rounded text-center"><div class="text-lg font-bold text-orange-700">' + fmt(run.kpis.merge_map) + '</div><div class="text-xs text-orange-600">MERGE/MAP</div></div>' +
            '<div class="bg-blue-50 p-3 rounded text-center"><div class="text-lg font-bold text-blue-700">' + fmt(run.kpis.redesign) + '</div><div class="text-xs text-blue-600">REDESIGN</div></div>';
        }
      });

      var el = document.getElementById('proposals-table');
      if (!d.items || !d.items.length) { el.textContent = 'No proposals found.'; return; }
      var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
        '<th class="py-2 px-2 text-left">ID</th><th class="py-2 px-2 text-left">CC ID</th>' +
        '<th class="py-2 px-2 text-left">Outcome</th><th class="py-2 px-2 text-left">Target</th>' +
        '<th class="py-2 px-2 text-left">Confidence</th><th class="py-2 px-2 text-left">Actions</th></tr></thead><tbody>';
      d.items.forEach(function(p) {
        var outcomeColor = { KEEP: 'text-green-700 bg-green-50', RETIRE: 'text-red-700 bg-red-50', MERGE_MAP: 'text-orange-700 bg-orange-50', REDESIGN: 'text-blue-700 bg-blue-50' }[p.cleansing_outcome] || '';
        html += '<tr class="border-b hover:bg-gray-50">' +
          '<td class="py-1.5 px-2">' + p.id + '</td>' +
          '<td class="py-1.5 px-2 font-mono">' + p.legacy_cc_id + '</td>' +
          '<td class="py-1.5 px-2"><span class="px-2 py-0.5 rounded text-xs ' + outcomeColor + '">' + esc(p.cleansing_outcome) + '</span></td>' +
          '<td class="py-1.5 px-2">' + esc(p.target_object || '-') + '</td>' +
          '<td class="py-1.5 px-2">' + (p.confidence ? parseFloat(p.confidence).toFixed(2) : '-') + '</td>' +
          '<td class="py-1.5 px-2"><button onclick="showWhy(' + preferredRunId + ',' + p.id + ')" class="text-blue-600 hover:underline text-xs">Why?</button></td></tr>';
      });
      el.innerHTML = html + '</tbody></table>';
      var pages = Math.ceil(d.total / d.size) || 1;
      document.getElementById('proposals-pager').innerHTML = '<span class="text-gray-500">' + fmt(d.total) + ' proposals, page ' + d.page + '/' + pages + '</span><div class="flex gap-1">' +
        (page > 1 ? '<button onclick="loadProposals(' + (page-1) + ')" class="btn-sm">Prev</button>' : '') +
        (page < pages ? '<button onclick="loadProposals(' + (page+1) + ')" class="btn-sm">Next</button>' : '') + '</div>';
    });
  };

  document.getElementById('filter-outcome').addEventListener('change', function() { loadProposals(1); });
  document.getElementById('filter-target').addEventListener('change', function() { loadProposals(1); });

  // Load proposals after a short delay to allow preferredRunId to be set
