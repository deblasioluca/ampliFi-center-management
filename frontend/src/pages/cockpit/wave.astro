  var _scopeCreating = false;
  document.getElementById('scope-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    if (_scopeCreating) return;
    _scopeCreating = true;
    var submitBtn = this.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating…';
    try {
      var type = document.getElementById('sf-type').value;
      var body = {
        name: document.getElementById('sf-name').value,
        scope_type: type,
        scope_filter: {},
      };
      // Include reviewer if selected
      var revName = document.getElementById('sf-reviewer-name').value;
      var revEmail = document.getElementById('sf-reviewer-email').value;
      var revUid = document.getElementById('sf-reviewer-uid').value;
      if (revName) body.reviewer_name = revName;
      if (revEmail) body.reviewer_email = revEmail;
      if (revUid) body.reviewer_user_id = parseInt(revUid, 10);

      if (type === 'hierarchy_node') {
        var hierId = document.getElementById('sf-hier-id').value;
        var nodeSetname = document.getElementById('sf-hier-node').value;
        if (!hierId) {
          uiAlert({ message: 'Pick a hierarchy first.', kind: 'warning' });
          return;
        }
        body.scope_filter.hierarchy_id = parseInt(hierId, 10);
        if (nodeSetname) body.scope_filter.node_setname = nodeSetname;
      } else {
        var ccodes = scopeEntityPicker.getCcodes();
        if (ccodes.length) body.scope_filter.entity_ccodes = ccodes;
      }
      var res = await fetch('/api/waves/' + waveId + '/scopes', {
        method: 'POST', headers: jsonHdr, body: JSON.stringify(body)
      });
      if (!res.ok) { var d = await res.json(); uiAlert({ message: d.detail, kind: 'danger' }); return; }
      document.getElementById('scope-overlay').classList.add('hidden');
      document.getElementById('sf-name').value = '';
      document.getElementById('sf-reviewer-search').value = '';
      document.getElementById('sf-reviewer-name').value = '';
      document.getElementById('sf-reviewer-email').value = '';
      document.getElementById('sf-reviewer-uid').value = '';
      loadScopes(); loadWave();
    } finally {
      _scopeCreating = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create';
    }
  });

  // Assign reviewer form submit
  document.getElementById('assign-reviewer-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!_assignScopeId) return;
    var btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Saving…';
    try {
      var arUid = document.getElementById('ar-uid').value;
      var res = await fetch('/api/waves/scopes/' + _assignScopeId + '/reviewer', {
        method: 'PATCH', headers: jsonHdr,
        body: JSON.stringify({
          reviewer_name: document.getElementById('ar-name').value || null,
          reviewer_email: document.getElementById('ar-email').value || null,
          reviewer_user_id: arUid ? parseInt(arUid, 10) : null,
        })
      });
      if (!res.ok) { var d = await res.json().catch(function() { return {}; }); uiAlert({ message: d.detail || 'Failed to assign reviewer', kind: 'danger' }); return; }
      document.getElementById('assign-reviewer-overlay').classList.add('hidden');
      document.getElementById('ar-search').value = '';
      document.getElementById('ar-name').value = '';
      document.getElementById('ar-email').value = '';
      document.getElementById('ar-uid').value = '';
      loadScopes();
    } finally {
      btn.disabled = false;
      btn.textContent = 'Assign';
    }
  });

