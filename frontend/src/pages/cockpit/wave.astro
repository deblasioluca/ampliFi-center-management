    .catch(function() {});

  // User search for assign-reviewer overlay
  var _arSearchTimer = null;
  document.getElementById('ar-search').addEventListener('input', function() {
    var q = this.value.trim();
    var resultsEl = document.getElementById('ar-results');
    clearTimeout(_arSearchTimer);
    document.getElementById('ar-name').value = '';
    document.getElementById('ar-email').value = '';
    if (q.length < 2) { resultsEl.classList.add('hidden'); return; }
    _arSearchTimer = setTimeout(function() {
      fetch('/api/admin/users?page=1&size=500', { headers: authHdr })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var items = (data.items || []).filter(function(u) {
            var text = ((u.display_name || '') + ' ' + (u.username || '') + ' ' + (u.email || '')).toLowerCase();
            return text.indexOf(q.toLowerCase()) >= 0;
          });
          if (!items.length) { resultsEl.innerHTML = '<div class="px-3 py-2 text-gray-400">No users found</div>'; resultsEl.classList.remove('hidden'); return; }
          var html = '';
          items.forEach(function(u) {
            html += '<div class="ar-pick px-3 py-2 hover:bg-blue-50 cursor-pointer border-b border-gray-100" ' +
              'data-uid="' + u.id + '" data-name="' + escAttr(u.display_name || u.username) + '" data-email="' + escAttr(u.email || '') + '">' +
              '<span class="font-medium">' + esc(u.display_name || u.username) + '</span>' +
              (u.email ? ' <span class="text-gray-400">' + esc(u.email) + '</span>' : '') +
              ' <span class="text-gray-300 text-[10px]">' + esc((u.roles || [u.role]).join(', ')) + '</span></div>';
          });
          resultsEl.innerHTML = html;
          resultsEl.classList.remove('hidden');
          resultsEl.querySelectorAll('.ar-pick').forEach(function(el) {
            el.addEventListener('click', function() {
              document.getElementById('ar-name').value = this.getAttribute('data-name');
              document.getElementById('ar-email').value = this.getAttribute('data-email');
              document.getElementById('ar-uid').value = this.getAttribute('data-uid');
              document.getElementById('ar-search').value = this.getAttribute('data-name') + (this.getAttribute('data-email') ? ' (' + this.getAttribute('data-email') + ')' : '');
              resultsEl.classList.add('hidden');
            });
          });
        });
    }, 300);
  });
  document.addEventListener('click', function(e) {
    var s = document.getElementById('ar-search');
    var r = document.getElementById('ar-results');
    if (s && r && !s.contains(e.target) && !r.contains(e.target)) r.classList.add('hidden');
  });

  // ── Scope-form context-sensitive UX ──────────────────────────────
  // The fields a reviewer needs to fill depend on scope_type:
  //   entity, list  → Entity picker is relevant; hierarchy block is hidden
  //   hierarchy_node → Hierarchy + node pickers are relevant; entity hidden
  // We also show a one-line help text per type so the user knows what
  // each scope means before filling the form.
  var SF_TYPE_HELP = {
    'entity':         'Reviewer sees centers belonging to one or more entities.',
    'hierarchy_node': 'Reviewer sees centers under a node in a hierarchy (e.g. all centers under "ROOT/EUROPE/DACH").',
    'list':           'Reviewer sees a hand-picked list of cost centers — same UI as entity, useful for ad-hoc spot reviews.',
  };
  function refreshScopeFormVisibility() {
    var type = document.getElementById('sf-type').value;
    var entityWrap = document.getElementById('sf-entity-wrap');
    var hierWrap = document.getElementById('sf-hier-wrap');
    var help = document.getElementById('sf-type-help');
    if (type === 'hierarchy_node') {
      entityWrap.classList.add('hidden');
      hierWrap.classList.remove('hidden');
    } else {
      entityWrap.classList.remove('hidden');
      hierWrap.classList.add('hidden');
    }
    help.textContent = SF_TYPE_HELP[type] || '';
  }
  document.getElementById('sf-type').addEventListener('change', refreshScopeFormVisibility);
  refreshScopeFormVisibility();

  // ── Reviewer search in Create Scope modal ─────────────────────────
  var _sfRevTimer = null;
  document.getElementById('sf-reviewer-search').addEventListener('input', function() {
    var q = this.value.trim();
    var resultsEl = document.getElementById('sf-reviewer-results');
    clearTimeout(_sfRevTimer);
    document.getElementById('sf-reviewer-name').value = '';
    document.getElementById('sf-reviewer-email').value = '';
    document.getElementById('sf-reviewer-uid').value = '';
    if (q.length < 2) { resultsEl.classList.add('hidden'); return; }
    _sfRevTimer = setTimeout(function() {
      fetch('/api/admin/users?page=1&size=500', { headers: authHdr })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var items = (data.items || []).filter(function(u) {
            var text = ((u.display_name || '') + ' ' + (u.username || '') + ' ' + (u.email || '')).toLowerCase();
            return text.indexOf(q.toLowerCase()) >= 0;
          });
          if (!items.length) { resultsEl.innerHTML = '<div class="px-3 py-2 text-gray-400">No users found</div>'; resultsEl.classList.remove('hidden'); return; }
          var html = '';
          items.forEach(function(u) {
            html += '<div class="sf-rev-pick px-3 py-2 hover:bg-blue-50 cursor-pointer border-b border-gray-100" ' +
              'data-uid="' + u.id + '" data-name="' + escAttr(u.display_name || u.username) + '" data-email="' + escAttr(u.email || '') + '">' +
              '<span class="font-medium">' + esc(u.display_name || u.username) + '</span>' +
              (u.email ? ' <span class="text-gray-400">' + esc(u.email) + '</span>' : '') +
              ' <span class="text-gray-300 text-[10px]">' + esc(u.role) + '</span></div>';
          });
          resultsEl.innerHTML = html;
          resultsEl.classList.remove('hidden');
          resultsEl.querySelectorAll('.sf-rev-pick').forEach(function(el) {
            el.addEventListener('click', function() {
              document.getElementById('sf-reviewer-name').value = this.getAttribute('data-name');
              document.getElementById('sf-reviewer-email').value = this.getAttribute('data-email');
              document.getElementById('sf-reviewer-uid').value = this.getAttribute('data-uid');
              document.getElementById('sf-reviewer-search').value = this.getAttribute('data-name') + (this.getAttribute('data-email') ? ' (' + this.getAttribute('data-email') + ')' : '');
              resultsEl.classList.add('hidden');
