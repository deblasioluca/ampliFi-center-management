  document.addEventListener('click', function(e) {
    var s = document.getElementById('sf-reviewer-search');
    var r = document.getElementById('sf-reviewer-results');
    if (s && r && !s.contains(e.target) && !r.contains(e.target)) r.classList.add('hidden');
  });

  // Cascade: when hierarchy changes, load nodes for it.
  fetch('/api/legacy/hierarchies?size=200', { headers: authHdr })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var sel = document.getElementById('sf-hier-id');
      (d.items || []).forEach(function(h) {
        var opt = document.createElement('option');
        opt.value = h.id;
        opt.textContent = h.setname + ' (' + (h.description || h.setclass) + ')';
        sel.appendChild(opt);
      });
    })
    .catch(function() {/* ignore — hierarchy not loaded */});
  document.getElementById('sf-hier-id').addEventListener('change', function(e) {
    var hierId = e.target.value;
    var nodeSel = document.getElementById('sf-hier-node');
    if (!hierId) {
      nodeSel.innerHTML = '<option value="">-- Pick a hierarchy first --</option>';
      nodeSel.disabled = true;
      return;
    }
    nodeSel.innerHTML = '<option value="">-- Loading nodes… --</option>';
    nodeSel.disabled = true;
    fetch('/api/legacy/hierarchies/' + hierId + '/nodes?size=500', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        nodeSel.innerHTML = '<option value="">-- Whole hierarchy --</option>';
        (d.items || []).forEach(function(n) {
          var opt = document.createElement('option');
          opt.value = n.setname;
          opt.textContent = n.setname + (n.description ? ' — ' + n.description : '');
          nodeSel.appendChild(opt);
        });
        nodeSel.disabled = false;
