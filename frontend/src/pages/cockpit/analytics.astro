---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Analytics Dashboard" requireAuth={true} requiredRole="data_manager">
  <!-- Header -->
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-3">
      <a href="/cockpit" class="text-xs text-amplifi-600 hover:underline">&larr; Cockpit</a>
      <h2 class="text-xl font-bold">Analytics Dashboard</h2>
    </div>
  </div>

  <!-- Selectors — single row -->
  <div class="bg-white border rounded-lg px-4 py-2 mb-2 flex items-center gap-3 flex-wrap">
    <div class="flex items-center gap-1">
      <label class="text-xs text-gray-500 whitespace-nowrap">Scope:</label>
      <select id="sel-wave" class="input text-xs py-1 w-40">
        <option value="">Select Wave...</option>
        <option value="__global__">Global (all data)</option>
      </select>
    </div>
    <div class="flex items-center gap-1">
      <label class="text-xs text-gray-500 whitespace-nowrap">Config:</label>
      <select id="sel-config" class="input text-xs py-1 w-40" title="Analysis configuration">
        <option value="">Default Config</option>
      </select>
    </div>
    <div class="flex items-center gap-1">
      <label class="text-xs text-gray-500 whitespace-nowrap">Run:</label>
      <select id="sel-run" class="input text-xs py-1 w-48">
        <option value="">Select Run...</option>
      </select>
    </div>
    <button id="btn-run-global" class="btn-amplifi text-xs py-1 px-3 whitespace-nowrap">Run Global Analysis</button>
    <button id="btn-delete-run" class="btn-sm bg-red-50 text-red-700 hover:bg-red-100 text-xs hidden" title="Delete selected run">Delete Run</button>
    <button id="btn-manage-configs" class="btn-sm bg-gray-100 text-gray-700 hover:bg-gray-200 text-xs" title="Manage configurations">Configs</button>
  </div>

  <!-- Config Manager Panel (hidden by default) -->
  <div id="config-panel" class="hidden bg-white border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold">Analysis Configurations</h3>
      <div class="flex gap-2">
        <button id="btn-new-config" class="btn-sm bg-blue-600 text-white hover:bg-blue-700 text-xs">+ New Config</button>
        <button onclick="document.getElementById('config-panel').classList.add('hidden')" class="btn-sm bg-gray-200 text-gray-600 hover:bg-gray-300 text-xs">Close</button>
      </div>
    </div>
    <p class="text-xs text-gray-500 mb-3">Each configuration defines which analysis routines to run and their parameters.</p>
    <div id="config-list" class="space-y-2"></div>
    <div id="config-editor" class="hidden mt-4 border-t pt-4"></div>
  </div>

  <!-- KPI Strip -->
  <div id="kpi-strip" class="bg-white border rounded-lg p-2 mb-2 flex flex-wrap gap-3"></div>

  <!-- Tab Bar -->
  <div class="flex gap-1 border-b mb-2">
    <button id="tab-visuals" class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-700" onclick="switchAnalyticsTab('visuals')">Visuals</button>
    <button id="tab-browser" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" onclick="switchAnalyticsTab('browser')">Data Browser</button>
  </div>

  <!-- ===== VISUALS TAB ===== -->
  <div id="panel-visuals" class="overflow-y-auto" style="max-height:calc(100vh - 280px)">
    <!-- Row 1: Outcome Donut + Target Bar (equal size) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
      <div class="card" style="min-height:280px">
        <h3 class="text-sm font-semibold mb-3">Outcome Distribution</h3>
        <div id="chart-outcome-donut" class="flex items-center justify-center" style="min-height:220px">
          <span class="text-sm text-gray-400">Select a run to see outcome distribution</span>
        </div>
      </div>
      <div class="card" style="min-height:280px">
        <h3 class="text-sm font-semibold mb-3">Target Object per Outcome</h3>
        <div id="chart-target-bar" style="min-height:220px">
          <span class="text-sm text-gray-400">Select a run to see target objects</span>
        </div>
      </div>
    </div>

    <!-- Row 2: Balance vs Activity + ML Confidence (equal size) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
      <div class="card" style="min-height:240px">
        <h3 class="text-sm font-semibold mb-3">Balance vs Activity</h3>
        <div id="chart-balance-activity" style="min-height:180px">
          <span class="text-sm text-gray-400">Select a run to see balance data</span>
        </div>
      </div>
      <div class="card" style="min-height:240px">
        <h3 class="text-sm font-semibold mb-3">ML Confidence Distribution</h3>
        <div id="chart-ml-hist" style="min-height:180px">
          <span class="text-sm text-gray-400">Select a run to see confidence data</span>
        </div>
      </div>
    </div>

    <!-- Row 3: Entity Heatmap -->
    <div class="card mb-4">
      <h3 class="text-sm font-semibold mb-3">Outcome by Entity (Heatmap)</h3>
      <div id="chart-entity-heatmap" class="overflow-x-auto"></div>
    </div>

    <!-- Row 4: Legacy → Target Flow -->
    <div class="card mb-4">
      <h3 class="text-sm font-semibold mb-3">Legacy → Target Flow</h3>
      <div id="chart-sankey" class="flex items-center justify-center text-sm text-gray-400" style="min-height:120px">
        Select a completed run to see the flow diagram
      </div>
    </div>

    <!-- Row 5: Housekeeping Charts (3-col) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
      <div class="card" style="min-height:200px">
        <h3 class="text-sm font-semibold mb-3">Housekeeping Flag Distribution</h3>
        <div id="chart-hk-flags" class="min-h-[120px]"></div>
      </div>
      <div class="card" style="min-height:200px">
        <h3 class="text-sm font-semibold mb-3">Owner Response Funnel</h3>
        <div id="chart-hk-funnel" class="space-y-2 text-sm"></div>
      </div>
      <div class="card" style="min-height:200px">
        <h3 class="text-sm font-semibold mb-3">Closure Trend</h3>
        <div id="chart-hk-trend" class="min-h-[120px]"></div>
      </div>
    </div>

    <!-- Run Comparison -->
    <div id="comparison-section" class="hidden mb-4">
      <h3 class="text-sm font-semibold mb-3">Run Comparison</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="card">
          <h4 class="text-sm font-semibold mb-3">Outcome Transition Matrix</h4>
          <div id="chart-outcome-diff"></div>
        </div>
        <div class="card">
          <h4 class="text-sm font-semibold mb-3">Target Transition Matrix</h4>
          <div id="chart-target-diff"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== DATA BROWSER TAB ===== -->
  <div id="panel-browser" class="hidden">
    <div class="card mb-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold">Results Browser</h3>
        <div class="flex gap-2">
          <button id="btn-view-tabular" class="btn-sm bg-blue-600 text-white text-xs" onclick="switchBrowserView('tabular')">Tabular</button>
          <button id="btn-view-hierarchy" class="btn-sm bg-gray-200 text-gray-700 text-xs" onclick="switchBrowserView('hierarchy')">Hierarchical</button>
          <button id="btn-view-mapping" class="btn-sm bg-gray-200 text-gray-700 text-xs" onclick="switchBrowserView('mapping')">CC → PC Mapping</button>
          <input id="browser-search" type="text" placeholder="Filter by CC, name, entity..." class="border rounded px-2 py-0.5 text-xs w-48" />
        </div>
      </div>
      <div id="data-browser-content" class="overflow-x-auto overflow-y-auto text-xs" style="max-height:calc(100vh - 320px)">
        <span class="text-sm text-gray-400">Select a run to browse data</span>
      </div>
    </div>
  </div>

  <!-- Decision Reasoning Side Panel (hidden by default) -->
  <div id="why-panel" class="fixed top-0 right-0 w-96 h-full bg-white shadow-xl border-l transform translate-x-full transition-transform z-50 overflow-y-auto">
    <div class="p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-bold">Decision Reasoning</h3>
        <button onclick="closeWhyPanel()" class="text-gray-400 hover:text-gray-600 text-lg">&times;</button>
      </div>
      <div id="why-panel-content" class="text-xs space-y-3"></div>
    </div>
  </div>
</Layout>

<style>
  #data-browser-content thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #f9fafb;
  }
</style>

<script>
  var token = localStorage.getItem('amplifi_token');
  if (!token) { window.location.href = '/login'; }
  var authHdr = { 'Authorization': 'Bearer ' + token };

  var COLORS = { KEEP: '#22c55e', RETIRE: '#ef4444', MERGE_MAP: '#f59e0b', REDESIGN: '#3b82f6', OTHER: '#9ca3af' };
  var TARGET_COLORS = { CC: '#6366f1', PC: '#8b5cf6', CC_AND_PC: '#a78bfa', PC_ONLY: '#c084fc', WBS_REAL: '#e879f9', WBS_STAT: '#f0abfc', NONE: '#d1d5db' };

  function fmt(n) { if (n == null) return '--'; if (typeof n === 'string') return n; return Number(n).toLocaleString(); }
  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
  function escAttr(s) { return esc(s).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }

  // Entity name lookup
  var _entityNames = {};
  fetch('/api/entities?size=500', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
    (d.items || []).forEach(function(e) { _entityNames[e.ccode] = e.name; });
  }).catch(function() {});

  // Tab switching
  window.switchAnalyticsTab = function(tab) {
    var visuals = document.getElementById('panel-visuals');
    var browser = document.getElementById('panel-browser');
    var tabV = document.getElementById('tab-visuals');
    var tabB = document.getElementById('tab-browser');
    if (tab === 'visuals') {
      visuals.classList.remove('hidden');
      browser.classList.add('hidden');
      tabV.className = 'px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-700';
      tabB.className = 'px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700';
    } else {
      visuals.classList.add('hidden');
      browser.classList.remove('hidden');
      tabV.className = 'px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700';
      tabB.className = 'px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-700';
    }
  };

  // ── Business-friendly decision reasoning panel ──────────────────────
  // Renders the proposal's outcome + decision steps in plain language,
  // pulls a fresh ML opinion automatically, and offers an LLM advisor on
  // demand (since LLM calls have cost).
  var _currentRunId = null;
  var _currentProposalId = null;

  // Wider panel — there's a lot to show now and the old 24rem cramped
  // probability bars and rule descriptions onto two lines each.
  (function widenPanel() {
    var panel = document.getElementById('why-panel');
    if (panel) {
      panel.classList.remove('w-96');
      panel.classList.add('w-[28rem]', 'md:w-[32rem]');
    }
  })();

  // Verdict badge colours — semantic, not arbitrary.
  var OUTCOME_BADGE = {
    KEEP:      { bg: 'bg-green-100', text: 'text-green-800', border: 'border-green-300' },
    RETIRE:    { bg: 'bg-red-100',   text: 'text-red-800',   border: 'border-red-300'   },
    MERGE_MAP: { bg: 'bg-blue-100',  text: 'text-blue-800',  border: 'border-blue-300'  },
    REDESIGN:  { bg: 'bg-amber-100', text: 'text-amber-800', border: 'border-amber-300' },
    MIGRATE:   { bg: 'bg-violet-100',text: 'text-violet-800',border: 'border-violet-300'},
    UNKNOWN:   { bg: 'bg-gray-100',  text: 'text-gray-700',  border: 'border-gray-300'  },
  };
  function outcomeBadge(verdict) {
    var c = OUTCOME_BADGE[verdict] || OUTCOME_BADGE.UNKNOWN;
    return '<span class="inline-block px-2 py-0.5 rounded border text-[11px] font-mono ' +
           c.bg + ' ' + c.text + ' ' + c.border + '">' + esc(verdict || 'UNKNOWN') + '</span>';
  }
  function pct(v) { return Math.round((v || 0) * 100) + '%'; }

  function renderProbabilityBars(probs) {
    if (!probs || !Object.keys(probs).length) return '';
    var entries = Object.entries(probs).sort(function(a, b) { return b[1] - a[1]; });
    return entries.map(function(kv) {
      var v = kv[0];
      var p = kv[1];
      var c = OUTCOME_BADGE[v] || OUTCOME_BADGE.UNKNOWN;
      return '<div class="flex items-center gap-2 text-[11px]">' +
        '<span class="inline-block w-20 font-mono">' + esc(v) + '</span>' +
        '<div class="flex-1 h-2.5 rounded overflow-hidden bg-gray-100">' +
          '<div class="h-full ' + c.bg + '" style="width:' + (p * 100).toFixed(1) + '%"></div>' +
        '</div>' +
        '<span class="w-10 text-right tabular-nums">' + pct(p) + '</span>' +
      '</div>';
    }).join('');
  }

  function renderAnomalyGauge(score) {
    if (score == null) return '';
    var p = Math.max(0, Math.min(1, score));
    var label, tone;
    if (p < 0.33)      { label = 'Typical'; tone = 'bg-green-100 text-green-800'; }
    else if (p < 0.66) { label = 'Somewhat unusual'; tone = 'bg-amber-100 text-amber-800'; }
    else               { label = 'Unusual — review carefully'; tone = 'bg-red-100 text-red-800'; }
    return '<div class="flex items-center gap-2 text-[11px] mt-2">' +
      '<span class="inline-block w-24 text-gray-500">Anomaly score</span>' +
      '<div class="flex-1 h-2 rounded overflow-hidden bg-gray-100">' +
        '<div class="h-full bg-gradient-to-r from-green-300 via-amber-300 to-red-400" style="width:' + (p * 100).toFixed(1) + '%"></div>' +
      '</div>' +
      '<span class="px-2 py-0.5 rounded text-[10px] ' + tone + '">' + label + '</span>' +
    '</div>';
  }

  function renderAgreement(treeVerdict, otherVerdict, otherEngineLabel) {
    if (!treeVerdict || !otherVerdict) return '';
    var same = treeVerdict === otherVerdict;
    var cls = same ? 'bg-green-50 text-green-800 border-green-200' : 'bg-amber-50 text-amber-800 border-amber-200';
    var msg = same
      ? otherEngineLabel + ' agrees with the rule tree.'
      : otherEngineLabel + ' disagrees: rule tree said ' + esc(treeVerdict) + ', ' + otherEngineLabel + ' says ' + esc(otherVerdict) + '. Worth a closer look.';
    return '<div class="mt-2 px-2 py-1 border rounded text-[11px] ' + cls + '">' + msg + '</div>';
  }

  function renderRuleSteps(steps) {
    if (!steps || !steps.length) {
      return '<p class="text-xs text-gray-400">No decision steps recorded for this center.</p>';
    }
    return '<ol class="space-y-2.5">' + steps.map(function(s, idx) {
      var num = '<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amplifi-100 text-amplifi-800 text-[10px] font-bold flex-shrink-0">' + (idx + 1) + '</span>';
      var conf = s.confidence != null ? ' <span class="text-[10px] text-gray-400">(' + pct(s.confidence) + ')</span>' : '';
      var meaning = s.verdict_meaning ? '<div class="text-xs text-gray-700 mt-0.5">' + esc(s.verdict_meaning) + '</div>' : '';
      var description = s.description ? '<div class="text-[11px] text-gray-500 mt-0.5 italic">' + esc(s.description) + '</div>' : '';
      var techDetail = '<div class="text-[10px] text-gray-400 font-mono mt-1">' + esc(s.code) + ' → ' + esc(s.verdict) + conf + '</div>';
      return '<li class="flex gap-2">' + num +
        '<div class="flex-1 min-w-0">' +
          '<div class="text-xs font-semibold text-gray-800">' + esc(s.label) + '</div>' +
          meaning +
          description +
          techDetail +
        '</div>' +
      '</li>';
    }).join('') + '</ol>';
  }

  window.showWhyPanel = function(proposalId) {
    if (!_currentRunId) return;
    _currentProposalId = proposalId;
    var panel = document.getElementById('why-panel');
    var content = document.getElementById('why-panel-content');
    content.innerHTML = '<div class="text-xs text-gray-400">Loading reasoning…</div>';
    panel.style.transform = 'translateX(0)';

    fetch('/api/runs/' + _currentRunId + '/proposals/' + proposalId + '/why', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        renderWhyPanelContent(d);
        // Auto-fetch ML opinion on open — it's free and fast.
        loadMlOpinion(_currentRunId, proposalId);
      })
      .catch(function(err) {
        content.innerHTML = '<span class="text-red-500 text-xs">Error: ' + esc(err.message) + '</span>';
      });
  };

  function renderWhyPanelContent(d) {
    var content = document.getElementById('why-panel-content');
    var outcome = (d.outcome_friendly && d.outcome_friendly.label) || d.cleansing_outcome || 'UNKNOWN';
    var verdict = d.cleansing_outcome || 'UNKNOWN';
    var sentence = (d.outcome_friendly && d.outcome_friendly.sentence) || '';
    var targetText = d.target_friendly || '';

    var html = '';

    // ── Header: outcome + plain-language sentence ─────────────────
    html += '<div class="pb-3 border-b">' +
      '<div class="flex items-center gap-2 mb-2">' +
        outcomeBadge(verdict) +
        (d.target_object ? ' <span class="text-xs text-gray-500">→ ' + esc(d.target_object) + '</span>' : '') +
      '</div>' +
      (sentence ? '<p class="text-sm text-gray-800">' + esc(sentence) + '</p>' : '') +
      (targetText ? '<p class="text-xs text-gray-500 mt-1">Target object: ' + esc(targetText) + '</p>' : '') +
      (d.confidence != null ? '<p class="text-[11px] text-gray-400 mt-1">Rule-tree confidence: ' + pct(d.confidence) + '</p>' : '') +
    '</div>';

    // ── How we decided: numbered steps in plain language ──────────
    html += '<section class="mt-4">' +
      '<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500 mb-2">How we decided</h4>' +
      renderRuleSteps(d.rule_path_translated) +
    '</section>';

    // ── ML Predictor placeholder (filled in async) ────────────────
    html += '<section class="mt-4 pt-3 border-t" id="why-ml-section">' +
      '<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500 mb-2">ML Predictor (second opinion)</h4>' +
      '<div id="why-ml-body" class="text-xs text-gray-400">Computing ML opinion…</div>' +
    '</section>';

    // ── LLM Advisor: opt-in button ────────────────────────────────
    html += '<section class="mt-4 pt-3 border-t" id="why-llm-section">' +
      '<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500 mb-2">LLM Advisor</h4>' +
      '<div id="why-llm-body">' +
        '<button id="why-llm-btn" class="text-xs px-2 py-1 rounded bg-amplifi-50 hover:bg-amplifi-100 text-amplifi-700 border border-amplifi-200">Get LLM opinion</button>' +
        '<p class="text-[11px] text-gray-400 mt-1.5">Costs a few cents. Asks the LLM for an independent verdict on this center.</p>' +
      '</div>' +
    '</section>';

    // ── Stored LLM commentary, if any ─────────────────────────────
    var llm = d.llm_commentary;
    if (llm && (llm.commentary || llm.assessment || llm.text || llm.recommendation || llm.suggested_outcome)) {
      html += '<section class="mt-4 pt-3 border-t">' +
        '<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500 mb-2">LLM review (from this run)</h4>' +
        '<div class="text-xs text-gray-700 space-y-1">' +
          (llm.commentary || llm.assessment || llm.text ? '<p class="whitespace-pre-wrap">' + esc(llm.commentary || llm.assessment || llm.text) + '</p>' : '') +
          (llm.recommendation ? '<p class="font-medium text-amplifi-700">Recommendation: ' + esc(llm.recommendation) + '</p>' : '') +
          (llm.suggested_outcome ? '<p>Suggested outcome: ' + outcomeBadge(llm.suggested_outcome) + '</p>' : '') +
        '</div>' +
      '</section>';
    }

    // ── Manual override, if any ───────────────────────────────────
    if (d.override && (d.override.outcome || d.override.target)) {
      html += '<section class="mt-4 pt-3 border-t bg-amber-50 -mx-4 px-4 py-3">' +
        '<h4 class="text-xs font-bold uppercase tracking-wider text-amber-700 mb-2">Manual Override</h4>' +
        '<div class="text-xs space-y-1">' +
          (d.override.outcome ? '<div>Final outcome: ' + outcomeBadge(d.override.outcome) + '</div>' : '') +
          (d.override.target  ? '<div>Final target: <span class="font-mono">' + esc(d.override.target) + '</span></div>' : '') +
          (d.override.reason  ? '<p class="italic text-gray-600 mt-1">"' + esc(d.override.reason) + '"</p>' : '') +
        '</div>' +
      '</section>';
    }

    // ── Technical detail (collapsed) ──────────────────────────────
    html += '<details class="mt-4 pt-3 border-t">' +
      '<summary class="cursor-pointer text-[11px] text-gray-400 hover:text-gray-700">Show technical detail</summary>' +
      '<pre class="text-[10px] text-gray-500 mt-2 whitespace-pre-wrap font-mono">' +
        esc(JSON.stringify({
          rule_path: d.rule_path,
          ml_scores: d.ml_scores,
          llm_commentary: d.llm_commentary,
        }, null, 2)) +
      '</pre>' +
    '</details>';

    content.innerHTML = html;

    // Wire LLM button
    var llmBtn = document.getElementById('why-llm-btn');
    if (llmBtn) {
      llmBtn.addEventListener('click', function() {
        loadLlmOpinion(_currentRunId, _currentProposalId);
      });
    }
  }

  // ── Async: load ML opinion ──────────────────────────────────────────
  function loadMlOpinion(runId, proposalId) {
    var body = document.getElementById('why-ml-body');
    if (!body) return;
    fetch('/api/runs/' + runId + '/proposals/' + proposalId + '/ml-opinion', { headers: authHdr })
      .then(function(r) {
        if (r.status === 401) { window.location.href = '/login'; return null; }
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || ('HTTP ' + r.status)); });
        return r.json();
      })
      .then(function(d) {
        if (!d) return;
        var html = '<div class="flex items-center gap-2 mb-2 text-xs">' +
          'Top prediction: ' + outcomeBadge(d.verdict || 'UNKNOWN') +
          (d.confidence != null ? ' <span class="text-gray-400">' + pct(d.confidence) + '</span>' : '') +
        '</div>';
        html += '<div class="space-y-1">' + renderProbabilityBars(d.probs) + '</div>';
        if (d.anomaly_score != null) html += renderAnomalyGauge(d.anomaly_score);
        if (d.contributors && d.contributors.length) {
          html += '<div class="mt-2 flex flex-wrap gap-1 text-[10px]">' +
            d.contributors.map(function(c) {
              return '<span class="px-2 py-0.5 rounded bg-gray-100 text-gray-700" title="' + escAttr(c.explain || '') + '">' + esc(c.explain || c.code) + '</span>';
            }).join('') +
          '</div>';
        }
        html += renderAgreement(d.tree_verdict, d.verdict, 'ML');
        body.innerHTML = html;
      })
      .catch(function(err) {
        body.innerHTML = '<p class="text-xs text-red-500">ML opinion unavailable: ' + esc(err.message) + '</p>';
      });
  }

  // ── Async: load LLM opinion (on demand) ─────────────────────────────
  function loadLlmOpinion(runId, proposalId) {
    var body = document.getElementById('why-llm-body');
    if (!body) return;
    body.innerHTML = '<div class="text-xs text-gray-400">Asking the LLM…</div>';
    fetch('/api/runs/' + runId + '/proposals/' + proposalId + '/llm-opinion', { headers: authHdr })
      .then(function(r) {
        if (r.status === 401) { window.location.href = '/login'; return null; }
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || ('HTTP ' + r.status)); });
        return r.json();
      })
      .then(function(d) {
        if (!d) return;
        if (!d.available) {
          body.innerHTML = '<p class="text-xs text-gray-500">LLM provider not configured. ' +
            '<span class="text-gray-400">(' + esc(d.reason || 'no provider') + ')</span></p>' +
            '<p class="text-[11px] text-gray-400 mt-1">Configure Azure OpenAI credentials in <code>backend/.env</code> to enable this.</p>';
          return;
        }
        var html = '<div class="flex items-center gap-2 mb-2 text-xs">' +
          'Verdict: ' + outcomeBadge(d.verdict || 'UNKNOWN') +
          (d.confidence != null ? ' <span class="text-gray-400">' + pct(d.confidence) + '</span>' : '') +
        '</div>';
        if (d.reasoning) {
          html += '<p class="text-xs text-gray-700 italic">"' + esc(d.reasoning) + '"</p>';
        }
        html += renderAgreement(d.tree_verdict, d.verdict, 'LLM');
        if (d.tokens_in || d.tokens_out) {
          html += '<p class="text-[10px] text-gray-400 mt-2">Model: ' + esc(d.model || '?') +
            ' · ' + (d.tokens_in || 0) + ' in / ' + (d.tokens_out || 0) + ' out tokens</p>';
        }
        body.innerHTML = html;
      })
      .catch(function(err) {
        body.innerHTML = '<p class="text-xs text-red-500">LLM call failed: ' + esc(err.message) + '</p>';
      });
  }
  window.closeWhyPanel = function() {
    document.getElementById('why-panel').style.transform = 'translateX(100%)';
  };

  // Load waves
  fetch('/api/waves?size=100', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
    var sel = document.getElementById('sel-wave');
    (d.items || []).forEach(function(w) {
      var opt = document.createElement('option');
      opt.value = w.id;
      opt.textContent = w.name + ' (' + w.status + ')';
      sel.appendChild(opt);
    });
    var params = new URLSearchParams(window.location.search);
    if (params.get('wave')) sel.value = params.get('wave');
    else sel.value = '__global__';
    if (sel.value) handleWaveSelect(sel.value);
  });

  document.getElementById('sel-wave').addEventListener('change', function() {
    if (this.value) handleWaveSelect(this.value);
  });

  function handleWaveSelect(val) {
    if (val === '__global__') { loadGlobalRuns(); } else { loadWaveRuns(val); }
  }

  function loadGlobalRuns() {
    fetch('/api/runs/global/list?size=50', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('sel-run');
      sel.innerHTML = '<option value="">Select Run...</option>';
      (d.items || []).filter(function(r) { return r.status === 'completed'; }).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = 'Global Run #' + r.id + (r.kpis ? ' (' + r.kpis.total_centers + ' centers)' : '');
        sel.appendChild(opt);
      });
      if (sel.options.length > 1) { sel.selectedIndex = 1; loadRunVisuals(sel.value, null); }
    });
  }

  function loadWaveRuns(waveId) {
    fetch('/api/waves/' + waveId + '/runs', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('sel-run');
      sel.innerHTML = '<option value="">Select Run...</option>';
      (d.items || []).filter(function(r) { return r.status === 'completed'; }).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = 'Run #' + r.id + (r.kpis ? ' (' + r.kpis.total_centers + ' centers)' : '');
        sel.appendChild(opt);
      });
      if (sel.options.length > 1) { sel.selectedIndex = 1; loadRunVisuals(sel.value, waveId); }
    });
  }

  document.getElementById('sel-run').addEventListener('change', function() {
    var waveId = document.getElementById('sel-wave').value;
    var delBtn = document.getElementById('btn-delete-run');
    if (this.value) {
      loadRunVisuals(this.value, waveId);
      delBtn.classList.remove('hidden');
    } else {
      delBtn.classList.add('hidden');
    }
  });

  document.getElementById('btn-delete-run').addEventListener('click', function() {
    var runSel = document.getElementById('sel-run');
    var runId = runSel.value;
    if (!runId) return;
    var runLabel = runSel.options[runSel.selectedIndex].textContent;
    if (!confirm('Delete "' + runLabel + '"? This will permanently remove the run and all its proposals.')) return;
    fetch('/api/runs/' + runId, { method: 'DELETE', headers: authHdr })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || 'Failed'); });
        // Refresh run list
        var waveSel = document.getElementById('sel-wave');
        if (waveSel.value === '__global__') { loadGlobalRuns(); }
        else if (waveSel.value) { loadWaveRuns(waveSel.value); }
        document.getElementById('kpi-strip').innerHTML = '';
        document.getElementById('btn-delete-run').classList.add('hidden');
      })
      .catch(function(err) { alert('Error: ' + err.message); });
  });

  function loadRunVisuals(runId, waveId) {
    _currentRunId = runId;
    // KPI Strip
    fetch('/api/runs/' + runId, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(run) {
      var k = run.kpis || {};
      var strip = document.getElementById('kpi-strip');
      var total = k.total_centers || 0;
      var keepCount = k.keep || 0;
      var reduction = total ? Math.round((1 - keepCount / total) * 100) + '%' : '--';
      var kpis = [
        { label: 'Total Centers', value: total, color: 'bg-gray-100' },
        { label: 'KEEP', value: keepCount, pct: total ? Math.round(keepCount / total * 100) : 0, color: 'bg-green-100 text-green-800' },
        { label: 'RETIRE', value: k.retire || 0, pct: total ? Math.round((k.retire || 0) / total * 100) : 0, color: 'bg-red-100 text-red-800' },
        { label: 'MERGE_MAP', value: k.merge_map || 0, pct: total ? Math.round((k.merge_map || 0) / total * 100) : 0, color: 'bg-amber-100 text-amber-800' },
        { label: 'REDESIGN', value: k.redesign || 0, pct: total ? Math.round((k.redesign || 0) / total * 100) : 0, color: 'bg-blue-100 text-blue-800' },
        { label: 'Reduction', value: reduction, color: 'bg-purple-100 text-purple-800' }
      ];
      strip.innerHTML = kpis.map(function(kpi) {
        return '<div class="rounded-lg px-4 py-2 ' + kpi.color + ' min-w-[120px]">' +
          '<div class="text-xs font-medium opacity-70">' + kpi.label + '</div>' +
          '<div class="text-lg font-bold">' + fmt(kpi.value) + '</div>' +
          (kpi.pct != null ? '<div class="text-xs opacity-60">' + kpi.pct + '% of total</div>' : '') + '</div>';
      }).join('');
    }).catch(function(err) { console.error('KPI fetch error:', err); });

    // Data Browser
    loadDataBrowser(runId);

    // Proposals for all charts
    fetch('/api/runs/' + runId + '/proposals?size=5000', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var items = d.items || [];
        if (!items.length) {
          document.getElementById('chart-outcome-donut').innerHTML = '<span class="text-sm text-gray-400">No proposals found for this run</span>';
          document.getElementById('chart-target-bar').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-entity-heatmap').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-sankey').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-balance-activity').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-ml-hist').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          return;
        }

        // -- Outcome Distribution (CSS Donut + Legend) --
        var outcomeCounts = {};
        items.forEach(function(p) {
          var o = p.cleansing_outcome || 'OTHER';
          outcomeCounts[o] = (outcomeCounts[o] || 0) + 1;
        });
        drawDonutCSS('chart-outcome-donut', outcomeCounts, COLORS);

        // -- Target Bar (HTML bars) --
        var targetByOutcome = {};
        items.forEach(function(p) {
          var o = p.cleansing_outcome || 'OTHER';
          var t = p.target_object || 'NONE';
          if (!targetByOutcome[o]) targetByOutcome[o] = {};
          targetByOutcome[o][t] = (targetByOutcome[o][t] || 0) + 1;
        });
        drawTargetBars('chart-target-bar', targetByOutcome, TARGET_COLORS);

        // -- Entity Heatmap --
        var entityOutcome = {};
        items.forEach(function(p) {
          var e = p.ccode || 'Unknown';
          var o = p.cleansing_outcome || 'OTHER';
          if (!entityOutcome[e]) entityOutcome[e] = {};
          entityOutcome[e][o] = (entityOutcome[e][o] || 0) + 1;
        });
        drawHeatmap('chart-entity-heatmap', entityOutcome, ['KEEP', 'RETIRE', 'MERGE_MAP', 'REDESIGN']);

        // -- Sankey (flow bars) --
        var flows = {};
        items.forEach(function(p) {
          var src = p.cleansing_outcome || 'OTHER';
          var tgt = p.target_object || 'NONE';
          var key = src + ' → ' + tgt;
          flows[key] = (flows[key] || 0) + 1;
        });
        drawSankey('chart-sankey', flows);

        // -- Balance vs Activity --
        drawBalanceActivity('chart-balance-activity', items);

        // -- ML Confidence Distribution --
        var confs = items.filter(function(p) { return p.confidence; }).map(function(p) { return parseFloat(p.confidence); });
        drawConfidenceHist('chart-ml-hist', confs);
      })
      .catch(function(err) {
        console.error('Proposals fetch error:', err);
        document.getElementById('chart-outcome-donut').innerHTML = '<span class="text-sm text-red-500">Error loading proposals: ' + err.message + '</span>';
      });
  }

  // --- CHART DRAWING FUNCTIONS (Pure HTML/CSS — no canvas) ---

  function drawDonutCSS(divId, data, colors) {
    var el = document.getElementById(divId);
    if (!el) return;
    var total = Object.values(data).reduce(function(a, b) { return a + b; }, 0);
    if (!total) { el.innerHTML = '<span class="text-sm text-gray-400">No data</span>'; return; }

    var segments = [];
    var cumPct = 0;
    Object.keys(data).forEach(function(key) {
      var pct = data[key] / total * 100;
      segments.push((colors[key] || '#999') + ' ' + cumPct + '% ' + (cumPct + pct) + '%');
      cumPct += pct;
    });

    var donutGradient = 'conic-gradient(' + segments.join(', ') + ')';
    var html = '<div class="flex flex-col items-center gap-4">' +
      '<div style="width:200px;height:200px;border-radius:50%;background:' + donutGradient + ';position:relative;">' +
      '<div style="position:absolute;top:25%;left:25%;width:50%;height:50%;border-radius:50%;background:white;display:flex;flex-direction:column;align-items:center;justify-content:center;">' +
      '<div class="text-2xl font-bold text-gray-800">' + total.toLocaleString() + '</div>' +
      '<div class="text-xs text-gray-400">Total</div></div></div>' +
      '<div class="flex flex-wrap justify-center gap-3">';
    Object.keys(data).forEach(function(key) {
      var pct = Math.round(data[key] / total * 100);
      html += '<span class="flex items-center gap-1 text-xs">' +
        '<span class="w-3 h-3 rounded-sm" style="background:' + (colors[key] || '#999') + '"></span>' +
        '<span class="font-medium">' + key + '</span>: ' + data[key] + ' (' + pct + '%)</span>';
    });
    html += '</div></div>';
    el.innerHTML = html;
  }

  function drawTargetBars(divId, data, colors) {
    var el = document.getElementById(divId);
    if (!el) return;
    var outcomes = Object.keys(data);
    if (!outcomes.length) { el.innerHTML = '<span class="text-sm text-gray-400">No data</span>'; return; }

    var maxVal = 0;
    outcomes.forEach(function(o) {
      var sum = Object.values(data[o]).reduce(function(a, b) { return a + b; }, 0);
      if (sum > maxVal) maxVal = sum;
    });

    var html = '<div class="space-y-3">';
    outcomes.forEach(function(o) {
      var parts = data[o];
      var sum = Object.values(parts).reduce(function(a, b) { return a + b; }, 0);
      var pct = maxVal ? Math.round(sum / maxVal * 100) : 0;
      html += '<div>' +
        '<div class="flex justify-between text-xs mb-1"><span class="font-medium" style="color:' + (COLORS[o] || '#666') + '">' + o + '</span><span class="text-gray-500">' + sum + '</span></div>' +
        '<div class="flex h-6 rounded overflow-hidden bg-gray-100" style="width:' + pct + '%">';
      Object.keys(parts).forEach(function(t) {
        var tPct = sum ? Math.round(parts[t] / sum * 100) : 0;
        html += '<div class="h-full flex items-center justify-center text-[10px] text-white font-medium" style="width:' + tPct + '%;background:' + (colors[t] || '#ddd') + '" title="' + t + ': ' + parts[t] + '">' +
          (tPct > 15 ? t : '') + '</div>';
      });
      html += '</div></div>';
    });
    // Legend
    html += '<div class="flex flex-wrap gap-2 mt-3 pt-2 border-t">';
    var allTargets = {};
    outcomes.forEach(function(o) { Object.keys(data[o]).forEach(function(t) { allTargets[t] = true; }); });
    Object.keys(allTargets).forEach(function(t) {
      html += '<span class="flex items-center gap-1 text-[10px]"><span class="w-2 h-2 rounded-sm" style="background:' + (colors[t] || '#ddd') + '"></span>' + t + '</span>';
    });
    html += '</div></div>';
    el.innerHTML = html;
  }

  function drawHeatmap(divId, data, cols) {
    var el = document.getElementById(divId);
    if (!el) return;
    var rows = Object.keys(data).sort();
    if (!rows.length) { el.textContent = 'No data available'; return; }
    var maxVal = 0;
    rows.forEach(function(r) { cols.forEach(function(c) { var v = (data[r] && data[r][c]) || 0; if (v > maxVal) maxVal = v; }); });
    var html = '<table class="w-full text-xs"><thead><tr><th class="py-1 px-2 text-left">Entity</th>';
    cols.forEach(function(c) { html += '<th class="py-1 px-2 text-center">' + c + '</th>'; });
    html += '<th class="py-1 px-2 text-center">Total</th></tr></thead><tbody>';
    rows.forEach(function(r) {
      var rowTotal = 0;
      var entityLabel = r + (_entityNames[r] ? ' — ' + _entityNames[r] : '');
      html += '<tr><td class="py-1 px-2 font-medium border-r whitespace-nowrap"><span class="font-mono">' + esc(r) + '</span>' + (_entityNames[r] ? ' <span class="text-gray-500 font-normal">' + esc(_entityNames[r]) + '</span>' : '') + '</td>';
      cols.forEach(function(c) {
        var v = (data[r] && data[r][c]) || 0;
        rowTotal += v;
        var intensity = maxVal ? (v / maxVal * 0.8 + 0.05) : 0.05;
        var color = COLORS[c] || '#999';
        var rgb = hexToRgb(color);
        html += '<td class="py-1 px-2 text-center font-mono" style="background:rgba(' + rgb + ',' + intensity.toFixed(2) + ')">' + (v || '-') + '</td>';
      });
      html += '<td class="py-1 px-2 text-center font-mono font-bold border-l">' + rowTotal + '</td></tr>';
    });
    el.innerHTML = html + '</tbody></table>';
  }

  function hexToRgb(hex) {
    var r = parseInt(hex.slice(1, 3), 16);
    var g = parseInt(hex.slice(3, 5), 16);
    var b = parseInt(hex.slice(5, 7), 16);
    return r + ',' + g + ',' + b;
  }

  function drawBalanceActivity(divId, items) {
    var el = document.getElementById(divId);
    if (!el) return;
    // Group by outcome, show count + avg postings
    var groups = {};
    items.forEach(function(p) {
      var o = p.cleansing_outcome || 'OTHER';
      if (!groups[o]) groups[o] = { count: 0, totalPostings: 0 };
      groups[o].count++;
      var trend = p.posting_trend || [];
      var sum = trend.reduce(function(a, b) { return a + b; }, 0);
      groups[o].totalPostings += sum;
    });

    var html = '<div class="space-y-2">';
    var maxPostings = 0;
    Object.keys(groups).forEach(function(o) {
      var avg = groups[o].count ? Math.round(groups[o].totalPostings / groups[o].count) : 0;
      if (avg > maxPostings) maxPostings = avg;
    });
    Object.keys(groups).forEach(function(o) {
      var avg = groups[o].count ? Math.round(groups[o].totalPostings / groups[o].count) : 0;
      var pct = maxPostings ? Math.round(avg / maxPostings * 100) : 0;
      html += '<div class="flex items-center gap-2">' +
        '<span class="w-24 text-xs font-medium text-right" style="color:' + (COLORS[o] || '#666') + '">' + o + ' (' + groups[o].count + ')</span>' +
        '<div class="flex-1 bg-gray-100 rounded h-5 relative">' +
        '<div class="h-full rounded" style="width:' + pct + '%;background:' + (COLORS[o] || '#999') + ';opacity:0.6"></div>' +
        '<span class="absolute inset-0 flex items-center pl-2 text-[10px] font-mono">avg ' + avg + ' postings</span></div></div>';
    });
    html += '</div>';
    el.innerHTML = html;
  }

  function drawConfidenceHist(divId, values) {
    var el = document.getElementById(divId);
    if (!el) return;
    if (!values.length) { el.innerHTML = '<span class="text-sm text-gray-400">No ML confidence data</span>'; return; }
    var bins = 10;
    var min = Math.min.apply(null, values), max = Math.max.apply(null, values);
    var step = (max - min) / bins || 0.1;
    var counts = new Array(bins).fill(0);
    values.forEach(function(v) {
      var idx = Math.min(Math.floor((v - min) / step), bins - 1);
      counts[idx]++;
    });
    var maxCount = Math.max.apply(null, counts);
    var html = '<div class="flex items-end gap-1 h-[160px]">';
    counts.forEach(function(c, i) {
      var hPct = maxCount ? Math.round(c / maxCount * 100) : 0;
      var label = (min + i * step).toFixed(2);
      html += '<div class="flex-1 flex flex-col items-center justify-end h-full">' +
        '<div class="text-[9px] font-mono text-gray-500 mb-1">' + c + '</div>' +
        '<div class="w-full rounded-t" style="height:' + hPct + '%;background:#6366f1;opacity:0.7;min-height:' + (c ? '2px' : '0') + '"></div>' +
        '<div class="text-[8px] font-mono text-gray-400 mt-1 truncate w-full text-center">' + label + '</div></div>';
    });
    html += '</div>';
    html += '<div class="text-center text-xs text-gray-500 mt-1">Confidence Score Range (' + values.length + ' proposals)</div>';
    el.innerHTML = html;
  }

  function drawSankey(divId, flows) {
    var el = document.getElementById(divId);
    if (!el || !Object.keys(flows).length) return;

    var sources = {}, targets = {};
    Object.keys(flows).forEach(function(k) {
      var parts = k.split(' → ');
      sources[parts[0]] = (sources[parts[0]] || 0) + flows[k];
      targets[parts[1]] = (targets[parts[1]] || 0) + flows[k];
    });

    var srcKeys = Object.keys(sources).sort(function(a, b) { return sources[b] - sources[a]; });
    var tgtKeys = Object.keys(targets).sort(function(a, b) { return targets[b] - targets[a]; });
    var totalAll = srcKeys.reduce(function(s, k) { return s + sources[k]; }, 0);
    if (!totalAll) return;

    var MIN_H = 22, GAP = 4;

    // Single pass: compute positions shared by labels AND SVG
    function computePositions(keys, vals) {
      var pos = {}, y = 0;
      keys.forEach(function(k, i) {
        var h = Math.max(MIN_H, Math.round(vals[k] / totalAll * 250));
        pos[k] = { y: y, h: h };
        y += h + GAP;
      });
      return { positions: pos, totalH: y - GAP };
    }
    var srcLayout = computePositions(srcKeys, sources);
    var tgtLayout = computePositions(tgtKeys, targets);
    var svgH = Math.max(srcLayout.totalH, tgtLayout.totalH);

    var html = '<div class="flex items-start" style="height:' + svgH + 'px">';

    // Left labels (absolute positioned to match SVG exactly)
    html += '<div class="w-28 flex-shrink-0 text-right pr-2 relative" style="height:' + svgH + 'px">';
    srcKeys.forEach(function(s) {
      var p = srcLayout.positions[s];
      html += '<div style="position:absolute;top:' + p.y + 'px;height:' + p.h + 'px;right:8px;display:flex;align-items:center;justify-content:flex-end">';
      html += '<span class="text-xs font-medium" style="color:' + (COLORS[s] || '#666') + '">' + esc(s) + ' <span class="text-gray-400">(' + sources[s] + ')</span></span>';
      html += '</div>';
    });
    html += '</div>';

    // SVG flow area
    html += '<div class="flex-1 relative" style="min-width:200px;height:' + svgH + 'px">';
    html += '<svg width="100%" height="' + svgH + '" viewBox="0 0 200 ' + svgH + '" preserveAspectRatio="none">';

    var srcOffset = {}, tgtOffset = {};
    srcKeys.forEach(function(s) { srcOffset[s] = 0; });
    tgtKeys.forEach(function(t) { tgtOffset[t] = 0; });

    Object.entries(flows).sort(function(a, b) { return b[1] - a[1]; }).forEach(function(f) {
      var parts = f[0].split(' → ');
      var src = parts[0], tgt = parts[1], cnt = f[1];
      var sInfo = srcLayout.positions[src], tInfo = tgtLayout.positions[tgt];
      var bandH = Math.max(2, Math.round(cnt / totalAll * 250));
      var sYStart = sInfo.y + srcOffset[src];
      var tYStart = tInfo.y + tgtOffset[tgt];
      srcOffset[src] += bandH;
      tgtOffset[tgt] += bandH;
      var color = COLORS[src] || '#999';
      html += '<path d="M0,' + sYStart + ' C80,' + sYStart + ' 120,' + tYStart + ' 200,' + tYStart + ' L200,' + (tYStart + bandH) + ' C120,' + (tYStart + bandH) + ' 80,' + (sYStart + bandH) + ' 0,' + (sYStart + bandH) + ' Z" fill="' + color + '" opacity="0.3"><title>' + esc(src + ' → ' + tgt + ': ' + cnt) + '</title></path>';
    });
    html += '</svg></div>';

    // Right labels (absolute positioned to match SVG exactly)
    html += '<div class="w-28 flex-shrink-0 text-left pl-2 relative" style="height:' + svgH + 'px">';
    tgtKeys.forEach(function(t) {
      var p = tgtLayout.positions[t];
      html += '<div style="position:absolute;top:' + p.y + 'px;height:' + p.h + 'px;left:8px;display:flex;align-items:center">';
      html += '<span class="text-xs font-medium" style="color:' + (TARGET_COLORS[t] || '#666') + '">' + esc(t) + ' <span class="text-gray-400">(' + targets[t] + ')</span></span>';
      html += '</div>';
    });
    html += '</div>';

    html += '</div>';
    el.innerHTML = html;
  }

  // --- Housekeeping Charts ---
  function loadHousekeepingCharts() {
    fetch('/api/stats/housekeeping-summary', { headers: authHdr })
      .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function(d) {
        drawHKFlags(d.flag_distribution);
        drawHKFunnel(d.funnel);
        drawHKTrend(d.trend);
      })
      .catch(function(err) {
        var msg = '<span class="text-xs text-gray-400">No housekeeping data yet</span>';
        var f = document.getElementById('chart-hk-flags');
        var fn = document.getElementById('chart-hk-funnel');
        var t = document.getElementById('chart-hk-trend');
        if (f) f.innerHTML = msg;
        if (fn) fn.innerHTML = msg;
        if (t) t.innerHTML = msg;
      });
  }

  function drawHKFlags(data) {
    var el = document.getElementById('chart-hk-flags');
    if (!el) return;
    var keys = Object.keys(data);
    if (!keys.length) { el.innerHTML = '<span class="text-xs text-gray-400">No housekeeping flags recorded yet</span>'; return; }
    var total = keys.reduce(function(s, k) { return s + data[k]; }, 0);
    var FLAG_COLORS = { UNUSED: '#ef4444', LOW_VOLUME: '#f59e0b', NO_OWNER: '#8b5cf6', ANOMALY: '#3b82f6' };
    var html = '<div class="space-y-2">';
    keys.sort(function(a, b) { return data[b] - data[a]; });
    keys.forEach(function(k) {
      var pct = total ? Math.round(data[k] / total * 100) : 0;
      var color = FLAG_COLORS[k] || '#9ca3af';
      html += '<div><div class="flex justify-between text-xs mb-0.5"><span class="font-medium">' + esc(k) + '</span><span class="text-gray-500">' + data[k] + ' (' + pct + '%)</span></div>';
      html += '<div class="w-full bg-gray-100 rounded h-4"><div class="h-full rounded" style="width:' + pct + '%;background:' + color + ';opacity:0.7"></div></div></div>';
    });
    html += '</div>';
    el.innerHTML = html;
  }

  function drawHKFunnel(data) {
    var el = document.getElementById('chart-hk-funnel');
    if (!el) return;
    if (!data.total) { el.innerHTML = '<span class="text-xs text-gray-400">No housekeeping items yet</span>'; return; }
    var stages = [
      { label: 'Total Flagged', value: data.total, color: '#6366f1' },
      { label: 'Notified', value: data.notified, color: '#3b82f6' },
      { label: 'Responded', value: data.responded, color: '#22c55e' }
    ];
    var maxVal = data.total;
    var html = '<div class="space-y-2">';
    stages.forEach(function(s) {
      var pct = maxVal ? Math.round(s.value / maxVal * 100) : 0;
      html += '<div class="flex items-center gap-2">';
      html += '<span class="w-24 text-xs text-right font-medium">' + s.label + '</span>';
      html += '<div class="flex-1 bg-gray-100 rounded h-6 relative">';
      html += '<div class="h-full rounded" style="width:' + pct + '%;background:' + s.color + ';opacity:0.6"></div>';
      html += '<span class="absolute inset-0 flex items-center pl-2 text-[10px] font-mono">' + s.value + ' (' + pct + '%)</span>';
      html += '</div></div>';
    });
    // Decision breakdown
    var decisions = data.decisions || {};
    var dKeys = Object.keys(decisions);
    if (dKeys.length) {
      html += '<div class="mt-2 pt-2 border-t"><div class="text-[10px] text-gray-500 mb-1">Decisions:</div><div class="flex gap-3">';
      var DEC_COLORS = { KEEP: '#22c55e', CLOSE: '#ef4444', DEFER: '#f59e0b' };
      dKeys.forEach(function(dk) {
        html += '<span class="flex items-center gap-1 text-xs"><span class="w-2.5 h-2.5 rounded" style="background:' + (DEC_COLORS[dk] || '#999') + '"></span>' + dk + ': ' + decisions[dk] + '</span>';
      });
      html += '</div></div>';
    }
    html += '</div>';
    el.innerHTML = html;
  }

  function drawHKTrend(data) {
    var el = document.getElementById('chart-hk-trend');
    if (!el) return;
    if (!data || !data.length) { el.innerHTML = '<span class="text-xs text-gray-400">No housekeeping cycles yet</span>'; return; }
    var maxItems = Math.max.apply(null, data.map(function(d) { return d.total_items; }));
    if (!maxItems) maxItems = 1;
    var html = '<div class="flex items-end gap-1" style="height:120px">';
    data.forEach(function(d) {
      var totalH = Math.round(d.total_items / maxItems * 100);
      var closedH = d.total_items ? Math.round(d.closed / d.total_items * totalH) : 0;
      var openH = totalH - closedH;
      html += '<div class="flex-1 flex flex-col items-center justify-end h-full">';
      html += '<div class="text-[9px] text-gray-500 mb-1">' + d.total_items + '</div>';
      html += '<div class="w-full flex flex-col">';
      if (openH > 0) html += '<div class="w-full rounded-t bg-blue-400" style="height:' + openH + 'px;opacity:0.5"></div>';
      if (closedH > 0) html += '<div class="w-full ' + (openH > 0 ? '' : 'rounded-t ') + 'bg-green-500" style="height:' + closedH + 'px;opacity:0.7"></div>';
      html += '</div>';
      html += '<div class="text-[8px] text-gray-400 mt-1 truncate w-full text-center">' + esc(d.period) + '</div></div>';
    });
    html += '</div>';
    html += '<div class="flex gap-3 mt-2 text-[10px] text-gray-500"><span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded bg-blue-400 opacity-50"></span>Open</span><span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded bg-green-500 opacity-70"></span>Closed</span></div>';
    el.innerHTML = html;
  }

  // Load housekeeping charts on page load
  loadHousekeepingCharts();

  // --- Config management ---
  var jsonHdr = Object.assign({ 'Content-Type': 'application/json' }, authHdr);

  function loadConfigs() {
    fetch('/api/configs', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(configs) {
      // Populate dropdown
      var sel = document.getElementById('sel-config');
      sel.innerHTML = '<option value="">Default Config</option>';
      configs.forEach(function(c) {
        var opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name + ' (v' + c.version + ')';
        sel.appendChild(opt);
      });
      // Populate config list in panel
      var listEl = document.getElementById('config-list');
      if (!configs.length) {
        listEl.innerHTML = '<p class="text-sm text-gray-400">No custom configurations yet. Click "+ New Config" to create one.</p>';
        return;
      }
      listEl.innerHTML = configs.map(function(c) {
        var routineNames = (c.config.routines || []).map(function(r) { return r.code || r; }).join(', ') || 'Default pipeline';
        return '<div class="flex items-center justify-between p-2 bg-gray-50 rounded text-sm">' +
          '<div><span class="font-semibold">' + esc(c.name) + '</span> <span class="text-gray-400">v' + c.version + '</span>' +
          '<div class="text-xs text-gray-500">' + esc(routineNames) + '</div></div>' +
          '<div class="flex gap-1">' +
          '<button onclick="editConfig(\'' + esc(c.code) + '\')" class="btn-sm bg-gray-200 text-gray-600 hover:bg-gray-300 text-xs">Edit</button>' +
          '</div></div>';
      }).join('');
    });
  }

  function loadRoutines(callback) {
    fetch('/api/admin/routines', { headers: authHdr }).then(function(r) { return r.json(); }).then(callback);
  }

  window.editConfig = function(code) {
    fetch('/api/configs/' + code, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(cfg) {
      loadRoutines(function(routines) {
        showConfigEditor(cfg, routines);
      });
    });
  };

  function showConfigEditor(cfg, routines) {
    var editorEl = document.getElementById('config-editor');
    editorEl.classList.remove('hidden');
    var selectedRoutines = (cfg ? (cfg.config.routines || []).map(function(r) { return r.code || r; }) : []);
    var html = '<div class="space-y-3">' +
      '<div><label class="block text-xs text-gray-500 mb-1">Config Name</label>' +
      '<input id="cfg-name" type="text" class="input text-sm w-full" value="' + escAttr(cfg ? cfg.name : '') + '" /></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Description</label>' +
      '<input id="cfg-desc" type="text" class="input text-sm w-full" value="' + escAttr(cfg ? (cfg.description || '') : '') + '" /></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Code (unique identifier)</label>' +
      '<input id="cfg-code" type="text" class="input text-sm w-48" value="' + escAttr(cfg ? cfg.code : '') + '" ' + (cfg ? 'readonly' : '') + ' /></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Select Routines to Include</label>' +
      '<div class="grid grid-cols-1 md:grid-cols-2 gap-1">';
    routines.forEach(function(r) {
      var checked = selectedRoutines.indexOf(r.code) >= 0 ? ' checked' : '';
      html += '<label class="flex items-center gap-2 text-sm p-1 bg-white rounded border">' +
        '<input type="checkbox" class="cfg-routine" value="' + escAttr(r.code) + '"' + checked + ' />' +
        '<span class="font-medium">' + esc(r.name) + '</span>' +
        '<span class="text-xs text-gray-400">(' + r.kind + '/' + (r.tree || 'any') + ')</span></label>';
    });
    html += '</div></div>' +
      '<div class="flex gap-2 mt-3">' +
      '<button id="btn-save-config" class="btn-sm bg-blue-600 text-white hover:bg-blue-700">Save Config</button>' +
      '<button onclick="document.getElementById(\'config-editor\').classList.add(\'hidden\')" class="btn-sm bg-gray-200 text-gray-600 hover:bg-gray-300">Cancel</button></div></div>';
    editorEl.innerHTML = html;

    document.getElementById('btn-save-config').addEventListener('click', function() {
      var name = document.getElementById('cfg-name').value.trim();
      var code = document.getElementById('cfg-code').value.trim();
      var desc = document.getElementById('cfg-desc').value.trim();
      if (!name || !code) { alert('Name and code are required'); return; }
      var selectedCodes = [];
      document.querySelectorAll('.cfg-routine:checked').forEach(function(cb) { selectedCodes.push(cb.value); });
      var configData = { routines: selectedCodes.map(function(c) { return { code: c }; }) };
      var url = cfg ? '/api/configs/' + code + '/amend' : '/api/configs';
      fetch(url, {
        method: 'POST', headers: jsonHdr,
        body: JSON.stringify({ code: code, name: name, description: desc || null, config: configData })
      }).then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || 'Failed'); });
        editorEl.classList.add('hidden');
        loadConfigs();
      }).catch(function(err) { alert('Error: ' + err.message); });
    });
  }

  document.getElementById('btn-manage-configs').addEventListener('click', function() {
    var panel = document.getElementById('config-panel');
    panel.classList.toggle('hidden');
    if (!panel.classList.contains('hidden')) loadConfigs();
  });

  document.getElementById('btn-new-config').addEventListener('click', function() {
    loadRoutines(function(routines) {
      showConfigEditor(null, routines);
    });
  });

  // Load config dropdown on page load
  loadConfigs();

  // Global Analysis button — pass selected config_id
  document.getElementById('btn-run-global').addEventListener('click', function() {
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Running...';
    var configId = document.getElementById('sel-config').value;
    var url = '/api/runs/global' + (configId ? '?config_id=' + configId : '');
    fetch(url, {
      method: 'POST',
      headers: jsonHdr,
    }).then(function(r) {
      if (!r.ok) return r.json().then(function(b) { throw new Error(b.detail || 'Failed'); });
      return r.json();
    }).then(function(d) {
      btn.textContent = 'Run Global Analysis';
      btn.disabled = false;
      alert('Global analysis completed — Run #' + d.run_id + ' (' + (d.kpis ? d.kpis.total_centers : '?') + ' centers)');
      document.getElementById('sel-wave').value = '__global__';
      loadGlobalRuns();
    }).catch(function(err) {
      btn.textContent = 'Run Global Analysis';
      btn.disabled = false;
      alert('Error: ' + err.message);
    });
  });

  // ========== DATA BROWSER ==========
  var browserData = null;
  var browserView = 'tabular';
  var browserSort = { col: 'cctr', dir: 'asc' };
  var OUTCOME_BADGES = {
    KEEP: 'bg-green-100 text-green-800',
    RETIRE: 'bg-red-100 text-red-800',
    MERGE_MAP: 'bg-amber-100 text-amber-800',
    REDESIGN: 'bg-blue-100 text-blue-800'
  };

  function loadDataBrowser(runId) {
    var el = document.getElementById('data-browser-content');
    el.innerHTML = '<span class="text-gray-400">Loading data browser...</span>';
    fetch('/api/runs/' + runId + '/data-browser', { headers: authHdr })
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(d) {
        browserData = d;
        if (!d.items || !d.items.length) {
          el.innerHTML = '<span class="text-gray-400">No proposals found for this run. Run analysis first to see data.</span>';
          return;
        }
        renderBrowser();
      })
      .catch(function(err) {
        el.innerHTML = '<span class="text-red-500">Error loading data browser: ' + esc(err.message) + '</span>';
      });
  }

  window.switchBrowserView = function(view) {
    browserView = view;
    ['tabular', 'hierarchy', 'mapping'].forEach(function(v) {
      var btn = document.getElementById('btn-view-' + v);
      if (btn) {
        btn.className = v === view
          ? 'btn-sm bg-blue-600 text-white text-xs'
          : 'btn-sm bg-gray-200 text-gray-700 text-xs';
      }
    });
    renderBrowser();
  };

  window.sortBrowser = function(col) {
    if (browserSort.col === col) {
      browserSort.dir = browserSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
      browserSort.col = col;
      browserSort.dir = 'asc';
    }
    renderBrowser();
  };

  function renderBrowser() {
    if (!browserData) return;
    var el = document.getElementById('data-browser-content');
    var search = (document.getElementById('browser-search').value || '').toLowerCase();
    var items = browserData.items || [];

    // Filter
    if (search) {
      items = items.filter(function(it) {
        return (it.cctr || '').toLowerCase().indexOf(search) >= 0 ||
          (it.txtsh || '').toLowerCase().indexOf(search) >= 0 ||
          (it.txtmi || '').toLowerCase().indexOf(search) >= 0 ||
          (it.ccode || '').toLowerCase().indexOf(search) >= 0 ||
          (it.coarea || '').toLowerCase().indexOf(search) >= 0 ||
          (it.responsible || '').toLowerCase().indexOf(search) >= 0 ||
          (it.merge_into_cctr || '').toLowerCase().indexOf(search) >= 0;
      });
    }

    if (browserView === 'tabular') {
      renderTabular(el, items);
    } else if (browserView === 'hierarchy') {
      renderHierarchical(el, items);
    } else if (browserView === 'mapping') {
      renderMapping(el, items);
    }
  }

  function sortArrow(col) {
    if (browserSort.col !== col) return ' <span class="text-gray-300">↕</span>';
    return browserSort.dir === 'asc' ? ' ↑' : ' ↓';
  }

  function sortItems(items) {
    var col = browserSort.col;
    var dir = browserSort.dir === 'asc' ? 1 : -1;
    return items.slice().sort(function(a, b) {
      var va = a[col], vb = b[col];
      if (va == null) va = '';
      if (vb == null) vb = '';
      if (typeof va === 'string') va = va.toLowerCase();
      if (typeof vb === 'string') vb = vb.toLowerCase();
      if (va < vb) return -1 * dir;
      if (va > vb) return 1 * dir;
      return 0;
    });
  }

  function renderTabular(el, items) {
    if (!items.length) { el.innerHTML = '<span class="text-gray-400">No data to display</span>'; return; }
    var sorted = sortItems(items);

    // Determine balance period columns
    var periodSet = {};
    items.forEach(function(it) {
      (it.monthly_balances || []).forEach(function(b) {
        var key = b.fiscal_year + '/' + String(b.period).padStart(2, '0');
        periodSet[key] = true;
      });
    });
    var periods = Object.keys(periodSet).sort();

    var cols = [
      { key: 'cctr', label: 'CC' },
      { key: 'txtsh', label: 'Short Text' },
      { key: 'ccode', label: 'Entity' },
      { key: 'coarea', label: 'CO Area' },
      { key: 'pctr', label: 'Profit Ctr (current)' },
      { key: 'responsible', label: 'Responsible' },
      { key: 'cleansing_outcome', label: 'Outcome' },
      { key: 'target_object', label: 'Target Type' },
      { key: 'merge_into_cctr', label: 'Proposed Target CC' },
      { key: 'confidence', label: 'Confidence' }
    ];

    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    cols.forEach(function(c) {
      html += '<th class="py-2 px-2 text-left cursor-pointer select-none whitespace-nowrap hover:bg-gray-100" onclick="sortBrowser(\'' + c.key + '\')">' +
        esc(c.label) + sortArrow(c.key) + '</th>';
    });
    html += '<th class="py-2 px-2 text-center whitespace-nowrap">Why?</th>';
    // Balance period headers
    periods.forEach(function(p) {
      html += '<th class="py-2 px-1 text-right whitespace-nowrap text-[10px] font-normal text-gray-500">' + esc(p) + '</th>';
    });
    html += '</tr></thead><tbody>';

    sorted.forEach(function(it) {
      var outcomeClass = OUTCOME_BADGES[it.cleansing_outcome] || 'bg-gray-100 text-gray-700';
      // Build balance lookup
      var balByPeriod = {};
      (it.monthly_balances || []).forEach(function(b) {
        var key = b.fiscal_year + '/' + String(b.period).padStart(2, '0');
        balByPeriod[key] = b;
      });

      html += '<tr class="border-b hover:bg-gray-50">' +
        '<td class="py-1.5 px-2 font-mono font-medium whitespace-nowrap">' + esc(it.cctr) + '</td>' +
        '<td class="py-1.5 px-2 max-w-[200px] truncate" title="' + escAttr(it.txtmi || it.txtsh || '') + '">' + esc(it.txtsh) + '</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(it.ccode) + '</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(it.coarea) + '</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(it.pctr) + '</td>' +
        '<td class="py-1.5 px-2">' + esc(it.responsible) + '</td>' +
        '<td class="py-1.5 px-2"><span class="px-1.5 py-0.5 rounded text-[10px] font-medium ' + outcomeClass + '">' + esc(it.cleansing_outcome) + '</span></td>' +
        '<td class="py-1.5 px-2">' + esc(it.target_object || '-') + '</td>' +
        '<td class="py-1.5 px-2 font-mono font-medium">' + (it.merge_into_cctr ? esc(it.merge_into_cctr) : '<span class="text-gray-300">-</span>') + '</td>' +
        '<td class="py-1.5 px-2 text-right">' + (it.confidence ? Number(it.confidence).toFixed(2) : '-') + '</td>' +
        '<td class="py-1.5 px-2 text-center"><button class="text-blue-600 hover:text-blue-800 underline text-[10px]" onclick="showWhyPanel(' + it.id + ')">Why?</button>' +
        (it.rule_path && it.rule_path.steps && it.rule_path.steps.length ? '<div class="text-[9px] text-gray-400 mt-0.5">' + it.rule_path.steps.map(function(s) { return (s.routine || s.code || '?'); }).join(' → ') + '</div>' : '') +
        '</td>';
      // Balance cells
      periods.forEach(function(p) {
        var b = balByPeriod[p];
        if (b) {
          var amt = b.amount;
          var cls = amt > 0 ? 'text-green-700' : amt < 0 ? 'text-red-600' : 'text-gray-400';
          html += '<td class="py-1.5 px-1 text-right font-mono ' + cls + '" title="' + b.postings + ' postings">' +
            Number(amt).toLocaleString(undefined, {maximumFractionDigits: 0}) + '</td>';
        } else {
          html += '<td class="py-1.5 px-1 text-right text-gray-300">-</td>';
        }
      });
      html += '</tr>';
    });
    html += '</tbody></table>';
    html += '<div class="mt-2 text-xs text-gray-500">' + items.length + ' centers' +
      (periods.length ? ' · ' + periods.length + ' periods' : '') + '</div>';
    el.innerHTML = html;
  }

  function renderHierarchical(el, items) {
    var hiers = browserData.hierarchies || [];
    if (!hiers.length) {
      el.innerHTML = '<span class="text-gray-400">No hierarchies loaded. Load hierarchy data first.</span>';
      return;
    }

    // Fetch hierarchy labels
    var html = '<div class="flex items-center gap-3 mb-3">';
    html += '<select id="browser-hier-select" class="input text-sm w-64" onchange="renderHierTree()">';
    hiers.forEach(function(h, i) {
      var label = h.label || (h.setclass === '0101' ? 'CC' : h.setclass === '0104' ? 'PC' : 'Entity') + ': ' + h.setname;
      html += '<option value="' + i + '">' + esc(label) + '</option>';
    });
    html += '</select>';
    html += '<button class="btn-sm bg-gray-200 text-gray-700 text-xs" onclick="expandAllBrowser(true)">Expand All</button>';
    html += '<button class="btn-sm bg-gray-200 text-gray-700 text-xs" onclick="expandAllBrowser(false)">Collapse All</button>';
    html += '</div>';
    html += '<div id="browser-hier-tree" class="font-mono text-xs"></div>';
    el.innerHTML = html;
    window.renderHierTree();
  }

  window.renderHierTree = function() {
    var sel = document.getElementById('browser-hier-select');
    if (!sel) return;
    var idx = parseInt(sel.value);
    var hier = browserData.hierarchies[idx];
    if (!hier) return;
    var treeEl = document.getElementById('browser-hier-tree');

    // Build lookup: node children and leaf values
    var childNodes = {};
    (hier.nodes || []).forEach(function(n) {
      if (!childNodes[n.parent]) childNodes[n.parent] = [];
      childNodes[n.parent].push(n.child);
    });
    var leafValues = {};
    (hier.leaves || []).forEach(function(lf) {
      if (!leafValues[lf.setname]) leafValues[lf.setname] = [];
      leafValues[lf.setname].push(lf.value);
    });

    // Build item lookup by cctr
    var itemByCctr = {};
    (browserData.items || []).forEach(function(it) {
      if (it.cctr) itemByCctr[it.cctr] = it;
    });

    function renderNode(name, depth) {
      var indent = '  '.repeat(depth);
      var html = '<div class="hier-node" data-depth="' + depth + '">';
      var children = childNodes[name] || [];
      var leaves = leafValues[name] || [];
      var hasKids = children.length > 0 || leaves.length > 0;

      html += '<div class="py-0.5 cursor-pointer hover:bg-blue-50 rounded px-1" onclick="toggleHierNode(this)">' +
        indent + (hasKids ? '<span class="hier-toggle">▼ </span>' : '  ') +
        '<span class="font-semibold text-blue-700">' + esc(name) + '</span></div>';

      if (hasKids) {
        html += '<div class="hier-children">';
        children.forEach(function(child) { html += renderNode(child, depth + 1); });
        leaves.forEach(function(val) {
          var it = itemByCctr[val];
          var outcomeHtml = '';
          if (it) {
            var cls = OUTCOME_BADGES[it.cleansing_outcome] || 'bg-gray-100';
            outcomeHtml = ' <span class="px-1 py-0.5 rounded text-[9px] ' + cls + '">' + esc(it.cleansing_outcome) + '</span>';
            if (it.merge_into_cctr) outcomeHtml += ' → <span class="font-semibold text-purple-700">' + esc(it.merge_into_cctr) + '</span>';
          }
          html += '<div class="py-0.5 px-1 hover:bg-gray-50">' + indent + '  ' +
            '<span class="text-gray-600">' + esc(val) + '</span>' +
            (it && it.txtsh ? ' <span class="text-gray-400">' + esc(it.txtsh) + '</span>' : '') +
            outcomeHtml + '</div>';
        });
        html += '</div>';
      }
      html += '</div>';
      return html;
    }

    // Find root(s)
    var allChildren = new Set();
    (hier.nodes || []).forEach(function(n) { allChildren.add(n.child); });
    var roots = [];
    (hier.nodes || []).forEach(function(n) {
      if (!allChildren.has(n.parent) && roots.indexOf(n.parent) < 0) roots.push(n.parent);
    });
    if (!roots.length) roots = [hier.setname];

    var treeHtml = '';
    roots.forEach(function(r) { treeHtml += renderNode(r, 0); });
    treeEl.innerHTML = treeHtml || '<span class="text-gray-400">No tree structure available</span>';
  };

  window.toggleHierNode = function(el) {
    var children = el.nextElementSibling;
    if (!children || !children.classList.contains('hier-children')) return;
    var toggle = el.querySelector('.hier-toggle');
    if (children.style.display === 'none') {
      children.style.display = '';
      if (toggle) toggle.textContent = '▼ ';
    } else {
      children.style.display = 'none';
      if (toggle) toggle.textContent = '▶ ';
    }
  };

  window.expandAllBrowser = function(expand) {
    document.querySelectorAll('.hier-children').forEach(function(el) {
      el.style.display = expand ? '' : 'none';
    });
    document.querySelectorAll('.hier-toggle').forEach(function(el) {
      el.textContent = expand ? '▼ ' : '▶ ';
    });
  };

  function renderMapping(el, items) {
    if (!items.length) { el.innerHTML = '<span class="text-gray-400">No data to display</span>'; return; }

    // Group by current PC (1:1 legacy mapping)
    var currentMap = {};
    items.forEach(function(it) {
      var pc = it.pctr || '(none)';
      if (!currentMap[pc]) currentMap[pc] = [];
      currentMap[pc].push(it);
    });

    // Group by proposed target (n:1 from merge_into_cctr)
    var proposedMap = {};
    items.forEach(function(it) {
      var target = it.merge_into_cctr || (it.cleansing_outcome === 'KEEP' ? it.cctr : '(no target)');
      if (!proposedMap[target]) proposedMap[target] = [];
      proposedMap[target].push(it);
    });

    var html = '<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">';

    // Current 1:1 mapping
    html += '<div><h4 class="text-sm font-semibold mb-2 text-gray-700">Current CC → PC Mapping (1:1)</h4>';
    html += '<div class="space-y-2 max-h-[500px] overflow-y-auto">';
    var sortedPCs = Object.keys(currentMap).sort();
    sortedPCs.forEach(function(pc) {
      var ccs = currentMap[pc];
      html += '<div class="border rounded p-2">';
      html += '<div class="flex items-center gap-2 mb-1"><span class="font-mono font-semibold text-purple-700">' +
        esc(pc) + '</span><span class="text-[10px] text-gray-400">' + ccs.length + ' CC' + (ccs.length > 1 ? 's' : '') + '</span></div>';
      ccs.forEach(function(cc) {
        var cls = OUTCOME_BADGES[cc.cleansing_outcome] || 'bg-gray-100';
        html += '<div class="flex items-center gap-2 ml-4 py-0.5">' +
          '<span class="font-mono text-[11px]">' + esc(cc.cctr) + '</span>' +
          '<span class="text-[10px] text-gray-400 truncate max-w-[120px]">' + esc(cc.txtsh || '') + '</span>' +
          '<span class="px-1 py-0.5 rounded text-[9px] ' + cls + '">' + esc(cc.cleansing_outcome) + '</span></div>';
      });
      html += '</div>';
    });
    html += '</div></div>';

    // Proposed n:1 mapping
    html += '<div><h4 class="text-sm font-semibold mb-2 text-gray-700">Proposed Mapping (n:1 consolidation)</h4>';
    html += '<div class="space-y-2 max-h-[500px] overflow-y-auto">';
    var sortedTargets = Object.keys(proposedMap).sort();
    sortedTargets.forEach(function(target) {
      var ccs = proposedMap[target];
      var isConsolidation = ccs.length > 1;
      html += '<div class="border rounded p-2 ' + (isConsolidation ? 'border-amber-300 bg-amber-50' : '') + '">';
      html += '<div class="flex items-center gap-2 mb-1"><span class="font-mono font-semibold ' +
        (isConsolidation ? 'text-amber-700' : 'text-green-700') + '">' +
        esc(target) + '</span>' +
        '<span class="text-[10px] text-gray-500">' + ccs.length + ' CC' + (ccs.length > 1 ? 's' : '') +
        (isConsolidation ? ' → consolidated' : '') + '</span></div>';
      ccs.forEach(function(cc) {
        var cls = OUTCOME_BADGES[cc.cleansing_outcome] || 'bg-gray-100';
        html += '<div class="flex items-center gap-2 ml-4 py-0.5">' +
          '<span class="font-mono text-[11px]">' + esc(cc.cctr) + '</span>' +
          '<span class="text-[10px] text-gray-400 truncate max-w-[120px]">' + esc(cc.txtsh || '') + '</span>' +
          '<span class="px-1 py-0.5 rounded text-[9px] ' + cls + '">' + esc(cc.cleansing_outcome) + '</span></div>';
      });
      html += '</div>';
    });
    html += '</div></div>';

    html += '</div>';
    html += '<div class="mt-3 text-xs text-gray-500">' +
      'Current: ' + sortedPCs.length + ' profit centers · Proposed: ' + sortedTargets.length + ' targets · ' +
      'Consolidation ratio: ' + items.length + ':' + sortedTargets.length + '</div>';
    el.innerHTML = html;
  }

  // Wire search filter
  document.getElementById('browser-search').addEventListener('input', function() {
    clearTimeout(this._t);
    var self = this;
    this._t = setTimeout(function() { renderBrowser(); }, 300);
  });
</script>
