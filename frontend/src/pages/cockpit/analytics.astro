---
import Layout from '../../components/layout/Layout.astro';
export const prerender = false;
---

<Layout title="Analytics Dashboard" requireAuth={true} requiredRole="data_manager">
  <a href="/cockpit" class="text-sm text-amplifi-600 hover:underline">&larr; Back to Cockpit</a>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold">Analytics Dashboard</h2>
      <p class="text-sm text-gray-500">Comprehensive visualizations of analysis results</p>
    </div>
    <div class="flex gap-2 items-center flex-wrap">
      <select id="sel-wave" class="input text-sm w-48">
        <option value="">Select Wave...</option>
        <option value="__global__">— Global (all data) —</option>
      </select>
      <select id="sel-config" class="input text-sm w-52" title="Analysis configuration to use">
        <option value="">Default Config</option>
      </select>
      <select id="sel-run" class="input text-sm w-48">
        <option value="">Select Run...</option>
      </select>
      <button id="btn-run-global" class="btn-amplifi text-sm whitespace-nowrap">Run Global Analysis</button>
      <button id="btn-delete-run" class="btn-sm bg-red-50 text-red-700 hover:bg-red-100 text-sm whitespace-nowrap hidden" title="Delete selected run">Delete Run</button>
      <button id="btn-manage-configs" class="btn-sm bg-gray-100 text-gray-700 hover:bg-gray-200 text-sm whitespace-nowrap" title="Manage analysis configurations">Configs</button>
    </div>
  </div>

  <!-- Config Manager Panel (hidden by default) -->
  <div id="config-panel" class="hidden bg-white border rounded-lg p-4 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold">Analysis Configurations</h3>
      <div class="flex gap-2">
        <button id="btn-new-config" class="btn-sm bg-blue-600 text-white hover:bg-blue-700 text-xs">+ New Config</button>
        <button onclick="document.getElementById('config-panel').classList.add('hidden')" class="btn-sm bg-gray-200 text-gray-600 hover:bg-gray-300 text-xs">Close</button>
      </div>
    </div>
    <p class="text-xs text-gray-500 mb-3">Each configuration defines which analysis routines to run and their parameters. Create different configs for different analysis scenarios.</p>
    <div id="config-list" class="space-y-2"></div>
    <div id="config-editor" class="hidden mt-4 border-t pt-4"></div>
  </div>

  <!-- Persistent KPI Strip -->
  <div id="kpi-strip" class="bg-white border rounded-lg p-3 mb-6 flex flex-wrap gap-3"></div>

  <!-- Outcome Donut + Target Bar -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Outcome Distribution</h3>
      <div id="chart-outcome-donut" class="flex items-center justify-center min-h-[200px]">
        <span class="text-sm text-gray-400">Select a run to see outcome distribution</span>
      </div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Target Object per Outcome</h3>
      <div id="chart-target-bar" class="min-h-[200px]">
        <span class="text-sm text-gray-400">Select a run to see target objects</span>
      </div>
    </div>
  </div>

  <!-- Entity × Outcome Heatmap -->
  <div class="card mb-6">
    <h3 class="text-sm font-semibold mb-3">Outcome by Entity (Heatmap)</h3>
    <div id="chart-entity-heatmap" class="overflow-x-auto"></div>
  </div>

  <!-- Balance vs Activity + ML Confidence -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Balance vs Activity</h3>
      <div id="chart-balance-activity" class="min-h-[200px]">
        <span class="text-sm text-gray-400">Select a run to see balance data</span>
      </div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">ML Confidence Distribution</h3>
      <div id="chart-ml-hist" class="min-h-[200px]">
        <span class="text-sm text-gray-400">Select a run to see confidence data</span>
      </div>
    </div>
  </div>

  <!-- Sankey / Flow -->
  <div class="card mb-6">
    <h3 class="text-sm font-semibold mb-3">Legacy → Target Flow</h3>
    <div id="chart-sankey" class="min-h-[100px] flex items-center justify-center text-sm text-gray-400">
      Select a completed run to see the flow diagram
    </div>
  </div>

  <!-- Run Comparison -->
  <div id="comparison-section" class="hidden mb-6">
    <h3 class="text-lg font-semibold mb-3">Run Comparison</h3>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="card">
        <h4 class="text-sm font-semibold mb-3">Outcome Transition Matrix</h4>
        <div id="chart-outcome-diff"></div>
      </div>
      <div class="card">
        <h4 class="text-sm font-semibold mb-3">Target Transition Matrix</h4>
        <div id="chart-target-diff"></div>
      </div>
    </div>
  </div>

  <!-- Housekeeping Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Housekeeping Flag Distribution</h3>
      <div id="chart-hk-flags" class="min-h-[120px]"></div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Owner Response Funnel</h3>
      <div id="chart-hk-funnel" class="space-y-2 text-sm"></div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold mb-3">Closure Trend</h3>
      <div id="chart-hk-trend" class="min-h-[120px]"></div>
    </div>
  </div>
</Layout>

<script>
  var token = localStorage.getItem('amplifi_token');
  if (!token) { window.location.href = '/login'; }
  var authHdr = { 'Authorization': 'Bearer ' + token };

  var COLORS = { KEEP: '#22c55e', RETIRE: '#ef4444', MERGE_MAP: '#f59e0b', REDESIGN: '#3b82f6', OTHER: '#9ca3af' };
  var TARGET_COLORS = { CC: '#6366f1', PC: '#8b5cf6', CC_AND_PC: '#a78bfa', PC_ONLY: '#c084fc', WBS_REAL: '#e879f9', WBS_STAT: '#f0abfc', NONE: '#d1d5db' };

  function fmt(n) { if (n == null) return '--'; if (typeof n === 'string') return n; return Number(n).toLocaleString(); }
  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  // Load waves
  fetch('/api/waves?size=100', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
    var sel = document.getElementById('sel-wave');
    (d.items || []).forEach(function(w) {
      var opt = document.createElement('option');
      opt.value = w.id;
      opt.textContent = w.name + ' (' + w.status + ')';
      sel.appendChild(opt);
    });
    var params = new URLSearchParams(window.location.search);
    if (params.get('wave')) sel.value = params.get('wave');
    else if (params.get('global') === '1') sel.value = '__global__';
    if (sel.value) handleWaveSelect(sel.value);
  });

  document.getElementById('sel-wave').addEventListener('change', function() {
    if (this.value) handleWaveSelect(this.value);
  });

  function handleWaveSelect(val) {
    if (val === '__global__') { loadGlobalRuns(); } else { loadWaveRuns(val); }
  }

  function loadGlobalRuns() {
    fetch('/api/runs/global/list?size=50', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('sel-run');
      sel.innerHTML = '<option value="">Select Run...</option>';
      (d.items || []).filter(function(r) { return r.status === 'completed'; }).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = 'Global Run #' + r.id + (r.kpis ? ' (' + r.kpis.total_centers + ' centers)' : '');
        sel.appendChild(opt);
      });
      if (sel.options.length > 1) { sel.selectedIndex = 1; loadRunVisuals(sel.value, null); }
    });
  }

  function loadWaveRuns(waveId) {
    fetch('/api/waves/' + waveId + '/runs', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('sel-run');
      sel.innerHTML = '<option value="">Select Run...</option>';
      (d.items || []).filter(function(r) { return r.status === 'completed'; }).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = 'Run #' + r.id + (r.kpis ? ' (' + r.kpis.total_centers + ' centers)' : '');
        sel.appendChild(opt);
      });
      if (sel.options.length > 1) { sel.selectedIndex = 1; loadRunVisuals(sel.value, waveId); }
    });
  }

  document.getElementById('sel-run').addEventListener('change', function() {
    var waveId = document.getElementById('sel-wave').value;
    var delBtn = document.getElementById('btn-delete-run');
    if (this.value) {
      loadRunVisuals(this.value, waveId);
      delBtn.classList.remove('hidden');
    } else {
      delBtn.classList.add('hidden');
    }
  });

  document.getElementById('btn-delete-run').addEventListener('click', function() {
    var runSel = document.getElementById('sel-run');
    var runId = runSel.value;
    if (!runId) return;
    var runLabel = runSel.options[runSel.selectedIndex].textContent;
    if (!confirm('Delete "' + runLabel + '"? This will permanently remove the run and all its proposals.')) return;
    fetch('/api/runs/' + runId, { method: 'DELETE', headers: authHdr })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || 'Failed'); });
        // Refresh run list
        var waveSel = document.getElementById('sel-wave');
        if (waveSel.value === '__global__') { loadGlobalRuns(); }
        else if (waveSel.value) { loadWaveRuns(waveSel.value); }
        document.getElementById('kpi-strip').innerHTML = '';
        document.getElementById('btn-delete-run').classList.add('hidden');
      })
      .catch(function(err) { alert('Error: ' + err.message); });
  });

  function loadRunVisuals(runId, waveId) {
    // KPI Strip
    fetch('/api/runs/' + runId, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(run) {
      var k = run.kpis || {};
      var strip = document.getElementById('kpi-strip');
      var total = k.total_centers || 0;
      var keepCount = k.keep || 0;
      var reduction = total ? Math.round((1 - keepCount / total) * 100) + '%' : '--';
      var kpis = [
        { label: 'Total Centers', value: total, color: 'bg-gray-100' },
        { label: 'KEEP', value: keepCount, pct: total ? Math.round(keepCount / total * 100) : 0, color: 'bg-green-100 text-green-800' },
        { label: 'RETIRE', value: k.retire || 0, pct: total ? Math.round((k.retire || 0) / total * 100) : 0, color: 'bg-red-100 text-red-800' },
        { label: 'MERGE_MAP', value: k.merge_map || 0, pct: total ? Math.round((k.merge_map || 0) / total * 100) : 0, color: 'bg-amber-100 text-amber-800' },
        { label: 'REDESIGN', value: k.redesign || 0, pct: total ? Math.round((k.redesign || 0) / total * 100) : 0, color: 'bg-blue-100 text-blue-800' },
        { label: 'Reduction', value: reduction, color: 'bg-purple-100 text-purple-800' }
      ];
      strip.innerHTML = kpis.map(function(kpi) {
        return '<div class="rounded-lg px-4 py-2 ' + kpi.color + ' min-w-[120px]">' +
          '<div class="text-xs font-medium opacity-70">' + kpi.label + '</div>' +
          '<div class="text-lg font-bold">' + fmt(kpi.value) + '</div>' +
          (kpi.pct != null ? '<div class="text-xs opacity-60">' + kpi.pct + '% of total</div>' : '') + '</div>';
      }).join('');
    }).catch(function(err) { console.error('KPI fetch error:', err); });

    // Proposals for all charts
    fetch('/api/runs/' + runId + '/proposals?size=5000', { headers: authHdr })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var items = d.items || [];
        if (!items.length) {
          document.getElementById('chart-outcome-donut').innerHTML = '<span class="text-sm text-gray-400">No proposals found for this run</span>';
          document.getElementById('chart-target-bar').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-entity-heatmap').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-sankey').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-balance-activity').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          document.getElementById('chart-ml-hist').innerHTML = '<span class="text-sm text-gray-400">No data</span>';
          return;
        }

        // -- Outcome Distribution (CSS Donut + Legend) --
        var outcomeCounts = {};
        items.forEach(function(p) {
          var o = p.cleansing_outcome || 'OTHER';
          outcomeCounts[o] = (outcomeCounts[o] || 0) + 1;
        });
        drawDonutCSS('chart-outcome-donut', outcomeCounts, COLORS);

        // -- Target Bar (HTML bars) --
        var targetByOutcome = {};
        items.forEach(function(p) {
          var o = p.cleansing_outcome || 'OTHER';
          var t = p.target_object || 'NONE';
          if (!targetByOutcome[o]) targetByOutcome[o] = {};
          targetByOutcome[o][t] = (targetByOutcome[o][t] || 0) + 1;
        });
        drawTargetBars('chart-target-bar', targetByOutcome, TARGET_COLORS);

        // -- Entity Heatmap --
        var entityOutcome = {};
        items.forEach(function(p) {
          var e = p.ccode || 'Unknown';
          var o = p.cleansing_outcome || 'OTHER';
          if (!entityOutcome[e]) entityOutcome[e] = {};
          entityOutcome[e][o] = (entityOutcome[e][o] || 0) + 1;
        });
        drawHeatmap('chart-entity-heatmap', entityOutcome, ['KEEP', 'RETIRE', 'MERGE_MAP', 'REDESIGN']);

        // -- Sankey (flow bars) --
        var flows = {};
        items.forEach(function(p) {
          var src = p.cleansing_outcome || 'OTHER';
          var tgt = p.target_object || 'NONE';
          var key = src + ' → ' + tgt;
          flows[key] = (flows[key] || 0) + 1;
        });
        drawSankey('chart-sankey', flows);

        // -- Balance vs Activity --
        drawBalanceActivity('chart-balance-activity', items);

        // -- ML Confidence Distribution --
        var confs = items.filter(function(p) { return p.confidence; }).map(function(p) { return parseFloat(p.confidence); });
        drawConfidenceHist('chart-ml-hist', confs);
      })
      .catch(function(err) {
        console.error('Proposals fetch error:', err);
        document.getElementById('chart-outcome-donut').innerHTML = '<span class="text-sm text-red-500">Error loading proposals: ' + err.message + '</span>';
      });
  }

  // --- CHART DRAWING FUNCTIONS (Pure HTML/CSS — no canvas) ---

  function drawDonutCSS(divId, data, colors) {
    var el = document.getElementById(divId);
    if (!el) return;
    var total = Object.values(data).reduce(function(a, b) { return a + b; }, 0);
    if (!total) { el.innerHTML = '<span class="text-sm text-gray-400">No data</span>'; return; }

    var segments = [];
    var cumPct = 0;
    Object.keys(data).forEach(function(key) {
      var pct = data[key] / total * 100;
      segments.push((colors[key] || '#999') + ' ' + cumPct + '% ' + (cumPct + pct) + '%');
      cumPct += pct;
    });

    var donutGradient = 'conic-gradient(' + segments.join(', ') + ')';
    var html = '<div class="flex flex-col items-center gap-4">' +
      '<div style="width:200px;height:200px;border-radius:50%;background:' + donutGradient + ';position:relative;">' +
      '<div style="position:absolute;top:25%;left:25%;width:50%;height:50%;border-radius:50%;background:white;display:flex;flex-direction:column;align-items:center;justify-content:center;">' +
      '<div class="text-2xl font-bold text-gray-800">' + total.toLocaleString() + '</div>' +
      '<div class="text-xs text-gray-400">Total</div></div></div>' +
      '<div class="flex flex-wrap justify-center gap-3">';
    Object.keys(data).forEach(function(key) {
      var pct = Math.round(data[key] / total * 100);
      html += '<span class="flex items-center gap-1 text-xs">' +
        '<span class="w-3 h-3 rounded-sm" style="background:' + (colors[key] || '#999') + '"></span>' +
        '<span class="font-medium">' + key + '</span>: ' + data[key] + ' (' + pct + '%)</span>';
    });
    html += '</div></div>';
    el.innerHTML = html;
  }

  function drawTargetBars(divId, data, colors) {
    var el = document.getElementById(divId);
    if (!el) return;
    var outcomes = Object.keys(data);
    if (!outcomes.length) { el.innerHTML = '<span class="text-sm text-gray-400">No data</span>'; return; }

    var maxVal = 0;
    outcomes.forEach(function(o) {
      var sum = Object.values(data[o]).reduce(function(a, b) { return a + b; }, 0);
      if (sum > maxVal) maxVal = sum;
    });

    var html = '<div class="space-y-3">';
    outcomes.forEach(function(o) {
      var parts = data[o];
      var sum = Object.values(parts).reduce(function(a, b) { return a + b; }, 0);
      var pct = maxVal ? Math.round(sum / maxVal * 100) : 0;
      html += '<div>' +
        '<div class="flex justify-between text-xs mb-1"><span class="font-medium" style="color:' + (COLORS[o] || '#666') + '">' + o + '</span><span class="text-gray-500">' + sum + '</span></div>' +
        '<div class="flex h-6 rounded overflow-hidden bg-gray-100" style="width:' + pct + '%">';
      Object.keys(parts).forEach(function(t) {
        var tPct = sum ? Math.round(parts[t] / sum * 100) : 0;
        html += '<div class="h-full flex items-center justify-center text-[10px] text-white font-medium" style="width:' + tPct + '%;background:' + (colors[t] || '#ddd') + '" title="' + t + ': ' + parts[t] + '">' +
          (tPct > 15 ? t : '') + '</div>';
      });
      html += '</div></div>';
    });
    // Legend
    html += '<div class="flex flex-wrap gap-2 mt-3 pt-2 border-t">';
    var allTargets = {};
    outcomes.forEach(function(o) { Object.keys(data[o]).forEach(function(t) { allTargets[t] = true; }); });
    Object.keys(allTargets).forEach(function(t) {
      html += '<span class="flex items-center gap-1 text-[10px]"><span class="w-2 h-2 rounded-sm" style="background:' + (colors[t] || '#ddd') + '"></span>' + t + '</span>';
    });
    html += '</div></div>';
    el.innerHTML = html;
  }

  function drawHeatmap(divId, data, cols) {
    var el = document.getElementById(divId);
    if (!el) return;
    var rows = Object.keys(data).sort();
    if (!rows.length) { el.textContent = 'No data available'; return; }
    var maxVal = 0;
    rows.forEach(function(r) { cols.forEach(function(c) { var v = (data[r] && data[r][c]) || 0; if (v > maxVal) maxVal = v; }); });
    var html = '<table class="w-full text-xs"><thead><tr><th class="py-1 px-2 text-left">Entity</th>';
    cols.forEach(function(c) { html += '<th class="py-1 px-2 text-center">' + c + '</th>'; });
    html += '<th class="py-1 px-2 text-center">Total</th></tr></thead><tbody>';
    rows.forEach(function(r) {
      var rowTotal = 0;
      html += '<tr><td class="py-1 px-2 font-mono font-medium border-r">' + r + '</td>';
      cols.forEach(function(c) {
        var v = (data[r] && data[r][c]) || 0;
        rowTotal += v;
        var intensity = maxVal ? (v / maxVal * 0.8 + 0.05) : 0.05;
        var color = COLORS[c] || '#999';
        var rgb = hexToRgb(color);
        html += '<td class="py-1 px-2 text-center font-mono" style="background:rgba(' + rgb + ',' + intensity.toFixed(2) + ')">' + (v || '-') + '</td>';
      });
      html += '<td class="py-1 px-2 text-center font-mono font-bold border-l">' + rowTotal + '</td></tr>';
    });
    el.innerHTML = html + '</tbody></table>';
  }

  function hexToRgb(hex) {
    var r = parseInt(hex.slice(1, 3), 16);
    var g = parseInt(hex.slice(3, 5), 16);
    var b = parseInt(hex.slice(5, 7), 16);
    return r + ',' + g + ',' + b;
  }

  function drawBalanceActivity(divId, items) {
    var el = document.getElementById(divId);
    if (!el) return;
    // Group by outcome, show count + avg postings
    var groups = {};
    items.forEach(function(p) {
      var o = p.cleansing_outcome || 'OTHER';
      if (!groups[o]) groups[o] = { count: 0, totalPostings: 0 };
      groups[o].count++;
      var trend = p.posting_trend || [];
      var sum = trend.reduce(function(a, b) { return a + b; }, 0);
      groups[o].totalPostings += sum;
    });

    var html = '<div class="space-y-2">';
    var maxPostings = 0;
    Object.keys(groups).forEach(function(o) {
      var avg = groups[o].count ? Math.round(groups[o].totalPostings / groups[o].count) : 0;
      if (avg > maxPostings) maxPostings = avg;
    });
    Object.keys(groups).forEach(function(o) {
      var avg = groups[o].count ? Math.round(groups[o].totalPostings / groups[o].count) : 0;
      var pct = maxPostings ? Math.round(avg / maxPostings * 100) : 0;
      html += '<div class="flex items-center gap-2">' +
        '<span class="w-24 text-xs font-medium text-right" style="color:' + (COLORS[o] || '#666') + '">' + o + ' (' + groups[o].count + ')</span>' +
        '<div class="flex-1 bg-gray-100 rounded h-5 relative">' +
        '<div class="h-full rounded" style="width:' + pct + '%;background:' + (COLORS[o] || '#999') + ';opacity:0.6"></div>' +
        '<span class="absolute inset-0 flex items-center pl-2 text-[10px] font-mono">avg ' + avg + ' postings</span></div></div>';
    });
    html += '</div>';
    el.innerHTML = html;
  }

  function drawConfidenceHist(divId, values) {
    var el = document.getElementById(divId);
    if (!el) return;
    if (!values.length) { el.innerHTML = '<span class="text-sm text-gray-400">No ML confidence data</span>'; return; }
    var bins = 10;
    var min = Math.min.apply(null, values), max = Math.max.apply(null, values);
    var step = (max - min) / bins || 0.1;
    var counts = new Array(bins).fill(0);
    values.forEach(function(v) {
      var idx = Math.min(Math.floor((v - min) / step), bins - 1);
      counts[idx]++;
    });
    var maxCount = Math.max.apply(null, counts);
    var html = '<div class="flex items-end gap-1 h-[160px]">';
    counts.forEach(function(c, i) {
      var hPct = maxCount ? Math.round(c / maxCount * 100) : 0;
      var label = (min + i * step).toFixed(2);
      html += '<div class="flex-1 flex flex-col items-center justify-end h-full">' +
        '<div class="text-[9px] font-mono text-gray-500 mb-1">' + c + '</div>' +
        '<div class="w-full rounded-t" style="height:' + hPct + '%;background:#6366f1;opacity:0.7;min-height:' + (c ? '2px' : '0') + '"></div>' +
        '<div class="text-[8px] font-mono text-gray-400 mt-1 truncate w-full text-center">' + label + '</div></div>';
    });
    html += '</div>';
    html += '<div class="text-center text-xs text-gray-500 mt-1">Confidence Score Range (' + values.length + ' proposals)</div>';
    el.innerHTML = html;
  }

  function drawSankey(divId, flows) {
    var el = document.getElementById(divId);
    if (!el || !Object.keys(flows).length) return;
    var sorted = Object.entries(flows).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 15);
    var total = sorted.reduce(function(s, f) { return s + f[1]; }, 0);
    var html = '<div class="space-y-1">';
    sorted.forEach(function(f) {
      var pct = Math.round(f[1] / total * 100);
      var parts = f[0].split(' → ');
      var color = COLORS[parts[0]] || '#999';
      html += '<div class="flex items-center gap-2 text-xs">' +
        '<span class="w-24 text-right font-medium" style="color:' + color + '">' + parts[0] + '</span>' +
        '<div class="flex-1 bg-gray-100 rounded h-5 relative">' +
        '<div class="h-full rounded" style="width:' + pct + '%;background:' + color + ';opacity:0.5"></div>' +
        '<span class="absolute inset-0 flex items-center justify-center text-xs font-mono">' + f[1] + ' (' + pct + '%)</span></div>' +
        '<span class="w-16 font-medium">' + parts[1] + '</span></div>';
    });
    el.innerHTML = html + '</div>';
  }

  // --- Config management ---
  var jsonHdr = Object.assign({ 'Content-Type': 'application/json' }, authHdr);

  function loadConfigs() {
    fetch('/api/configs', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(configs) {
      // Populate dropdown
      var sel = document.getElementById('sel-config');
      sel.innerHTML = '<option value="">Default Config</option>';
      configs.forEach(function(c) {
        var opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name + ' (v' + c.version + ')';
        sel.appendChild(opt);
      });
      // Populate config list in panel
      var listEl = document.getElementById('config-list');
      if (!configs.length) {
        listEl.innerHTML = '<p class="text-sm text-gray-400">No custom configurations yet. Click "+ New Config" to create one.</p>';
        return;
      }
      listEl.innerHTML = configs.map(function(c) {
        var routineNames = (c.config.routines || []).map(function(r) { return r.code || r; }).join(', ') || 'Default pipeline';
        return '<div class="flex items-center justify-between p-2 bg-gray-50 rounded text-sm">' +
          '<div><span class="font-semibold">' + esc(c.name) + '</span> <span class="text-gray-400">v' + c.version + '</span>' +
          '<div class="text-xs text-gray-500">' + esc(routineNames) + '</div></div>' +
          '<div class="flex gap-1">' +
          '<button onclick="editConfig(\'' + esc(c.code) + '\')" class="btn-sm bg-gray-200 text-gray-600 hover:bg-gray-300 text-xs">Edit</button>' +
          '</div></div>';
      }).join('');
    });
  }

  function loadRoutines(callback) {
    fetch('/api/admin/routines', { headers: authHdr }).then(function(r) { return r.json(); }).then(callback);
  }

  window.editConfig = function(code) {
    fetch('/api/configs/' + code, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(cfg) {
      loadRoutines(function(routines) {
        showConfigEditor(cfg, routines);
      });
    });
  };

  function showConfigEditor(cfg, routines) {
    var editorEl = document.getElementById('config-editor');
    editorEl.classList.remove('hidden');
    var selectedRoutines = (cfg ? (cfg.config.routines || []).map(function(r) { return r.code || r; }) : []);
    var html = '<div class="space-y-3">' +
      '<div><label class="block text-xs text-gray-500 mb-1">Config Name</label>' +
      '<input id="cfg-name" type="text" class="input text-sm w-full" value="' + esc(cfg ? cfg.name : '') + '" /></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Description</label>' +
      '<input id="cfg-desc" type="text" class="input text-sm w-full" value="' + esc(cfg ? (cfg.description || '') : '') + '" /></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Code (unique identifier)</label>' +
      '<input id="cfg-code" type="text" class="input text-sm w-48" value="' + esc(cfg ? cfg.code : '') + '" ' + (cfg ? 'readonly' : '') + ' /></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Select Routines to Include</label>' +
      '<div class="grid grid-cols-1 md:grid-cols-2 gap-1">';
    routines.forEach(function(r) {
      var checked = selectedRoutines.indexOf(r.code) >= 0 ? ' checked' : '';
      html += '<label class="flex items-center gap-2 text-sm p-1 bg-white rounded border">' +
        '<input type="checkbox" class="cfg-routine" value="' + esc(r.code) + '"' + checked + ' />' +
        '<span class="font-medium">' + esc(r.name) + '</span>' +
        '<span class="text-xs text-gray-400">(' + r.kind + '/' + (r.tree || 'any') + ')</span></label>';
    });
    html += '</div></div>' +
      '<div class="flex gap-2 mt-3">' +
      '<button id="btn-save-config" class="btn-sm bg-blue-600 text-white hover:bg-blue-700">Save Config</button>' +
      '<button onclick="document.getElementById(\'config-editor\').classList.add(\'hidden\')" class="btn-sm bg-gray-200 text-gray-600 hover:bg-gray-300">Cancel</button></div></div>';
    editorEl.innerHTML = html;

    document.getElementById('btn-save-config').addEventListener('click', function() {
      var name = document.getElementById('cfg-name').value.trim();
      var code = document.getElementById('cfg-code').value.trim();
      var desc = document.getElementById('cfg-desc').value.trim();
      if (!name || !code) { alert('Name and code are required'); return; }
      var selectedCodes = [];
      document.querySelectorAll('.cfg-routine:checked').forEach(function(cb) { selectedCodes.push(cb.value); });
      var configData = { routines: selectedCodes.map(function(c) { return { code: c }; }) };
      var url = cfg ? '/api/configs/' + code + '/amend' : '/api/configs';
      fetch(url, {
        method: 'POST', headers: jsonHdr,
        body: JSON.stringify({ code: code, name: name, description: desc || null, config: configData })
      }).then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || 'Failed'); });
        editorEl.classList.add('hidden');
        loadConfigs();
      }).catch(function(err) { alert('Error: ' + err.message); });
    });
  }

  document.getElementById('btn-manage-configs').addEventListener('click', function() {
    var panel = document.getElementById('config-panel');
    panel.classList.toggle('hidden');
    if (!panel.classList.contains('hidden')) loadConfigs();
  });

  document.getElementById('btn-new-config').addEventListener('click', function() {
    loadRoutines(function(routines) {
      showConfigEditor(null, routines);
    });
  });

  // Load config dropdown on page load
  loadConfigs();

  // Global Analysis button — pass selected config_id
  document.getElementById('btn-run-global').addEventListener('click', function() {
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Running...';
    var configId = document.getElementById('sel-config').value;
    var url = '/api/runs/global' + (configId ? '?config_id=' + configId : '');
    fetch(url, {
      method: 'POST',
      headers: jsonHdr,
    }).then(function(r) {
      if (!r.ok) return r.json().then(function(b) { throw new Error(b.detail || 'Failed'); });
      return r.json();
    }).then(function(d) {
      btn.textContent = 'Run Global Analysis';
      btn.disabled = false;
      alert('Global analysis completed — Run #' + d.run_id + ' (' + (d.kpis ? d.kpis.total_centers : '?') + ' centers)');
      document.getElementById('sel-wave').value = '__global__';
      loadGlobalRuns();
    }).catch(function(err) {
      btn.textContent = 'Run Global Analysis';
      btn.disabled = false;
      alert('Error: ' + err.message);
    });
  });
</script>
