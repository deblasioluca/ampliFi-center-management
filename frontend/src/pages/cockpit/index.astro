---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Analyst Cockpit — ampliFi">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-amplifi-700 text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="text-2xl font-bold tracking-tight hover:text-amplifi-200">ampliFi</a>
          <span class="text-amplifi-200 text-sm">Cockpit</span>
        </div>
        <nav class="flex gap-4 text-sm">
          <a href="/" class="hover:text-amplifi-200">Home</a>
          <a href="/admin" class="hover:text-amplifi-200">Admin</a>
        </nav>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Analyst Cockpit</h2>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <!-- Sidebar: Wave selector -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-lg shadow p-4">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">Waves</h3>
            <div id="wave-list" class="space-y-2 text-sm">Loading waves...</div>
          </div>
        </div>

        <!-- Main content -->
        <div class="lg:col-span-3 space-y-6">
          <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Wave Overview</h3>
            <p class="text-gray-500">Select a wave to view its analysis results, proposals, and review status.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-white rounded-lg shadow p-4">
              <h4 class="text-sm font-medium text-gray-500">Proposals</h4>
              <p class="text-2xl font-bold text-gray-900 mt-1">—</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4">
              <h4 class="text-sm font-medium text-gray-500">Reviews</h4>
              <p class="text-2xl font-bold text-gray-900 mt-1">—</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4">
              <h4 class="text-sm font-medium text-gray-500">Overrides</h4>
              <p class="text-2xl font-bold text-gray-900 mt-1">—</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  async function loadWaves() {
    try {
      const resp = await fetch('/api/waves');
      if (!resp.ok) {
        document.getElementById('wave-list')!.textContent = 'Login required';
        return;
      }
      const data = await resp.json();
      const el = document.getElementById('wave-list');
      if (!el) return;
      if (data.items.length === 0) {
        el.textContent = 'No waves yet. Create one from Admin.';
        return;
      }
      el.innerHTML = data.items
        .map((w: any) => `<a href="/cockpit/${w.id}" class="block p-2 rounded hover:bg-amplifi-50">
          <span class="font-medium">${w.code}</span>
          <span class="text-xs text-gray-400 ml-1">${w.status}</span>
        </a>`)
        .join('');
    } catch {
      document.getElementById('wave-list')!.textContent = 'Unable to load';
    }
  }
  loadWaves();
</script>
