---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Cockpit" requireAuth={true} requiredRole="data_manager">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Cockpit</h1>
    <p class="text-sm text-gray-500 mt-1">Manage waves, run analysis, review proposals, and export results</p>
  </div>

  <!-- Workflow guide -->
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
    <p class="text-xs font-semibold text-blue-800 mb-2">Wave Lifecycle</p>
    <div class="flex items-center gap-1 text-[10px] text-blue-700 flex-wrap">
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">1. Create Wave</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">2. Define Scope</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">3. Run Analysis</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">4. Review Proposals</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">5. Lock &amp; Assign Reviewers</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">6. Stakeholder Review</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">7. Sign Off</span>
      <span class="text-blue-400">&rarr;</span>
      <span class="bg-white px-2 py-0.5 rounded shadow-sm font-medium">8. MDG Export</span>
    </div>
  </div>

  <!-- Global Stats -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-4">
    <div class="card">
      <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Entities</h4>
      <p id="stat-entities" class="text-2xl font-bold text-gray-900 mt-1">--</p>
    </div>
    <div class="card">
      <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Cost Centers</h4>
      <p id="stat-cc" class="text-2xl font-bold text-gray-900 mt-1">--</p>
    </div>
    <div class="card">
      <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Profit Centers</h4>
      <p id="stat-pc" class="text-2xl font-bold text-gray-900 mt-1">--</p>
    </div>
    <div class="card">
      <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Waves</h4>
      <p id="stat-waves" class="text-2xl font-bold text-gray-900 mt-1">--</p>
    </div>
    <div class="card">
      <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Balances</h4>
      <p id="stat-balances" class="text-2xl font-bold text-gray-900 mt-1">--</p>
    </div>
  </div>

  <!-- Scope Coverage -->
  <div class="card mb-8">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Scope Coverage</h3>
    <div id="coverage-content" class="text-sm text-gray-400">Loading coverage data...</div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Sidebar: Wave selector -->
    <div class="lg:col-span-1">
      <div class="card mb-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-gray-700">Waves</h3>
          <button id="create-wave-btn" class="text-xs text-amplifi-600 hover:text-amplifi-800">+ New</button>
        </div>
        <div id="wave-list" class="space-y-2 text-sm">Loading waves...</div>
      </div>
      <a href="/cockpit/analytics" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">Analytics</p>
            <p class="text-xs text-gray-500">Charts & visualizations</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/compare" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">Compare Runs</p>
            <p class="text-xs text-gray-500">Outcome diff matrices</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/pipeline" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">Pipeline Editor</p>
            <p class="text-xs text-gray-500">Configure analysis steps</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/llm-review" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">LLM Transcripts</p>
            <p class="text-xs text-gray-500">Review AI commentary</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/mdg-export" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">MDG Export</p>
            <p class="text-xs text-gray-500">Generate export files</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/housekeeping" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">Housekeeping</p>
            <p class="text-xs text-gray-500">Monthly cycle reviews</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/data-quality" class="card block hover:shadow-md transition-shadow mb-3">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">Data Quality</p>
            <p class="text-xs text-gray-500">Completeness & consistency</p>
          </div>
        </div>
      </a>
      <a href="/cockpit/cluster" class="card block hover:shadow-md transition-shadow">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          <div>
            <p class="text-sm font-medium text-gray-700">Cluster Explorer</p>
            <p class="text-xs text-gray-500">Find duplicates & similar centers</p>
          </div>
        </div>
      </a>

      <!-- Create wave form (hidden by default) -->
      <div id="new-wave-form" class="card mt-4 hidden">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Create Wave</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Code</label>
            <input type="text" id="wave-code" class="input text-sm" placeholder="e.g. WAVE-001" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Name</label>
            <input type="text" id="wave-name" class="input text-sm" placeholder="Wave name" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Description</label>
            <input type="text" id="wave-desc" class="input text-sm" placeholder="Description" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Scope: Entities (comma-separated company codes)</label>
            <input type="text" id="wave-entities" class="input text-sm" placeholder="DE01, US01, JP01" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Scope: Hierarchy Node</label>
            <div class="flex gap-2">
              <select id="wave-hier-id" class="input text-sm flex-1">
                <option value="">-- Select Hierarchy --</option>
              </select>
              <input type="text" id="wave-hier-node" class="input text-sm flex-1" placeholder="Node setname" />
            </div>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="wave-full-scope" />
            <label for="wave-full-scope" class="text-xs text-gray-500">Full scope (all cost centers)</label>
          </div>
          <div class="flex gap-2">
            <button id="save-wave-btn" class="btn-amplifi text-xs flex-1">Create</button>
            <button id="cancel-wave-btn" class="btn-secondary text-xs">Cancel</button>
          </div>
          <div id="wave-error" class="text-xs text-red-600 hidden"></div>
        </div>
      </div>
    </div>

    <!-- Main content: wave details -->
    <div class="lg:col-span-3 space-y-6">
      <div id="wave-detail" class="card">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Wave Overview</h3>
        <p class="text-gray-500">Select a wave to view its analysis results, proposals, and review status.</p>
      </div>

      <div id="wave-stats" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="card">
            <h4 class="text-sm font-medium text-gray-500">Proposals</h4>
            <p id="wd-proposals" class="text-2xl font-bold text-gray-900 mt-1">--</p>
          </div>
          <div class="card">
            <h4 class="text-sm font-medium text-gray-500">Reviews</h4>
            <p id="wd-reviews" class="text-2xl font-bold text-gray-900 mt-1">--</p>
          </div>
          <div class="card">
            <h4 class="text-sm font-medium text-gray-500">Status</h4>
            <p id="wd-status" class="text-2xl font-bold text-gray-900 mt-1">--</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  (function() {
    var token = localStorage.getItem('amplifi_token');
    var headers = token ? { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } : { 'Content-Type': 'application/json' };

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text || '';
      return div.innerHTML;
    }

    // Global stats
    fetch('/api/stats/global', { headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var u = data.universe || {};
        document.getElementById('stat-entities').textContent = (u.entities_total || 0).toLocaleString();
        document.getElementById('stat-cc').textContent = (u.legacy_cc_total || 0).toLocaleString();
        document.getElementById('stat-pc').textContent = (u.legacy_pc_total || 0).toLocaleString();
        document.getElementById('stat-waves').textContent = (u.waves_total || 0).toLocaleString();
        document.getElementById('stat-balances').textContent = (u.balances_total || 0).toLocaleString();
      })
      .catch(function() {});

    // Waves list
    function loadWaves() {
      fetch('/api/waves?page=1&size=100', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var el = document.getElementById('wave-list');
          if (!data.items || data.items.length === 0) {
            el.textContent = 'No waves yet.';
            return;
          }
          el.innerHTML = '';
          var STEPS = ['draft','scope','analysing','proposed','locked','in_review','signed_off'];
          var STEP_LABELS = ['Define','Scope','Analyse','Confirm','Start','Review','Done'];
          function stepForStatus(s, ec) {
            if (s === 'closed' || s === 'signed_off') return 6;
            if (s === 'in_review') return 5;
            if (s === 'locked') return 4;
            if (s === 'proposed') return 3;
            if (s === 'analysing') return 2;
            if (s === 'draft' && ec > 0) return 1;
            return 0;
          }
          data.items.forEach(function(w) {
            var wrapper = document.createElement('div');
            wrapper.className = 'flex items-center gap-1 border-b';
            var link = document.createElement('a');
            link.className = 'block flex-1 p-3 rounded hover:bg-amplifi-50 transition-colors';
            link.setAttribute('data-id', w.id);
            var cs = stepForStatus(w.status, w.entity_count || 0);
            var dots = '';
            for (var si = 0; si < 7; si++) {
              var col = si < cs ? '#22c55e' : si === cs ? '#3b82f6' : '#d1d5db';
              dots += '<div title="' + STEP_LABELS[si] + '" style="width:8px;height:8px;border-radius:50%;background:' + col + '"></div>';
            }
            link.innerHTML = '<div class="flex items-center justify-between">' +
              '<span class="font-medium">' + escapeHtml(w.code) + '</span>' +
              '<span class="text-xs text-gray-400">' + escapeHtml(w.status.replace('_',' ')) + '</span></div>' +
              '<div class="flex gap-1 mt-1">' + dots + '</div>';
            link.href = '/cockpit/wave?id=' + w.id;
            wrapper.appendChild(link);
            // Delete button (not for in_review or signed_off)
            if (w.status !== 'in_review' && w.status !== 'signed_off') {
              var delBtn = document.createElement('button');
              delBtn.className = 'text-gray-300 hover:text-red-500 p-1 transition-colors flex-shrink-0';
              delBtn.title = 'Delete wave';
              delBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>';
              delBtn.setAttribute('data-wave-id', w.id);
              delBtn.setAttribute('data-wave-code', w.code);
              delBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var wid = this.getAttribute('data-wave-id');
                var wcode = this.getAttribute('data-wave-code');
                if (!confirm('Delete wave "' + wcode + '"? This will permanently remove the wave and all its proposals, runs, and scopes.')) return;
                fetch('/api/waves/' + wid, { method: 'DELETE', headers: headers })
                  .then(function(r) { if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || 'Failed'); }); loadWaves(); loadCoverage(); })
                  .catch(function(err) { alert('Error: ' + err.message); });
              });
              wrapper.appendChild(delBtn);
            }
            el.appendChild(wrapper);
          });
        })
        .catch(function() {
          document.getElementById('wave-list').textContent = 'Unable to load';
        });
    }
    loadWaves();

    function loadCoverage() {
      fetch('/api/stats/coverage', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var el = document.getElementById('coverage-content');
          var ePct = d.entity_pct || 0;
          var cPct = d.cc_pct || 0;
          var html = '<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">';
          // Entity coverage bar
          html += '<div><div class="flex justify-between text-xs mb-1"><span class="font-medium text-gray-600">Entities</span><span class="text-gray-500">' + d.covered_entities + ' / ' + d.total_entities + ' (' + ePct + '%)</span></div>';
          html += '<div class="w-full bg-gray-200 rounded h-4"><div class="h-full rounded ' + (ePct >= 100 ? 'bg-green-500' : 'bg-blue-500') + '" style="width:' + Math.min(ePct, 100) + '%"></div></div></div>';
          // CC coverage bar
          html += '<div><div class="flex justify-between text-xs mb-1"><span class="font-medium text-gray-600">Cost Centers (analysed)</span><span class="text-gray-500">' + d.covered_cc + ' / ' + d.total_cc + ' (' + cPct + '%)</span></div>';
          html += '<div class="w-full bg-gray-200 rounded h-4"><div class="h-full rounded ' + (cPct >= 100 ? 'bg-green-500' : 'bg-blue-500') + '" style="width:' + Math.min(cPct, 100) + '%"></div></div></div>';
          html += '</div>';
          // Per-wave breakdown table
          if (d.waves && d.waves.length) {
            html += '<table class="w-full text-xs"><thead><tr class="border-b text-gray-500"><th class="py-1 text-left">Wave</th><th class="py-1 text-center">Status</th><th class="py-1 text-center">Entities</th><th class="py-1 text-center">CCs Analysed</th><th class="py-1 text-center">Scope</th></tr></thead><tbody>';
            d.waves.forEach(function(w) {
              html += '<tr class="border-b hover:bg-gray-50">';
              html += '<td class="py-1 font-medium"><a href="/cockpit/wave?id=' + w.id + '" class="text-blue-600 hover:underline">' + escapeHtml(w.code) + '</a></td>';
              html += '<td class="py-1 text-center"><span class="px-1.5 py-0.5 rounded text-[10px] bg-gray-100">' + escapeHtml(w.status) + '</span></td>';
              html += '<td class="py-1 text-center">' + w.entities_covered + '</td>';
              html += '<td class="py-1 text-center">' + w.cc_covered + '</td>';
              html += '<td class="py-1 text-center">' + (w.is_full_scope ? '<span class="text-green-600">Full</span>' : 'Scoped') + '</td>';
              html += '</tr>';
            });
            html += '</tbody></table>';
          }
          el.innerHTML = html;
        })
        .catch(function() {
          document.getElementById('coverage-content').textContent = 'Unable to load coverage data';
        });
    }
    loadCoverage();

    function loadWaveDetail(waveId, waveData) {
      var detail = document.getElementById('wave-detail');
      detail.innerHTML =
        '<h3 class="text-lg font-semibold text-gray-900 mb-2">' + escapeHtml(waveData.code) + '</h3>' +
        '<p class="text-sm text-gray-500">' + escapeHtml(waveData.description || 'No description') + '</p>' +
        '<div class="mt-3 flex gap-2">' +
          '<span class="text-xs px-2 py-1 rounded bg-amplifi-50 text-amplifi-700">' + escapeHtml(waveData.status) + '</span>' +
          '<span class="text-xs text-gray-400">Created: ' + escapeHtml(waveData.created_at ? new Date(waveData.created_at).toLocaleDateString() : '--') + '</span>' +
        '</div>';
      document.getElementById('wave-stats').classList.remove('hidden');

      fetch('/api/stats/wave/' + waveId, { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(s) {
          document.getElementById('wd-proposals').textContent = (s.proposals_total || s.total_proposals || 0).toLocaleString();
          document.getElementById('wd-reviews').textContent = (s.reviews_total || s.total_reviews || 0).toLocaleString();
          document.getElementById('wd-status').textContent = s.status || waveData.status || '--';
        })
        .catch(function() {});
    }

    // Create wave toggle
    document.getElementById('create-wave-btn').addEventListener('click', function() {
      document.getElementById('new-wave-form').classList.toggle('hidden');
    });
    document.getElementById('cancel-wave-btn').addEventListener('click', function() {
      document.getElementById('new-wave-form').classList.add('hidden');
    });
    // Load hierarchies for wave scope selector
    fetch('/api/legacy/hierarchies?size=200', { headers: headers }).then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('wave-hier-id');
      (d.items || []).forEach(function(h) {
        var opt = document.createElement('option');
        opt.value = h.id;
        opt.textContent = h.setname + ' (' + (h.description || h.setclass) + ')';
        sel.appendChild(opt);
      });
    }).catch(function(){});

    document.getElementById('save-wave-btn').addEventListener('click', async function() {
      var code = document.getElementById('wave-code').value.trim();
      var name = document.getElementById('wave-name').value.trim();
      var desc = document.getElementById('wave-desc').value.trim();
      var entitiesRaw = document.getElementById('wave-entities').value.trim();
      var hierId = document.getElementById('wave-hier-id').value;
      var hierNode = document.getElementById('wave-hier-node').value.trim();
      var fullScope = document.getElementById('wave-full-scope').checked;
      var errEl = document.getElementById('wave-error');
      errEl.classList.add('hidden');
      if (!code) { errEl.textContent = 'Code required'; errEl.classList.remove('hidden'); return; }
      if (!name) { errEl.textContent = 'Name required'; errEl.classList.remove('hidden'); return; }
      var entity_ccodes = entitiesRaw ? entitiesRaw.split(',').map(function(s){return s.trim();}).filter(Boolean) : [];
      var hierarchy_scopes = [];
      if (hierId && hierNode) {
        hierarchy_scopes.push({ hierarchy_id: parseInt(hierId), node_setname: hierNode });
      }
      try {
        var body = { code: code, name: name, description: desc, entity_ccodes: entity_ccodes, hierarchy_scopes: hierarchy_scopes, is_full_scope: fullScope };
        var res = await fetch('/api/waves', { method: 'POST', headers: headers, body: JSON.stringify(body) });
        if (!res.ok) { var b = await res.json().catch(function(){return {};}); throw new Error(b.detail || 'Failed'); }
        document.getElementById('new-wave-form').classList.add('hidden');
        loadWaves();
      } catch(e) { errEl.textContent = e.message; errEl.classList.remove('hidden'); }
    });
  })();
</script>
