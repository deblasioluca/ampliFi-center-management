---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Cockpit" requireAuth={true} requiredRole="data_manager">
  <!-- Header row -->
  <div class="flex items-center justify-between mb-3">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Cockpit</h1>
      <p class="text-xs text-gray-500">Manage waves, run analysis, review proposals, and export results</p>
    </div>
    <div class="flex items-center gap-1 text-[9px] text-blue-600 flex-wrap">
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">1. Create</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">2. Scope</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">3. Analyse</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">4. Review</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">5. Lock</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">6. Stakeholder</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">7. Sign Off</span>
      <span class="text-blue-300">&rarr;</span>
      <span class="bg-blue-50 px-1.5 py-0.5 rounded font-medium">8. Export</span>
    </div>
  </div>

  <!-- Stats row (compact) -->
  <div class="flex gap-3 mb-3 flex-wrap">
    <div class="bg-white border rounded-lg px-3 py-1.5 min-w-[100px]">
      <span class="text-[10px] text-gray-500 uppercase">Entities</span>
      <p id="stat-entities" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 min-w-[100px]">
      <span class="text-[10px] text-gray-500 uppercase">Cost Centers</span>
      <p id="stat-cc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 min-w-[100px]">
      <span class="text-[10px] text-gray-500 uppercase">Profit Centers</span>
      <p id="stat-pc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 min-w-[100px]">
      <span class="text-[10px] text-gray-500 uppercase">Waves</span>
      <p id="stat-waves" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 min-w-[100px]">
      <span class="text-[10px] text-gray-500 uppercase">Balances</span>
      <p id="stat-balances" class="text-lg font-bold text-gray-900">--</p>
    </div>
  </div>

  <!-- Quick-nav toolbar (horizontal, compact) -->
  <div class="bg-white border rounded-lg px-3 py-2 mb-3 flex items-center gap-3 flex-wrap text-xs">
    <a href="/cockpit/analytics" class="flex items-center gap-1.5 text-gray-600 hover:text-indigo-600">
      <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
      Analytics
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/engines" class="flex items-center gap-1.5 text-gray-600 hover:text-fuchsia-600">
      <svg class="w-4 h-4 text-fuchsia-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
      Engines
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/compare" class="flex items-center gap-1.5 text-gray-600 hover:text-purple-600">
      <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
      Compare
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/pipeline" class="flex items-center gap-1.5 text-gray-600 hover:text-green-600">
      <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
      Pipeline
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/llm-review" class="flex items-center gap-1.5 text-gray-600 hover:text-pink-600">
      <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
      LLM Review
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/mdg-export" class="flex items-center gap-1.5 text-gray-600 hover:text-teal-600">
      <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
      MDG Export
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/housekeeping" class="flex items-center gap-1.5 text-gray-600 hover:text-orange-600">
      <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      Housekeeping
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/data-quality" class="flex items-center gap-1.5 text-gray-600 hover:text-cyan-600">
      <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      Data Quality
    </a>
    <span class="text-gray-300">|</span>
    <a href="/cockpit/cluster" class="flex items-center gap-1.5 text-gray-600 hover:text-yellow-600">
      <svg class="w-4 h-4 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      Clusters
    </a>
  </div>

  <!-- Coverage bar (collapsible) -->
  <details class="bg-white border rounded-lg mb-3">
    <summary class="px-4 py-2 cursor-pointer text-sm font-semibold text-gray-700 select-none">Scope Coverage</summary>
    <div class="px-4 pb-3">
      <div id="coverage-content" class="text-sm text-gray-400">Loading coverage data...</div>
    </div>
  </details>

  <!-- Main content: Waves list + detail (fits viewport) -->
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-4" style="height:calc(100vh - 320px);min-height:300px">
    <!-- Wave list (scrollable) -->
    <div class="lg:col-span-1 flex flex-col">
      <div class="bg-white border rounded-lg flex-1 flex flex-col overflow-hidden">
        <div class="flex items-center justify-between px-3 py-2 border-b bg-gray-50 flex-shrink-0">
          <h3 class="text-sm font-semibold text-gray-700">Waves</h3>
          <button id="create-wave-btn" class="text-xs text-amplifi-600 hover:text-amplifi-800 font-medium">+ New</button>
        </div>
        <div id="wave-list" class="flex-1 overflow-y-auto space-y-0 text-sm">Loading waves...</div>
      </div>
    </div>

    <!-- Wave detail (right panel) -->
    <div class="lg:col-span-3 flex flex-col gap-3 overflow-y-auto">
      <div id="wave-detail" class="card">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Wave Overview</h3>
        <p class="text-gray-500 text-sm">Select a wave to view its analysis results, proposals, and review status.</p>
      </div>

      <div id="wave-stats" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div class="card">
            <h4 class="text-xs font-medium text-gray-500">Proposals</h4>
            <p id="wd-proposals" class="text-xl font-bold text-gray-900 mt-1">--</p>
          </div>
          <div class="card">
            <h4 class="text-xs font-medium text-gray-500">Reviews</h4>
            <p id="wd-reviews" class="text-xl font-bold text-gray-900 mt-1">--</p>
          </div>
          <div class="card">
            <h4 class="text-xs font-medium text-gray-500">Status</h4>
            <p id="wd-status" class="text-xl font-bold text-gray-900 mt-1">--</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Create Wave Modal (overlay) -->
  <div id="new-wave-modal" class="fixed inset-0 bg-black bg-opacity-30 z-50 flex items-center justify-center hidden">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md p-5">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-700">Create Wave</h3>
        <button id="close-wave-modal" class="text-gray-400 hover:text-gray-600 text-lg">&times;</button>
      </div>
      <div class="space-y-3">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Code</label>
          <input type="text" id="wave-code" class="input text-sm" placeholder="e.g. WAVE-001" />
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Name</label>
          <input type="text" id="wave-name" class="input text-sm" placeholder="Wave name" />
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Description</label>
          <input type="text" id="wave-desc" class="input text-sm" placeholder="Description" />
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Scope: Entities</label>
          <div id="wave-entity-picker"></div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Scope: Hierarchy Node</label>
          <div class="flex gap-2">
            <select id="wave-hier-id" class="input text-sm flex-1">
              <option value="">-- Select Hierarchy --</option>
            </select>
            <select id="wave-hier-node" class="input text-sm flex-1" disabled>
              <option value="">-- Pick a hierarchy first --</option>
            </select>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="wave-full-scope" />
          <label for="wave-full-scope" class="text-xs text-gray-500">Full scope (all cost centers)</label>
        </div>
        <div class="flex gap-2">
          <button id="save-wave-btn" class="btn-amplifi text-xs flex-1">Create</button>
          <button id="cancel-wave-btn" class="btn-secondary text-xs">Cancel</button>
        </div>
        <div id="wave-error" class="text-xs text-red-600 hidden"></div>
      </div>
    </div>
  </div>
</Layout>

<script src="/entity-picker.js" is:inline></script>
<script is:inline>
  (function() {
    var token = localStorage.getItem('amplifi_token');
    var headers = token ? { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } : { 'Content-Type': 'application/json' };

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text || '';
      return div.innerHTML;
    }

    // Global stats
    fetch('/api/stats/global', { headers: headers })
      .then(function(r) { if (r.status === 401) { localStorage.removeItem('amplifi_token'); localStorage.removeItem('amplifi_user'); window.location.href = '/login'; throw new Error('expired'); } return r; })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var u = data.universe || {};
        document.getElementById('stat-entities').textContent = (u.entities_total || 0).toLocaleString();
        document.getElementById('stat-cc').textContent = (u.legacy_cc_total || 0).toLocaleString();
        document.getElementById('stat-pc').textContent = (u.legacy_pc_total || 0).toLocaleString();
        document.getElementById('stat-waves').textContent = (u.waves_total || 0).toLocaleString();
        document.getElementById('stat-balances').textContent = (u.balances_total || 0).toLocaleString();
      })
      .catch(function() {});

    // Helper: redirect to login on 401
    function checkAuth(r) {
      if (r.status === 401) {
        localStorage.removeItem('amplifi_token');
        localStorage.removeItem('amplifi_user');
        window.location.href = '/login';
        throw new Error('Session expired');
      }
      return r;
    }

    // Waves list
    function loadWaves() {
      fetch('/api/waves?page=1&size=100', { headers: headers })
        .then(checkAuth)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var el = document.getElementById('wave-list');
          if (!data.items || data.items.length === 0) {
            el.textContent = 'No waves yet.';
            return;
          }
          el.innerHTML = '';
          var STEPS = ['draft','scope','analysing','proposed','locked','in_review','signed_off'];
          var STEP_LABELS = ['Define','Scope','Analyse','Confirm','Start','Review','Done'];
          function stepForStatus(s, ec) {
            if (s === 'closed' || s === 'signed_off') return 6;
            if (s === 'in_review') return 5;
            if (s === 'locked') return 4;
            if (s === 'proposed') return 3;
            if (s === 'analysing') return 2;
            if (s === 'draft' && ec > 0) return 1;
            return 0;
          }
          data.items.forEach(function(w) {
            var wrapper = document.createElement('div');
            wrapper.className = 'flex items-center gap-1 border-b';
            var link = document.createElement('a');
            link.className = 'block flex-1 p-3 rounded hover:bg-amplifi-50 transition-colors';
            link.setAttribute('data-id', w.id);
            var cs = stepForStatus(w.status, w.entity_count || 0);
            var dots = '';
            for (var si = 0; si < 7; si++) {
              var col = si < cs ? '#22c55e' : si === cs ? '#3b82f6' : '#d1d5db';
              dots += '<div title="' + STEP_LABELS[si] + '" style="width:8px;height:8px;border-radius:50%;background:' + col + '"></div>';
            }
            link.innerHTML = '<div class="flex items-center justify-between">' +
              '<span class="font-medium">' + escapeHtml(w.code) + '</span>' +
              '<span class="text-xs text-gray-400">' + escapeHtml(w.status.replace('_',' ')) + '</span></div>' +
              '<div class="flex gap-1 mt-1">' + dots + '</div>';
            link.href = '/cockpit/wave?id=' + w.id;
            wrapper.appendChild(link);

            // Action button on the right of each row.
            // * Active waves (draft, analysing, proposed, locked, in_review):
            //   Delete button — admin can abandon work-in-progress.
            //   PR #84 lifted the previous block on in_review.
            // * Terminal waves (signed_off, closed, cancelled):
            //   Archive button — moves the wave out of the active list
            //   into the admin archive view, where it can be deleted
            //   in a separate step. This is the "two-step pattern"
            //   that protects audit history of completed work.
            var TERMINAL = ['signed_off', 'closed', 'cancelled'];
            var isTerminal = TERMINAL.indexOf(w.status) >= 0;
            if (!isTerminal) {
              // Active wave → Delete trash icon
              var delBtn = document.createElement('button');
              delBtn.className = 'text-gray-300 hover:text-red-500 p-1 transition-colors flex-shrink-0';
              delBtn.title = 'Delete wave (in_review and earlier statuses can be deleted directly)';
              delBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>';
              delBtn.setAttribute('data-wave-id', w.id);
              delBtn.setAttribute('data-wave-code', w.code);
              delBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var wid = this.getAttribute('data-wave-id');
                var wcode = this.getAttribute('data-wave-code');
                if (!confirm('Delete wave "' + wcode + '"? This will permanently remove the wave and all its proposals, runs, and scopes.')) return;
                fetch('/api/waves/' + wid, { method: 'DELETE', headers: headers })
                  .then(function(r) {
                    if (!r.ok) return r.text().then(function(t) {
                      try { var e = JSON.parse(t); throw new Error(e.detail || 'Failed'); }
                      catch(pe) { if (pe instanceof SyntaxError) throw new Error('Server error: ' + r.status); throw pe; }
                    });
                    loadWaves(); loadCoverage();
                  })
                  .catch(function(err) { alert('Error: ' + err.message); });
              });
              wrapper.appendChild(delBtn);
            } else {
              // Terminal wave → Archive box icon
              var archBtn = document.createElement('button');
              archBtn.className = 'text-gray-300 hover:text-amber-500 p-1 transition-colors flex-shrink-0';
              archBtn.title = 'Archive wave — moves it to the admin archive view (out of the active list)';
              // Box-with-arrow-down icon = archive
              archBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>';
              archBtn.setAttribute('data-wave-id', w.id);
              archBtn.setAttribute('data-wave-code', w.code);
              archBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var wid = this.getAttribute('data-wave-id');
                var wcode = this.getAttribute('data-wave-code');
                if (!confirm('Archive wave "' + wcode + '"? It will disappear from the active list and only be visible in the admin archive view (where it can be deleted permanently).')) return;
                fetch('/api/waves/' + wid + '/archive', { method: 'POST', headers: headers })
                  .then(function(r) {
                    if (!r.ok) return r.text().then(function(t) {
                      try { var e = JSON.parse(t); throw new Error(e.detail || 'Failed'); }
                      catch(pe) { if (pe instanceof SyntaxError) throw new Error('Server error: ' + r.status); throw pe; }
                    });
                    loadWaves(); loadCoverage();
                  })
                  .catch(function(err) { alert('Error: ' + err.message); });
              });
              wrapper.appendChild(archBtn);
            }
            el.appendChild(wrapper);
          });
        })
        .catch(function() {
          document.getElementById('wave-list').textContent = 'Unable to load';
        });
    }
    loadWaves();

    function loadCoverage() {
      fetch('/api/stats/coverage', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var el = document.getElementById('coverage-content');
          // The endpoint splits into `scoped` (real wave work) and
          // `global` (full-scope reference waves + wave_id IS NULL runs).
          // The main progress bars below show *scoped* progress so the
          // global wave doesn't inflate the picture to 100%.
          var s = d.scoped || {};
          var g = d.global || {};
          var html = '';

          // ── Wave Progress (scoped only) ──────────────────────────
          html += '<div class="mb-4">';
          html += '<div class="text-xs font-semibold text-gray-700 mb-2">Wave Progress <span class="text-gray-400 font-normal">— ' + (s.wave_count || 0) + ' scoped wave' + (s.wave_count === 1 ? '' : 's') + ', excludes global analysis</span></div>';
          html += '<div class="grid grid-cols-1 md:grid-cols-2 gap-4">';
          var sePct = s.entity_pct || 0;
          var scPct = s.cc_pct || 0;
          html += '<div><div class="flex justify-between text-xs mb-1"><span class="font-medium text-gray-600">Entities in scoped waves</span><span class="text-gray-500">' + (s.covered_entities || 0) + ' / ' + d.total_entities + ' (' + sePct + '%)</span></div>';
          html += '<div class="w-full bg-gray-200 rounded h-4"><div class="h-full rounded ' + (sePct >= 100 ? 'bg-green-500' : 'bg-blue-500') + '" style="width:' + Math.min(sePct, 100) + '%"></div></div></div>';
          html += '<div><div class="flex justify-between text-xs mb-1"><span class="font-medium text-gray-600">Cost Centers analysed in scoped runs</span><span class="text-gray-500">' + (s.covered_cc || 0) + ' / ' + d.total_cc + ' (' + scPct + '%)</span></div>';
          html += '<div class="w-full bg-gray-200 rounded h-4"><div class="h-full rounded ' + (scPct >= 100 ? 'bg-green-500' : 'bg-blue-500') + '" style="width:' + Math.min(scPct, 100) + '%"></div></div></div>';
          html += '</div>';
          // Scoped wave breakdown
          if (d.scoped_waves && d.scoped_waves.length) {
            html += '<table class="w-full text-xs mt-3"><thead><tr class="border-b text-gray-500"><th class="py-1 text-left">Wave</th><th class="py-1 text-center">Status</th><th class="py-1 text-center">Entities</th><th class="py-1 text-center">CCs Analysed</th></tr></thead><tbody>';
            d.scoped_waves.forEach(function(w) {
              html += '<tr class="border-b hover:bg-gray-50">';
              html += '<td class="py-1 font-medium"><a href="/cockpit/wave?id=' + w.id + '" class="text-blue-600 hover:underline">' + escapeHtml(w.code) + '</a></td>';
              html += '<td class="py-1 text-center"><span class="px-1.5 py-0.5 rounded text-[10px] bg-gray-100">' + escapeHtml(w.status) + '</span></td>';
              html += '<td class="py-1 text-center">' + w.entities_covered + '</td>';
              html += '<td class="py-1 text-center">' + w.cc_covered + '</td>';
              html += '</tr>';
            });
            html += '</tbody></table>';
          } else {
            html += '<p class="text-xs text-gray-400 italic mt-3">No scoped waves yet. Click "+ New" in the Waves panel below to start one.</p>';
          }
          html += '</div>';

          // ── Global Analysis (separate) ────────────────────────────
          html += '<div class="border-t pt-3 mt-2">';
          html += '<div class="text-xs font-semibold text-gray-700 mb-2">Global Analysis <span class="text-gray-400 font-normal">— full-scope reference; not part of wave progress</span></div>';
          var gcPct = g.cc_pct || 0;
          html += '<div class="grid grid-cols-1 md:grid-cols-2 gap-4">';
          html += '<div><div class="flex justify-between text-xs mb-1"><span class="font-medium text-gray-600">Cost Centers analysed globally</span><span class="text-gray-500">' + (g.covered_cc || 0) + ' / ' + d.total_cc + ' (' + gcPct + '%)</span></div>';
          html += '<div class="w-full bg-gray-200 rounded h-4"><div class="h-full rounded ' + (gcPct >= 100 ? 'bg-green-500' : 'bg-purple-400') + '" style="width:' + Math.min(gcPct, 100) + '%"></div></div></div>';
          html += '<div class="text-xs text-gray-500 self-center"><span class="font-medium">Global runs:</span> ' + (g.wave_count || 0) + ' wave-row' + (g.wave_count === 1 ? '' : 's') + (g.unassigned_run_cc > 0 ? ' + ' + g.unassigned_run_cc + ' CCs from wave-less runs' : '') + '</div>';
          html += '</div>';
          // Global wave breakdown
          if (d.global_waves && d.global_waves.length) {
            html += '<table class="w-full text-xs mt-3"><thead><tr class="border-b text-gray-500"><th class="py-1 text-left">Wave / Source</th><th class="py-1 text-center">Status</th><th class="py-1 text-center">Entities</th><th class="py-1 text-center">CCs Analysed</th></tr></thead><tbody>';
            d.global_waves.forEach(function(w) {
              html += '<tr class="border-b hover:bg-gray-50">';
              html += '<td class="py-1 font-medium">' + (w.id ? '<a href="/cockpit/wave?id=' + w.id + '" class="text-blue-600 hover:underline">' + escapeHtml(w.code) + '</a>' : '<span class="text-gray-400 italic">' + escapeHtml(w.code) + '</span>') + '</td>';
              html += '<td class="py-1 text-center"><span class="px-1.5 py-0.5 rounded text-[10px] bg-gray-100">' + escapeHtml(w.status) + '</span></td>';
              html += '<td class="py-1 text-center">' + w.entities_covered + '</td>';
              html += '<td class="py-1 text-center">' + w.cc_covered + '</td>';
              html += '</tr>';
            });
            html += '</tbody></table>';
          } else {
            html += '<p class="text-xs text-gray-400 italic mt-3">No global analysis runs yet.</p>';
          }
          html += '</div>';

          el.innerHTML = html;
        })
        .catch(function() {
          document.getElementById('coverage-content').textContent = 'Unable to load coverage data';
        });
    }
    loadCoverage();

    function loadWaveDetail(waveId, waveData) {
      var detail = document.getElementById('wave-detail');
      detail.innerHTML =
        '<h3 class="text-lg font-semibold text-gray-900 mb-2">' + escapeHtml(waveData.code) + '</h3>' +
        '<p class="text-sm text-gray-500">' + escapeHtml(waveData.description || 'No description') + '</p>' +
        '<div class="mt-3 flex gap-2">' +
          '<span class="text-xs px-2 py-1 rounded bg-amplifi-50 text-amplifi-700">' + escapeHtml(waveData.status) + '</span>' +
          '<span class="text-xs text-gray-400">Created: ' + escapeHtml(waveData.created_at ? new Date(waveData.created_at).toLocaleDateString() : '--') + '</span>' +
        '</div>';
      document.getElementById('wave-stats').classList.remove('hidden');

      fetch('/api/stats/wave/' + waveId, { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(s) {
          document.getElementById('wd-proposals').textContent = (s.proposals_total || s.total_proposals || 0).toLocaleString();
          document.getElementById('wd-reviews').textContent = (s.reviews_total || s.total_reviews || 0).toLocaleString();
          document.getElementById('wd-status').textContent = s.status || waveData.status || '--';
        })
        .catch(function() {});
    }

    // Create wave modal
    document.getElementById('create-wave-btn').addEventListener('click', function() {
      document.getElementById('new-wave-modal').classList.remove('hidden');
    });
    document.getElementById('cancel-wave-btn').addEventListener('click', function() {
      document.getElementById('new-wave-modal').classList.add('hidden');
    });
    document.getElementById('close-wave-modal').addEventListener('click', function() {
      document.getElementById('new-wave-modal').classList.add('hidden');
    });
    // Load hierarchies for wave scope selector
    fetch('/api/legacy/hierarchies?size=200&scope=cleanup', { headers: headers }).then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('wave-hier-id');
      (d.items || []).forEach(function(h) {
        var opt = document.createElement('option');
        opt.value = h.id;
        opt.textContent = h.setname + ' (' + (h.description || h.setclass) + ')';
        sel.appendChild(opt);
      });
    }).catch(function(){});

    // Cascade: when hierarchy changes, load its nodes into the second select
    document.getElementById('wave-hier-id').addEventListener('change', function(e) {
      var hierId = e.target.value;
      var nodeSel = document.getElementById('wave-hier-node');
      nodeSel.innerHTML = '<option value="">-- Loading nodes… --</option>';
      nodeSel.disabled = true;
      if (!hierId) {
        nodeSel.innerHTML = '<option value="">-- Pick a hierarchy first --</option>';
        return;
      }
      fetch('/api/legacy/hierarchies/' + hierId + '/nodes?size=500', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          nodeSel.innerHTML = '<option value="">-- Whole hierarchy --</option>';
          (d.items || []).forEach(function(n) {
            var opt = document.createElement('option');
            opt.value = n.setname;
            var label = n.setname;
            if (n.description) label += ' — ' + n.description;
            opt.textContent = label;
            nodeSel.appendChild(opt);
          });
          nodeSel.disabled = false;
        })
        .catch(function() {
          nodeSel.innerHTML = '<option value="">-- Failed to load nodes --</option>';
        });
    });

    // Mount the entity picker for scope.
    var waveEntityPicker = window.mountEntityPicker('wave-entity-picker', {
      multi: true,
      placeholder: 'Pick entities for this wave (or check Full Scope below)…',
    });
    document.getElementById('wave-full-scope').addEventListener('change', function(e) {
      waveEntityPicker.setEnabled(!e.target.checked);
    });

    document.getElementById('save-wave-btn').addEventListener('click', async function() {
      var code = document.getElementById('wave-code').value.trim();
      var name = document.getElementById('wave-name').value.trim();
      var desc = document.getElementById('wave-desc').value.trim();
      var hierId = document.getElementById('wave-hier-id').value;
      var hierNode = document.getElementById('wave-hier-node').value.trim();
      var fullScope = document.getElementById('wave-full-scope').checked;
      var errEl = document.getElementById('wave-error');
      errEl.classList.add('hidden');
      if (!code) { errEl.textContent = 'Code required'; errEl.classList.remove('hidden'); return; }
      if (!name) { errEl.textContent = 'Name required'; errEl.classList.remove('hidden'); return; }
      var entity_ccodes = fullScope ? [] : waveEntityPicker.getCcodes();
      var hierarchy_scopes = [];
      if (hierId && hierNode) {
        hierarchy_scopes.push({ hierarchy_id: parseInt(hierId), node_setname: hierNode });
      }
      try {
        var body = { code: code, name: name, description: desc, entity_ccodes: entity_ccodes, hierarchy_scopes: hierarchy_scopes, is_full_scope: fullScope };
        var res = await fetch('/api/waves', { method: 'POST', headers: headers, body: JSON.stringify(body) });
        if (!res.ok) { var b = await res.json().catch(function(){return {};}); throw new Error(b.detail || 'Failed'); }
        // PR #85: backend now reports which ccodes failed to resolve so
        // the user knows when a silent partial failure happened (multiple
        // Entity rows for the same ccode used to crash the lookup; now
        // the helper picks deterministically but really-missing ccodes
        // still get surfaced here).
        var resp = await res.json().catch(function(){ return {}; });
        document.getElementById('new-wave-modal').classList.add('hidden');
        loadWaves();
        if (resp && resp.missing_ccodes && resp.missing_ccodes.length) {
          var miss = resp.missing_ccodes.slice(0, 8).join(', ');
          if (resp.missing_ccodes.length > 8) miss += ', …';
          alert('Wave created — but ' + resp.missing_ccodes.length +
            ' of the ' + entity_ccodes.length + ' selected entities could not be ' +
            'resolved and were skipped:\n\n' + miss + '\n\n' +
            'Check the Entity master — these company codes may not exist or ' +
            'may be in a non-cleanup scope.');
        }
      } catch(e) { errEl.textContent = e.message; errEl.classList.remove('hidden'); }
    });
  })();
</script>
