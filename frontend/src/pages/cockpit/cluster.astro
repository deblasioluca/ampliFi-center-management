---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Cluster Explorer" requireAuth={true} requiredRole="data_manager">
  <div class="mb-4">
    <a href="/cockpit" class="text-sm text-amplifi-600 hover:underline">&larr; Back to Cockpit</a>
    <h2 class="text-xl font-bold mt-2">Cluster Explorer</h2>
    <p class="text-sm text-gray-500 mt-1">Find groups of similar cost centers using semantic similarity</p>
  </div>

  <!-- What does this page do? -->
  <details class="bg-blue-50 border border-blue-200 rounded-lg mb-4">
    <summary class="cursor-pointer px-4 py-2 text-sm font-medium text-blue-900 select-none">
      ℹ️ What does this page do?
    </summary>
    <div class="px-4 pb-3 pt-1 text-xs text-blue-900 space-y-1.5 leading-relaxed">
      <p>
        Cluster Explorer helps you find <strong>near-duplicate cost centers</strong>
        in your master data — different cost-center IDs that describe the same
        thing in slightly different words (e.g. "Marketing EMEA" vs "EMEA
        Marketing"). It uses sentence embeddings to compute semantic similarity
        between the short and medium texts of every cost center within a CO Area
        and returns pairs above the similarity threshold.
      </p>
      <p>
        <strong>How to use:</strong> pick a CO Area (auto-selected if you only
        have one), keep the threshold at <em>0.85</em> for a good precision /
        recall balance (raise it for stricter matches, lower it to surface more
        candidates), then click <em>Find Duplicates</em>. Use the resulting
        pairs to inform your wave scoping or to feed the <em>MERGE_MAP</em>
        outcome downstream.
      </p>
    </div>
  </details>

  <!-- Controls -->
  <div class="card mb-6">
    <div class="flex flex-wrap gap-4 items-end">
      <div>
        <label class="block text-xs text-gray-500 mb-1" for="clu-coarea">CO Area</label>
        <select id="clu-coarea" class="input text-sm w-48">
          <option value="">Loading…</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Similarity Threshold</label>
        <input id="clu-threshold" type="number" step="0.05" min="0.5" max="0.99" value="0.85" class="input text-sm w-24" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Max Results</label>
        <input id="clu-limit" type="number" min="10" max="500" value="100" class="input text-sm w-20" />
      </div>
      <button id="btn-run-cluster" class="btn-amplifi text-sm">Find Duplicates</button>
    </div>
  </div>

  <!-- Results -->
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold">Duplicate Pairs</h3>
      <span id="clu-count" class="text-xs text-gray-500"></span>
    </div>

    <!-- Progress strip — visible only while a job is in flight (PR #88) -->
    <div id="clu-progress" class="hidden mb-3 bg-blue-50 border border-blue-200 rounded p-3">
      <div class="flex items-center justify-between text-xs mb-1">
        <span class="font-medium text-blue-900" id="clu-progress-label">Starting…</span>
        <button id="clu-cancel" class="text-amber-700 hover:underline text-xs">Cancel</button>
      </div>
      <div class="h-1.5 bg-blue-100 rounded-full overflow-hidden">
        <div id="clu-progress-bar" class="h-full bg-blue-500 transition-all" style="width:0%"></div>
      </div>
      <p class="text-[11px] text-blue-700 mt-1">
        Running in the background — you can navigate away and come back; results will appear here when done.
      </p>
    </div>

    <div id="clu-results" class="text-sm text-gray-500">Configure parameters above and click "Find Duplicates"</div>
  </div>
</Layout>

<script>
  var token = localStorage.getItem('amplifi_token');
  if (!token) { window.location.href = '/login'; }
  var headers = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

  function esc(v) { var d = document.createElement('div'); d.textContent = v || '--'; return d.innerHTML; }

  // Populate the CO Area dropdown from the actual values in the DB so
  // users don't have to remember exact codes. Auto-selects when there's
  // only one — common case for single-coarea customers.
  fetch('/api/stats/coareas', { headers: headers })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var sel = document.getElementById('clu-coarea');
      var items = d.items || [];
      sel.innerHTML = '';
      if (items.length === 0) {
        sel.innerHTML = '<option value="">(no CO areas found)</option>';
        sel.disabled = true;
        return;
      }
      // Add a placeholder option only if more than one — single-coarea
      // case auto-selects that coarea so the user doesn't have to click.
      if (items.length > 1) {
        sel.innerHTML = '<option value="">— pick a CO area —</option>';
      }
      items.forEach(function(it) {
        var opt = document.createElement('option');
        opt.value = it.coarea;
        opt.textContent = it.coarea + ' (' + it.cc_count.toLocaleString() + ' CCs)';
        sel.appendChild(opt);
      });
      if (items.length === 1) {
        sel.value = items[0].coarea;  // auto-select the only one
      }
    })
    .catch(function() {
      var sel = document.getElementById('clu-coarea');
      sel.innerHTML = '<option value="">(failed to load CO areas)</option>';
    });

  // PR #88 — async duplicate-check. Previously the click handler held
  // the request open for the full ML run (model load + embedding +
  // pairwise cosine — many seconds on real datasets, locking up the
  // UI). Now we POST once to dispatch a job, then poll
  // /api/data/duplicate-check/jobs/{id} every 2s for status. Cancel
  // button just stops polling on the client; the backend job runs to
  // completion either way (acceptable: it's a read-only ML job).
  var cluPollTimer = null;
  var cluCurrentJob = null;

  function setCluProgress(label, pct) {
    document.getElementById('clu-progress-label').textContent = label;
    document.getElementById('clu-progress-bar').style.width = (pct || 0) + '%';
  }

  function showCluProgress(visible) {
    var el = document.getElementById('clu-progress');
    if (visible) el.classList.remove('hidden');
    else el.classList.add('hidden');
  }

  function stopCluPolling() {
    if (cluPollTimer) {
      clearInterval(cluPollTimer);
      cluPollTimer = null;
    }
    cluCurrentJob = null;
    showCluProgress(false);
  }

  function pollCluJob(jobId) {
    fetch('/api/data/duplicate-check/jobs/' + encodeURIComponent(jobId), { headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (cluCurrentJob !== jobId) return; // user cancelled / started new job
        if (d.status === 'queued') {
          setCluProgress('Queued — starting up…', 5);
          return;
        }
        if (d.status === 'running') {
          var stage = d.stage || 'running';
          var label = stage === 'loading' ? 'Loading cost centers from database…'
            : stage === 'embedding' ? 'Embedding ' + (d.total || 0) + ' cost-center names…'
            : stage === 'pairing' ? 'Comparing pairs and filtering by threshold…'
            : 'Running…';
          var pct = d.total > 0 ? Math.min(95, Math.round((d.progress / d.total) * 100)) : 25;
          setCluProgress(label, pct);
          return;
        }
        if (d.status === 'failed') {
          stopCluPolling();
          document.getElementById('clu-results').innerHTML =
            '<span class="text-red-500">Error: ' + esc(d.error || 'Job failed') + '</span>';
          document.getElementById('clu-count').textContent = '';
          return;
        }
        if (d.status === 'done') {
          stopCluPolling();
          renderCluResults(d.result || { total: 0, pairs: [] });
        }
      })
      .catch(function(err) {
        stopCluPolling();
        document.getElementById('clu-results').innerHTML =
          '<span class="text-red-500">Polling error: ' + esc(err.message) + '</span>';
      });
  }

  function renderCluResults(data) {
    var resultsEl = document.getElementById('clu-results');
    var countEl = document.getElementById('clu-count');
    countEl.textContent = data.total + ' pairs found';
    var pairs = data.pairs || [];
    if (!pairs.length) {
      resultsEl.textContent = 'No duplicates found at this threshold.';
      return;
    }
    var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
      '<th class="py-2 px-2 text-left">Name A</th>' +
      '<th class="py-2 px-2 text-left">Name B</th>' +
      '<th class="py-2 px-2 text-center">Similarity</th>' +
      '<th class="py-2 px-2 text-center">ID A</th>' +
      '<th class="py-2 px-2 text-center">ID B</th></tr></thead><tbody>';
    pairs.forEach(function(p) {
      var pct = Math.round(p.similarity * 100);
      var barColor = pct >= 95 ? 'bg-red-400' : pct >= 90 ? 'bg-amber-400' : 'bg-blue-400';
      html += '<tr class="border-b hover:bg-gray-50">' +
        '<td class="py-1.5 px-2">' + esc(p.name_a) + '</td>' +
        '<td class="py-1.5 px-2">' + esc(p.name_b) + '</td>' +
        '<td class="py-1.5 px-2 text-center"><div class="flex items-center gap-1 justify-center">' +
          '<div class="w-16 bg-gray-100 rounded-full h-1.5"><div class="h-1.5 rounded-full ' + barColor + '" style="width:' + pct + '%"></div></div>' +
          '<span class="font-mono">' + pct + '%</span></div></td>' +
        '<td class="py-1.5 px-2 text-center font-mono text-gray-400">' + p.id_a + '</td>' +
        '<td class="py-1.5 px-2 text-center font-mono text-gray-400">' + p.id_b + '</td></tr>';
    });
    resultsEl.innerHTML = html + '</tbody></table>';
  }

  document.getElementById('clu-cancel').addEventListener('click', function() {
    stopCluPolling();
    document.getElementById('clu-results').innerHTML =
      '<span class="text-gray-400">Cancelled. (The backend may still finish — re-running gives fresh results.)</span>';
    document.getElementById('clu-count').textContent = '';
  });

  document.getElementById('btn-run-cluster').addEventListener('click', async function() {
    var coarea = document.getElementById('clu-coarea').value;
    if (!coarea) {
      alert('Please select a CO Area first.');
      return;
    }
    var threshold = parseFloat(document.getElementById('clu-threshold').value) || 0.85;
    var limit = parseInt(document.getElementById('clu-limit').value) || 100;
    var resultsEl = document.getElementById('clu-results');
    var countEl = document.getElementById('clu-count');

    // Stop any in-flight polling from a previous run
    stopCluPolling();

    resultsEl.innerHTML = '<span class="text-gray-400">Dispatching job…</span>';
    countEl.textContent = '';
    showCluProgress(true);
    setCluProgress('Submitting…', 2);

    try {
      var url = '/api/data/duplicate-check?threshold=' + threshold + '&limit=' + limit;
      if (coarea) url += '&coarea=' + encodeURIComponent(coarea);
      var resp = await fetch(url, { method: 'POST', headers: headers });
      if (!resp.ok) throw new Error('Failed: ' + resp.status);
      var data = await resp.json();
      cluCurrentJob = data.job_id;
      resultsEl.innerHTML = '<span class="text-gray-400">Running… results will appear here.</span>';
      // Poll immediately, then every 2s
      pollCluJob(cluCurrentJob);
      cluPollTimer = setInterval(function() {
        if (cluCurrentJob) pollCluJob(cluCurrentJob);
      }, 2000);
    } catch(e) {
      stopCluPolling();
      resultsEl.innerHTML = '<span class="text-red-500">Error: ' + esc(e.message) + '</span>';
    }
  });
</script>
