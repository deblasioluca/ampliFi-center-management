  // --- SAP Extraction (binding-based) ---
  (function initSAPExtract() {
    var area = document.getElementById('sap-extract-area');
    var noConn = document.getElementById('sap-no-connections');
    var listEl = document.getElementById('sap-connections-list');
    var resEl = document.getElementById('sap-extract-result');

    fetch('/api/data/sap-extract/available', { headers: authHdr })
      .then(function(r) { return r.ok ? r.json() : []; })
      .then(function(connections) {
        if (!connections || !connections.length) {
          area.classList.add('hidden');
          noConn.classList.remove('hidden');
          return;
        }
        // Load bindings for each connection
        var html = '';
        var pending = connections.length;
        connections.forEach(function(c) {
          fetch('/api/admin/sap/' + c.connection_id + '/bindings', { headers: authHdr })
            .then(function(r) { return r.ok ? r.json() : []; })
            .then(function(bindings) {
              html += '<div class="border rounded-lg p-3 bg-white">';
              html += '<div class="flex items-center gap-2 mb-2"><span class="font-semibold text-sm">' + esc(c.name) + '</span>';
              html += '<span class="text-xs px-1.5 py-0.5 bg-gray-100 rounded text-gray-600">' + esc(c.protocol || 'OData') + '</span></div>';
              if (!bindings.length) {
                html += '<p class="text-xs text-gray-400">No bindings configured. <a href="/admin/sap" class="text-blue-600 underline">Add bindings</a> to enable extraction.</p>';
              } else {
                html += '<table class="w-full text-xs"><thead><tr class="bg-gray-50">' +
                  '<th class="px-2 py-1 text-left">Object Type</th>' +
                  '<th class="px-2 py-1 text-left">Method</th>' +
                  '<th class="px-2 py-1 text-left">Params</th>' +
                  '<th class="px-2 py-1"></th></tr></thead><tbody>';
                bindings.forEach(function(b) {
                  var uid = 'ext_' + c.connection_id + '_' + b.id;
                  var ot = b.object_type || '';
                  html += '<tr class="border-t">' +
                    '<td class="px-2 py-1 font-mono">' + esc(ot) + '</td>' +
                    '<td class="px-2 py-1 font-mono text-xs">' + esc(b.entity_set || b.path || '-') + '</td>' +
                    '<td class="px-2 py-1">';
                  if (ot === 'cost_center' || ot === 'profit_center') {
                    html += '<select id="' + uid + '_co" class="border rounded px-2 py-0.5 text-xs w-40" data-conn="' + c.connection_id + '">' +
                      '<option value="">All CO Areas</option></select>';
                  } else if (ot === 'hierarchy') {
                    html += '<select id="' + uid + '_co" class="border rounded px-2 py-0.5 text-xs w-36 mr-1" data-conn="' + c.connection_id + '" data-hier-trigger="' + uid + '_hier">' +
                      '<option value="">All CO Areas</option></select>' +
                      '<select id="' + uid + '_hier" multiple class="border rounded px-2 py-0.5 text-xs w-48" style="min-height:28px;max-height:80px" data-conn="' + c.connection_id + '">' +
                      '<option value="">Loading hierarchies...</option></select>';
                  } else if (ot === 'balance') {
                    html += '<select id="' + uid + '_co" class="border rounded px-2 py-0.5 text-xs w-28 mr-1" data-conn="' + c.connection_id + '">' +
                      '<option value="">All CO Areas</option></select>' +
                      '<input id="' + uid + '_pfrom" type="text" placeholder="Period from" class="border rounded px-2 py-0.5 text-xs w-20 mr-1" />' +
                      '<input id="' + uid + '_pto" type="text" placeholder="Period to" class="border rounded px-2 py-0.5 text-xs w-20 mr-1" />' +
                      '<input id="' + uid + '_cc" type="text" placeholder="Company code" class="border rounded px-2 py-0.5 text-xs w-20 mr-1" />' +
                      '<input id="' + uid + '_ledger" type="text" placeholder="Ledger" class="border rounded px-2 py-0.5 text-xs w-16" />';
                  }
                  html += '</td>' +
                    '<td class="px-2 py-1"><button onclick="extractBinding(' + c.connection_id + ',' + b.id + ',this,\'' + uid + '\',\'' + esc(ot) + '\')" ' +
                    'class="btn-sm bg-blue-600 text-white hover:bg-blue-700 text-xs">Extract</button></td></tr>';
                });
                html += '</tbody></table>';
              }
              html += '</div>';
              pending--;
              if (pending === 0) {
                listEl.innerHTML = html;
                // Populate CO Area dropdowns from SAP
                populateCoAreaDropdowns();
              }
            });
        });
      })
      .catch(function() {
        listEl.textContent = 'Failed to load SAP connections.';
      });

    // Dynamic SAP lookups
    var coAreaCache = {};
    var hierCache = {};

    function populateCoAreaDropdowns() {
      var selects = listEl.querySelectorAll('select[data-conn]');
      var connIds = new Set();
      selects.forEach(function(sel) { connIds.add(sel.getAttribute('data-conn')); });
      connIds.forEach(function(connId) {
        if (coAreaCache[connId]) { fillCoAreaSelects(connId); return; }
        fetch('/api/admin/sap/' + connId + '/lookup/co-areas', { headers: authHdr })
          .then(function(r) { return r.ok ? r.json() : []; })
          .then(function(areas) {
            coAreaCache[connId] = areas;
            fillCoAreaSelects(connId);
            // Also load hierarchies for hierarchy selects
            loadHierarchiesForConn(connId, '');
          }).catch(function() {});
      });
    }

    function fillCoAreaSelects(connId) {
      var areas = coAreaCache[connId] || [];
      listEl.querySelectorAll('select[data-conn="' + connId + '"]').forEach(function(sel) {
        if (sel.multiple) return; // skip hierarchy multi-selects
        var val = sel.value;
        var opts = '<option value="">All CO Areas</option>';
        areas.forEach(function(a) {
          opts += '<option value="' + escAttr(a.co_area) + '">' + esc(a.co_area) + (a.description ? ' — ' + esc(a.description) : '') + '</option>';
        });
        sel.innerHTML = opts;
        sel.value = val;
        // Wire change event for hierarchy trigger
        var hierTarget = sel.getAttribute('data-hier-trigger');
        if (hierTarget) {
          sel.addEventListener('change', function() {
            loadHierarchiesForConn(connId, sel.value);
          });
        }
      });
    }

    function loadHierarchiesForConn(connId, coArea) {
      var cacheKey = connId + ':' + (coArea || '*');
      if (hierCache[cacheKey]) { fillHierSelects(connId, hierCache[cacheKey]); return; }
      var url = '/api/admin/sap/' + connId + '/lookup/hierarchies';
      if (coArea) url += '?co_area=' + encodeURIComponent(coArea);
      fetch(url, { headers: authHdr })
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(hiers) {
          hierCache[cacheKey] = hiers;
          fillHierSelects(connId, hiers);
        }).catch(function() {});
    }

    function fillHierSelects(connId, hiers) {
      listEl.querySelectorAll('select[multiple][data-conn="' + connId + '"]').forEach(function(sel) {
        sel.innerHTML = '';
        if (!hiers.length) {
          sel.innerHTML = '<option value="" disabled>No hierarchies found</option>';
          return;
        }
        hiers.forEach(function(h) {
          var opt = document.createElement('option');
          opt.value = h.set_name;
          opt.textContent = h.set_name + (h.description ? ' — ' + h.description : '') + ' (' + h.kind + ')';
          sel.appendChild(opt);
        });
      });
    }

    window.extractBinding = async function(connId, bindingId, btn, uid, objType) {
      btn.disabled = true;
      btn.textContent = 'Extracting...';
      resEl.className = 'text-sm mt-2 p-3 bg-blue-50 rounded text-blue-700';
      resEl.textContent = 'Connecting to SAP and extracting data...';
      resEl.classList.remove('hidden');
      // Collect selection parameters
      var params = {};
      var coEl = document.getElementById(uid + '_co');
      if (coEl && coEl.value.trim()) params.co_area = coEl.value.trim();
      var hierEl = document.getElementById(uid + '_hier');
      if (hierEl) {
        if (hierEl.multiple) {
          var selected = Array.from(hierEl.selectedOptions).map(function(o) { return o.value; }).filter(Boolean);
          if (selected.length) params.hierarchy_name = selected.join(',');
        } else if (hierEl.value.trim()) {
          params.hierarchy_name = hierEl.value.trim();
        }
      }
      var pfromEl = document.getElementById(uid + '_pfrom');
      if (pfromEl && pfromEl.value.trim()) params.period_from = pfromEl.value.trim();
      var ptoEl = document.getElementById(uid + '_pto');
      if (ptoEl && ptoEl.value.trim()) params.period_to = ptoEl.value.trim();
      var ccEl = document.getElementById(uid + '_cc');
      if (ccEl && ccEl.value.trim()) params.company_code = ccEl.value.trim();
      var ledgerEl = document.getElementById(uid + '_ledger');
      if (ledgerEl && ledgerEl.value.trim()) params.ledger = ledgerEl.value.trim();
      try {
        var fetchHeaders = Object.assign({}, authHdr, { 'Content-Type': 'application/json' });
        var res = await fetch('/api/admin/sap/' + connId + '/bindings/' + bindingId + '/extract', {
          method: 'POST', headers: fetchHeaders, body: JSON.stringify(params)
        });
        var ct = res.headers.get('content-type') || '';
        var d = ct.indexOf('json') >= 0 ? await res.json() : { detail: await res.text() };
        if (!res.ok) throw new Error(d.detail || 'Extraction failed');
        resEl.className = 'text-sm mt-2 p-3 bg-green-50 rounded text-green-700';
        resEl.textContent = 'Extraction successful: ' + (d.rows_extracted || 0) + ' records imported.';
        if (d.batch_id) resEl.textContent += ' Batch #' + d.batch_id;
        if (d.status) resEl.textContent += ' (Status: ' + d.status + ')';
        refreshAllData();
        loadUploadHistory();
      } catch(e) {
        resEl.className = 'text-sm mt-2 p-3 bg-red-50 rounded text-red-700';
        resEl.textContent = 'Error: ' + e.message;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Extract';
      }
    };
  })();

  // ─── Data Browser (unified view) ───────────────────────────────────
  var dbData = null;
  var dbView = 'tabular';
  var dbSort = { col: 'cctr', dir: 'asc' };

  function loadDataBrowser() {
    var el = document.getElementById('db-content');
    el.innerHTML = '<span class="text-gray-400">Loading data browser...</span>';
    fetch('/api/data/browser', { headers: authHdr })
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(d) {
        dbData = d;
        renderDB();
      })
      .catch(function(err) {
        el.innerHTML = '<span class="text-red-500">Error: ' + esc(err.message) + '</span>';
      });
  }

  window.switchDataBrowserView = function(view) {
    dbView = view;
    var tabBtn = document.getElementById('db-view-tabular');
    var hierBtn = document.getElementById('db-view-hierarchy');
    if (tabBtn) tabBtn.className = view === 'tabular' ? 'btn-sm bg-blue-600 text-white text-xs' : 'btn-sm bg-gray-200 text-gray-700 text-xs';
    if (hierBtn) hierBtn.className = view === 'hierarchy' ? 'btn-sm bg-blue-600 text-white text-xs' : 'btn-sm bg-gray-200 text-gray-700 text-xs';
    renderDB();
  };

  window.sortDB = function(col) {
    if (dbSort.col === col) {
      dbSort.dir = dbSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
      dbSort.col = col;
      dbSort.dir = 'asc';
    }
    renderDB();
  };

  function dbSortArrow(col) {
    if (dbSort.col !== col) return ' <span class="text-gray-300">&#8597;</span>';
    return dbSort.dir === 'asc' ? ' &#8593;' : ' &#8595;';
  }

  function dbSortItems(items) {
    var col = dbSort.col, dir = dbSort.dir === 'asc' ? 1 : -1;
    return items.slice().sort(function(a, b) {
      var va = a[col], vb = b[col];
      if (va == null) va = '';
      if (vb == null) vb = '';
      if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * dir;
      va = String(va).toLowerCase(); vb = String(vb).toLowerCase();
      if (va < vb) return -1 * dir;
      if (va > vb) return 1 * dir;
      return 0;
    });
  }

  window.renderDB = renderDB;
  function renderDB() {
    if (!dbData) return;
    var el = document.getElementById('db-content');
    var search = (document.getElementById('db-search').value || '').toLowerCase();
    var items = dbData.items || [];
    if (search) {
      items = items.filter(function(it) {
        return (it.cctr || '').toLowerCase().indexOf(search) >= 0 ||
          (it.txtsh || '').toLowerCase().indexOf(search) >= 0 ||
          (it.txtmi || '').toLowerCase().indexOf(search) >= 0 ||
          (it.ccode || '').toLowerCase().indexOf(search) >= 0 ||
          (it.coarea || '').toLowerCase().indexOf(search) >= 0 ||
          (it.responsible || '').toLowerCase().indexOf(search) >= 0 ||
          (it.pctr || '').toLowerCase().indexOf(search) >= 0;
      });
    }
    if (dbView === 'tabular') {
      renderDBTabular(el, items);
    } else {
      renderDBHierarchical(el, items);
    }
  }

  function renderDBTabular(el, items) {
    if (!items.length) { el.innerHTML = '<span class="text-gray-400">No cost centers loaded.</span>'; return; }
    var sorted = dbSortItems(items);
    // Collect all balance periods
    var periods = {};
    items.forEach(function(it) {
      (it.monthly_balances || []).forEach(function(b) {
        var key = b.fiscal_year + '/' + String(b.period).padStart(2, '0');
        periods[key] = 1;
      });
    });
    var pKeys = Object.keys(periods).sort();

    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    var cols = [
      { key: 'cctr', label: 'CC' },
      { key: 'txtsh', label: 'Short Text' },
      { key: 'ccode', label: 'Entity' },
      { key: 'coarea', label: 'CO Area' },
      { key: 'pctr', label: 'Profit Ctr' },
      { key: 'pc_txtsh', label: 'PC Text' },
      { key: 'responsible', label: 'Responsible' },
      { key: 'is_active', label: 'Active' }
    ];
    cols.forEach(function(c) {
      html += '<th class="py-2 px-2 text-left cursor-pointer select-none whitespace-nowrap" onclick="sortDB(\'' + c.key + '\')">' + c.label + dbSortArrow(c.key) + '</th>';
    });
    pKeys.forEach(function(pk) {
      html += '<th class="py-2 px-2 text-right whitespace-nowrap">' + esc(pk) + '</th>';
    });
    html += '</tr></thead><tbody>';

    sorted.forEach(function(it) {
      var balMap = {};
      (it.monthly_balances || []).forEach(function(b) {
        balMap[b.fiscal_year + '/' + String(b.period).padStart(2, '0')] = b;
      });
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1 px-2 font-mono font-medium">' + esc(it.cctr) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.txtsh) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.ccode) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.coarea) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.pctr) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.pc_txtsh) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.responsible) + '</td>';
      html += '<td class="py-1 px-2 text-center">' + (it.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td>';
      pKeys.forEach(function(pk) {
        var b = balMap[pk];
        if (b) {
          var amt = b.amount >= 0 ? b.amount.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0}) : '-' + Math.abs(b.amount).toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});
          html += '<td class="py-1 px-2 text-right font-mono' + (b.amount < 0 ? ' text-red-600' : '') + '">' + amt + '</td>';
        } else {
          html += '<td class="py-1 px-2 text-right text-gray-300">-</td>';
        }
      });
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
  }

  function renderDBHierarchical(el, items) {
    var hiers = (dbData.hierarchies || []);
    if (!hiers.length) { el.innerHTML = '<span class="text-gray-400">No hierarchies loaded. Load hierarchies via SAP extraction or upload.</span>'; return; }

    // Build a map of cctr -> item for leaf lookup
    var ccMap = {};
    items.forEach(function(it) { if (it.cctr) ccMap[it.cctr] = it; });

    // Build balance totals per CC for display
    var balTotals = {};
    items.forEach(function(it) {
      var total = 0;
      (it.monthly_balances || []).forEach(function(b) { total += b.amount; });
      balTotals[it.cctr] = total;
    });

    // Hierarchy selector — read current selection before rebuilding
    var selIdx = 0;
    var selEl = document.getElementById('db-hier-select');
    if (selEl) selIdx = parseInt(selEl.value) || 0;
    var hier = hiers[selIdx] || hiers[0];

    var html = '<div class="mb-3"><label class="text-xs font-medium mr-2">Hierarchy:</label><select id="db-hier-select" class="input text-xs w-64" onchange="renderDB()">';
    hiers.forEach(function(h, i) {
      html += '<option value="' + i + '"' + (i === selIdx ? ' selected' : '') + '>' + esc(h.label) + '</option>';
    });
    html += '</select></div>';

    // Build tree from nodes + leaves
    var childMap = {};
    (hier.nodes || []).forEach(function(n) {
      if (!childMap[n.parent]) childMap[n.parent] = [];
      childMap[n.parent].push({ type: 'node', name: n.child, seq: n.seq });
    });
    (hier.leaves || []).forEach(function(lf) {
      if (!childMap[lf.setname]) childMap[lf.setname] = [];
      childMap[lf.setname].push({ type: 'leaf', value: lf.value, seq: lf.seq });
    });

    // Find root: nodes that appear as parents but not as children
    var allChildren = {};
    (hier.nodes || []).forEach(function(n) { allChildren[n.child] = 1; });
    var roots = [];
    (hier.nodes || []).forEach(function(n) {
      if (!allChildren[n.parent] && roots.indexOf(n.parent) < 0) roots.push(n.parent);
    });
    if (!roots.length && hier.nodes && hier.nodes.length) roots.push(hier.nodes[0].parent);

    function buildTree(nodeName, depth) {
      var pad = depth * 20;
      var children = childMap[nodeName] || [];
      children.sort(function(a, b) { return (a.seq || 0) - (b.seq || 0); });
      var out = '<div style="padding-left:' + pad + 'px" class="py-0.5">';
      out += '<span class="font-medium text-blue-800 cursor-pointer" onclick="var tc=this.parentElement.nextElementSibling;if(tc)tc.classList.toggle(\'hidden\')">';
      out += '&#9654; ' + esc(nodeName) + '</span></div>';
      out += '<div class="tree-children">';
      children.forEach(function(c) {
        if (c.type === 'node') {
          out += buildTree(c.name, depth + 1);
        } else {
          var cc = ccMap[c.value];
          var bal = balTotals[c.value];
          out += '<div style="padding-left:' + ((depth + 1) * 20) + 'px" class="py-0.5 flex items-center gap-3 hover:bg-gray-50">';
          out += '<span class="font-mono text-xs">' + esc(c.value) + '</span>';
          if (cc) {
            out += ' <span class="text-gray-600">' + esc(cc.txtsh || '') + '</span>';
            out += ' <span class="text-gray-400 text-[10px]">' + esc(cc.ccode || '') + '</span>';
            if (cc.pctr) out += ' <span class="text-purple-600 text-[10px]">PC: ' + esc(cc.pctr) + '</span>';
          }
          if (bal != null) {
            var balStr = bal.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});
            out += ' <span class="font-mono text-[10px]' + (bal < 0 ? ' text-red-600' : ' text-green-700') + '">' + balStr + '</span>';
          }
          out += '</div>';
        }
      });
      out += '</div>';
      return out;
    }

    roots.forEach(function(root) {
      html += buildTree(root, 0);
    });

    // Show unassigned CCs (not in any hierarchy leaf)
    var assigned = {};
    (hier.leaves || []).forEach(function(lf) { assigned[lf.value] = 1; });
    var unassigned = items.filter(function(it) { return it.cctr && !assigned[it.cctr]; });
    if (unassigned.length) {
      html += '<div class="mt-4 pt-3 border-t"><span class="font-medium text-gray-500">Unassigned (' + unassigned.length + ')</span></div>';
      unassigned.forEach(function(it) {
        html += '<div style="padding-left:20px" class="py-0.5 text-gray-500">';
        html += '<span class="font-mono">' + esc(it.cctr) + '</span> ' + esc(it.txtsh || '');
        html += '</div>';
      });
    }

    el.innerHTML = html;
  }

  // Wire search
  document.getElementById('db-search').addEventListener('input', function() {
    clearTimeout(this._t);
    this._t = setTimeout(function() { renderDB(); }, 300);
  });

  // Load on page init
  loadDataBrowser();

})();
</script>
