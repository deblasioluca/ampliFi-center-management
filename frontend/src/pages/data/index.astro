  window.editHierLabel = function(hierId) {
    var textEl = document.getElementById('hier-label-' + hierId + '-text');
    var inputEl = document.getElementById('hier-label-' + hierId + '-input');
    if (!inputEl) return;
    if (inputEl.classList.contains('hidden')) {
      inputEl.classList.remove('hidden');
      textEl.classList.add('hidden');
      inputEl.focus();
      inputEl.onkeydown = function(e) {
        if (e.key === 'Enter') { saveHierLabel(hierId); }
        if (e.key === 'Escape') { inputEl.classList.add('hidden'); textEl.classList.remove('hidden'); }
      };
      inputEl.onblur = function() { saveHierLabel(hierId); };
    }
  };
  function saveHierLabel(hierId) {
    var inputEl = document.getElementById('hier-label-' + hierId + '-input');
    var textEl = document.getElementById('hier-label-' + hierId + '-text');
    if (!inputEl || inputEl.classList.contains('hidden')) return;
    var label = inputEl.value.trim();
    var origVal = inputEl.getAttribute('data-orig') || '';
    // Skip save if value unchanged (prevents freezing auto-labels on blur)
    if (label === origVal) {
      inputEl.classList.add('hidden');
      textEl.classList.remove('hidden');
      return;
    }
    fetch('/api/admin/hierarchies/' + hierId + '?label=' + encodeURIComponent(label), {
      method: 'PATCH', headers: authHdr
    }).then(function(r) { if (!r.ok) throw new Error('Save failed'); return r.json(); }).then(function(h) {
      textEl.textContent = h.display_label || h.label || '';
      inputEl.value = h.label || '';
      inputEl.setAttribute('data-orig', h.label || '');
      inputEl.classList.add('hidden');
      textEl.classList.remove('hidden');
    }).catch(function() {
      inputEl.classList.add('hidden');
      textEl.classList.remove('hidden');
    });
  }
