              '<h5 class="font-semibold text-sm">Auto-derive from completed runs</h5>' +
            '</div>' +
            '<p class="text-xs text-gray-600 mb-3">Pull every <span class="font-mono">MERGE_MAP</span> proposal from your completed analysis runs and create mapping rows automatically.</p>' +
            '<button id="btn-mapping-auto-derive" class="btn-amplifi text-xs px-3 py-1" onclick="autoDeriveMappings()">Auto-derive now</button>' +
          '</div>' +
