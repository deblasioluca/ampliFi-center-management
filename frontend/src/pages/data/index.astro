        '<td class="py-1.5 px-2 max-w-xs truncate">' + esc(m.notes) + '</td></tr>';
    });
    el.innerHTML = html + '</tbody></table>';
  };

  // PR #89 — A13. Auto-derive button handler. Calls the new
  // /api/center-mappings/auto-derive endpoint, which reads MERGE_MAP
  // proposals from completed runs and inserts/refreshes mapping rows
  // (idempotent — re-running is safe).
  window.autoDeriveMappings = function() {
    var btn = document.getElementById('btn-mapping-auto-derive');
    if (btn) { btn.disabled = true; btn.textContent = 'Deriving…'; }
    fetch('/api/center-mappings/auto-derive', { method: 'POST', headers: authHdr })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.detail || 'Failed'); });
        return r.json();
      })
      .then(function(d) {
        var msg = 'Auto-derive complete: ' + d.created + ' created · ' + d.updated + ' updated · ' + d.skipped + ' skipped';
        if (d.runs_consulted === 0) {
          msg = 'No completed runs to derive from. Run a global analysis first, then come back here.';
        } else {
          msg += '\n(consulted ' + d.runs_consulted + ' run' + (d.runs_consulted === 1 ? '' : 's') + ')';
        }
        alert(msg);
        loadMapping(1);
      })
      .catch(function(err) {
        alert('Error: ' + err.message);
        if (btn) { btn.disabled = false; btn.textContent = 'Auto-derive now'; }
      });
  };
  loadMapping(1);
  document.getElementById('search-mapping').addEventListener('input', function() { clearTimeout(this._t); this._t = setTimeout(function() { loadMapping(1); }, 300); });
  document.getElementById('filter-mapping-type').addEventListener('change', function() { loadMapping(1); });

