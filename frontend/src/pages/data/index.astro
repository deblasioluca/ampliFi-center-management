  // --- SAP Extraction (binding-based) ---
  (function initSAPExtract() {
    var area = document.getElementById('sap-extract-area');
    var noConn = document.getElementById('sap-no-connections');
    var listEl = document.getElementById('sap-connections-list');
    var resEl = document.getElementById('sap-extract-result');

    fetch('/api/data/sap-extract/available', { headers: authHdr })
      .then(function(r) { return r.ok ? r.json() : []; })
      .then(function(connections) {
        if (!connections || !connections.length) {
          area.classList.add('hidden');
          noConn.classList.remove('hidden');
          return;
        }
        // Load bindings for each connection
        var html = '';
        var pending = connections.length;
        connections.forEach(function(c) {
          fetch('/api/admin/sap/' + c.connection_id + '/bindings', { headers: authHdr })
            .then(function(r) { return r.ok ? r.json() : []; })
            .then(function(bindings) {
              html += '<div class="border rounded-lg p-3 bg-white">';
              html += '<div class="flex items-center gap-2 mb-2"><span class="font-semibold text-sm">' + esc(c.name) + '</span>';
              html += '<span class="text-xs px-1.5 py-0.5 bg-gray-100 rounded text-gray-600">' + esc(c.protocol || 'OData') + '</span></div>';
              if (!bindings.length) {
                html += '<p class="text-xs text-gray-400">No bindings configured. <a href="/admin/sap" class="text-blue-600 underline">Add bindings</a> to enable extraction.</p>';
              } else {
                html += '<table class="w-full text-xs"><thead><tr class="bg-gray-50">' +
                  '<th class="px-2 py-1 text-left">Object Type</th>' +
                  '<th class="px-2 py-1 text-left">Method</th>' +
                  '<th class="px-2 py-1 text-left">Params</th>' +
                  '<th class="px-2 py-1"></th></tr></thead><tbody>';
                bindings.forEach(function(b) {
                  var uid = 'ext_' + c.connection_id + '_' + b.id;
                  var ot = b.object_type || '';
                  html += '<tr class="border-t">' +
                    '<td class="px-2 py-1 font-mono">' + esc(ot) + '</td>' +
                    '<td class="px-2 py-1 font-mono text-xs">' + esc(b.entity_set || b.path || '-') + '</td>' +
                    '<td class="px-2 py-1">';
                  if (ot === 'cost_center' || ot === 'profit_center') {
                    html += '<select id="' + uid + '_co" class="border rounded px-2 py-0.5 text-xs w-40" data-conn="' + c.connection_id + '">' +
                      '<option value="">All CO Areas</option></select>';
                  } else if (ot === 'hierarchy') {
                    html += '<select id="' + uid + '_co" class="border rounded px-2 py-0.5 text-xs w-36 mr-1" data-conn="' + c.connection_id + '" data-hier-trigger="' + uid + '_hier">' +
                      '<option value="">All CO Areas</option></select>' +
                      '<select id="' + uid + '_hier" multiple class="border rounded px-2 py-0.5 text-xs w-48" style="min-height:28px;max-height:80px" data-conn="' + c.connection_id + '">' +
                      '<option value="">Loading hierarchies...</option></select>';
                  } else if (ot === 'entity_hierarchy') {
                    html += '<input id="' + uid + '_period" type="text" placeholder="Period (e.g. 202605)" class="border rounded px-2 py-0.5 text-xs w-36" />';
                  } else if (ot === 'balance') {
                    html += '<select id="' + uid + '_co" class="border rounded px-2 py-0.5 text-xs w-28 mr-1" data-conn="' + c.connection_id + '">' +
                      '<option value="">All CO Areas</option></select>' +
                      '<input id="' + uid + '_pfrom" type="text" placeholder="Period from" class="border rounded px-2 py-0.5 text-xs w-20 mr-1" />' +
                      '<input id="' + uid + '_pto" type="text" placeholder="Period to" class="border rounded px-2 py-0.5 text-xs w-20 mr-1" />' +
                      '<input id="' + uid + '_cc" type="text" placeholder="Company code" class="border rounded px-2 py-0.5 text-xs w-20 mr-1" />' +
                      '<input id="' + uid + '_ledger" type="text" placeholder="Ledger" class="border rounded px-2 py-0.5 text-xs w-16" />';
                  }
                  html += '</td>' +
                    '<td class="px-2 py-1"><button onclick="extractBinding(' + c.connection_id + ',' + b.id + ',this,\'' + uid + '\',\'' + esc(ot) + '\')" ' +
                    'class="btn-sm bg-blue-600 text-white hover:bg-blue-700 text-xs">Extract</button></td></tr>';
                });
                html += '</tbody></table>';
              }
              html += '</div>';
              pending--;
              if (pending === 0) {
                listEl.innerHTML = html;
                // Populate CO Area dropdowns from SAP
                populateCoAreaDropdowns();
              }
            });
        });
      })
      .catch(function() {
        listEl.textContent = 'Failed to load SAP connections.';
      });

    // Dynamic SAP lookups
    var coAreaCache = {};
    var hierCache = {};

    function populateCoAreaDropdowns() {
      var selects = listEl.querySelectorAll('select[data-conn]');
      var connIds = new Set();
      selects.forEach(function(sel) { connIds.add(sel.getAttribute('data-conn')); });
      connIds.forEach(function(connId) {
        if (coAreaCache[connId]) { fillCoAreaSelects(connId); return; }
        fetch('/api/admin/sap/' + connId + '/lookup/co-areas', { headers: authHdr })
          .then(function(r) { return r.ok ? r.json() : []; })
          .then(function(areas) {
            coAreaCache[connId] = areas;
            fillCoAreaSelects(connId);
            // Also load hierarchies for hierarchy selects
            loadHierarchiesForConn(connId, '');
          }).catch(function() {});
      });
    }

    function fillCoAreaSelects(connId) {
      var areas = coAreaCache[connId] || [];
      listEl.querySelectorAll('select[data-conn="' + connId + '"]').forEach(function(sel) {
        if (sel.multiple) return; // skip hierarchy multi-selects
        var val = sel.value;
        var opts = '<option value="">All CO Areas</option>';
        areas.forEach(function(a) {
          opts += '<option value="' + escAttr(a.co_area) + '">' + esc(a.co_area) + (a.description ? ' — ' + esc(a.description) : '') + '</option>';
        });
        sel.innerHTML = opts;
        sel.value = val;
        // Wire change event for hierarchy trigger
        var hierTarget = sel.getAttribute('data-hier-trigger');
        if (hierTarget) {
          sel.addEventListener('change', function() {
            loadHierarchiesForConn(connId, sel.value);
          });
        }
      });
    }

    function loadHierarchiesForConn(connId, coArea) {
      var cacheKey = connId + ':' + (coArea || '*');
      if (hierCache[cacheKey]) { fillHierSelects(connId, hierCache[cacheKey]); return; }
      var url = '/api/admin/sap/' + connId + '/lookup/hierarchies';
      if (coArea) url += '?co_area=' + encodeURIComponent(coArea);
      fetch(url, { headers: authHdr })
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(hiers) {
          hierCache[cacheKey] = hiers;
          fillHierSelects(connId, hiers);
        }).catch(function() {});
    }

    function fillHierSelects(connId, hiers) {
      listEl.querySelectorAll('select[multiple][data-conn="' + connId + '"]').forEach(function(sel) {
        sel.innerHTML = '';
        if (!hiers.length) {
          sel.innerHTML = '<option value="" disabled>No hierarchies found</option>';
          return;
        }
        hiers.forEach(function(h) {
          var opt = document.createElement('option');
          opt.value = h.set_name;
          opt.textContent = h.set_name + (h.description ? ' — ' + h.description : '') + ' (' + h.kind + ')';
          sel.appendChild(opt);
        });
      });
    }

    window.extractBinding = async function(connId, bindingId, btn, uid, objType) {
      btn.disabled = true;
      btn.textContent = 'Extracting...';
      resEl.className = 'text-sm mt-2 p-3 bg-blue-50 rounded text-blue-700';
      resEl.textContent = 'Connecting to SAP and extracting data...';
      resEl.classList.remove('hidden');
      // Collect selection parameters
      var params = {};
      var coEl = document.getElementById(uid + '_co');
      if (coEl && coEl.value.trim()) params.co_area = coEl.value.trim();
      var hierEl = document.getElementById(uid + '_hier');
      if (hierEl) {
        if (hierEl.multiple) {
          var selected = Array.from(hierEl.selectedOptions).map(function(o) { return o.value; }).filter(Boolean);
          if (selected.length) params.hierarchy_name = selected.join(',');
        } else if (hierEl.value.trim()) {
          params.hierarchy_name = hierEl.value.trim();
        }
      }
      var pfromEl = document.getElementById(uid + '_pfrom');
      if (pfromEl && pfromEl.value.trim()) params.period_from = pfromEl.value.trim();
      var ptoEl = document.getElementById(uid + '_pto');
      if (ptoEl && ptoEl.value.trim()) params.period_to = ptoEl.value.trim();
      var ccEl = document.getElementById(uid + '_cc');
      if (ccEl && ccEl.value.trim()) params.company_code = ccEl.value.trim();
      var ledgerEl = document.getElementById(uid + '_ledger');
      if (ledgerEl && ledgerEl.value.trim()) params.ledger = ledgerEl.value.trim();
      var periodEl = document.getElementById(uid + '_period');
      if (periodEl && periodEl.value.trim()) params.period = periodEl.value.trim();
      try {
        var fetchHeaders = Object.assign({}, authHdr, { 'Content-Type': 'application/json' });
        var res = await fetch('/api/admin/sap/' + connId + '/bindings/' + bindingId + '/extract', {
          method: 'POST', headers: fetchHeaders, body: JSON.stringify(params)
        });
        var ct = res.headers.get('content-type') || '';
        var d = ct.indexOf('json') >= 0 ? await res.json() : { detail: await res.text() };
        if (!res.ok) throw new Error(d.detail || 'Extraction failed');
        resEl.className = 'text-sm mt-2 p-3 bg-green-50 rounded text-green-700';
        resEl.textContent = 'Extraction successful: ' + (d.rows_extracted || 0) + ' records imported.';
        if (d.batch_id) resEl.textContent += ' Batch #' + d.batch_id;
        if (d.status) resEl.textContent += ' (Status: ' + d.status + ')';
        refreshAllData();
        loadUploadHistory();
      } catch(e) {
        resEl.className = 'text-sm mt-2 p-3 bg-red-50 rounded text-red-700';
        resEl.textContent = 'Error: ' + e.message;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Extract';
      }
    };
  })();

  // ─── Data Browser (unified view) ───────────────────────────────────
  // PR #87 — perf rework. Default load is now bounded: 200 rows max,
  // no balances inline, no hierarchy nodes/leaves inline. Pagination,
  // search and hierarchy drill-down all happen as separate small
  // fetches so the UI stays responsive on large datasets.
  var dbData = null;
  var dbView = 'tabular';
  var dbSort = { col: 'cctr', dir: 'asc' };
  var dbColFilters = {};
  var dbPage = 1;
  var dbSize = 200;
  var dbSearchTimer = null;
  var _dbTreeIdSeq = 0;
  // PR #90 — selected hierarchy for L0..LX columns in tabular AND for
  // tree view in hierarchical. Defaults to the first CC hierarchy
  // when one is loaded; nullable for "no L cols" mode.
  var dbSelectedHierarchyId = null;
  var _dbHierPickerPopulated = false;

  // PR #90 — populate the Data Browser hierarchy picker from the
  // hierarchies that came back inlined. Operator opt-in: stays hidden
  // until at least one hierarchy is loaded (which happens after the
  // operator clicks "+ Show hierarchy levels" or switches to the
  // hierarchical view). Same kind labels (CC/PC/Entity) as elsewhere.
  function populateDbHierPicker() {
    var sel = document.getElementById('db-tabular-hier-picker');
    var wrap = document.getElementById('db-hier-picker-wrap');
    if (!sel || !wrap) return;
    var hiers = (dbData && dbData.hierarchies) || [];
    if (!hiers.length) {
      wrap.classList.add('hidden');
      _dbHierPickerPopulated = false;
      return;
    }
    wrap.classList.remove('hidden');
    if (_dbHierPickerPopulated) return;
    _dbHierPickerPopulated = true;
    var ccHiers = hiers.filter(function(h) { return _normSc(h.setclass) === '0101'; });
    var pcHiers = hiers.filter(function(h) { return _normSc(h.setclass) === '0104'; });
    var entHiers = hiers.filter(function(h) { return _normSc(h.setclass) === '0106'; });
    var otherHiers = hiers.filter(function(h) {
      var ns = _normSc(h.setclass);
      return ns !== '0101' && ns !== '0104' && ns !== '0106';
    });
    sel.innerHTML = '<option value="">(none — no L columns)</option>';
    function appendGroup(label, list) {
      if (!list.length) return;
      var g = document.createElement('optgroup');
      g.label = label;
      list.forEach(function(h) {
        var o = document.createElement('option');
        o.value = h.id;
        o.textContent = (h.label || h.setname) + (h.description ? ' — ' + h.description : '');
        g.appendChild(o);
      });
      sel.appendChild(g);
    }
    appendGroup('Cost Center hierarchies (CC)', ccHiers);
    appendGroup('Profit Center hierarchies (PC)', pcHiers);
    appendGroup('Entity hierarchies', entHiers);
    appendGroup('Other', otherHiers);
    // Auto-pick the first CC hierarchy as default
    if (ccHiers.length && !dbSelectedHierarchyId) {
      dbSelectedHierarchyId = ccHiers[0].id;
      sel.value = dbSelectedHierarchyId;
    }
  }

  window.onDbHierPickerChange = function() {
    var sel = document.getElementById('db-tabular-hier-picker');
    var v = sel ? sel.value : '';
    dbSelectedHierarchyId = v ? parseInt(v, 10) : null;
    _cachedHierMap = null;
    dbHierSelectedNode = null;
    renderDB();
  };

  function loadDataBrowser() {
    var el = document.getElementById('db-content');
    el.innerHTML = '<span class="text-gray-400">Loading data browser…</span>';
    var search = (document.getElementById('db-search').value || '').trim();
    var dbParams = '?scope=' + encodeURIComponent(getScope()) +
      '&page=' + dbPage + '&size=' + dbSize;
    if (getCategory()) dbParams += '&data_category=' + encodeURIComponent(getCategory());
    if (search) dbParams += '&search=' + encodeURIComponent(search);
    if (dbIncludeBalances) dbParams += '&include_balances=true';
    if (dbIncludeHierarchies) dbParams += '&include_hierarchies=true';
    // Hierarchies fetched separately on demand by the hierarchical view —
    // keep the metadata-only payload here so we don't pay the nodes+leaves
    // cost on every page-of-200 fetch.
    (window.apiFetch || fetch)('/api/data/browser' + dbParams)
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(d) {
        dbData = d;
        dbColFilters = {};
        dbHierSelectedNode = null;
        _cachedHierMap = null;
        // PR #90 — populate the tabular hierarchy picker once
        // hierarchies are inlined. Hidden by default until the
        // operator clicks "+ Show hierarchy levels" — same pattern
        // as the existing balances toggle.
        populateDbHierPicker();
        renderDB();
      })
      .catch(function(err) {
        el.innerHTML = '<span class="text-red-500">Error: ' + esc(err.message) + '</span>';
      });
  }

  window.dbExpandCollapseAll = function(expand) {
    var el = document.getElementById('db-content');
    if (!el) return;
    el.querySelectorAll('.tree-children').forEach(function(tc) {
      if (expand) tc.classList.remove('hidden'); else tc.classList.add('hidden');
    });
    el.querySelectorAll('[data-db-toggle]').forEach(function(tog) {
      tog.innerHTML = expand ? '&#9660;' : '&#9654;';
    });
  };

  window.switchDataBrowserView = function(view) {
    dbView = view;
    var tabBtn = document.getElementById('db-view-tabular');
    var hierBtn = document.getElementById('db-view-hierarchy');
    if (tabBtn) tabBtn.className = view === 'tabular' ? 'btn-sm bg-blue-600 text-white text-xs' : 'btn-sm bg-gray-200 text-gray-700 text-xs';
    if (hierBtn) hierBtn.className = view === 'hierarchy' ? 'btn-sm bg-blue-600 text-white text-xs' : 'btn-sm bg-gray-200 text-gray-700 text-xs';
    // Show/hide expand/collapse buttons
    var expBtn = document.getElementById('db-expand-all');
    var colBtn = document.getElementById('db-collapse-all');
    if (expBtn) { if (view === 'hierarchy') expBtn.classList.remove('hidden'); else expBtn.classList.add('hidden'); }
    if (colBtn) { if (view === 'hierarchy') colBtn.classList.remove('hidden'); else colBtn.classList.add('hidden'); }
    // Hierarchical view needs:
    //   1. hier.nodes / hier.leaves to walk the tree (PR #87 — kept
    //      initial load fast).
    //   2. ALL items to count & display (the default page is 200 rows;
    //      with 100k+ CCs hierarchy nodes show counts based on the
    //      current page only and most click-to-view-detail produced
    //      "no cost centers under X" — operator complaint
    //      post-PR-#88).
    // PR #90 — flip both flags + bump page size so hierarchical mode
    // gets the full set in one fetch. Tabular returns to size=200 on
    // switch back.
    if (view === 'hierarchy') {
      var needFetch = false;
      if (!dbIncludeHierarchies) { dbIncludeHierarchies = true; needFetch = true; }
      if (dbSize !== 10000) { dbSize = 10000; needFetch = true; }
      if (needFetch) { loadDataBrowser(); return; }
    } else {
      // Tabular — back to paginated default if we'd bumped size for hierarchy
      if (dbSize === 10000) { dbSize = 200; loadDataBrowser(); return; }
    }
    renderDB();
  };

  window.sortDB = function(col) {
    if (dbSort.col === col) {
      dbSort.dir = dbSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
      dbSort.col = col;
      dbSort.dir = 'asc';
    }
    if (dbView === 'hierarchy' && dbHierSelectedNode) {
      renderHierDetail();
    } else {
      renderDB();
    }
  };

  function dbSortArrow(col) {
    if (dbSort.col !== col) return ' <span class="text-gray-300">&#8597;</span>';
    return dbSort.dir === 'asc' ? ' &#8593;' : ' &#8595;';
  }

  function dbSortItems(items) {
    var col = dbSort.col, dir = dbSort.dir === 'asc' ? 1 : -1;
    var isHierCol = col && col.indexOf('hier_') === 0;
    var hierMap = isHierCol ? getCachedHierMap().map : null;
    return items.slice().sort(function(a, b) {
      var va, vb;
      if (isHierCol) {
        va = (hierMap[a.cctr] || {})[col] || '';
        vb = (hierMap[b.cctr] || {})[col] || '';
      } else {
        va = a[col]; vb = b[col];
      }
      if (va == null) va = '';
      if (vb == null) vb = '';
      if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * dir;
      va = String(va).toLowerCase(); vb = String(vb).toLowerCase();
      if (va < vb) return -1 * dir;
      if (va > vb) return 1 * dir;
      return 0;
    });
  }

  window.setDbFilter = function(col, val) {
    if (val === '') { delete dbColFilters[col]; } else { dbColFilters[col] = val; }
    renderDB();
  };

  var _cachedHierMap = null;
  function getCachedHierMap() {
    if (!_cachedHierMap) _cachedHierMap = buildHierLevelMap();
    return _cachedHierMap;
  }

  function getFilteredItems() {
    var search = (document.getElementById('db-search').value || '').toLowerCase();
    var items = (dbData && dbData.items) || [];
    var hierMap = getCachedHierMap().map;
    if (search) {
      items = items.filter(function(it) {
        return (it.cctr || '').toLowerCase().indexOf(search) >= 0 ||
          (it.txtsh || '').toLowerCase().indexOf(search) >= 0 ||
          (it.txtmi || '').toLowerCase().indexOf(search) >= 0 ||
          (it.ccode || '').toLowerCase().indexOf(search) >= 0 ||
          (it.coarea || '').toLowerCase().indexOf(search) >= 0 ||
          (it.responsible || '').toLowerCase().indexOf(search) >= 0 ||
          (it.pctr || '').toLowerCase().indexOf(search) >= 0;
      });
    }
    Object.keys(dbColFilters).forEach(function(col) {
      var fv = dbColFilters[col];
      if (!fv) return;
      items = items.filter(function(it) {
        if (col === 'is_active') return String(it.is_active) === fv;
        if (col.indexOf('hier_') === 0) {
          var hm = hierMap[it.cctr] || {};
          return String(hm[col] || '') === fv;
        }
        return String(it[col] || '') === fv;
      });
    });
    return items;
  }

  window.renderDB = renderDB;
  function renderDB() {
    if (!dbData) return;
    var el = document.getElementById('db-content');
    var items = getFilteredItems();
    if (dbView === 'tabular') {
      renderDBTabular(el, items);
    } else {
      renderDBHierarchical(el, items);
    }
  }

  function buildHierLevelMap() {
    // When the picker is explicitly set to "(none)", return no levels.
    if (dbSelectedHierarchyId == null) return { levels: [], map: {} };
    var hiers = (dbData && dbData.hierarchies) || [];
    var hier = hiers.filter(function(h) { return h.id === dbSelectedHierarchyId; })[0];
    if (!hier) return { levels: [], map: {} };

    var childMap = {};
    (hier.nodes || []).forEach(function(n) {
      if (!childMap[n.parent]) childMap[n.parent] = [];
      childMap[n.parent].push({ type: 'node', name: n.child, seq: n.seq });
    });
    (hier.leaves || []).forEach(function(lf) {
      if (!childMap[lf.setname]) childMap[lf.setname] = [];
      childMap[lf.setname].push({ type: 'leaf', value: lf.value, seq: lf.seq });
    });

    // Find roots
    var allChildren = {};
    (hier.nodes || []).forEach(function(n) { allChildren[n.child] = 1; });
    var roots = [];
    (hier.nodes || []).forEach(function(n) {
      if (!allChildren[n.parent] && roots.indexOf(n.parent) < 0) roots.push(n.parent);
    });
    if (!roots.length && hier.nodes && hier.nodes.length) roots.push(hier.nodes[0].parent);

    // DFS to build paths: CC value -> [level0, level1, level2, ...]
    var ccPaths = {};
    var maxDepth = 0;
    function dfs(nodeName, path) {
      var children = childMap[nodeName] || [];
      children.forEach(function(c) {
        if (c.type === 'leaf') {
          ccPaths[c.value] = path.slice();
          if (path.length > maxDepth) maxDepth = path.length;
        } else {
          dfs(c.name, path.concat([c.name]));
        }
      });
    }
    roots.forEach(function(r) { dfs(r, [r]); });

    var levelCols = [];
    for (var i = 0; i < maxDepth; i++) {
      levelCols.push('L' + (i + 1));
    }

    // Build map: cctr -> { L1: 'X', L2: 'Y', ... }
    // PR #90 — setclass-aware mapping. ``ccPaths`` is keyed by the
    // hierarchy's leaf value (cctr / ccode / pctr depending on
    // setclass). Tabular-view rows are always keyed by cctr, so we
    // walk the loaded items to flip the key:
    //   * 0101 (CC)     → leaf is cctr, identity map
    //   * 0106 (Entity) → leaf is ccode, look up by it.cctr → it.ccode
    //   * 0104 (PC)     → leaf is pctr, look up by it.cctr → it.pctr
    var ccLevelMap = {};
    var setclass = _normSc(hier.setclass);
    var allItems = (dbData && dbData.items) || [];
    function levelObj(p) {
      var obj = {};
      for (var i = 0; i < maxDepth; i++) {
        obj['hier_L' + (i + 1)] = p[i] || '';
      }
      return obj;
    }
    if (setclass === '0106') {
      allItems.forEach(function(it) {
        if (it.cctr && it.ccode && ccPaths[it.ccode]) {
          ccLevelMap[it.cctr] = levelObj(ccPaths[it.ccode]);
        }
      });
    } else if (setclass === '0104') {
      allItems.forEach(function(it) {
        if (it.cctr && it.pctr && ccPaths[it.pctr]) {
          ccLevelMap[it.cctr] = levelObj(ccPaths[it.pctr]);
        }
      });
    } else {
      // 0101 / unknown — leaf key IS cctr
      Object.keys(ccPaths).forEach(function(cctr) {
        ccLevelMap[cctr] = levelObj(ccPaths[cctr]);
      });
    }

    return { levels: levelCols, map: ccLevelMap, hierLabel: hier.label || hier.setname || 'Hierarchy' };
  }

  function renderDBTabular(el, items) {
    var allItems = (dbData && dbData.items) || [];
    if (!allItems.length) {
      el.innerHTML = '<span class="text-gray-400">No cost centers loaded for this scope/category. ' +
        'Try clearing the search or selecting another scope.</span>';
      return;
    }
    var sorted = dbSortItems(items);

    // Build hierarchy level data only when a hierarchy is selected
    // AND hierarchies are inlined. When picker is "(none)" or no
    // hierarchy data is loaded, skip L columns entirely.
    var hierInfo = (dbSelectedHierarchyId != null && dbData.hierarchies_inlined && (dbData.hierarchies || []).some(function(h) { return h.nodes; }))
      ? buildHierLevelMap()
      : { levels: [], map: {} };
    var hierLevels = hierInfo.levels;
    var hierMap = hierInfo.map;

    // Balance period columns: only when balances are inlined. Default
    // response doesn't carry balances; the operator opts in via the
    // "Show monthly balances" toggle (which sets dbIncludeBalances and
    // re-fetches the page with include_balances=true).
    var hasBalances = (dbData.items || []).some(function(it) { return it.monthly_balances; });
    var periods = {};
    var currencyForPeriod = {};
    if (hasBalances) {
      allItems.forEach(function(it) {
        (it.monthly_balances || []).forEach(function(b) {
          var key = b.fiscal_year + '/' + String(b.period).padStart(2, '0');
          periods[key] = 1;
          if (b.currency) currencyForPeriod[key] = b.currency;
        });
      });
    }
    var pKeys = Object.keys(periods).sort();

    var cols = [
      { key: 'cctr', label: 'CC' },
      { key: 'txtsh', label: 'Short Text' },
      { key: 'ccode', label: 'Entity' },
      { key: 'coarea', label: 'CO Area' },
      { key: 'pctr', label: 'Profit Ctr' },
      { key: 'pc_txtsh', label: 'PC Text' },
      { key: 'responsible', label: 'Responsible' },
      { key: 'is_active', label: 'Active' }
    ];
    var hierCols = hierLevels.map(function(lvl, i) {
      return { key: 'hier_L' + (i + 1), label: lvl };
    });
    var allCols = cols.concat(hierCols);

    var html = '<table class="w-full text-xs border-collapse"><thead>';
    html += '<tr class="border-b bg-gray-50">';
    allCols.forEach(function(c) {
      html += '<th class="py-2 px-2 text-left cursor-pointer select-none whitespace-nowrap" ' +
        'onclick="sortDB(\'' + c.key + '\')">' + c.label + dbSortArrow(c.key) + '</th>';
    });
    pKeys.forEach(function(pk) {
      var curr = currencyForPeriod[pk];
      var label = curr ? pk + ' (' + curr + ')' : pk;
      html += '<th class="py-2 px-2 text-right whitespace-nowrap">' + esc(label) + '</th>';
    });
    html += '</tr></thead><tbody>';
    // Note: per-column auto-filter dropdowns were removed in PR #87.
    // Building one <select> per column with thousands of distinct
    // values for thousands of rows was the dominant cost in
    // renderDBTabular (DOM measured in 100k+ nodes for a real SAP
    // dataset, locking up the browser for many seconds). Use the
    // top-of-page search box for filtering — it goes through the
    // server (LIKE on cctr / txtsh / txtmi / ccode / responsible)
    // and is consistent across pages.

    if (!sorted.length) {
      html += '<tr><td colspan="' + (allCols.length + pKeys.length) + '" class="py-4 text-center text-gray-400">' +
        'No rows match the search on this page.</td></tr>';
    }

    sorted.forEach(function(it) {
      var balMap = {};
      (it.monthly_balances || []).forEach(function(b) {
        balMap[b.fiscal_year + '/' + String(b.period).padStart(2, '0')] = b;
      });
      var hm = hierMap[it.cctr] || {};
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1 px-2 font-mono font-medium">' + esc(it.cctr) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.txtsh) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.ccode) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.coarea) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.pctr) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.pc_txtsh) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.responsible) + '</td>';
      html += '<td class="py-1 px-2 text-center">' + (it.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td>';
      hierCols.forEach(function(c) {
        html += '<td class="py-1 px-2 text-xs text-gray-600">' + esc(hm[c.key] || '') + '</td>';
      });
      pKeys.forEach(function(pk) {
        var b = balMap[pk];
        if (b) {
          var amt = b.amount >= 0
            ? b.amount.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0})
            : '-' + Math.abs(b.amount).toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});
          var curr = b.currency ? ' <span class="text-gray-400 text-[9px]">' + esc(b.currency) + '</span>' : '';
          html += '<td class="py-1 px-2 text-right font-mono' + (b.amount < 0 ? ' text-red-600' : '') + '">' + amt + curr + '</td>';
        } else {
          html += '<td class="py-1 px-2 text-right text-gray-300">-</td>';
        }
      });
      html += '</tr>';
    });
    html += '</tbody></table>';

    // Pager (server-side pagination).
    var total = (dbData && dbData.total) || 0;
    var page = (dbData && dbData.page) || 1;
    var size = (dbData && dbData.size) || dbSize;
    var totalPages = Math.max(1, Math.ceil(total / size));
    var start = total === 0 ? 0 : (page - 1) * size + 1;
    var end = Math.min(page * size, total);
    var pager = '<div class="flex items-center justify-between mt-3 text-xs text-gray-600">' +
      '<div>Showing <strong>' + start + '–' + end + '</strong> of <strong>' + total + '</strong> rows' +
      (hasBalances ? '' : ' &nbsp;·&nbsp; <button onclick="dbToggleBalances()" class="text-amplifi-600 hover:underline">+ Show monthly balances</button>') +
      (dbData.hierarchies_inlined ? '' : ' &nbsp;·&nbsp; <button onclick="dbToggleHierarchies()" class="text-amplifi-600 hover:underline">+ Show hierarchy levels</button>') +
      '</div>' +
      '<div class="flex items-center gap-1">' +
      (page > 1 ? '<button onclick="dbGoToPage(1)" class="px-2 py-1 hover:bg-gray-100 rounded">« First</button>' : '') +
      (page > 1 ? '<button onclick="dbGoToPage(' + (page - 1) + ')" class="px-2 py-1 hover:bg-gray-100 rounded">‹ Prev</button>' : '') +
      '<span class="px-2">Page ' + page + ' / ' + totalPages + '</span>' +
      (page < totalPages ? '<button onclick="dbGoToPage(' + (page + 1) + ')" class="px-2 py-1 hover:bg-gray-100 rounded">Next ›</button>' : '') +
      (page < totalPages ? '<button onclick="dbGoToPage(' + totalPages + ')" class="px-2 py-1 hover:bg-gray-100 rounded">Last »</button>' : '') +
      '</div></div>';

    el.innerHTML = html + pager;
  }

  // Opt-in toggles for the heavy parts of the response. The first
  // click makes a fetch with the relevant include_X=true; from then on
  // all paginated fetches keep that flag on (per dbIncludeBalances /
  // dbIncludeHierarchies state).
  var dbIncludeBalances = false;
  var dbIncludeHierarchies = false;
  window.dbToggleBalances = function() {
    dbIncludeBalances = true;
    loadDataBrowser();
  };
  window.dbToggleHierarchies = function() {
    dbIncludeHierarchies = true;
    loadDataBrowser();
  };

  var dbHierSelectedNode = null;

  window.resetHierSelection = function() {
    dbHierSelectedNode = null;
    renderDB();
  };

  window.selectHierNode = function(nodeName) {
    // Remove highlight from previous selection
    var prev = document.querySelector('[data-hier-node].bg-blue-50');
    if (prev) {
      prev.classList.remove('font-bold', 'text-blue-700', 'bg-blue-50');
      prev.classList.add(prev.dataset.hierNode === '__unassigned__' ? 'text-gray-500' : 'text-gray-800');
    }
    dbHierSelectedNode = nodeName;
    // Add highlight to new selection
    var cur = document.querySelector('[data-hier-node="' + CSS.escape(nodeName) + '"]');
    if (cur) {
      cur.classList.add('font-bold', 'text-blue-700', 'bg-blue-50');
      cur.classList.remove('text-gray-800', 'text-gray-500');
    }
    renderHierDetail();
  };

  function renderHierDetail() {
    var detailEl = document.getElementById('db-hier-detail');
    if (!detailEl || !dbData) return;
    var items = getFilteredItems();

    var hiers = dbData.hierarchies || [];
    // PR #90 — use the unified picker selection (same as
    // renderDBHierarchical above). Was reading from `db-hier-select`
    // which is now removed in favour of `db-tabular-hier-picker`.
    var hier = null;
    if (dbSelectedHierarchyId != null) {
      hier = hiers.filter(function(h) { return h.id === dbSelectedHierarchyId; })[0];
    }
    if (!hier) {
      hier = hiers.filter(function(h) { return _normSc(h.setclass) === '0101'; })[0] || hiers[0];
    }
    if (!hier) return;

    // PR #90 — setclass-aware leafItemsMap. See renderDBHierarchical
    // for the full rationale.
    var leafItemsMap = {};
    var setclass = _normSc(hier.setclass);
    if (setclass === '0106') {
      items.forEach(function(it) {
        if (!it.ccode) return;
        if (!leafItemsMap[it.ccode]) leafItemsMap[it.ccode] = [];
        leafItemsMap[it.ccode].push(it);
      });
    } else if (setclass === '0104') {
      items.forEach(function(it) {
        if (!it.pctr) return;
        if (!leafItemsMap[it.pctr]) leafItemsMap[it.pctr] = [];
        leafItemsMap[it.pctr].push(it);
      });
    } else {
      items.forEach(function(it) {
        if (it.cctr) leafItemsMap[it.cctr] = [it];
      });
    }

    var childMap = {};
    (hier.nodes || []).forEach(function(n) {
      if (!childMap[n.parent]) childMap[n.parent] = [];
      childMap[n.parent].push({ type: 'node', name: n.child, seq: n.seq });
    });
    (hier.leaves || []).forEach(function(lf) {
      if (!childMap[lf.setname]) childMap[lf.setname] = [];
      childMap[lf.setname].push({ type: 'leaf', value: lf.value, seq: lf.seq });
    });

    // Collect all leaf CCs under the selected node (recursively).
    // Uses leafItemsMap so entity hierarchies surface every CC under
    // the picked entity, etc.
    var leafCCs = [];
    function collectLeaves(node) {
      var ch = childMap[node] || [];
      ch.forEach(function(c) {
        if (c.type === 'leaf') {
          (leafItemsMap[c.value] || []).forEach(function(it) { leafCCs.push(it); });
        }
        else { collectLeaves(c.name); }
      });
    }

    if (dbHierSelectedNode === '__unassigned__') {
      // For unassigned: items whose lookup key isn't in any leaf
      var assigned = {};
      (hier.leaves || []).forEach(function(lf) { assigned[lf.value] = 1; });
      if (setclass === '0106') {
        leafCCs = items.filter(function(it) { return it.cctr && it.ccode && !assigned[it.ccode]; });
      } else if (setclass === '0104') {
        leafCCs = items.filter(function(it) { return it.cctr && it.pctr && !assigned[it.pctr]; });
      } else {
        leafCCs = items.filter(function(it) { return it.cctr && !assigned[it.cctr]; });
      }
    } else if (dbHierSelectedNode && dbHierSelectedNode.indexOf('__leaf__') === 0) {
      // Clicked on a leaf directly in the tree
      var leafVal = dbHierSelectedNode.substring(8);
      leafCCs = leafItemsMap[leafVal] || [];
    } else if (dbHierSelectedNode) {
      collectLeaves(dbHierSelectedNode);
    } else {
      detailEl.innerHTML = '<div class="flex items-center justify-center h-full text-gray-400 text-sm">Select a node in the tree to view its cost centers.</div>';
      return;
    }

    if (!leafCCs.length) {
      detailEl.innerHTML = '<div class="flex items-center justify-center h-full text-gray-400 text-sm">No cost centers under <b>' + esc(dbHierSelectedNode === '__unassigned__' ? 'Unassigned' : dbHierSelectedNode) + '</b></div>';
      return;
    }

    // Build table similar to tabular view
    var periods = {};
    leafCCs.forEach(function(it) {
      (it.monthly_balances || []).forEach(function(b) {
        var key = b.fiscal_year + '/' + String(b.period).padStart(2, '0');
        periods[key] = 1;
      });
    });
    var pKeys = Object.keys(periods).sort();
    var sorted = dbSortItems(leafCCs);

    var label = dbHierSelectedNode === '__unassigned__' ? 'Unassigned' : dbHierSelectedNode;
    var html = '<div class="mb-2 flex items-center gap-2"><span class="font-semibold text-sm text-blue-800">' + esc(label) + '</span>';
    html += '<span class="text-xs text-gray-500">(' + leafCCs.length + ' cost center' + (leafCCs.length !== 1 ? 's' : '') + ')</span></div>';
    html += '<div class="overflow-auto" style="max-height:calc(100vh - 480px)"><table class="w-full text-xs border-collapse"><thead>';
    html += '<tr class="border-b bg-gray-50 sticky top-0">';
    var cols = [
      { key: 'cctr', label: 'CC' },
      { key: 'txtsh', label: 'Short Text' },
      { key: 'ccode', label: 'Entity' },
      { key: 'coarea', label: 'CO Area' },
      { key: 'pctr', label: 'Profit Ctr' },
      { key: 'pc_txtsh', label: 'PC Text' },
      { key: 'responsible', label: 'Responsible' }
    ];
    cols.forEach(function(c) {
      html += '<th class="py-2 px-2 text-left cursor-pointer select-none whitespace-nowrap bg-gray-50" onclick="sortDB(\'' + c.key + '\')">' + c.label + dbSortArrow(c.key) + '</th>';
    });
    html += '<th class="py-2 px-2 text-right whitespace-nowrap bg-gray-50">Total</th>';
    pKeys.forEach(function(pk) {
      html += '<th class="py-2 px-2 text-right whitespace-nowrap bg-gray-50">' + esc(pk) + '</th>';
    });
    html += '</tr></thead><tbody>';

    sorted.forEach(function(it) {
      var balMap = {};
      var total = 0;
      (it.monthly_balances || []).forEach(function(b) {
        balMap[b.fiscal_year + '/' + String(b.period).padStart(2, '0')] = b;
        total += b.amount;
      });
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1 px-2 font-mono font-medium">' + esc(it.cctr) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.txtsh) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.ccode) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.coarea) + '</td>';
      html += '<td class="py-1 px-2 font-mono">' + esc(it.pctr) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.pc_txtsh) + '</td>';
      html += '<td class="py-1 px-2">' + esc(it.responsible) + '</td>';
      var totalStr = total.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});
      html += '<td class="py-1 px-2 text-right font-mono font-semibold' + (total < 0 ? ' text-red-600' : '') + '">' + totalStr + '</td>';
      pKeys.forEach(function(pk) {
        var b = balMap[pk];
        if (b) {
          var amt = b.amount >= 0 ? b.amount.toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0}) : '-' + Math.abs(b.amount).toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});
          html += '<td class="py-1 px-2 text-right font-mono' + (b.amount < 0 ? ' text-red-600' : '') + '">' + amt + '</td>';
        } else {
          html += '<td class="py-1 px-2 text-right text-gray-300">-</td>';
        }
      });
      html += '</tr>';
    });
    detailEl.innerHTML = html + '</tbody></table></div>';
  }

  function renderDBHierarchical(el, items) {
    var hiers = (dbData.hierarchies || []);
    if (!hiers.length) { el.innerHTML = '<span class="text-gray-400">No hierarchies loaded. Load hierarchies via SAP extraction or upload.</span>'; return; }

    var ccMap = {};
    items.forEach(function(it) { if (it.cctr) ccMap[it.cctr] = it; });

    // PR #90 — use the unified dbSelectedHierarchyId picker at the
    // top of the Data Browser tab instead of a second inline picker
    // here. The previous inline picker confused operators ("two
    // hierarchy dropdowns?") and didn't share selection with tabular.
    var hier = null;
    if (dbSelectedHierarchyId != null) {
      hier = hiers.filter(function(h) { return h.id === dbSelectedHierarchyId; })[0];
    }
    if (!hier) {
      hier = hiers.filter(function(h) { return _normSc(h.setclass) === '0101'; })[0] || hiers[0];
    }
    if (!hier) {
      el.innerHTML = '<span class="text-gray-400">Select a hierarchy from the picker above to drill into it.</span>';
      return;
    }

    // Setclass-aware ccMap with normalised setclass.
    var leafItemsMap = {};
    var setclass = _normSc(hier.setclass);
    if (setclass === '0106') {
      items.forEach(function(it) {
        if (!it.ccode) return;
        if (!leafItemsMap[it.ccode]) leafItemsMap[it.ccode] = [];
        leafItemsMap[it.ccode].push(it);
      });
    } else if (setclass === '0104') {
      items.forEach(function(it) {
        if (!it.pctr) return;
        if (!leafItemsMap[it.pctr]) leafItemsMap[it.pctr] = [];
        leafItemsMap[it.pctr].push(it);
      });
    } else {
      items.forEach(function(it) {
        if (it.cctr) leafItemsMap[it.cctr] = [it];
      });
    }

    var html = '';

    // Split panel: tree left, detail right
    // PR #90 — wider tree panel (w-80 was w-64) + no truncate on node
    // names. Operator screenshot showed ``TM_CC_Group_Operat_Analyti…``
    // cut off at the 30-character mark — full setnames fit in 80
    // characters and operators need to read them to know which subtree
    // they're in.
    html += '<div class="flex gap-3" style="height:calc(100vh - 480px);min-height:200px">';

    // Left panel — compact tree
    html += '<div class="w-80 flex-shrink-0 border rounded bg-white overflow-auto">';

    var childMap = {};
    (hier.nodes || []).forEach(function(n) {
      if (!childMap[n.parent]) childMap[n.parent] = [];
      childMap[n.parent].push({ type: 'node', name: n.child, seq: n.seq });
    });
    (hier.leaves || []).forEach(function(lf) {
      if (!childMap[lf.setname]) childMap[lf.setname] = [];
      childMap[lf.setname].push({ type: 'leaf', value: lf.value, seq: lf.seq });
    });

    var allChildren = {};
    (hier.nodes || []).forEach(function(n) { allChildren[n.child] = 1; });
    var roots = [];
    (hier.nodes || []).forEach(function(n) {
      if (!allChildren[n.parent] && roots.indexOf(n.parent) < 0) roots.push(n.parent);
    });
    if (!roots.length && hier.nodes && hier.nodes.length) roots.push(hier.nodes[0].parent);

    function countLeaves(node) {
      var ch = childMap[node] || [];
      var cnt = 0;
      ch.forEach(function(c) {
        // PR #90 — leafItemsMap is setclass-aware (keyed by ccode for
        // entity hierarchies, pctr for PC, cctr for CC). Each entry
        // is the list of CC items under that leaf — sum lengths.
        if (c.type === 'leaf') { cnt += (leafItemsMap[c.value] || []).length; }
        else { cnt += countLeaves(c.name); }
      });
      return cnt;
    }

    function buildTree(nodeName, depth) {
      var pad = depth * 12;
      var lc = countLeaves(nodeName);
      var isSelected = dbHierSelectedNode === nodeName;
      var nodeToggleId = 'db-tn-' + (++_dbTreeIdSeq);
      var out = '<div style="padding-left:' + pad + 'px" class="py-0.5 flex items-center gap-1">';
      out += '<span class="text-[10px] text-gray-400 cursor-pointer select-none" data-db-toggle="' + escAttr(nodeToggleId) + '">&#9660;</span>';
      out += '<span data-hier-node="' + escAttr(nodeName) + '" class="text-xs cursor-pointer hover:text-blue-600 px-1 rounded' + (isSelected ? ' font-bold text-blue-700 bg-blue-50' : ' text-gray-800') + '" title="' + escAttr(nodeName) + '">';
      out += esc(nodeName) + ' <span class="text-[10px] text-gray-400">(' + lc + ')</span></span></div>';
      var children = childMap[nodeName] || [];
      children.sort(function(a, b) { return (a.seq || 0) - (b.seq || 0); });
      out += '<div id="' + escAttr(nodeToggleId) + '" class="tree-children">';
      children.forEach(function(c) {
        if (c.type === 'node') {
          out += buildTree(c.name, depth + 1);
        } else if (c.type === 'leaf') {
          // Render leaf items directly in the tree
          var leafItems = leafItemsMap[c.value] || [];
          var leafPad = (depth + 1) * 12;
          if (leafItems.length) {
            leafItems.forEach(function(item) {
              var idField = item.cctr || c.value;
              var label = item.txtsh || item.name || '';
              out += '<div style="padding-left:' + leafPad + 'px" class="py-0.5">' +
                '<span data-hier-node="__leaf__' + escAttr(c.value) + '" class="text-xs cursor-pointer hover:text-blue-600 px-1 rounded font-medium text-gray-700">' +
                esc(idField) + (label ? ' — ' + esc(label) : '') +
                '</span></div>';
            });
          } else {
            out += '<div style="padding-left:' + leafPad + 'px" class="py-0.5">' +
              '<span class="text-xs text-gray-400 px-1">' + esc(c.value) + ' (no match)</span></div>';
          }
        }
      });
      out += '</div>';
      return out;
    }

    roots.forEach(function(root) { html += buildTree(root, 0); });

    // Unassigned entry — items whose hierarchy lookup key isn't in
    // any leaf of the chosen hierarchy. Setclass-aware so picking an
    // entity hierarchy lists CCs whose ccode isn't in the tree, etc.
    var assigned = {};
    (hier.leaves || []).forEach(function(lf) { assigned[lf.value] = 1; });
    var unassignedCount;
    if (setclass === '0106') {
      unassignedCount = items.filter(function(it) { return it.cctr && it.ccode && !assigned[it.ccode]; }).length;
    } else if (setclass === '0104') {
      unassignedCount = items.filter(function(it) { return it.cctr && it.pctr && !assigned[it.pctr]; }).length;
    } else {
      unassignedCount = items.filter(function(it) { return it.cctr && !assigned[it.cctr]; }).length;
    }
    if (unassignedCount) {
      var isUA = dbHierSelectedNode === '__unassigned__';
      html += '<div data-hier-node="__unassigned__" class="mt-2 pt-2 border-t px-2 py-1 cursor-pointer hover:bg-gray-50' + (isUA ? ' bg-blue-50 font-bold text-blue-700' : ' text-gray-500') + '">';
      html += 'Unassigned (' + unassignedCount + ')</div>';
    }

    html += '</div>';

    // Right panel — detail table
    html += '<div class="flex-1 border rounded bg-white overflow-auto" id="db-hier-detail">';
    html += '<div class="flex items-center justify-center h-full text-gray-400 text-sm">Select a node in the tree to view its cost centers.</div>';
    html += '</div>';

    html += '</div>';
    el.innerHTML = html;

    // Bind click handlers via addEventListener (avoids XSS from inline onclick with dynamic data)
    el.querySelectorAll('[data-hier-node]').forEach(function(nodeEl) {
      nodeEl.addEventListener('click', function() {
        selectHierNode(this.dataset.hierNode);
      });
    });

    // Bind toggle (expand/collapse) handlers
    el.querySelectorAll('[data-db-toggle]').forEach(function(toggleEl) {
      toggleEl.addEventListener('click', function(e) {
        e.stopPropagation();
        var targetId = this.dataset.dbToggle;
        var target = document.getElementById(targetId);
        if (target) {
          target.classList.toggle('hidden');
          this.innerHTML = target.classList.contains('hidden') ? '&#9654;' : '&#9660;';
        }
      });
    });

    // If a node was previously selected, render its detail
    if (dbHierSelectedNode) renderHierDetail();
  }

  // Wire search — fires a server-side fetch (paginated). Debounced so
  // we don't spam the API on every keystroke. Resets to page 1 on
  // every change since the previous page may not exist for the new
  // result set.
  document.getElementById('db-search').addEventListener('input', function() {
    clearTimeout(dbSearchTimer);
    dbSearchTimer = setTimeout(function() {
      dbPage = 1;
      loadDataBrowser();
    }, 350);
  });

  // Pager actions (called from the rendered pager HTML)
  window.dbGoToPage = function(p) {
    if (p < 1) p = 1;
    dbPage = p;
    loadDataBrowser();
  };

  // Load on page init
  loadDataBrowser();

})();
</script>
