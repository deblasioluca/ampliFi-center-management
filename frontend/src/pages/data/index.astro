  function pollBatchStatus(id, targetStatuses, label) {
    return new Promise(function(resolve) {
      loadUploadHistory();
      var attempts = 0;
      var maxAttempts = 180; // 6 minutes at 2s intervals
      var interval = setInterval(function() {
        attempts++;
        fetch('/api/admin/uploads/' + id, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(b) {
          loadUploadHistory();
          if (targetStatuses.indexOf(b.status) !== -1) {
            clearInterval(interval);
            resolve(b);
          } else if (attempts >= maxAttempts) {
            clearInterval(interval);
            resolve(null);
          }
        }).catch(function() {
          if (attempts >= maxAttempts) { clearInterval(interval); resolve(null); }
        });
      }, 2000);
    });
  }
  window.validateUpload = async function(id) {
    if (!token) { alert('Please log in first.'); return; }
    var res = await fetch('/api/admin/uploads/' + id + '/validate', { method: 'POST', headers: authHdr });
    if (res.status === 401 || res.status === 403) { alert('Session expired — please log in again.'); return; }
    var d = await res.json();
    if (!res.ok) { alert('Validation error: ' + (d.detail || 'Unknown error')); loadUploadHistory(); return; }
    loadUploadHistory();
    var result = await pollBatchStatus(id, ['validated', 'failed'], 'Validating');
    if (!result) { alert('Validation timed out — check status manually.'); return; }
    if (result.status === 'failed') {
      alert('Validation failed — check upload errors for details.');
    } else {
      alert('Validation: ' + result.status + (result.rows_error ? ' (' + result.rows_error + ' errors)' : '') + ' — ' + (result.rows_valid || 0) + ' valid rows');
    }
    loadUploadHistory();
  };
  window.loadUpload = async function(id) {
    if (!token) { alert('Please log in first.'); return; }
    var res = await fetch('/api/admin/uploads/' + id + '/load', { method: 'POST', headers: authHdr });
    if (res.status === 401 || res.status === 403) { alert('Session expired — please log in again.'); return; }
    var d = await res.json();
    if (!res.ok) { alert('Load error: ' + (d.detail || 'Unknown error')); loadUploadHistory(); return; }
    loadUploadHistory();
    var result = await pollBatchStatus(id, ['loaded', 'failed'], 'Loading');
    if (!result) { alert('Load timed out — check status manually.'); return; }
    if (result.status === 'failed') {
      alert('Load failed — check upload errors for details.');
    } else {
      alert('Load: ' + result.status + (result.rows_loaded ? ' (' + result.rows_loaded + ' rows)' : ''));
    }
    loadUploadHistory(); refreshAllData();
  };
  window.rollbackUpload = async function(id) {
    if (!confirm('Rollback this upload? This will remove all data loaded from this batch.')) return;
    if (!token) { alert('Please log in first.'); return; }
    var res = await fetch('/api/admin/uploads/' + id + '/rollback', { method: 'POST', headers: authHdr });
    if (res.status === 401 || res.status === 403) { alert('Session expired — please log in again.'); return; }
    var d = await res.json();
    if (!res.ok) { alert('Rollback error: ' + (d.detail || 'Unknown error')); loadUploadHistory(); return; }
    alert('Rollback: ' + d.status + (d.rows_deleted ? ' (' + d.rows_deleted + ' rows removed)' : ''));
    loadUploadHistory(); refreshAllData();
  };
  window.deleteUpload = async function(id) {
    if (!confirm('Delete this upload batch? If data was loaded, it will remain in the system — use Rollback first to remove loaded data.')) return;
    try {
