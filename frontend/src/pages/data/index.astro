---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Data Management" requireAuth={true} requiredRole="data_manager">
  <div class="flex items-center justify-between mb-2">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Data Management</h1>
      <p class="text-xs text-gray-500">Upload, browse, and manage cost centers, profit centers, balances, hierarchies, and employees</p>
    </div>
  </div>

  <!-- Scope Selector -->
  <div class="flex items-center gap-3 mb-3">
    <label class="text-sm font-medium text-gray-700">Scope:</label>
    <select id="scope-selector" class="input w-auto text-sm">
      <option value="cleanup" selected>Center Management — Cleanup</option>
      <option value="housekeeping">Center Management — Housekeeping</option>
      <option value="explorer">Data Explorer</option>
    </select>
    <label class="text-sm font-medium text-gray-700 ml-4">Category:</label>
    <select id="category-selector" class="input w-auto text-sm">
      <option value="">All</option>
      <option value="legacy">Legacy</option>
      <option value="target">Target</option>
    </select>
  </div>

  <!-- Data Counts -->
  <div class="grid grid-cols-4 lg:grid-cols-8 gap-3 mb-3">
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Entities</span>
      <p id="cnt-entities" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Cost Centers</span>
      <p id="cnt-cc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Profit Centers</span>
      <p id="cnt-pc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">GL Accounts</span>
      <p id="cnt-gl" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Balances</span>
      <p id="cnt-balances" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Hierarchies</span>
      <p id="cnt-hierarchies" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Employees</span>
      <p id="cnt-employees" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Uploads</span>
      <p id="cnt-uploads" class="text-lg font-bold text-gray-900">--</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white border-b border-gray-200 rounded-t-lg mb-0">
    <div class="flex space-x-0 overflow-x-auto" id="data-tabs">
      <button class="tab-active px-4 py-3 whitespace-nowrap font-semibold text-blue-700" data-tab="data-browser">Data Browser</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="entities">Entities</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="cost-centers">Cost Centers</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="profit-centers">Profit Centers</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="gl-accounts">GL Accounts</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="mapping">Mapping</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="balances">Balances</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="hierarchies">Hierarchies</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="employees">Employees</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="upload">Upload</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="sample-data">Sample Data</button>
    </div>
  </div>

  <!-- Tab Content -->
  <div class="card rounded-t-none border-t-0">
    <!-- Data Browser Tab -->
    <div id="tab-data-browser">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold">Data Browser</h3>
        <div class="flex items-center gap-2">
          <button id="db-view-tabular" class="btn-sm bg-blue-600 text-white text-xs" onclick="switchDataBrowserView('tabular')">Tabular</button>
          <button id="db-view-hierarchy" class="btn-sm bg-gray-200 text-gray-700 text-xs" onclick="switchDataBrowserView('hierarchy')">Hierarchical</button>
          <button id="db-expand-all" class="btn-sm bg-gray-200 text-gray-700 text-xs hidden" onclick="dbExpandCollapseAll(true)">Expand All</button>
          <button id="db-collapse-all" class="btn-sm bg-gray-200 text-gray-700 text-xs hidden" onclick="dbExpandCollapseAll(false)">Collapse All</button>
          <input id="db-search" type="text" placeholder="Filter by CC, name, entity..." class="border rounded px-2 py-0.5 text-xs w-48" />
          <button onclick="downloadTableCSV('db-content','data_browser.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
        </div>
      </div>
      <!-- PR #90 — Hierarchy picker (applies to BOTH views).
           In tabular view it adds L0..LX columns from the chosen
           hierarchy. In hierarchical view it picks the tree to render.
           Hidden until at least one hierarchy is loaded; the operator
           clicks "+ Show hierarchy levels" to opt in (the load is
           deferred for performance — see PR #87). -->
      <div id="db-hier-picker-wrap" class="flex items-center gap-2 mb-2 hidden">
        <label class="text-xs text-gray-500 whitespace-nowrap">Hierarchy:</label>
        <select id="db-tabular-hier-picker" class="input text-xs w-72" onchange="onDbHierPickerChange()">
          <option value="">(none — no L columns)</option>
        </select>
      </div>
      <div id="db-content" class="text-xs overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 480px)">
        <span class="text-sm text-gray-400">Loading data browser...</span>
      </div>
    </div>

    <!-- Entities Tab -->
    <div id="tab-entities" class="hidden">
      <!-- Toolbar — PR #88 split into two rows. The previous one-row
           layout used flex-wrap, but on narrow viewports (e.g. side-by-side
           windows on the operator's MacBook screenshot) the toggle group
           ended up squeezed and the "Hierarchical" label got clipped to
           a single character. Two rows is unambiguous: title + destructive
           actions on top, view controls + search below. -->
      <div class="flex items-center justify-between mb-2 gap-3 flex-wrap">
        <h3 class="text-base font-semibold flex-shrink-0">Entities (Legal Entities / Company Codes)</h3>
        <div class="flex items-center gap-2 flex-wrap ml-auto">
          <button onclick="downloadTableCSV('entities-table','entities.csv')" class="btn-secondary text-xs flex-shrink-0" title="Download as CSV">CSV</button>
          <button id="delete-all-entities" class="btn-danger text-xs flex-shrink-0">Delete All</button>
        </div>
      </div>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <div class="inline-flex rounded-md border border-gray-300 text-xs">
          <button id="entities-view-tabular" class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium whitespace-nowrap" onclick="switchEntitiesView('tabular')">Tabular</button>
          <button id="entities-view-hierarchy" class="px-3 py-1.5 text-gray-600 hover:bg-gray-50 whitespace-nowrap border-l border-gray-300" onclick="switchEntitiesView('hierarchy')">Hierarchical</button>
        </div>
        <input id="search-entities" type="text" placeholder="Search..." class="input text-sm w-48 flex-shrink-0" />
      </div>
      <!-- Tabular -->
      <div id="entities-table-wrap">
        <div id="entities-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 480px)">Loading...</div>
        <div id="entities-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      <!-- Hierarchical -->
      <div id="entities-hier-wrap" class="hidden">
        <p class="text-xs text-gray-500 mb-2">Grouped by <span class="font-medium">Country &rarr; Region &rarr; Entity</span>. Click rows to expand.</p>
        <div id="entities-hier" class="text-sm text-gray-700 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Loading...</div>
      </div>
    </div>

    <!-- Cost Centers Tab -->
    <div id="tab-cost-centers" class="hidden">
      <!-- View toggle (applies to both Legacy and Target) -->
      <div class="flex items-center justify-end mb-2">
        <div class="flex rounded-md border border-gray-300 overflow-hidden text-xs">
          <button id="cc-view-tabular" class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium" onclick="switchCCView('tabular')">Tabular</button>
          <button id="cc-view-hierarchy" class="px-3 py-1.5 text-gray-600 hover:bg-gray-50" onclick="switchCCView('hierarchy')">Hierarchical</button>
        </div>
      </div>
      <!-- Hierarchy picker (applies to BOTH views) -->
      <div class="flex items-center justify-end mb-2 gap-2 text-xs">
        <label for="cc-hier-picker" class="text-gray-500">Hierarchy:</label>
        <select id="cc-hier-picker" class="input text-xs w-64">
          <option value="">(none — flat list)</option>
        </select>
      </div>
      <!-- Tabular wrap -->
      <div id="cc-tabular-wrap">
      <!-- Legacy Section -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold">Legacy Cost Centers</h3>
          <div class="flex items-center gap-2">
            <input id="search-cc" type="text" placeholder="Search..." class="input text-sm w-48" />
            <select id="filter-cc-ccode" class="input text-sm w-32"><option value="">All Entities</option></select>
            <button onclick="downloadTableCSV('cc-table','legacy_cost_centers.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
            <button id="delete-all-cc" class="btn-danger text-xs">Delete All</button>
          </div>
        </div>
        <div id="cc-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 620px)">Loading...</div>
        <div id="cc-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      <!-- Target Section -->
      <div class="border-t border-gray-200 pt-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold">Target Cost Centers <span class="text-xs font-normal text-amplifi-600">(ampliFi)</span></h3>
          <div class="flex items-center gap-2">
            <input id="search-tcc" type="text" placeholder="Search..." class="input text-sm w-48" />
            <button onclick="downloadTableCSV('tcc-table','target_cost_centers.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
            <button id="delete-all-tcc" class="btn-danger text-xs">Delete All</button>
          </div>
        </div>
        <div id="tcc-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 620px)">Loading...</div>
        <div id="tcc-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      </div><!-- /cc-tabular-wrap -->
      <!-- Hierarchical -->
      <div id="cc-hier-wrap" class="hidden">
        <p class="text-xs text-gray-500 mb-2">Grouped by the hierarchy you pick above. Click rows to expand.</p>
        <div id="cc-hier" class="text-sm text-gray-700 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Loading...</div>
      </div>
    </div>

    <!-- Profit Centers Tab -->
    <div id="tab-profit-centers" class="hidden">
      <!-- View toggle -->
      <div class="flex items-center justify-end mb-2">
        <div class="flex rounded-md border border-gray-300 overflow-hidden text-xs">
          <button id="pc-view-tabular" class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium" onclick="switchPCView('tabular')">Tabular</button>
          <button id="pc-view-hierarchy" class="px-3 py-1.5 text-gray-600 hover:bg-gray-50" onclick="switchPCView('hierarchy')">Hierarchical</button>
        </div>
      </div>
      <!-- Hierarchy picker (applies to BOTH views) -->
      <div class="flex items-center justify-end mb-2 gap-2 text-xs">
        <label for="pc-hier-picker" class="text-gray-500">Hierarchy:</label>
        <select id="pc-hier-picker" class="input text-xs w-64">
          <option value="">(none — flat list)</option>
        </select>
      </div>
      <!-- Tabular wrap -->
      <div id="pc-tabular-wrap">
      <!-- Legacy Section -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold">Legacy Profit Centers</h3>
          <div class="flex items-center gap-2">
            <input id="search-pc" type="text" placeholder="Search..." class="input text-sm w-48" />
            <select id="filter-pc-ccode" class="input text-sm w-32"><option value="">All Entities</option></select>
            <button onclick="downloadTableCSV('pc-table','legacy_profit_centers.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
            <button id="delete-all-pc" class="btn-danger text-xs">Delete All</button>
          </div>
        </div>
        <div id="pc-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 620px)">Loading...</div>
        <div id="pc-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      <!-- Target Section -->
      <div class="border-t border-gray-200 pt-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold">Target Profit Centers <span class="text-xs font-normal text-amplifi-600">(ampliFi)</span></h3>
          <div class="flex items-center gap-2">
            <input id="search-tpc" type="text" placeholder="Search..." class="input text-sm w-48" />
            <button onclick="downloadTableCSV('tpc-table','target_profit_centers.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
            <button id="delete-all-tpc" class="btn-danger text-xs">Delete All</button>
          </div>
        </div>
        <div id="tpc-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 620px)">Loading...</div>
        <div id="tpc-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      </div><!-- /pc-tabular-wrap -->
      <!-- Hierarchical -->
      <div id="pc-hier-wrap" class="hidden">
        <p class="text-xs text-gray-500 mb-2">Grouped by the hierarchy you pick above. Click rows to expand.</p>
        <div id="pc-hier" class="text-sm text-gray-700 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Loading...</div>
      </div>
    </div>

    <!-- GL Accounts Tab -->
    <div id="tab-gl-accounts" class="hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold">GL Accounts <span class="text-xs font-normal text-gray-500">(SKA1 chart-of-accounts)</span></h3>
        <div class="flex items-center gap-2">
          <div class="flex rounded-md border border-gray-300 overflow-hidden text-xs">
            <button id="gl-view-tabular" class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium" onclick="switchGLView('tabular')">Tabular</button>
            <button id="gl-view-hierarchy" class="px-3 py-1.5 text-gray-600 hover:bg-gray-50" onclick="switchGLView('hierarchy')">Hierarchical</button>
          </div>
          <input id="search-gl" type="text" placeholder="Search saknr / text..." class="input text-sm w-48" />
          <button onclick="downloadTableCSV('gl-table','gl_accounts.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
        </div>
      </div>
      <!-- Tabular -->
      <div id="gl-tabular-wrap">
        <div id="gl-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 480px)">Loading...</div>
        <div id="gl-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      <!-- Hierarchical -->
      <div id="gl-hier-wrap" class="hidden">
        <p class="text-xs text-gray-500 mb-2">Grouped by <span class="font-medium">first digit (Account class) &rarr; first 5 digits (Group) &rarr; full saknr</span>. Click rows to expand.</p>
        <div id="gl-hier" class="text-sm text-gray-700 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Loading...</div>
      </div>
    </div>

    <!-- Mapping Tab -->
    <div id="tab-mapping" class="hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold">Center Mapping <span class="text-xs font-normal text-gray-500">(Legacy → Target)</span></h3>
        <div class="flex items-center gap-2">
          <input id="search-mapping" type="text" placeholder="Search centers..." class="input text-sm w-48" />
          <select id="filter-mapping-type" class="input text-sm w-36">
            <option value="">All Types</option>
            <option value="cost_center">Cost Centers</option>
            <option value="profit_center">Profit Centers</option>
          </select>
          <!-- PR #89 — A13: keep auto-derive available even after the
               table has rows, so operators can refresh mappings after
               a new analysis run completes. -->
          <button onclick="autoDeriveMappings()" class="btn-secondary text-xs whitespace-nowrap" title="Re-derive mappings from completed analysis runs (idempotent)">Auto-derive</button>
          <button onclick="downloadTableCSV('mapping-table','center_mapping.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
          <button id="delete-all-mapping" class="btn-danger text-xs">Delete All</button>
        </div>
      </div>
      <div id="mapping-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 480px)">Loading...</div>
      <div id="mapping-pager" class="flex items-center justify-between mt-3 text-sm"></div>
    </div>

    <!-- Balances Tab -->
    <div id="tab-balances" class="hidden">
      <!-- PR #89 — Hierarchical view added (A14). The Balances tab now
           has the same Tabular/Hierarchical toggle as Entities/CC/PC.
           In hierarchical mode the table is replaced by a tree where
           each cost center sits under its hierarchy path and shows
           aggregated TC_AMT + posting count for the selected fiscal
           year. The aggregation is server-side (one GROUP BY per
           request via /legacy/balances/by-hierarchy) so we can render
           millions of underlying balance rows without shipping them
           all to the browser. -->
      <div class="flex items-center justify-between mb-2 gap-3 flex-wrap">
        <h3 class="text-base font-semibold flex-shrink-0">Balances</h3>
        <div class="flex items-center gap-2 flex-wrap ml-auto">
          <button onclick="downloadTableCSV('bal-table','balances.csv')" class="btn-secondary text-xs flex-shrink-0" title="Download as CSV">CSV</button>
          <button id="delete-all-bal" class="btn-danger text-xs flex-shrink-0">Delete All</button>
        </div>
      </div>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <div class="inline-flex rounded-md border border-gray-300 text-xs">
          <button id="bal-view-tabular" class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium whitespace-nowrap" onclick="switchBalView('tabular')">Tabular</button>
          <button id="bal-view-hierarchy" class="px-3 py-1.5 text-gray-600 hover:bg-gray-50 whitespace-nowrap border-l border-gray-300" onclick="switchBalView('hierarchy')">Hierarchical</button>
        </div>
        <input id="filter-bal-cctr" type="text" placeholder="Cost Center..." class="input text-sm w-32" />
        <input id="filter-bal-year" type="number" placeholder="Year..." class="input text-sm w-24" />
        <!-- Hierarchy picker (used by hierarchical mode only) -->
        <select id="bal-hier-picker" class="input text-xs w-64 hidden">
          <option value="">(pick a hierarchy)</option>
        </select>
      </div>
      <!-- Tabular wrap (existing) -->
      <div id="bal-table-wrap">
        <div id="bal-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 480px)">Loading...</div>
        <div id="bal-pager" class="flex items-center justify-between mt-3 text-sm"></div>
      </div>
      <!-- Hierarchical wrap (PR #89) -->
      <div id="bal-hier-wrap" class="hidden">
        <div id="bal-hier" class="text-sm text-gray-700 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Pick a hierarchy above to load aggregated balances.</div>
      </div>
    </div>

    <!-- Hierarchies Tab -->
    <div id="tab-hierarchies" class="hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold">Hierarchies</h3>
        <div class="flex items-center gap-2">
          <div class="flex rounded-md border border-gray-300 overflow-hidden text-xs">
            <button id="hier-view-list" class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium" onclick="switchHierView('list')">List</button>
            <button id="hier-view-tree" class="px-3 py-1.5 text-gray-600 hover:bg-gray-50" onclick="switchHierView('tree')">Tree View</button>
          </div>
          <button id="delete-all-hier" class="btn-danger text-xs">Delete All</button>
        </div>
      </div>
      <!-- List view -->
      <div id="hier-list-view">
        <div id="hier-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Loading...</div>
      </div>
      <!-- Tree view -->
      <div id="hier-tree-view" class="hidden">
        <div class="flex items-center gap-3 mb-3">
          <select id="hier-tree-select" class="input text-sm w-64">
            <option value="">Select a hierarchy...</option>
          </select>
          <button id="expand-all-btn" class="btn-secondary text-xs" onclick="toggleAllNodes(true)">Expand All</button>
          <button id="collapse-all-btn" class="btn-secondary text-xs" onclick="toggleAllNodes(false)">Collapse All</button>
          <input id="hier-tree-search" type="text" placeholder="Search nodes/centers..." class="input text-sm w-48" />
        </div>
        <div id="hier-tree-container" class="text-sm text-gray-600 font-mono overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 540px)">Select a hierarchy to view its tree structure.</div>
      </div>
    </div>

    <!-- Employees Tab -->
    <div id="tab-employees" class="hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold">Employees (SAP HR Master Data)</h3>
        <div class="flex items-center gap-2">
          <input id="search-emp" type="text" placeholder="Search GPN, name, email..." class="input text-sm w-56" />
          <button onclick="downloadTableCSV('emp-table','employees.csv')" class="btn-secondary text-xs" title="Download as CSV">CSV</button>
          <button id="delete-all-emp" class="btn-danger text-xs">Delete All</button>
        </div>
      </div>
      <p class="text-xs text-gray-500 mb-3">Employee data is used to resolve cost center owners. Owner format: <strong>GPN Name</strong> (e.g. "12345 John Smith"). Upload via the Upload tab or extract from SAP.</p>
      <div id="emp-table" class="text-sm text-gray-500 overflow-x-auto overflow-y-auto" style="max-height:calc(100vh - 500px)">Loading...</div>
      <div id="emp-pager" class="flex items-center justify-between mt-3 text-sm"></div>
    </div>

    <!-- Upload Tab -->
    <div id="tab-upload" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Option A: File Upload -->
        <div>
          <h3 class="text-base font-semibold mb-1">Option A: Upload from File</h3>
          <p class="text-xs text-gray-500 mb-4">Upload CSV or Excel files. After upload, validate and then load into the database.</p>
          <form id="upload-form" class="space-y-4">
            <!-- Step 1: Scope -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">1. Scope</label>
              <select id="upload-scope" class="input">
                <option value="">— Select scope —</option>
                <option value="cleanup">Center Management — Cleanup</option>
                <option value="housekeeping">Center Management — Housekeeping</option>
                <option value="explorer">Data Explorer</option>
              </select>
            </div>
            <!-- Step 2: Category -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">2. Data Category</label>
              <select id="upload-category" class="input" disabled>
                <option value="">— Select scope first —</option>
              </select>
            </div>
            <!-- Step 3: Object Type -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">3. Data Type</label>
              <select id="upload-type" class="input" disabled>
                <option value="">— Select category first —</option>
              </select>
            </div>
            <!-- CC with Hierarchy options (shown only for cc_with_hierarchy) -->
            <div id="cc-hier-options" class="hidden p-3 bg-amber-50 border border-amber-200 rounded space-y-3">
              <p class="text-xs font-medium text-amber-800">Excel Upload Options</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs text-gray-600 mb-1">Sheet Name</label>
                  <input type="text" id="cc-hier-sheet" value="Database" class="input text-sm" placeholder="Database" />
                </div>
                <div>
                  <label class="block text-xs text-gray-600 mb-1">Header Row</label>
                  <input type="number" id="cc-hier-header-row" value="2" min="1" max="100" class="input text-sm" />
                </div>
              </div>
              <div class="space-y-1">
                <p class="text-xs text-gray-600 font-medium">What to import:</p>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-cc" checked class="rounded border-gray-300" />
                  <span>Cost Center data</span>
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-ext" checked class="rounded border-gray-300" />
                  <span>External Hierarchy</span>
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-cema" checked class="rounded border-gray-300" />
                  <span>CEMA Hierarchy</span>
                </label>
              </div>
            </div>
            <div class="p-3 bg-blue-50 border border-blue-200 rounded text-xs text-blue-700">
              <span class="font-medium">Template:</span>
              <button type="button" id="download-template-btn" class="ml-1 underline hover:text-blue-900">Download CSV template for selected type</button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">File</label>
              <input type="file" id="upload-file" accept=".csv,.xlsx,.xls,.tsv" class="input" required />
            </div>
            <div class="flex gap-3 items-center">
              <button type="submit" id="upload-btn" class="btn-amplifi">Upload</button>
              <div id="upload-progress" class="hidden flex-1 flex items-center gap-2">
                <div class="flex-1 bg-gray-200 rounded-full h-4 overflow-hidden">
                  <div id="upload-progress-bar" class="bg-amplifi-500 h-4 rounded-full transition-all duration-200" style="width:0%"></div>
                </div>
                <span id="upload-progress-text" class="text-xs text-gray-600 whitespace-nowrap">0%</span>
              </div>
            </div>
            <div id="upload-result" class="text-sm hidden"></div>
          </form>
        </div>

        <!-- Option B: Source from SAP -->
        <div>
          <h3 class="text-base font-semibold mb-1">Option B: Source from SAP</h3>
          <p class="text-xs text-gray-500 mb-4">Extract data directly from a connected SAP system using pre-configured bindings. Set up connections and bindings under <a href="/admin/sap" class="text-blue-600 underline">Admin &rarr; SAP Connections</a>.</p>
          <div id="sap-extract-area" class="space-y-3">
            <div id="sap-connections-list" class="text-sm text-gray-500">Loading connections...</div>
            <div id="sap-extract-result" class="text-sm hidden"></div>
          </div>
          <div id="sap-no-connections" class="hidden p-4 bg-gray-50 rounded-lg text-center">
            <p class="text-sm text-gray-500">No SAP connections configured yet.</p>
            <a href="/admin/sap" class="text-blue-600 text-sm underline mt-1 inline-block">Configure SAP Connections &rarr;</a>
          </div>
        </div>
      </div>

      <!-- Upload History with Actions -->
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="text-base font-semibold mb-3">Upload History</h3>
        <div id="upload-history" class="text-sm text-gray-500">Loading...</div>
      </div>
    </div>

    <!-- Sample Data Tab -->
    <div id="tab-sample-data" class="hidden">
      <h3 class="text-base font-semibold mb-3">Sample Data Management</h3>
      <p class="text-xs text-gray-500 mb-4">Generate or delete sample data for testing.</p>
      <div id="sample-status" class="mb-4 p-3 bg-gray-50 rounded text-sm text-gray-600">Loading status...</div>
      <div class="flex gap-3">
        <button id="gen-sample-btn" class="btn-success">Generate Sample Data</button>
        <button id="del-sample-btn" class="btn-danger">Delete Sample Data</button>
      </div>
      <div id="sample-result" class="text-sm mt-3 hidden"></div>
    </div>
  </div>
</Layout>

<style>
  /* Sticky table headers inside scrollable containers */
  #db-content thead th,
  #db-hier-detail thead th,
  #entities-table thead th,
  #cc-table thead th,
  #pc-table thead th,
  #bal-table thead th,
  #hier-table thead th,
  #emp-table thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #f9fafb;
  }
</style>

<script is:inline>
(function() {
  var token = localStorage.getItem('amplifi_token');
  var authHdr = token ? { 'Authorization': 'Bearer ' + token } : {};
  var jsonHdr = token ? { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } : {};

  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }
  function escAttr(s) { return esc(s).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
  function fmt(n) { return (n || 0).toLocaleString(); }

  // CSV download of current visible table
  window.downloadTableCSV = function(tableId, filename) {
    var table = document.getElementById(tableId);
    if (!table) return;
    var tbl = table.querySelector('table');
    if (!tbl) { alert('No data to download.'); return; }
    var csv = [];
    tbl.querySelectorAll('tr').forEach(function(row) {
      var cells = [];
      row.querySelectorAll('th,td').forEach(function(cell) {
        var v = cell.textContent.replace(/"/g, '""').replace(/ [▲▼]$/, '');
        cells.push('"' + v + '"');
      });
      csv.push(cells.join(','));
    });
    var blob = new Blob([csv.join('\n')], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a'); a.href = url; a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };

  // Client-side column sorting for loaded page data
  function sortTable(tableEl) {
    var thead = tableEl.querySelector('thead');
    if (!thead) return;
    thead.querySelectorAll('th').forEach(function(th, colIdx) {
      th.style.cursor = 'pointer';
      th.title = 'Click to sort';
      th.addEventListener('click', function() {
        var tbody = tableEl.querySelector('tbody');
        if (!tbody) return;
        var rows = Array.from(tbody.querySelectorAll('tr'));
        var asc = th.dataset.sort !== 'asc';
        thead.querySelectorAll('th').forEach(function(h) { delete h.dataset.sort; h.textContent = h.textContent.replace(/ [▲▼]$/, ''); });
        th.dataset.sort = asc ? 'asc' : 'desc';
        th.textContent += asc ? ' ▲' : ' ▼';
        rows.sort(function(a, b) {
          var ac = (a.cells[colIdx] || {}).textContent || '';
          var bc = (b.cells[colIdx] || {}).textContent || '';
          var an = parseFloat(ac.replace(/,/g, '')), bn = parseFloat(bc.replace(/,/g, ''));
          if (!isNaN(an) && !isNaN(bn)) return asc ? an - bn : bn - an;
          return asc ? ac.localeCompare(bc) : bc.localeCompare(ac);
        });
        rows.forEach(function(r) { tbody.appendChild(r); });
      });
    });
  }
  // Apply sorting after each table render
  var sortObserver = new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
      var t = m.target.querySelector('table');
      if (t) sortTable(t);
    });
  });
  ['entities-table','cc-table','pc-table','tcc-table','tpc-table','mapping-table','bal-table','hier-table','emp-table'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) sortObserver.observe(el, { childList: true });
  });

  var allTabs = ['data-browser','entities','cost-centers','profit-centers','gl-accounts','mapping','balances','hierarchies','employees','upload','sample-data'];

  // Tab switching
  document.querySelectorAll('#data-tabs button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      document.querySelectorAll('#data-tabs button').forEach(function(b) { b.className = 'tab px-4 py-3 whitespace-nowrap'; });
      this.className = 'tab-active px-4 py-3 whitespace-nowrap';
      allTabs.forEach(function(t) {
        var el = document.getElementById('tab-' + t);
        if (el) el.classList.toggle('hidden', t !== tab);
      });
    });
  });

  // Refresh all browse tabs + counts after data changes
  function refreshAllData() {
    loadCounts();
    if (typeof loadCC === 'function') loadCC(1);
    if (typeof loadPC === 'function') loadPC(1);
    if (typeof loadGL === 'function') loadGL(1);
    if (typeof loadTargetCC === 'function') loadTargetCC(1);
    if (typeof loadTargetPC === 'function') loadTargetPC(1);
    if (typeof loadMapping === 'function') loadMapping(1);
    if (typeof loadEntities === 'function') loadEntities(1);
    if (typeof loadBalances === 'function') loadBalances(1);
    if (typeof loadHierarchies === 'function') loadHierarchies();
    if (typeof loadEmployees === 'function') loadEmployees(1);
    if (typeof loadDataBrowser === 'function') loadDataBrowser();
  }

  // Scope/category selectors
  var scopeSel = document.getElementById('scope-selector');
  var catSel = document.getElementById('category-selector');
  function getScope() { return scopeSel.value; }
  function getCategory() { return catSel.value; }
  function scopeParams() {
    var p = '&scope=' + encodeURIComponent(getScope());
    if (getCategory()) p += '&data_category=' + encodeURIComponent(getCategory());
    return p;
  }
  scopeSel.addEventListener('change', function() { refreshAllData(); });
  catSel.addEventListener('change', function() { refreshAllData(); });

  // Load data counts with scope filtering
  function loadCounts() {
    var params = '?scope=' + encodeURIComponent(getScope());
    if (getCategory()) params += '&data_category=' + encodeURIComponent(getCategory());
    fetch('/api/data/counts' + params, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      document.getElementById('cnt-entities').textContent = fmt(d.entities);
      document.getElementById('cnt-cc').textContent = fmt(d.cost_centers);
      document.getElementById('cnt-pc').textContent = fmt(d.profit_centers);
      document.getElementById('cnt-gl').textContent = fmt(d.gl_accounts || 0);
      document.getElementById('cnt-balances').textContent = fmt(d.balances);
      document.getElementById('cnt-hierarchies').textContent = fmt(d.hierarchies);
      document.getElementById('cnt-employees').textContent = fmt(d.employees || 0);
      document.getElementById('cnt-uploads').textContent = fmt(d.upload_batches);
    }).catch(function() {});
  }
  loadCounts();

  // Upload rules from backend
  var uploadRules = {};
  fetch('/api/admin/upload-rules', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
    uploadRules = d.rules || {};
  }).catch(function() {});

  // Object display names
  var objLabels = {
    cost_center: 'Cost Centers', cc_with_hierarchy: 'Cost Centers with Hierarchy (Excel)',
    profit_center: 'Profit Centers',
    gl_account_ska1: 'GL Accounts (SKA1)', gl_account_skb1: 'GL Accounts (SKB1)',
    entity: 'Entities',
    hierarchy: 'Hierarchies (SET format)', hierarchy_flat: 'Hierarchies (SAP flat export)', entity_hierarchy: 'Entity Hierarchy (GCRS)',
    balance: 'Balances', balance_gcr: 'Balances (GCR aggregated)',
    employee: 'Employees'
  };

  // 3-step upload cascading
  var uploadScopeSel = document.getElementById('upload-scope');
  var uploadCatSel = document.getElementById('upload-category');
  var uploadTypeSel = document.getElementById('upload-type');

  uploadScopeSel.addEventListener('change', function() {
    var scope = this.value;
    uploadCatSel.innerHTML = '<option value="">— Select category —</option>';
    uploadTypeSel.innerHTML = '<option value="">— Select category first —</option>';
    uploadCatSel.disabled = true;
    uploadTypeSel.disabled = true;
    if (!scope || !uploadRules[scope]) return;
    var cats = Object.keys(uploadRules[scope]);
    cats.forEach(function(cat) {
      var opt = document.createElement('option');
      opt.value = cat;
      opt.textContent = cat.charAt(0).toUpperCase() + cat.slice(1);
      uploadCatSel.appendChild(opt);
    });
    uploadCatSel.disabled = false;
  });

  uploadCatSel.addEventListener('change', function() {
    var scope = uploadScopeSel.value;
    var cat = this.value;
    uploadTypeSel.innerHTML = '<option value="">— Select data type —</option>';
    uploadTypeSel.disabled = true;
    if (!scope || !cat || !uploadRules[scope] || !uploadRules[scope][cat]) return;
    uploadRules[scope][cat].forEach(function(obj) {
      var opt = document.createElement('option');
      opt.value = obj;
      opt.textContent = objLabels[obj] || obj;
      uploadTypeSel.appendChild(opt);
    });
    uploadTypeSel.disabled = false;
  });

  uploadTypeSel.addEventListener('change', function() {
    var ccHierOpts = document.getElementById('cc-hier-options');
    if (this.value === 'cc_with_hierarchy') {
      ccHierOpts.classList.remove('hidden');
    } else {
      ccHierOpts.classList.add('hidden');
    }
  });

  function pagerHtml(total, page, size, loadFn) {
    var pages = Math.ceil(total / size) || 1;
    var html = '<span class="text-gray-500">' + fmt(total) + ' total, page ' + page + '/' + pages + '</span><div class="flex gap-1">';
    if (page > 1) html += '<button onclick="' + loadFn + '(' + (page-1) + ')" class="btn-sm">Prev</button>';
    if (page < pages) html += '<button onclick="' + loadFn + '(' + (page+1) + ')" class="btn-sm">Next</button>';
    return html + '</div>';
  }

  // --- Entities ---
  window.loadEntities = function(page) {
    page = page || 1;
    var search = document.getElementById('search-entities').value;
    // Larger page size so hierarchy view sees the full set; tabular still paginates the rendered table
    var url = '/api/entities?page=' + page + '&size=500' + scopeParams();
    if (search) url += '&search=' + encodeURIComponent(search);
    fetch(url, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      window._entityData = d.items || [];
      var el = document.getElementById('entities-table');
      if (!d.items || !d.items.length) { el.textContent = 'No entities found.'; return; }
      var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
        '<th class="py-2 px-2 text-left">Code</th><th class="py-2 px-2 text-left">Name</th>' +
        '<th class="py-2 px-2 text-left">Country</th><th class="py-2 px-2 text-left">Region</th>' +
        '<th class="py-2 px-2 text-left">Currency</th><th class="py-2 px-2 text-center">Active</th></tr></thead><tbody>';
      d.items.forEach(function(e) {
        html += '<tr class="border-b hover:bg-gray-50">' +
          '<td class="py-1.5 px-2 font-mono font-medium">' + esc(e.ccode) + '</td>' +
          '<td class="py-1.5 px-2">' + esc(e.name) + '</td>' +
          '<td class="py-1.5 px-2">' + esc(e.country) + '</td>' +
          '<td class="py-1.5 px-2">' + esc(e.region) + '</td>' +
          '<td class="py-1.5 px-2">' + esc(e.currency) + '</td>' +
          '<td class="py-1.5 px-2 text-center">' + (e.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td></tr>';
      });
      el.innerHTML = html + '</tbody></table>';
      document.getElementById('entities-pager').innerHTML = pagerHtml(d.total, d.page, d.size, 'loadEntities');
      // If hierarchy view is active, re-render with fresh data
      var hierWrap = document.getElementById('entities-hier-wrap');
      if (hierWrap && !hierWrap.classList.contains('hidden') && typeof _renderEntityHierarchy === 'function') {
        _renderEntityHierarchy();
      }
    }).catch(function(e) { document.getElementById('entities-table').textContent = 'Error: ' + e.message; });
  };
  loadEntities(1);
  document.getElementById('search-entities').addEventListener('input', function() { clearTimeout(this._t); this._t = setTimeout(function() { loadEntities(1); }, 300); });

  // Normalise setclass aliases (ENT→0106, CC→0101, PC→0104)
  var _SC_MAP = { CC: '0101', PC: '0104', ENT: '0106', ENTITY: '0106' };
  function _normSc(raw) {
    if (!raw) return '';
    var u = String(raw).trim().toUpperCase();
    return _SC_MAP[u] || u;
  }

  // --- Cost Centers ---
  // Sortable table helper
  var _tableSort = {};
  window.sortTable = function(tableId, col, renderFn) {
    var s = _tableSort[tableId] || { col: col, dir: 'asc' };
    if (s.col === col) { s.dir = s.dir === 'asc' ? 'desc' : 'asc'; } else { s.col = col; s.dir = 'asc'; }
    _tableSort[tableId] = s;
    renderFn();
  };
  function sortTableData(tableId, data) {
    var s = _tableSort[tableId];
    if (!s) return data;
    return data.slice().sort(function(a, b) {
      var va = a[s.col], vb = b[s.col];
      if (va == null) va = ''; if (vb == null) vb = '';
      if (typeof va === 'string') va = va.toLowerCase();
      if (typeof vb === 'string') vb = vb.toLowerCase();
      return (va < vb ? -1 : va > vb ? 1 : 0) * (s.dir === 'asc' ? 1 : -1);
    });
  }
  function sortIcon(tableId, col) {
    var s = _tableSort[tableId];
    if (!s || s.col !== col) return ' <span class="text-gray-300 text-[10px]">↕</span>';
    return s.dir === 'asc' ? ' ↑' : ' ↓';
  }
  function sortTh(tableId, col, label, renderFn) {
    return '<th class="py-2 px-2 text-left cursor-pointer select-none whitespace-nowrap hover:bg-gray-100" onclick="sortTable(\'' +
      tableId + '\',\'' + col + '\',' + renderFn + ')">' + label + sortIcon(tableId, col) + '</th>';
  }

  var _ccData = [];
  // Track the picked hierarchy id and max_depth from the last fetch.
  // null = no hierarchy picked → render flat (no L* columns, no tree).
  var _ccHierId = null;
  var _ccHierMaxDepth = 0;
  window.loadCC = function(page) {
    page = page || 1;
    var search = document.getElementById('search-cc').value;
    var ccode = document.getElementById('filter-cc-ccode').value;
    var url = '/api/legacy/cost-centers?page=' + page + '&size=500' + scopeParams();
    if (search) url += '&search=' + encodeURIComponent(search);
    if (ccode) url += '&ccode=' + encodeURIComponent(ccode);
    if (_ccHierId) url += '&hierarchy_id=' + _ccHierId;
    fetch(url, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      _ccData = d.items || [];
      _ccHierMaxDepth = d.hierarchy_max_depth || 0;
      window._ccData = _ccData;
      window._ccHierMaxDepth = _ccHierMaxDepth;
      _renderCCTable();
      document.getElementById('cc-pager').innerHTML = pagerHtml(d.total, d.page, d.size, 'loadCC');
      var ccHierWrap = document.getElementById('cc-hier-wrap');
      if (ccHierWrap && !ccHierWrap.classList.contains('hidden') && typeof _renderCCHierarchy === 'function') {
        _renderCCHierarchy();
      }
    }).catch(function(e) { document.getElementById('cc-table').textContent = 'Error: ' + e.message; });
  };
  window._renderCCTable = function() {
    var el = document.getElementById('cc-table');
    if (!_ccData.length) { el.textContent = 'No cost centers found.'; return; }
    var items = sortTableData('cc', _ccData);
    var lvlCols = '';
    for (var i = 0; i < _ccHierMaxDepth; i++) {
      lvlCols += '<th class="py-1.5 px-2 text-left font-medium bg-amplifi-50">L' + i + '</th>';
    }
    var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
      lvlCols +
      sortTh('cc','cctr','CC','_renderCCTable') +
      sortTh('cc','txtsh','Short Text','_renderCCTable') +
      sortTh('cc','txtmi','Medium Text','_renderCCTable') +
      sortTh('cc','ccode','Entity','_renderCCTable') +
      sortTh('cc','coarea','CO Area','_renderCCTable') +
      sortTh('cc','cctrcgy','Category','_renderCCTable') +
      sortTh('cc','responsible','Responsible','_renderCCTable') +
      sortTh('cc','pctr','PC','_renderCCTable') +
      sortTh('cc','is_active','Active','_renderCCTable') +
      '</tr></thead><tbody>';
    items.forEach(function(c) {
      var lvlCells = '';
      var levels = c.levels || [];
      for (var j = 0; j < _ccHierMaxDepth; j++) {
        var v = levels[j] || '';
        // Empty cell text-muted so users can spot CCs that aren't in the
        // selected hierarchy (or end at a higher level than the deepest).
        lvlCells += '<td class="py-1.5 px-2 font-mono text-amplifi-700">' + esc(v) + '</td>';
      }
      html += '<tr class="border-b hover:bg-gray-50">' +
        lvlCells +
        '<td class="py-1.5 px-2 font-mono font-medium">' + esc(c.cctr) + '</td>' +
        '<td class="py-1.5 px-2">' + esc(c.txtsh) + '</td>' +
        '<td class="py-1.5 px-2 max-w-xs truncate">' + esc(c.txtmi) + '</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(c.ccode) + '</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(c.coarea) + '</td>' +
        '<td class="py-1.5 px-2">' + esc(c.cctrcgy) + '</td>' +
        '<td class="py-1.5 px-2">' + esc(c.responsible) + '</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(c.pctr) + '</td>' +
        '<td class="py-1.5 px-2 text-center">' + (c.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td></tr>';
    });
    el.innerHTML = html + '</tbody></table>';
  };
  loadCC(1);
