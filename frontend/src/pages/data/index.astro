  // --- Generic hierarchy rendering helper ---
  // Buckets items by an array of key-extractor fns. Renders an expandable tree.
  // levelDefs: [{ keyFn, labelFn, sublabelFn? }, ...]; last level renders leaves via leafRenderer(item).
  // containerId: the DOM element id to render into.
  function renderHierTree(containerId, items, levelDefs, leafRenderer, emptyMsg) {
    var el = document.getElementById(containerId);
    if (!el) return;
    if (!items || !items.length) {
      el.textContent = emptyMsg || 'No data.';
      return;
    }
    // Build nested map
    function bucketize(arr, depth) {
      if (depth >= levelDefs.length) return arr;
      var def = levelDefs[depth];
      var groups = {};
      var order = [];
      arr.forEach(function(it) {
        var k = def.keyFn(it);
        if (k == null || k === '') k = '(blank)';
        if (!(k in groups)) { groups[k] = []; order.push(k); }
        groups[k].push(it);
      });
      order.sort();
      var nested = {};
      order.forEach(function(k) { nested[k] = bucketize(groups[k], depth + 1); });
      return { __order: order, __children: nested };
    }
    var tree = bucketize(items, 0);

    // Stable id helper for collapsibles
    var nodeIdSeq = 0;
    function nextId() { return containerId + '-n' + (++nodeIdSeq); }

    function countDescLeaves(subtree, depth) {
      if (depth >= levelDefs.length) return subtree.length;
      var sum = 0;
      subtree.__order.forEach(function(k) {
        sum += countDescLeaves(subtree.__children[k], depth + 1);
      });
      return sum;
    }

    function renderNode(subtree, depth) {
      if (depth >= levelDefs.length) {
        // Leaves
        var rows = subtree.map(leafRenderer).join('');
        return '<div class="ml-6 mt-1 mb-2"><table class="w-full text-xs border border-gray-200 rounded">' + rows + '</table></div>';
      }
      var def = levelDefs[depth];
      var html = '';
      subtree.__order.forEach(function(k) {
        var child = subtree.__children[k];
        var nid = nextId();
        var leafCount = countDescLeaves(child, depth + 1);
        // Resolve label/sublabel using the first item in this bucket so labelFn can read whole-item fields
        var firstItem = (function dive(s, d) {
          if (d >= levelDefs.length) return s[0];
          return dive(s.__children[s.__order[0]], d + 1);
        })(child, depth + 1);
        var label = def.labelFn ? def.labelFn(k, firstItem) : k;
        var sub = def.sublabelFn ? def.sublabelFn(k, firstItem) : '';
        // Indent via inline style instead of `ml-N` Tailwind classes.
        // PR #91 — operator screenshot showed sub-nodes flush against
        // their parents because Tailwind's JIT compiler only emits
        // utilities it sees as literal strings in source; the dynamic
        // ``'ml-' + Math.min(depth*4, 12)`` template never produced
        // ``ml-4``/``ml-8``/``ml-12`` literals so those classes weren't
        // in the bundle. Inline styles work regardless.
        var indentPx = depth === 0 ? 0 : Math.min(depth * 16, 96);
        html += '<div style="margin-left:' + indentPx + 'px" class="my-1">' +
          '<button type="button" class="w-full text-left flex items-center gap-2 hover:bg-gray-50 px-2 py-1 rounded" ' +
                 'onclick="(function(b){var t=document.getElementById(\'' + nid + '\');if(!t)return;var open=t.classList.toggle(\'hidden\');b.querySelector(\'.hier-caret\').textContent=open?\'\\u25B6\':\'\\u25BC\';})(this)">' +
            '<span class="hier-caret text-gray-400">\u25B6</span>' +
            '<span class="font-mono font-medium text-gray-800">' + esc(label) + '</span>' +
            (sub ? '<span class="text-xs text-gray-500">' + esc(sub) + '</span>' : '') +
            '<span class="ml-auto text-[10px] text-gray-400">' + leafCount + ' record' + (leafCount === 1 ? '' : 's') + '</span>' +
          '</button>' +
          '<div id="' + nid + '" data-coll-tgt class="hidden">' + renderNode(child, depth + 1) + '</div>' +
          '</div>';
      });
      return html;
    }
    // PR #91 — operator request: collapse-all / expand-all toolbar.
    // Trees can be deep (5+ levels for UBS_GROUP_ENT) and the operator
    // wants one click to fully expand or collapse rather than walking
    // each caret manually. The buttons toggle every collapsible
    // ``<div>`` inside the container — same target the per-row caret
    // hits, just in bulk. Uses ``data-coll-tgt`` markers added by the
    // node template so we don't accidentally hit unrelated elements.
    var toolbarHtml =
      '<div class="flex items-center gap-2 mb-2 text-xs">' +
        '<button type="button" onclick="(function(c){c.querySelectorAll(\'[data-coll-tgt]\').forEach(function(t){t.classList.remove(\'hidden\');});c.querySelectorAll(\'.hier-caret\').forEach(function(c){c.textContent=\'\\u25BC\';});})(document.getElementById(\'' + containerId + '\'))" ' +
                'class="px-2 py-1 rounded border border-gray-200 text-gray-600 hover:bg-gray-50">▼ Expand all</button>' +
        '<button type="button" onclick="(function(c){c.querySelectorAll(\'[data-coll-tgt]\').forEach(function(t){t.classList.add(\'hidden\');});c.querySelectorAll(\'.hier-caret\').forEach(function(c){c.textContent=\'\\u25B6\';});})(document.getElementById(\'' + containerId + '\'))" ' +
                'class="px-2 py-1 rounded border border-gray-200 text-gray-600 hover:bg-gray-50">▶ Collapse all</button>' +
      '</div>';
    el.innerHTML = toolbarHtml + renderNode(tree, 0);
  }

  // --- GL hierarchy: char[0] -> char[0:5] -> full saknr ---
  window._renderGLHierarchy = function() {
