  // --- CC hierarchy: built from c.levels (the picked stored hierarchy) ---
  // PR #91 — picker now shows "(none — flat list)" so when no
  // hierarchy is picked we render the flat list, not a dead-end
  // message. Operator complaint: switching to Hierarchical view with
  // no picker selection used to show an empty pane.
  window._renderCCHierarchy = function() {
    var el = document.getElementById('cc-hier');
    if (!_ccData.length) {
      el.innerHTML = '<p class="text-gray-500 text-sm">No cost centers loaded.</p>';
      return;
    }
    if (!_ccHierId) {
      // Flat list — same columns as tabular view minus the L* cols.
      var rows = _ccData.map(function(c) {
        return '<tr class="border-b hover:bg-gray-50">' +
          '<td class="py-1 px-2 font-mono w-32">' + esc(c.cctr) + '</td>' +
          '<td class="py-1 px-2">' + esc(c.txtsh) + '</td>' +
          '<td class="py-1 px-2 max-w-md truncate text-gray-500">' + esc(c.txtmi) + '</td>' +
          '<td class="py-1 px-2 font-mono">' + esc(c.ccode) + '</td>' +
          '<td class="py-1 px-2 font-mono">' + esc(c.pctr) + '</td>' +
          '<td class="py-1 px-2 text-xs text-gray-500">' + esc(c.responsible || '') + '</td>' +
          '</tr>';
      }).join('');
      el.innerHTML = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
        '<th class="py-1.5 px-2 text-left font-medium">CC</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Short Text</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Medium Text</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Entity</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">PC</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Responsible</th>' +
        '</tr></thead><tbody>' + rows + '</tbody></table>';
      return;
    }
    // PR #91 — diagnose silent empty trees: if the operator picked a
    // hierarchy but every CC came back with empty levels, the smart
    // resolver didn't match (e.g. the hierarchy's leaves use a key
    // we don't have on these CCs). Surface that explicitly so the
    // operator knows it isn't broken — the data simply doesn't link.
    var anyMapped = _ccData.some(function(c) { return c.levels && c.levels.length; });
    if (!anyMapped) {
      el.innerHTML =
        '<div class="rounded border border-amber-200 bg-amber-50 p-3 text-xs text-amber-900">' +
          '<div class="font-medium mb-1">No cost centers map to this hierarchy.</div>' +
          '<div>None of the ' + _ccData.length + ' loaded cost centers appear as leaves in the picked hierarchy. ' +
          'Check that the hierarchy was loaded for the same scope/category — or pick a different hierarchy.</div>' +
        '</div>';
      return;
    }
    // Build levelDefs dynamically: one per L0..L(maxDepth-2). The leaves
    // of the picked hierarchy are the deepest L*, so the leaf renderer
    // shows the actual CC row. We use (maxDepth - 1) levels of grouping
    // because the deepest setname IS the leaf-row level.
    var levelDefs = [];
    for (var i = 0; i < _ccHierMaxDepth - 1; i++) {
      (function(idx) {
        levelDefs.push({
          keyFn: function(c) { return (c.levels && c.levels[idx]) || '(unmapped)'; },
          labelFn: function(k) { return k; },
          sublabelFn: function(_k) { return 'L' + idx; },
        });
      })(i);
    }
    renderHierTree('cc-hier', _ccData || [], levelDefs, function(c) {
      var leafSetname = (c.levels && c.levels[c.levels.length - 1]) || '';
      return '<tr class="border-b hover:bg-gray-50">' +
        '<td class="py-1 px-2 font-mono text-amplifi-700 w-40">' + esc(leafSetname) + '</td>' +
        '<td class="py-1 px-2 font-mono w-32">' + esc(c.cctr) + '</td>' +
        '<td class="py-1 px-2">' + esc(c.txtsh) + '</td>' +
        '<td class="py-1 px-2 max-w-md truncate text-gray-500">' + esc(c.txtmi) + '</td>' +
        '<td class="py-1 px-2 text-xs text-gray-500">' + esc(c.responsible || '') + '</td>' +
        '</tr>';
    }, 'No cost centers in this hierarchy.');
  };

  // --- PC hierarchy: same pattern as CC ---
  window._renderPCHierarchy = function() {
    var el = document.getElementById('pc-hier');
    if (!_pcData.length) {
      el.innerHTML = '<p class="text-gray-500 text-sm">No profit centers loaded.</p>';
      return;
    }
    if (!_pcHierId) {
      // PR #91 — flat list when no hierarchy picked.
      var rows = _pcData.map(function(p) {
        return '<tr class="border-b hover:bg-gray-50">' +
          '<td class="py-1 px-2 font-mono w-32">' + esc(p.pctr) + '</td>' +
          '<td class="py-1 px-2">' + esc(p.txtsh) + '</td>' +
          '<td class="py-1 px-2 max-w-md truncate text-gray-500">' + esc(p.txtmi) + '</td>' +
          '<td class="py-1 px-2 font-mono">' + esc(p.ccode) + '</td>' +
          '<td class="py-1 px-2 text-xs text-gray-500">' + esc(p.responsible || '') + '</td>' +
          '</tr>';
      }).join('');
      el.innerHTML = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
        '<th class="py-1.5 px-2 text-left font-medium">PC</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Short Text</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Medium Text</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Entity</th>' +
        '<th class="py-1.5 px-2 text-left font-medium">Responsible</th>' +
        '</tr></thead><tbody>' + rows + '</tbody></table>';
      return;
    }
    // PR #91 — diagnostic when picked hierarchy doesn't link to any
    // PC. Particularly likely when an Entity hierarchy is picked on
    // PCs whose ccode isn't represented, or a CC hierarchy (which
    // _resolve_paths_for_pcs deliberately returns empty for).
    var anyMapped = _pcData.some(function(p) { return p.levels && p.levels.length; });
    if (!anyMapped) {
      el.innerHTML =
        '<div class="rounded border border-amber-200 bg-amber-50 p-3 text-xs text-amber-900">' +
          '<div class="font-medium mb-1">No profit centers map to this hierarchy.</div>' +
          '<div>None of the ' + _pcData.length + ' loaded profit centers appear as leaves in the picked hierarchy. ' +
          'Profit Centers cannot be placed in Cost Center hierarchies — pick a Profit Center or Entity hierarchy instead.</div>' +
        '</div>';
      return;
    }
    var levelDefs = [];
    for (var i = 0; i < _pcHierMaxDepth - 1; i++) {
      (function(idx) {
        levelDefs.push({
          keyFn: function(p) { return (p.levels && p.levels[idx]) || '(unmapped)'; },
          labelFn: function(k) { return k; },
          sublabelFn: function(_k) { return 'L' + idx; },
        });
      })(i);
    }
    renderHierTree('pc-hier', _pcData || [], levelDefs, function(p) {
      var leafSetname = (p.levels && p.levels[p.levels.length - 1]) || '';
      return '<tr class="border-b hover:bg-gray-50">' +
        '<td class="py-1 px-2 font-mono text-amplifi-700 w-40">' + esc(leafSetname) + '</td>' +
        '<td class="py-1 px-2 font-mono w-32">' + esc(p.pctr) + '</td>' +
        '<td class="py-1 px-2">' + esc(p.txtsh) + '</td>' +
        '<td class="py-1 px-2 max-w-md truncate text-gray-500">' + esc(p.txtmi) + '</td>' +
        '<td class="py-1 px-2 text-xs text-gray-500">' + esc(p.responsible || '') + '</td>' +
        '</tr>';
    }, 'No profit centers in this hierarchy.');
  };

  // --- Entity hierarchy: country -> region -> ccode ---
  // Note: _entityData is populated by loadEntities (set on window so this fn picks it up)
  window._renderEntityHierarchy = function() {
    var data = window._entityData || [];
    renderHierTree('entities-hier', data, [
      {
        keyFn: function(e) { return e.country || '(no country)'; },
