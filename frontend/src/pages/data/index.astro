        '<td class="py-1.5 px-2 text-center text-gray-400">→</td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(m.target_coarea) + '</td>' +
        '<td class="py-1.5 px-2 font-mono font-medium text-amplifi-700">' + esc(m.target_center) + '</td>' +
