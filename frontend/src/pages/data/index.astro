      var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
        '<th class="py-2 px-2 text-left">ID</th><th class="py-2 px-2 text-left">Scope</th>' +
        '<th class="py-2 px-2 text-left">Category</th><th class="py-2 px-2 text-left">Type</th>' +
        '<th class="py-2 px-2 text-left">Source</th><th class="py-2 px-2 text-left">Status</th>' +
        '<th class="py-2 px-2 text-right">Rows</th><th class="py-2 px-2 text-right">Valid</th>' +
        '<th class="py-2 px-2 text-right">Errors</th><th class="py-2 px-2 text-right">Loaded</th>' +
        '<th class="py-2 px-2 text-left">Actions</th></tr></thead><tbody>';
      items.forEach(function(u) {
        var statusColor = u.status === 'loaded' ? 'text-green-600' : u.status === 'failed' ? 'text-red-600' : (u.status === 'validating' || u.status === 'loading') ? 'text-yellow-600' : 'text-gray-600';
        var actions = '';
        if (u.status === 'uploaded' || u.status === 'failed') {
          actions = '<button onclick="validateUpload(' + u.id + ')" class="text-blue-600 hover:underline mr-2">Validate</button>';
        } else if (u.status === 'validated') {
          actions = '<button onclick="loadUpload(' + u.id + ')" class="text-green-600 hover:underline mr-2">Load</button>';
        } else if (u.status === 'loaded') {
          actions = '<button onclick="rollbackUpload(' + u.id + ')" class="text-red-600 hover:underline mr-2">Rollback</button>';
        } else if (u.status === 'validating' || u.status === 'loading') {
          var pct = (u.rows_total > 0 && u.rows_processed != null) ? Math.round((u.rows_processed / u.rows_total) * 100) : 0;
          var progressLabel = u.status === 'validating' ? 'Validating' : 'Loading';
          actions = '<div class="inline-flex items-center gap-2">' +
            '<div class="w-28 bg-gray-200 rounded-full h-3 overflow-hidden" title="' + fmt(u.rows_processed || 0) + ' / ' + fmt(u.rows_total) + ' rows">' +
            '<div class="bg-yellow-500 h-3 rounded-full transition-all duration-300" style="width:' + pct + '%"></div></div>' +
            '<span class="text-yellow-700 text-[10px] font-medium whitespace-nowrap">' + progressLabel + ' ' + pct + '%</span>' +
            '</div> ' +
            '<button onclick="resetUpload(' + u.id + ')" class="text-orange-600 hover:underline text-xs mr-2" title="Reset stuck batch">Reset</button>';
        }
        actions += '<button onclick="deleteUpload(' + u.id + ')" class="text-red-500 hover:underline text-xs" title="Delete this upload batch">Delete</button>';
        var scopeLabel = { cleanup: 'CM Cleanup', housekeeping: 'CM Housekeeping', explorer: 'Data Explorer' };
        var sourceInfo = (u.source_method || 'file') + (u.source_detail ? ': ' + u.source_detail : '');
        html += '<tr class="border-b hover:bg-gray-50">' +
          '<td class="py-1.5 px-2">' + u.id + '</td>' +
          '<td class="py-1.5 px-2">' + esc(scopeLabel[u.scope] || u.scope || '-') + '</td>' +
          '<td class="py-1.5 px-2">' + esc(u.data_category || '-') + '</td>' +
          '<td class="py-1.5 px-2">' + esc(u.kind) + '</td>' +
          '<td class="py-1.5 px-2 text-[10px]">' + esc(sourceInfo) + '</td>' +
