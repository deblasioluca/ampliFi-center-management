---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Data Management" requireAuth={true} requiredRole="data_manager">
  <div class="flex items-center justify-between mb-2">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Data Management</h1>
      <p class="text-xs text-gray-500">Upload, browse, and manage cost centers, profit centers, balances, hierarchies, and employees</p>
    </div>
  </div>

  <!-- Scope Selector -->
  <div class="flex items-center gap-3 mb-3">
    <label class="text-sm font-medium text-gray-700">Scope:</label>
    <select id="scope-selector" class="input w-auto text-sm">
      <option value="cleanup" selected>Center Management — Cleanup</option>
      <option value="housekeeping">Center Management — Housekeeping</option>
      <option value="explorer">Data Explorer</option>
    </select>
    <label class="text-sm font-medium text-gray-700 ml-4">Category:</label>
    <select id="category-selector" class="input w-auto text-sm">
      <option value="legacy" selected>Legacy</option>
      <option value="target">Target (ampliFi)</option>
    </select>
    <button id="transfer-to-explorer-btn" class="ml-auto btn-secondary text-xs border-blue-300 text-blue-700 hover:bg-blue-50" title="Copy cleanup data to the standalone Data Explorer">
      &#8594; Publish to Explorer
    </button>
  </div>

  <!-- Data Counts -->
  <div class="grid grid-cols-4 lg:grid-cols-8 gap-3 mb-3">
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Entities</span>
      <p id="cnt-entities" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Cost Centers</span>
      <p id="cnt-cc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Profit Centers</span>
      <p id="cnt-pc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">GL Accounts</span>
      <p id="cnt-gl" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Balances</span>
      <p id="cnt-balances" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Hierarchies</span>
      <p id="cnt-hierarchies" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Employees</span>
      <p id="cnt-employees" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Uploads</span>
      <p id="cnt-uploads" class="text-lg font-bold text-gray-900">--</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white border-b border-gray-200 rounded-t-lg mb-0">
    <div class="flex space-x-0 overflow-x-auto" id="data-tabs">
      <button class="tab-active px-4 py-3 whitespace-nowrap font-semibold text-blue-700" data-tab="data-browser">Data Browser</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="entities">Entities</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="cost-centers">Cost Centers</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="profit-centers">Profit Centers</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="gl-accounts">GL Accounts</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="mapping">Mapping</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="balances">Balances</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="hierarchies">Hierarchies</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="employees">Employees</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="upload">Upload</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="sample-data">Sample Data</button>
    </div>
  </div>

  <!-- Tab Content -->
  <div class="card rounded-t-none border-t-0">
    <!-- Data Browser — rendered by DataObjectDisplay -->
    <div id="tab-data-browser">
      <div id="dod-data-browser" class="text-xs"></div>
    </div>

    <!-- Entities — rendered by DataObjectDisplay -->
    <div id="tab-entities" class="hidden">
      <div id="dod-entities" class="text-xs"></div>
    </div>

    <!-- Cost Centers — rendered by DataObjectDisplay (Legacy + Target) -->
    <div id="tab-cost-centers" class="hidden">
      <div id="dod-cc-legacy" class="text-xs mb-6"></div>
      <div class="border-t border-gray-200 pt-4">
        <div id="dod-cc-target" class="text-xs"></div>
      </div>
    </div>

    <!-- Profit Centers — rendered by DataObjectDisplay (Legacy + Target) -->
    <div id="tab-profit-centers" class="hidden">
      <div id="dod-pc-legacy" class="text-xs mb-6"></div>
      <div class="border-t border-gray-200 pt-4">
        <div id="dod-pc-target" class="text-xs"></div>
      </div>
    </div>

    <!-- GL Accounts — rendered by DataObjectDisplay -->
    <div id="tab-gl-accounts" class="hidden">
      <div id="dod-gl" class="text-xs"></div>
    </div>

    <!-- Mapping — rendered by DataObjectDisplay -->
    <div id="tab-mapping" class="hidden">
      <div id="dod-mapping" class="text-xs"></div>
    </div>

    <!-- Balances — rendered by DataObjectDisplay -->
    <div id="tab-balances" class="hidden">
      <div id="dod-balances" class="text-xs"></div>
    </div>

    <!-- Hierarchies — rendered by DataObjectDisplay -->
    <div id="tab-hierarchies" class="hidden">
      <div id="dod-hierarchies" class="text-xs"></div>
    </div>

    <!-- Employees — rendered by DataObjectDisplay -->
    <div id="tab-employees" class="hidden">
      <div id="dod-employees" class="text-xs"></div>
    </div>

    <!-- Upload Tab -->
    <div id="tab-upload" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Option A: File Upload -->
        <div>
          <h3 class="text-base font-semibold mb-1">Option A: Upload from File</h3>
          <p class="text-xs text-gray-500 mb-4">Upload CSV or Excel files. After upload, validate and then load into the database.</p>
          <form id="upload-form" class="space-y-4">
            <!-- Scope & Category (auto-filled from top selector) -->
            <div class="p-3 bg-gray-50 border border-gray-200 rounded text-sm">
              <span class="text-gray-500">Uploading to:</span>
              <span id="upload-scope-label" class="font-semibold text-gray-800 ml-1"></span>
              <span class="text-gray-400 mx-1">·</span>
              <span id="upload-category-label" class="font-semibold text-gray-800"></span>
            </div>
            <!-- Data Type -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Data Type</label>
              <select id="upload-type" class="input">
                <option value="">— Select data type —</option>
              </select>
            </div>
            <!-- CC with Hierarchy options (shown only for cc_with_hierarchy) -->
            <div id="cc-hier-options" class="hidden p-3 bg-amber-50 border border-amber-200 rounded space-y-3">
              <p class="text-xs font-medium text-amber-800">Excel Upload Options</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs text-gray-600 mb-1">Sheet Name</label>
                  <input type="text" id="cc-hier-sheet" value="Database" class="input text-sm" placeholder="Database" />
                </div>
                <div>
                  <label class="block text-xs text-gray-600 mb-1">Header Row</label>
                  <input type="number" id="cc-hier-header-row" value="2" min="1" max="100" class="input text-sm" />
                </div>
              </div>
              <div class="space-y-1">
                <p class="text-xs text-gray-600 font-medium">What to import:</p>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-cc" checked class="rounded border-gray-300" />
                  <span>Cost Center data</span>
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-ext" checked class="rounded border-gray-300" />
                  <span>External Hierarchy</span>
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-cema" checked class="rounded border-gray-300" />
                  <span>CEMA Hierarchy</span>
                </label>
              </div>
            </div>
            <!-- Hierarchy display name (shown for hierarchy upload types) -->
            <div id="hier-name-options" class="hidden">
              <label class="block text-sm font-medium text-gray-700 mb-1">Hierarchy Display Name</label>
              <input type="text" id="hier-display-name" class="input text-sm" placeholder="e.g. Cost Center Hierarchy Q2 2026" />
              <p class="text-xs text-gray-400 mt-1">Optional — shown in the hierarchy picker instead of the technical name</p>
            </div>
            <div class="p-3 bg-blue-50 border border-blue-200 rounded text-xs text-blue-700">
              <span class="font-medium">Template:</span>
              <button type="button" id="download-template-btn" class="ml-1 underline hover:text-blue-900">Download CSV template for selected type</button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">File</label>
              <input type="file" id="upload-file" accept=".csv,.xlsx,.xls,.tsv" class="input" required />
            </div>
            <div class="flex gap-3 items-center">
              <button type="submit" id="upload-btn" class="btn-amplifi">Upload</button>
              <div id="upload-progress" class="hidden flex-1 flex items-center gap-2">
                <div class="flex-1 bg-gray-200 rounded-full h-4 overflow-hidden">
                  <div id="upload-progress-bar" class="bg-amplifi-500 h-4 rounded-full transition-all duration-200" style="width:0%"></div>
                </div>
                <span id="upload-progress-text" class="text-xs text-gray-600 whitespace-nowrap">0%</span>
              </div>
            </div>
            <div id="upload-result" class="text-sm hidden"></div>
          </form>
        </div>

        <!-- Option B: Source from SAP -->
        <div>
          <h3 class="text-base font-semibold mb-1">Option B: Source from SAP</h3>
          <p class="text-xs text-gray-500 mb-4">Extract data directly from a connected SAP system using pre-configured bindings. Set up connections and bindings under <a href="/admin/sap" class="text-blue-600 underline">Admin &rarr; SAP Connections</a>.</p>
          <div id="sap-extract-area" class="space-y-3">
            <div id="sap-connections-list" class="text-sm text-gray-500">Loading connections...</div>
            <div id="sap-extract-result" class="text-sm hidden"></div>
          </div>
          <div id="sap-no-connections" class="hidden p-4 bg-gray-50 rounded-lg text-center">
            <p class="text-sm text-gray-500">No SAP connections configured yet.</p>
            <a href="/admin/sap" class="text-blue-600 text-sm underline mt-1 inline-block">Configure SAP Connections &rarr;</a>
          </div>
        </div>
      </div>

      <!-- Upload History with Actions -->
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="text-base font-semibold mb-3">Upload History</h3>
        <div id="upload-history" class="text-sm text-gray-500">Loading...</div>
      </div>
    </div>

    <!-- Sample Data Tab -->
    <div id="tab-sample-data" class="hidden">
      <h3 class="text-base font-semibold mb-3">Sample Data Management</h3>
      <p class="text-xs text-gray-500 mb-4">Generate or delete sample data for testing.</p>
      <div id="sample-status" class="mb-4 p-3 bg-gray-50 rounded text-sm text-gray-600">Loading status...</div>
      <div class="flex gap-3">
        <button id="gen-sample-btn" class="btn-success">Generate Sample Data</button>
        <button id="del-sample-btn" class="btn-danger">Delete Sample Data</button>
      </div>
      <div id="sample-result" class="text-sm mt-3 hidden"></div>
    </div>
  </div>

  <!-- Upload Error Log Modal -->
  <div id="error-log-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl max-h-[80vh] flex flex-col mx-4">
      <div class="flex items-center justify-between px-5 py-3 border-b">
        <h3 class="text-lg font-semibold text-gray-900">Upload Error Log — Batch <span id="error-log-batch-id"></span></h3>
        <button onclick="document.getElementById('error-log-modal').classList.add('hidden')"
          class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
      </div>
      <div id="error-log-content" class="px-5 py-4 overflow-auto flex-1 text-sm">
        Loading...
      </div>
      <div class="px-5 py-3 border-t text-right">
        <button onclick="document.getElementById('error-log-modal').classList.add('hidden')"
          class="px-4 py-1.5 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 text-sm">Close</button>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Sticky table headers inside scrollable containers */
  .card thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #f9fafb;
  }
</style>

<script is:inline src="/data-object-display.js"></script>
<script is:inline>
(function() {
  var token = localStorage.getItem('amplifi_token');
  var authHdr = token ? { 'Authorization': 'Bearer ' + token } : {};
  var jsonHdr = token ? { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } : {};

  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }
  function escAttr(s) { return esc(s).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
  function fmt(n) { return (n || 0).toLocaleString(); }

  // CSV download of current visible table
  window.downloadTableCSV = function(tableId, filename) {
    var table = document.getElementById(tableId);
    if (!table) return;
    var tbl = table.querySelector('table');
    if (!tbl) { alert('No data to download.'); return; }
    var csv = [];
    tbl.querySelectorAll('tr').forEach(function(row) {
      var cells = [];
      row.querySelectorAll('th,td').forEach(function(cell) {
        var v = cell.textContent.replace(/"/g, '""').replace(/ [▲▼]$/, '');
        cells.push('"' + v + '"');
      });
      csv.push(cells.join(','));
    });
    var blob = new Blob([csv.join('\n')], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a'); a.href = url; a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };



  var allTabs = ['data-browser','entities','cost-centers','profit-centers','gl-accounts','mapping','balances','hierarchies','employees','upload','sample-data'];

  // Tab switching
  document.querySelectorAll('#data-tabs button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      document.querySelectorAll('#data-tabs button').forEach(function(b) { b.className = 'tab px-4 py-3 whitespace-nowrap'; });
      this.className = 'tab-active px-4 py-3 whitespace-nowrap';
      allTabs.forEach(function(t) {
        var el = document.getElementById('tab-' + t);
        if (el) el.classList.toggle('hidden', t !== tab);
      });
    });
  });

  var refreshAllData = function() { loadCounts(); };

  // Scope/category selectors
  var scopeSel = document.getElementById('scope-selector');
  var catSel = document.getElementById('category-selector');
  function getScope() { return scopeSel.value; }
  function getCategory() { return catSel.value; }
  function scopeParams() {
    var p = '&scope=' + encodeURIComponent(getScope());
    if (getCategory()) p += '&data_category=' + encodeURIComponent(getCategory());
    return p;
  }
  scopeSel.addEventListener('change', function() { refreshAllData(); });
  catSel.addEventListener('change', function() { refreshAllData(); });

  // Transfer to Explorer
  document.getElementById('transfer-to-explorer-btn').addEventListener('click', async function() {
    if (!confirm('This will replace all Explorer data with the current Cleanup data.\n\nObject types: Cost Centers, Profit Centers, Entities, Employees, Balances.\n\nContinue?')) return;
    this.disabled = true;
    this.textContent = 'Transferring...';
    try {
      var res = await fetch('/api/explore/transfer-to-explorer', { method: 'POST', headers: jsonHdr });
      if (!res.ok) { var err = await res.json().catch(function(){return {};}); throw new Error(err.detail || 'Transfer failed'); }
      var data = await res.json();
      var summary = Object.entries(data.results || {}).map(function(e) { return e[0] + ': ' + e[1].inserted + ' rows'; }).join(', ');
      alert('Transfer complete!\n\n' + summary);
    } catch(e) {
      alert('Error: ' + e.message);
    } finally {
      this.disabled = false;
      this.textContent = '\u2192 Publish to Explorer';
    }
  });

  // Load data counts with scope filtering
  function loadCounts() {
    var params = '?scope=' + encodeURIComponent(getScope());
    params += '&data_category=' + encodeURIComponent(getCategory());
    fetch('/api/data/counts' + params, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      document.getElementById('cnt-entities').textContent = fmt(d.entities);
      var cat = getCategory();
      document.getElementById('cnt-cc').textContent = fmt(cat === 'target' ? d.target_cost_centers : d.cost_centers);
      document.getElementById('cnt-pc').textContent = fmt(cat === 'target' ? d.target_profit_centers : d.profit_centers);
      document.getElementById('cnt-gl').textContent = fmt(d.gl_accounts || 0);
      document.getElementById('cnt-balances').textContent = fmt(d.balances);
      document.getElementById('cnt-hierarchies').textContent = fmt(d.hierarchies);
      document.getElementById('cnt-employees').textContent = fmt(d.employees || 0);
      document.getElementById('cnt-uploads').textContent = fmt(d.upload_batches);
    }).catch(function() {});
  }
  loadCounts();

  // Upload rules from backend
  var uploadRules = {};
  fetch('/api/admin/upload-rules', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
    uploadRules = d.rules || {};
    updateUploadContext();
  }).catch(function() {});

  // Object display names
  var objLabels = {
    cost_center: 'Cost Centers', cc_with_hierarchy: 'Cost Centers with Hierarchy (Excel)',
    profit_center: 'Profit Centers',
    gl_account_ska1: 'GL Accounts (SKA1)', gl_account_skb1: 'GL Accounts (SKB1)',
    entity: 'Entities',
    hierarchy: 'Hierarchies (SET format)', hierarchy_flat: 'Hierarchies (SAP flat export)', entity_hierarchy: 'Entity Hierarchy (GCRS)',
    balance: 'Balances', balance_gcr: 'Balances (GCR aggregated)',
    employee: 'Employees'
  };

  // Upload type dropdown — populated from top-level scope+category
  var uploadTypeSel = document.getElementById('upload-type');
  var scopeLabels = {
    cleanup: 'Center Management — Cleanup',
    housekeeping: 'Center Management — Housekeeping',
    explorer: 'Data Explorer'
  };
  var catLabels = { legacy: 'Legacy', target: 'Target (ampliFi)' };

  function updateUploadContext() {
    var scope = getScope();
    var cat = getCategory();
    document.getElementById('upload-scope-label').textContent = scopeLabels[scope] || scope;
    document.getElementById('upload-category-label').textContent = catLabels[cat] || cat;
    // Repopulate data type dropdown
    uploadTypeSel.innerHTML = '<option value="">— Select data type —</option>';
    if (uploadRules[scope] && uploadRules[scope][cat]) {
      uploadRules[scope][cat].forEach(function(obj) {
        var opt = document.createElement('option');
        opt.value = obj;
        opt.textContent = objLabels[obj] || obj;
        uploadTypeSel.appendChild(opt);
      });
    }
  }

  var _hierTypes = ['hierarchy', 'hierarchy_flat', 'entity_hierarchy', 'cc_with_hierarchy'];
  uploadTypeSel.addEventListener('change', function() {
    var ccHierOpts = document.getElementById('cc-hier-options');
    var hierNameOpts = document.getElementById('hier-name-options');
    if (this.value === 'cc_with_hierarchy') {
      ccHierOpts.classList.remove('hidden');
    } else {
      ccHierOpts.classList.add('hidden');
    }
    if (_hierTypes.indexOf(this.value) >= 0) {
      hierNameOpts.classList.remove('hidden');
    } else {
      hierNameOpts.classList.add('hidden');
      document.getElementById('hier-display-name').value = '';
    }
  });

  // ── Upload form submit handler ──────────────────────────────────────
  document.getElementById('upload-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var fileInput = document.getElementById('upload-file');
    var uScope = getScope();
    var uCat = getCategory();
    var type = document.getElementById('upload-type').value;
    var resultEl = document.getElementById('upload-result');
    var progressEl = document.getElementById('upload-progress');
    var progressBar = document.getElementById('upload-progress-bar');
    var progressText = document.getElementById('upload-progress-text');
    resultEl.classList.add('hidden');
    if (!uScope) { alert('Please select a scope.'); return; }
    if (!uCat) { alert('Please select a data category.'); return; }
    if (!type) { alert('Please select a data type.'); return; }
    if (!fileInput.files[0]) return;
    if (!token) { alert('Please log in first to upload data.'); return; }
    var kindMap = {
      cost_center: 'cost_centers', profit_center: 'profit_centers',
      gl_account_ska1: 'gl_accounts_ska1', gl_account_skb1: 'gl_accounts_skb1',
      entity: 'entities',
      hierarchy: 'hierarchies', hierarchy_flat: 'hierarchies_flat',
      entity_hierarchy: 'entity_hierarchy',
      balance: 'balances', balance_gcr: 'balances_gcr',
      employee: 'employees'
    };
    var uploadKind = kindMap[type] || type;
    if (uCat === 'target' && type === 'cost_center') uploadKind = 'target_cost_centers';
    if (uCat === 'target' && type === 'profit_center') uploadKind = 'target_profit_centers';

    var formData = new FormData();
    formData.append('file', fileInput.files[0]);
    document.getElementById('upload-btn').disabled = true;
    document.getElementById('upload-btn').textContent = 'Uploading...';
    progressEl.classList.remove('hidden');
    progressBar.style.width = '0%';
    progressText.textContent = '0%';

    var xhr = new XMLHttpRequest();
    xhr.upload.addEventListener('progress', function(ev) {
      if (ev.lengthComputable) {
        var pct = Math.round((ev.loaded / ev.total) * 100);
        progressBar.style.width = pct + '%';
        progressText.textContent = pct + '%';
      }
    });
    xhr.addEventListener('load', function() {
      progressEl.classList.add('hidden');
      document.getElementById('upload-btn').disabled = false;
      document.getElementById('upload-btn').textContent = 'Upload';
      try {
        var data = JSON.parse(xhr.responseText);
        if (xhr.status === 401 || xhr.status === 403) {
          resultEl.textContent = 'Error: Session expired — please log in again.';
          resultEl.className = 'text-sm text-red-600';
        } else if (xhr.status >= 400) {
          resultEl.textContent = 'Error: ' + (data.detail || 'Upload failed');
          resultEl.className = 'text-sm text-red-600';
        } else {
          resultEl.textContent = 'Upload successful (ID: ' + data.id + '). Use Validate then Load to import data.';
          resultEl.className = 'text-sm text-green-600';
          refreshAllData(); loadUploadHistory();
        }
      } catch(err) {
        resultEl.textContent = 'Error: Upload failed';
        resultEl.className = 'text-sm text-red-600';
      }
      resultEl.classList.remove('hidden');
    });
    xhr.addEventListener('error', function() {
      progressEl.classList.add('hidden');
      document.getElementById('upload-btn').disabled = false;
      document.getElementById('upload-btn').textContent = 'Upload';
      resultEl.textContent = 'Error: Network error during upload';
      resultEl.className = 'text-sm text-red-600';
      resultEl.classList.remove('hidden');
    });
    var uploadUrl = '/api/admin/uploads?kind=' + encodeURIComponent(uploadKind) +
      '&scope=' + encodeURIComponent(uScope) +
      '&data_category=' + encodeURIComponent(uCat);
    if (uploadKind === 'cc_with_hierarchy') {
      var sheetName = document.getElementById('cc-hier-sheet').value || 'Database';
      var headerRow = document.getElementById('cc-hier-header-row').value || '2';
      var loadCc = document.getElementById('cc-hier-load-cc').checked;
      var loadExt = document.getElementById('cc-hier-load-ext').checked;
      var loadCema = document.getElementById('cc-hier-load-cema').checked;
      uploadUrl += '&sheet_name=' + encodeURIComponent(sheetName) +
        '&header_row=' + encodeURIComponent(headerRow) +
        '&load_cc=' + loadCc + '&load_ext_hier=' + loadExt +
        '&load_cema_hier=' + loadCema;
    }
    var hierLabel = (document.getElementById('hier-display-name').value || '').trim();
    if (hierLabel && _hierTypes.indexOf(type) >= 0) {
      uploadUrl += '&hierarchy_label=' + encodeURIComponent(hierLabel);
    }
    xhr.open('POST', uploadUrl);
    xhr.setRequestHeader('Authorization', 'Bearer ' + token);
    xhr.send(formData);
  });

  // ── Upload history ──────────────────────────────────────────────────
  function loadUploadHistory() {
    var uhParams = '?size=20&scope=' + encodeURIComponent(getScope()) +
      '&data_category=' + encodeURIComponent(getCategory());
    fetch('/api/admin/uploads' + uhParams, { headers: authHdr })
      .then(function(r) { return r.json(); }).then(function(d) {
      var el = document.getElementById('upload-history');
      var items = d.items || [];
      if (!items.length) { el.textContent = 'No uploads yet.'; return; }
      var html = '<table class="w-full text-xs"><thead>' +
        '<tr class="border-b bg-gray-50">' +
        '<th class="py-2 px-2 text-left">ID</th>' +
        '<th class="py-2 px-2 text-left">Scope</th>' +
        '<th class="py-2 px-2 text-left">Category</th>' +
        '<th class="py-2 px-2 text-left">Type</th>' +
        '<th class="py-2 px-2 text-left">Source</th>' +
        '<th class="py-2 px-2 text-left">Status</th>' +
        '<th class="py-2 px-2 text-right">Rows</th>' +
        '<th class="py-2 px-2 text-right">Valid</th>' +
        '<th class="py-2 px-2 text-right">Errors</th>' +
        '<th class="py-2 px-2 text-right">Loaded</th>' +
        '<th class="py-2 px-2 text-left">Actions</th>' +
        '</tr></thead><tbody>';
      items.forEach(function(u) {
        var statusColor = u.status === 'loaded' ? 'text-green-600'
          : u.status === 'failed' ? 'text-red-600'
          : (u.status === 'validating' || u.status === 'loading')
            ? 'text-yellow-600' : 'text-gray-600';
        var actions = '';
        if (u.status === 'uploaded' || u.status === 'failed') {
          actions = '<button onclick="validateUpload(' + u.id +
            ')" class="text-blue-600 hover:underline mr-2">Validate</button>';
        } else if (u.status === 'validated') {
          actions = '<button onclick="loadUpload(' + u.id +
            ')" class="text-green-600 hover:underline mr-2">Load</button>';
        } else if (u.status === 'loaded') {
          actions = '<button onclick="rollbackUpload(' + u.id +
            ')" class="text-red-600 hover:underline mr-2">Rollback</button>';
        } else if (u.status === 'validating' || u.status === 'loading') {
          var isReading = (u.rows_total || 0) < 0;
          var pct = (u.rows_total > 0 && u.rows_processed != null)
            ? Math.min(100, Math.round((u.rows_processed / u.rows_total) * 100)) : 0;
          var progressLabel = isReading ? 'Reading file…' : (u.status === 'validating' ? 'Validating' : 'Loading');
          actions = '<div class="inline-flex items-center gap-2">' +
            '<div class="w-28 bg-gray-200 rounded-full h-3 overflow-hidden" ' +
            'title="' + (isReading ? 'Reading file' : fmt(u.rows_processed || 0) + ' / ' +
            fmt(u.rows_total) + ' rows') + '">' +
            '<div class="bg-yellow-500 h-3 rounded-full transition-all ' +
            'duration-300' + (isReading ? ' animate-pulse' : '') + '" style="width:' + (isReading ? '100%' : pct + '%') + '"' +
            '></div></div>' +
            '<span class="text-yellow-700 text-[10px] font-medium ' +
            'whitespace-nowrap">' + progressLabel + (isReading ? '' : ' ' + pct + '%') + '</span>' +
            '</div> ' +
            '<button onclick="resetUpload(' + u.id +
            ')" class="text-orange-600 hover:underline text-xs mr-2" ' +
            'title="Reset stuck batch">Reset</button>';
        }
        if (u.error_count > 0 || u.status === 'failed') {
          actions += '<button onclick="viewUploadErrors(' + u.id +
            ')" class="text-orange-600 hover:underline text-xs mr-2" ' +
            'title="View error log">Errors (' + (u.error_count || '!') + ')</button>';
        }
        actions += '<button onclick="deleteUpload(' + u.id +
          ')" class="text-red-500 hover:underline text-xs" ' +
          'title="Delete this upload batch">Delete</button>';
        var scopeLabel = {
          cleanup: 'CM Cleanup',
          housekeeping: 'CM Housekeeping',
          explorer: 'Data Explorer'
        };
        var sourceInfo = (u.source_method || 'file') +
          (u.source_detail ? ': ' + u.source_detail : '');
        html += '<tr class="border-b hover:bg-gray-50">' +
          '<td class="py-1.5 px-2">' + u.id + '</td>' +
          '<td class="py-1.5 px-2">' +
          esc(scopeLabel[u.scope] || u.scope || '-') + '</td>' +
          '<td class="py-1.5 px-2">' + esc(u.data_category || '-') + '</td>' +
          '<td class="py-1.5 px-2">' + esc(u.kind) + '</td>' +
          '<td class="py-1.5 px-2 text-[10px]">' + esc(sourceInfo) + '</td>' +
          '<td class="py-1.5 px-2 ' + statusColor + ' font-medium">' +
          esc(u.status) + '</td>' +
          '<td class="py-1.5 px-2 text-right">' + fmt(u.rows_total) + '</td>' +
          '<td class="py-1.5 px-2 text-right">' + fmt(u.rows_valid) + '</td>' +
          '<td class="py-1.5 px-2 text-right">' + fmt(u.rows_error) + '</td>' +
          '<td class="py-1.5 px-2 text-right">' + fmt(u.rows_loaded) + '</td>' +
          '<td class="py-1.5 px-2">' + actions + '</td></tr>';
      });
      el.innerHTML = html + '</tbody></table>';
    }).catch(function() {
      document.getElementById('upload-history').textContent = 'Error loading uploads.';
    });
  }
  loadUploadHistory();

  function pollBatchStatus(id, targetStatuses, label) {
    return new Promise(function(resolve) {
      loadUploadHistory();
      var attempts = 0;
      var maxAttempts = 180;
      var interval = setInterval(function() {
        attempts++;
        fetch('/api/admin/uploads/' + id, { headers: authHdr })
          .then(function(r) { return r.json(); }).then(function(b) {
          loadUploadHistory();
          if (targetStatuses.indexOf(b.status) !== -1) {
            clearInterval(interval); resolve(b);
          } else if (attempts >= maxAttempts) {
            clearInterval(interval); resolve(null);
          }
        }).catch(function() {
          if (attempts >= maxAttempts) { clearInterval(interval); resolve(null); }
        });
      }, 2000);
    });
  }
  window.validateUpload = async function(id) {
    if (!token) { alert('Please log in first.'); return; }
    var res = await fetch('/api/admin/uploads/' + id + '/validate',
      { method: 'POST', headers: authHdr });
    if (res.status === 401 || res.status === 403) {
      alert('Session expired — please log in again.'); return;
    }
    var d = await res.json();
    if (!res.ok) { alert('Validation error: ' + (d.detail || 'Unknown error')); loadUploadHistory(); return; }
    loadUploadHistory();
    var result = await pollBatchStatus(id, ['validated', 'failed'], 'Validating');
    if (!result) { alert('Validation timed out — check status manually.'); return; }
    if (result.status === 'failed') {
      viewUploadErrors(id);
    } else {
      alert('Validation: ' + result.status +
        (result.rows_error ? ' (' + result.rows_error + ' errors)' : '') +
        ' — ' + (result.rows_valid || 0) + ' valid rows');
      if (result.rows_error > 0) viewUploadErrors(id);
    }
    loadUploadHistory();
  };
  window.loadUpload = async function(id) {
    if (!token) { alert('Please log in first.'); return; }
    var res = await fetch('/api/admin/uploads/' + id + '/load',
      { method: 'POST', headers: authHdr });
    if (res.status === 401 || res.status === 403) {
      alert('Session expired — please log in again.'); return;
    }
    var d = await res.json();
    if (!res.ok) { alert('Load error: ' + (d.detail || 'Unknown error')); loadUploadHistory(); return; }
    loadUploadHistory();
    var result = await pollBatchStatus(id, ['loaded', 'failed'], 'Loading');
    if (!result) { alert('Load timed out — check status manually.'); return; }
    if (result.status === 'failed') {
      viewUploadErrors(id);
    } else {
      alert('Load: ' + result.status +
        (result.rows_loaded ? ' (' + result.rows_loaded + ' rows)' : ''));
    }
    loadUploadHistory(); refreshAllData();
  };
  window.rollbackUpload = async function(id) {
    if (!confirm('Rollback this upload? This will remove all data loaded from this batch.')) return;
    if (!token) { alert('Please log in first.'); return; }
    var res = await fetch('/api/admin/uploads/' + id + '/rollback',
      { method: 'POST', headers: authHdr });
    if (res.status === 401 || res.status === 403) {
      alert('Session expired — please log in again.'); return;
    }
    var d = await res.json();
    if (!res.ok) { alert('Rollback error: ' + (d.detail || 'Unknown error')); loadUploadHistory(); return; }
    alert('Rollback: ' + d.status +
      (d.rows_deleted ? ' (' + d.rows_deleted + ' rows removed)' : ''));
    loadUploadHistory(); refreshAllData();
  };
  window.deleteUpload = async function(id) {
    if (!confirm('Delete this upload batch? If data was loaded, it will remain — use Rollback first.')) return;
    try {
      var res = await fetch('/api/data/uploads', {
        method: 'DELETE', headers: jsonHdr,
        body: JSON.stringify({ ids: [id] })
      });
      var d = await res.json();
      if (!res.ok) throw new Error(d.detail || 'Delete failed');
      loadUploadHistory(); refreshAllData();
    } catch(e) { alert('Error: ' + e.message); }
  };
  window.resetUpload = async function(id) {
    if (!confirm('Reset this stuck batch? This will allow you to re-try validation or loading.')) return;
    if (!token) { alert('Please log in first.'); return; }
    try {
      var res = await fetch('/api/admin/uploads/' + id + '/reset',
        { method: 'POST', headers: authHdr });
      var d = await res.json();
      if (!res.ok) throw new Error(d.detail || 'Reset failed');
      alert(d.message || 'Batch reset successfully.');
      loadUploadHistory();
    } catch(e) { alert('Error: ' + e.message); }
  };

  window.viewUploadErrors = async function(batchId) {
    document.getElementById('error-log-batch-id').textContent = batchId;
    document.getElementById('error-log-content').innerHTML = '<p class="text-gray-500">Loading errors...</p>';
    document.getElementById('error-log-modal').classList.remove('hidden');
    try {
      var res = await fetch('/api/admin/uploads/' + batchId + '/errors?size=200', { headers: authHdr });
      if (!res.ok) throw new Error('Failed to load errors');
      var d = await res.json();
      var items = d.items || [];
      if (!items.length) {
        document.getElementById('error-log-content').innerHTML =
          '<p class="text-gray-500">No error details recorded for this batch.</p>';
        return;
      }
      var html = '<table class="w-full text-xs border"><thead>' +
        '<tr class="bg-gray-50 border-b">' +
        '<th class="py-2 px-2 text-left">Row</th>' +
        '<th class="py-2 px-2 text-left">Column</th>' +
        '<th class="py-2 px-2 text-left">Code</th>' +
        '<th class="py-2 px-2 text-left">Message</th>' +
        '</tr></thead><tbody>';
      items.forEach(function(e) {
        html += '<tr class="border-b hover:bg-red-50">' +
          '<td class="py-1.5 px-2 font-mono">' + (e.row_number || '-') + '</td>' +
          '<td class="py-1.5 px-2">' + esc(e.column_name || '-') + '</td>' +
          '<td class="py-1.5 px-2"><span class="px-1.5 py-0.5 bg-red-100 text-red-700 rounded text-[10px] font-medium">' +
          esc(e.error_code) + '</span></td>' +
          '<td class="py-1.5 px-2 text-gray-700">' + esc(e.message) + '</td></tr>';
      });
      html += '</tbody></table>';
      if (d.total > items.length) {
        html += '<p class="text-xs text-gray-500 mt-2">Showing ' + items.length +
          ' of ' + d.total + ' errors.</p>';
      }
      document.getElementById('error-log-content').innerHTML = html;
    } catch(e) {
      document.getElementById('error-log-content').innerHTML =
        '<p class="text-red-600">Error loading error log: ' + esc(e.message) + '</p>';
    }
  };

  // ── Download upload template ────────────────────────────────────────
  document.getElementById('download-template-btn').addEventListener('click', async function() {
    var rawKind = document.getElementById('upload-type').value;
    if (!rawKind) { alert('Please select a data type first.'); return; }
    if (rawKind === 'cc_with_hierarchy') {
      alert('No CSV template for this type — use your existing Excel file with the sheet/header options above.');
      return;
    }
    var templateKindMap = {
      cost_center: 'cost_centers', profit_center: 'profit_centers',
      gl_account_ska1: 'gl_accounts_ska1', gl_account_skb1: 'gl_accounts_skb1',
      entity: 'entities',
      hierarchy: 'hierarchies', hierarchy_flat: 'hierarchies_flat',
      entity_hierarchy: 'entity_hierarchy',
      balance: 'balances', balance_gcr: 'balances_gcr',
      employee: 'employees'
    };
    var cat = getCategory();
    var kind = templateKindMap[rawKind] || rawKind;
    if (cat === 'target' && rawKind === 'cost_center') kind = 'target_cost_centers';
    if (cat === 'target' && rawKind === 'profit_center') kind = 'target_profit_centers';
    try {
      var res = await fetch('/api/data/upload-templates/' + encodeURIComponent(kind));
      if (!res.ok) { alert('Failed to fetch template'); return; }
      var d = await res.json();
      var blob = new Blob([d.content], { type: 'text/csv' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = kind + '_template.csv';
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch(e) { alert('Error: ' + e.message); }
  });

