  function renderBalTree(el, data) {
    var items = data.items || [];
    if (!items.length) {
      el.innerHTML = '<span class="text-gray-400 text-xs italic">No balances found for this hierarchy / year combination.</span>';
      return;
    }
    // Build the same path-based tree structure used in the analytics
    // hierarchical view, but with year totals at the leaves.
    function emptyNode() { return { children: {}, leaves: [], order: [] }; }
    var root = emptyNode();
    items.forEach(function(it) {
      var path = it.hierarchy_path || [];
      if (!path.length) {
        if (!root.children['(unassigned)']) {
          root.children['(unassigned)'] = emptyNode();
          root.order.push('(unassigned)');
        }
        root.children['(unassigned)'].leaves.push(it);
        return;
      }
      var node = root;
      for (var i = 0; i < path.length - 1; i++) {
        var key = path[i];
        if (!node.children[key]) {
          node.children[key] = emptyNode();
          node.order.push(key);
        }
        node = node.children[key];
      }
      node.leaves.push(it);
    });

    function nodeTotals(node) {
      var t = { tc: 0, postings: 0, ccs: 0 };
      node.leaves.forEach(function(it) {
        t.tc += it.totals.tc_amt;
        t.postings += it.totals.posting_count;
        t.ccs += 1;
      });
      node.order.forEach(function(k) {
        var sub = nodeTotals(node.children[k]);
        t.tc += sub.tc; t.postings += sub.postings; t.ccs += sub.ccs;
      });
      return t;
    }

    var idSeq = 0;
    function nid() { return 'bal-tree-n' + (++idSeq); }

    function renderNode(node, depth) {
      var html = '';
      node.order.sort();
      node.order.forEach(function(k) {
        var child = node.children[k];
        var id = nid();
        var totals = nodeTotals(child);
        var indent = depth === 0 ? '' : 'ml-' + Math.min(depth * 4, 12);
        var openByDefault = depth < 2;
        var caret = openByDefault ? '\u25BC' : '\u25B6';
        var hide = openByDefault ? '' : ' hidden';
        var tcFmt = totals.tc.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        html += '<div class="' + indent + ' my-0.5">' +
          '<button type="button" class="w-full text-left flex items-center gap-2 hover:bg-blue-50 px-2 py-1 rounded" ' +
                 'onclick="(function(b){var t=document.getElementById(\'' + id + '\');if(!t)return;var o=t.classList.toggle(\'hidden\');b.querySelector(\'.bal-caret\').textContent=o?\'\\u25B6\':\'\\u25BC\';})(this)">' +
            '<span class="bal-caret text-gray-400">' + caret + '</span>' +
            '<span class="font-mono font-semibold text-blue-700">' + esc(k) + '</span>' +
            '<span class="ml-auto flex items-center gap-3 text-[10px] text-gray-500">' +
              '<span>' + totals.ccs + ' CC' + (totals.ccs === 1 ? '' : 's') + '</span>' +
              '<span class="font-mono">' + tcFmt + '</span>' +
            '</span>' +
          '</button>' +
          '<div id="' + id + '" class="bal-children' + hide + '">' + renderNode(child, depth + 1) + '</div>' +
        '</div>';
      });
      if (node.leaves.length) {
        var indent2 = depth === 0 ? '' : 'ml-' + Math.min(depth * 4 + 2, 14);
        html += '<div class="' + indent2 + ' my-1">' + balLeafTable(node.leaves) + '</div>';
      }
      return html;
    }

    function balLeafTable(leaves) {
      // Sort leaves by tc_amt descending so the highest-volume CCs
      // are visible first — this is the most common operator question
      // ('which CCs have the most spend in this part of the tree?').
      leaves.sort(function(a, b) { return b.totals.tc_amt - a.totals.tc_amt; });
      var rows = leaves.map(function(it) {
        var tcFmt = it.totals.tc_amt.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return '<tr class="border-b last:border-0 hover:bg-gray-50">' +
          '<td class="py-1 px-2 font-mono text-[11px] font-medium">' + esc(it.cctr) + '</td>' +
          '<td class="py-1 px-2 font-mono text-[11px]">' + esc(it.ccode) + '</td>' +
          '<td class="py-1 px-2 text-[11px] truncate max-w-[260px]" title="' + esc(it.txtsh) + '">' + esc(it.txtsh) + '</td>' +
          '<td class="py-1 px-2 text-right font-mono text-[11px]">' + tcFmt + '</td>' +
          '<td class="py-1 px-2 text-right text-[11px] text-gray-500">' + it.totals.posting_count + '</td>' +
          '<td class="py-1 px-2 text-right text-[11px] text-gray-400">' + it.totals.rows + '</td>' +
          '</tr>';
      }).join('');
      return '<table class="w-full text-xs border border-gray-200 rounded">' +
        '<thead><tr class="bg-gray-50 border-b text-[10px] text-gray-500">' +
          '<th class="py-1 px-2 text-left">CC</th>' +
          '<th class="py-1 px-2 text-left">Entity</th>' +
          '<th class="py-1 px-2 text-left">Short Text</th>' +
          '<th class="py-1 px-2 text-right">TC Amount (sum)</th>' +
          '<th class="py-1 px-2 text-right">Postings</th>' +
          '<th class="py-1 px-2 text-right">Bal rows</th>' +
        '</tr></thead><tbody>' + rows + '</tbody></table>';
    }

    var root_totals = nodeTotals(root);
    var summary = '<div class="text-xs text-gray-500 mb-2 px-2">' +
      'Aggregated balances · ' + root_totals.ccs + ' cost centers · ' +
      'TC total: ' + root_totals.tc.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) +
      ' · ' + root_totals.postings + ' postings' +
      (data.fiscal_year ? ' · year ' + data.fiscal_year : ' · all years') +
      '</div>';

    el.innerHTML = summary + renderNode(root, 0);
  }


