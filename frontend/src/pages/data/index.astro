  function renderTree(tree, filter) {
    var container = document.getElementById('hier-tree-container');
    if (!tree || !tree.length) { container.textContent = 'No nodes in this hierarchy.'; return; }
    var html = '<div class="space-y-0.5">';
    tree.forEach(function(node) { html += renderNode(node, 0, filter); });
    html += '</div>';
    container.innerHTML = html;
  }

  function renderNode(node, depth, filter) {
    var indent = depth * 24;
    var hasChildren = node.children && node.children.length > 0;
    var hasCCs = node.cost_centers && node.cost_centers.length > 0;
    var matches = !filter || node.setname.toLowerCase().indexOf(filter) >= 0;
    var childMatches = false;
    var childHtml = '';
    if (hasChildren) {
      node.children.forEach(function(c) {
        var ch = renderNode(c, depth + 1, filter);
        if (ch) { childHtml += ch; childMatches = true; }
      });
    }
    var ccHtml = '';
    if (hasCCs) {
      node.cost_centers.forEach(function(cc) {
        var ccMatch = !filter || cc.cctr.toLowerCase().indexOf(filter) >= 0 || (cc.name || '').toLowerCase().indexOf(filter) >= 0;
        if (ccMatch || matches) {
          childMatches = true;
          ccHtml += '<div class="flex items-center gap-2 py-0.5 text-xs" style="padding-left:' + ((depth+1)*24+16) + 'px">' +
            '<span class="text-blue-500">&#9679;</span> ' +
            '<span class="font-mono font-medium">' + esc(cc.cctr) + '</span>' +
            '<span class="text-gray-500">' + esc(cc.name || '') + '</span>' +
            (cc.ccode ? '<span class="text-gray-400 text-[10px]">[' + esc(cc.ccode) + ']</span>' : '') +
            (cc.responsible ? '<span class="text-gray-400 text-[10px]">Owner: ' + esc(cc.responsible) + '</span>' : '') +
            '</div>';
        }
      });
    }
    if (filter && !matches && !childMatches) return '';
    var icon = hasChildren || hasCCs ? '<span class="tree-toggle cursor-pointer select-none text-gray-400 hover:text-gray-700 w-4 text-center inline-block" onclick="toggleTreeNode(this)">' + (hasChildren || hasCCs ? '&#9660;' : '&nbsp;') + '</span>' : '<span class="w-4 inline-block">&nbsp;</span>';
    var typeLabel = node.type === 'leaf' ? '<span class="text-[10px] bg-green-100 text-green-700 px-1 rounded">LEAF</span>' : '<span class="text-[10px] bg-gray-100 text-gray-600 px-1 rounded">NODE</span>';
    var ccCount = hasCCs ? '<span class="text-[10px] text-blue-500 ml-1">(' + node.cost_centers.length + ' CCs)</span>' : '';
    var html = '<div class="tree-node">' +
      '<div class="flex items-center gap-1 py-0.5 hover:bg-gray-50 rounded px-1" style="padding-left:' + indent + 'px">' +
      icon + ' ' + typeLabel + ' <span class="font-mono font-medium text-sm">' + esc(node.setname) + '</span>' + ccCount +
      '</div>';
    if (hasChildren || hasCCs) {
      html += '<div class="tree-children">' + childHtml + ccHtml + '</div>';
    }
    html += '</div>';
    return html;
  }

  window.toggleTreeNode = function(el) {
    var children = el.closest('.tree-node').querySelector('.tree-children');
