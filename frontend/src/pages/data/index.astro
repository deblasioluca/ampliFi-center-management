---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Data Management" requireAuth={true} requiredRole="data_manager">
  <div class="flex items-center justify-between mb-2">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Data Management</h1>
      <p class="text-xs text-gray-500">Upload, browse, and manage cost centers, profit centers, balances, hierarchies, and employees</p>
    </div>
  </div>

  <!-- Scope Selector -->
  <div class="flex items-center gap-3 mb-3">
    <label class="text-sm font-medium text-gray-700">Scope:</label>
    <select id="scope-selector" class="input w-auto text-sm">
      <option value="cleanup" selected>Center Management — Cleanup</option>
      <option value="housekeeping">Center Management — Housekeeping</option>
      <option value="explorer">Data Explorer</option>
    </select>
    <label class="text-sm font-medium text-gray-700 ml-4">Category:</label>
    <select id="category-selector" class="input w-auto text-sm">
      <option value="">All</option>
      <option value="legacy">Legacy</option>
      <option value="target">Target</option>
    </select>
  </div>

  <!-- Data Counts -->
  <div class="grid grid-cols-4 lg:grid-cols-8 gap-3 mb-3">
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Entities</span>
      <p id="cnt-entities" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Cost Centers</span>
      <p id="cnt-cc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Profit Centers</span>
      <p id="cnt-pc" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">GL Accounts</span>
      <p id="cnt-gl" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Balances</span>
      <p id="cnt-balances" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Hierarchies</span>
      <p id="cnt-hierarchies" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Employees</span>
      <p id="cnt-employees" class="text-lg font-bold text-gray-900">--</p>
    </div>
    <div class="bg-white border rounded-lg px-3 py-1.5 text-center">
      <span class="text-[10px] text-gray-500 uppercase">Uploads</span>
      <p id="cnt-uploads" class="text-lg font-bold text-gray-900">--</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white border-b border-gray-200 rounded-t-lg mb-0">
    <div class="flex space-x-0 overflow-x-auto" id="data-tabs">
      <button class="tab-active px-4 py-3 whitespace-nowrap font-semibold text-blue-700" data-tab="data-browser">Data Browser</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="entities">Entities</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="cost-centers">Cost Centers</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="profit-centers">Profit Centers</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="gl-accounts">GL Accounts</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="mapping">Mapping</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="balances">Balances</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="hierarchies">Hierarchies</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="employees">Employees</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="upload">Upload</button>
      <button class="tab px-4 py-3 whitespace-nowrap" data-tab="sample-data">Sample Data</button>
    </div>
  </div>

  <!-- Tab Content -->
  <div class="card rounded-t-none border-t-0">
    <!-- Data Browser — rendered by DataObjectDisplay -->
    <div id="tab-data-browser">
      <div id="dod-data-browser" class="text-xs"></div>
    </div>

    <!-- Entities — rendered by DataObjectDisplay -->
    <div id="tab-entities" class="hidden">
      <div id="dod-entities" class="text-xs"></div>
    </div>

    <!-- Cost Centers — rendered by DataObjectDisplay (Legacy + Target) -->
    <div id="tab-cost-centers" class="hidden">
      <div id="dod-cc-legacy" class="text-xs mb-6"></div>
      <div class="border-t border-gray-200 pt-4">
        <div id="dod-cc-target" class="text-xs"></div>
      </div>
    </div>

    <!-- Profit Centers — rendered by DataObjectDisplay (Legacy + Target) -->
    <div id="tab-profit-centers" class="hidden">
      <div id="dod-pc-legacy" class="text-xs mb-6"></div>
      <div class="border-t border-gray-200 pt-4">
        <div id="dod-pc-target" class="text-xs"></div>
      </div>
    </div>

    <!-- GL Accounts — rendered by DataObjectDisplay -->
    <div id="tab-gl-accounts" class="hidden">
      <div id="dod-gl" class="text-xs"></div>
    </div>

    <!-- Mapping — rendered by DataObjectDisplay -->
    <div id="tab-mapping" class="hidden">
      <div id="dod-mapping" class="text-xs"></div>
    </div>

    <!-- Balances — rendered by DataObjectDisplay -->
    <div id="tab-balances" class="hidden">
      <div id="dod-balances" class="text-xs"></div>
    </div>

    <!-- Hierarchies — rendered by DataObjectDisplay -->
    <div id="tab-hierarchies" class="hidden">
      <div id="dod-hierarchies" class="text-xs"></div>
    </div>

    <!-- Employees — rendered by DataObjectDisplay -->
    <div id="tab-employees" class="hidden">
      <div id="dod-employees" class="text-xs"></div>
    </div>

    <!-- Upload Tab -->
    <div id="tab-upload" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Option A: File Upload -->
        <div>
          <h3 class="text-base font-semibold mb-1">Option A: Upload from File</h3>
          <p class="text-xs text-gray-500 mb-4">Upload CSV or Excel files. After upload, validate and then load into the database.</p>
          <form id="upload-form" class="space-y-4">
            <!-- Step 1: Scope -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">1. Scope</label>
              <select id="upload-scope" class="input">
                <option value="">— Select scope —</option>
                <option value="cleanup">Center Management — Cleanup</option>
                <option value="housekeeping">Center Management — Housekeeping</option>
                <option value="explorer">Data Explorer</option>
              </select>
            </div>
            <!-- Step 2: Category -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">2. Data Category</label>
              <select id="upload-category" class="input" disabled>
                <option value="">— Select scope first —</option>
              </select>
            </div>
            <!-- Step 3: Object Type -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">3. Data Type</label>
              <select id="upload-type" class="input" disabled>
                <option value="">— Select category first —</option>
              </select>
            </div>
            <!-- CC with Hierarchy options (shown only for cc_with_hierarchy) -->
            <div id="cc-hier-options" class="hidden p-3 bg-amber-50 border border-amber-200 rounded space-y-3">
              <p class="text-xs font-medium text-amber-800">Excel Upload Options</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs text-gray-600 mb-1">Sheet Name</label>
                  <input type="text" id="cc-hier-sheet" value="Database" class="input text-sm" placeholder="Database" />
                </div>
                <div>
                  <label class="block text-xs text-gray-600 mb-1">Header Row</label>
                  <input type="number" id="cc-hier-header-row" value="2" min="1" max="100" class="input text-sm" />
                </div>
              </div>
              <div class="space-y-1">
                <p class="text-xs text-gray-600 font-medium">What to import:</p>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-cc" checked class="rounded border-gray-300" />
                  <span>Cost Center data</span>
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-ext" checked class="rounded border-gray-300" />
                  <span>External Hierarchy</span>
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" id="cc-hier-load-cema" checked class="rounded border-gray-300" />
                  <span>CEMA Hierarchy</span>
                </label>
              </div>
            </div>
            <div class="p-3 bg-blue-50 border border-blue-200 rounded text-xs text-blue-700">
              <span class="font-medium">Template:</span>
              <button type="button" id="download-template-btn" class="ml-1 underline hover:text-blue-900">Download CSV template for selected type</button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">File</label>
              <input type="file" id="upload-file" accept=".csv,.xlsx,.xls,.tsv" class="input" required />
            </div>
            <div class="flex gap-3 items-center">
              <button type="submit" id="upload-btn" class="btn-amplifi">Upload</button>
              <div id="upload-progress" class="hidden flex-1 flex items-center gap-2">
                <div class="flex-1 bg-gray-200 rounded-full h-4 overflow-hidden">
                  <div id="upload-progress-bar" class="bg-amplifi-500 h-4 rounded-full transition-all duration-200" style="width:0%"></div>
                </div>
                <span id="upload-progress-text" class="text-xs text-gray-600 whitespace-nowrap">0%</span>
              </div>
            </div>
            <div id="upload-result" class="text-sm hidden"></div>
          </form>
        </div>

        <!-- Option B: Source from SAP -->
        <div>
          <h3 class="text-base font-semibold mb-1">Option B: Source from SAP</h3>
          <p class="text-xs text-gray-500 mb-4">Extract data directly from a connected SAP system using pre-configured bindings. Set up connections and bindings under <a href="/admin/sap" class="text-blue-600 underline">Admin &rarr; SAP Connections</a>.</p>
          <div id="sap-extract-area" class="space-y-3">
            <div id="sap-connections-list" class="text-sm text-gray-500">Loading connections...</div>
            <div id="sap-extract-result" class="text-sm hidden"></div>
          </div>
          <div id="sap-no-connections" class="hidden p-4 bg-gray-50 rounded-lg text-center">
            <p class="text-sm text-gray-500">No SAP connections configured yet.</p>
            <a href="/admin/sap" class="text-blue-600 text-sm underline mt-1 inline-block">Configure SAP Connections &rarr;</a>
          </div>
        </div>
      </div>

      <!-- Upload History with Actions -->
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="text-base font-semibold mb-3">Upload History</h3>
        <div id="upload-history" class="text-sm text-gray-500">Loading...</div>
      </div>
    </div>

    <!-- Sample Data Tab -->
    <div id="tab-sample-data" class="hidden">
      <h3 class="text-base font-semibold mb-3">Sample Data Management</h3>
      <p class="text-xs text-gray-500 mb-4">Generate or delete sample data for testing.</p>
      <div id="sample-status" class="mb-4 p-3 bg-gray-50 rounded text-sm text-gray-600">Loading status...</div>
      <div class="flex gap-3">
        <button id="gen-sample-btn" class="btn-success">Generate Sample Data</button>
        <button id="del-sample-btn" class="btn-danger">Delete Sample Data</button>
      </div>
      <div id="sample-result" class="text-sm mt-3 hidden"></div>
    </div>
  </div>
</Layout>

<style>
  /* Sticky table headers inside scrollable containers */
  .card thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #f9fafb;
  }
</style>

<script is:inline src="/data-object-display.js"></script>
<script is:inline>
(function() {
  var token = localStorage.getItem('amplifi_token');
  var authHdr = token ? { 'Authorization': 'Bearer ' + token } : {};
  var jsonHdr = token ? { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } : {};

  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }
  function escAttr(s) { return esc(s).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
  function fmt(n) { return (n || 0).toLocaleString(); }

  // CSV download of current visible table
  window.downloadTableCSV = function(tableId, filename) {
    var table = document.getElementById(tableId);
    if (!table) return;
    var tbl = table.querySelector('table');
    if (!tbl) { alert('No data to download.'); return; }
    var csv = [];
    tbl.querySelectorAll('tr').forEach(function(row) {
      var cells = [];
      row.querySelectorAll('th,td').forEach(function(cell) {
        var v = cell.textContent.replace(/"/g, '""').replace(/ [▲▼]$/, '');
        cells.push('"' + v + '"');
      });
      csv.push(cells.join(','));
    });
    var blob = new Blob([csv.join('\n')], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a'); a.href = url; a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };



  var allTabs = ['data-browser','entities','cost-centers','profit-centers','gl-accounts','mapping','balances','hierarchies','employees','upload','sample-data'];

  // Tab switching
  document.querySelectorAll('#data-tabs button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      document.querySelectorAll('#data-tabs button').forEach(function(b) { b.className = 'tab px-4 py-3 whitespace-nowrap'; });
      this.className = 'tab-active px-4 py-3 whitespace-nowrap';
      allTabs.forEach(function(t) {
        var el = document.getElementById('tab-' + t);
        if (el) el.classList.toggle('hidden', t !== tab);
      });
    });
  });

  var refreshAllData = function() { loadCounts(); };

  // Scope/category selectors
  var scopeSel = document.getElementById('scope-selector');
  var catSel = document.getElementById('category-selector');
  function getScope() { return scopeSel.value; }
  function getCategory() { return catSel.value; }
  function scopeParams() {
    var p = '&scope=' + encodeURIComponent(getScope());
    if (getCategory()) p += '&data_category=' + encodeURIComponent(getCategory());
    return p;
  }
  scopeSel.addEventListener('change', function() { refreshAllData(); });
  catSel.addEventListener('change', function() { refreshAllData(); });

  // Load data counts with scope filtering
  function loadCounts() {
    var params = '?scope=' + encodeURIComponent(getScope());
    if (getCategory()) params += '&data_category=' + encodeURIComponent(getCategory());
    fetch('/api/data/counts' + params, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      document.getElementById('cnt-entities').textContent = fmt(d.entities);
      document.getElementById('cnt-cc').textContent = fmt(d.cost_centers);
      document.getElementById('cnt-pc').textContent = fmt(d.profit_centers);
      document.getElementById('cnt-gl').textContent = fmt(d.gl_accounts || 0);
      document.getElementById('cnt-balances').textContent = fmt(d.balances);
      document.getElementById('cnt-hierarchies').textContent = fmt(d.hierarchies);
      document.getElementById('cnt-employees').textContent = fmt(d.employees || 0);
      document.getElementById('cnt-uploads').textContent = fmt(d.upload_batches);
    }).catch(function() {});
  }
  loadCounts();

  // Upload rules from backend
  var uploadRules = {};
  fetch('/api/admin/upload-rules', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
    uploadRules = d.rules || {};
  }).catch(function() {});

  // Object display names
  var objLabels = {
    cost_center: 'Cost Centers', cc_with_hierarchy: 'Cost Centers with Hierarchy (Excel)',
    profit_center: 'Profit Centers',
    gl_account_ska1: 'GL Accounts (SKA1)', gl_account_skb1: 'GL Accounts (SKB1)',
    entity: 'Entities',
    hierarchy: 'Hierarchies (SET format)', hierarchy_flat: 'Hierarchies (SAP flat export)', entity_hierarchy: 'Entity Hierarchy (GCRS)',
    balance: 'Balances', balance_gcr: 'Balances (GCR aggregated)',
    employee: 'Employees'
  };

  // 3-step upload cascading
  var uploadScopeSel = document.getElementById('upload-scope');
  var uploadCatSel = document.getElementById('upload-category');
  var uploadTypeSel = document.getElementById('upload-type');

  uploadScopeSel.addEventListener('change', function() {
    var scope = this.value;
    uploadCatSel.innerHTML = '<option value="">— Select category —</option>';
    uploadTypeSel.innerHTML = '<option value="">— Select category first —</option>';
    uploadCatSel.disabled = true;
    uploadTypeSel.disabled = true;
    if (!scope || !uploadRules[scope]) return;
    var cats = Object.keys(uploadRules[scope]);
    cats.forEach(function(cat) {
      var opt = document.createElement('option');
      opt.value = cat;
      opt.textContent = cat.charAt(0).toUpperCase() + cat.slice(1);
      uploadCatSel.appendChild(opt);
    });
    uploadCatSel.disabled = false;
  });

  uploadCatSel.addEventListener('change', function() {
    var scope = uploadScopeSel.value;
    var cat = this.value;
    uploadTypeSel.innerHTML = '<option value="">— Select data type —</option>';
    uploadTypeSel.disabled = true;
    if (!scope || !cat || !uploadRules[scope] || !uploadRules[scope][cat]) return;
    uploadRules[scope][cat].forEach(function(obj) {
      var opt = document.createElement('option');
      opt.value = obj;
      opt.textContent = objLabels[obj] || obj;
      uploadTypeSel.appendChild(opt);
    });
    uploadTypeSel.disabled = false;
  });

  uploadTypeSel.addEventListener('change', function() {
    var ccHierOpts = document.getElementById('cc-hier-options');
    if (this.value === 'cc_with_hierarchy') {
      ccHierOpts.classList.remove('hidden');
    } else {
      ccHierOpts.classList.add('hidden');
    }
  });



  // ═══════════════════════════════════════════════════════════════════
  // Central DataObjectDisplay instances for ALL data tabs.
  // Each tab delegates rendering, search, sort, column-filter,
  // hierarchy picker, pagination, and CSV export to the shared class.
  // ═══════════════════════════════════════════════════════════════════

  function dodScopeParams() {
    var p = {};
    p.scope = getScope();
    if (getCategory()) p.data_category = getCategory();
    return p;
  }

  function makeDeleteBtn(label, endpoint, dod) {
    return {
      label: label,
      className: 'btn-danger text-xs',
      onclick: function() {
        if (!confirm('Delete ALL ' + label.replace('Delete All ', '') + '?')) return;
        fetch(endpoint, { method: 'DELETE', headers: authHdr })
          .then(function() { loadCounts(); dod.load(); });
      }
    };
  }

  // --- Data Browser ---
  var dodDB = new DataObjectDisplay({
    containerId: 'dod-data-browser',
    objectType: 'data-browser',
    title: 'Data Browser',
    dataEndpoint: '/api/data/browser',
    hierarchyEndpoint: '/api/legacy/hierarchies',
    identityField: 'cctr',
    showViewToggle: true,
    showHierarchyPicker: true,
    showSearch: true,
    showCSV: true,
    pageSize: 200,
    hierPageSize: 2000,
    inlineHierarchies: true,
    includeBalances: false,
    extraQueryParams: dodScopeParams(),
    authHeaders: authHdr
  });
  dodDB.load();

  // --- Entities ---
  var dodEntities = new DataObjectDisplay({
    containerId: 'dod-entities',
    objectType: 'entities',
    title: 'Entities (Legal Entities / Company Codes)',
    dataEndpoint: '/api/entities',
    hierarchyEndpoint: '/api/legacy/hierarchies',
    identityField: 'ccode',
    showViewToggle: true,
    showHierarchyPicker: true,
    hierarchyTypes: ['0106'],
    showSearch: true,
    showCSV: true,
    pageSize: 500,
    hierPageSize: 2000,
    extraQueryParams: dodScopeParams(),
    authHeaders: authHdr,
    toolbarButtons: [
      { label: 'Delete All', className: 'btn-danger text-xs', onclick: function() {
        if (!confirm('Delete ALL entities?')) return;
        fetch('/api/data/entities/all', { method: 'DELETE', headers: authHdr })
          .then(function() { loadCounts(); dodEntities.load(); });
      }}
    ]
  });
  dodEntities.load();

  // --- Cost Centers (Legacy) ---
  var dodCCLegacy = new DataObjectDisplay({
    containerId: 'dod-cc-legacy',
    objectType: 'cost-centers',
    title: 'Legacy Cost Centers',
    dataEndpoint: '/api/legacy/cost-centers',
    hierarchyEndpoint: '/api/legacy/hierarchies',
    identityField: 'cctr',
    entityField: 'ccode',
    showViewToggle: true,
    showHierarchyPicker: true,
    hierarchyTypes: ['0101', '0106'],
    showSearch: true,
    showCSV: true,
    pageSize: 500,
    hierPageSize: 5000,
    extraQueryParams: dodScopeParams(),
    authHeaders: authHdr,
    toolbarButtons: [
      { label: 'Delete All', className: 'btn-danger text-xs', onclick: function() {
        if (!confirm('Delete ALL legacy cost centers?')) return;
        fetch('/api/data/legacy/cost-centers/all', { method: 'DELETE', headers: authHdr })
          .then(function() { loadCounts(); dodCCLegacy.load(); });
      }}
    ]
  });
  dodCCLegacy.load();

  // --- Cost Centers (Target) ---
  var dodCCTarget = new DataObjectDisplay({
    containerId: 'dod-cc-target',
    objectType: 'target-cost-centers',
    title: 'Target Cost Centers',
    subtitle: '(ampliFi)',
    dataEndpoint: '/api/target/cost-centers',
    identityField: 'cctr',
    showViewToggle: false,
    showHierarchyPicker: false,
    showSearch: true,
    showCSV: true,
    pageSize: 50,
    extraQueryParams: dodScopeParams(),
    authHeaders: authHdr,
    toolbarButtons: [
      { label: 'Delete All', className: 'btn-danger text-xs', onclick: function() {
        if (!confirm('Delete ALL target cost centers?')) return;
        fetch('/api/data/target/cost-centers/all', { method: 'DELETE', headers: authHdr })
          .then(function() { loadCounts(); dodCCTarget.load(); });
      }}
    ]
  });
  dodCCTarget.load();

  // --- Profit Centers (Legacy) ---
  var dodPCLegacy = new DataObjectDisplay({
    containerId: 'dod-pc-legacy',
    objectType: 'profit-centers',
    title: 'Legacy Profit Centers',
    dataEndpoint: '/api/legacy/profit-centers',
    hierarchyEndpoint: '/api/legacy/hierarchies',
    identityField: 'pctr',
    entityField: 'ccode',
    showViewToggle: true,
    showHierarchyPicker: true,
    hierarchyTypes: ['0104', '0106'],
    showSearch: true,
    showCSV: true,
    pageSize: 500,
    hierPageSize: 5000,
    extraQueryParams: dodScopeParams(),
    authHeaders: authHdr,
    toolbarButtons: [
      { label: 'Delete All', className: 'btn-danger text-xs', onclick: function() {
        if (!confirm('Delete ALL legacy profit centers?')) return;
        fetch('/api/data/legacy/profit-centers/all', { method: 'DELETE', headers: authHdr })
          .then(function() { loadCounts(); dodPCLegacy.load(); });
      }}
    ]
  });
  dodPCLegacy.load();

  // --- Profit Centers (Target) ---
  var dodPCTarget = new DataObjectDisplay({
    containerId: 'dod-pc-target',
    objectType: 'target-profit-centers',
    title: 'Target Profit Centers',
    subtitle: '(ampliFi)',
    dataEndpoint: '/api/target/profit-centers',
