            '<p class="text-xs text-gray-600 mb-3">Use this if you already have a curated legacy → target list (e.g. from a migration spreadsheet).</p>' +
            '<a href="/uploads" class="inline-block btn-amplifi text-xs px-3 py-1">Go to Upload page →</a>' +
            '<a href="/api/admin/upload-templates/center_mapping/download" class="inline-block ml-2 text-xs text-blue-700 hover:underline" target="_blank">Download CSV template</a>' +
          '</div>' +
          // Path B — auto-derive
          '<div class="border rounded-lg p-4 bg-amber-50">' +
