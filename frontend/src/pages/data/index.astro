    }
    var items = sortTableData('mapping', _mappingData);
    var html = '<table class="w-full text-xs"><thead><tr class="border-b bg-gray-50">' +
      sortTh('mapping','object_type','Type','_renderMappingTable') +
      sortTh('mapping','legacy_coarea','Legacy CO','_renderMappingTable') +
      sortTh('mapping','legacy_center','Legacy Center','_renderMappingTable') +
      sortTh('mapping','legacy_name','Legacy Name','_renderMappingTable') +
      '<th class="py-2 px-2 text-center">→</th>' +
