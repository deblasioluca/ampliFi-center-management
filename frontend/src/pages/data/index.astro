  // --- Center Mapping ---
  var _mappingData = [];
  var _mappingTotal = 0;
  window.loadMapping = function(page) {
    page = page || 1;
    var search = document.getElementById('search-mapping').value;
    var objType = document.getElementById('filter-mapping-type').value;
    var url = '/api/center-mappings?page=' + page + '&size=50' + scopeParams();
    if (search) url += '&search=' + encodeURIComponent(search);
    if (objType) url += '&object_type=' + encodeURIComponent(objType);
    fetch(url, { headers: authHdr }).then(function(r) { return r.json(); }).then(function(d) {
      _mappingData = d.items || [];
      _mappingTotal = d.total || 0;
      _renderMappingTable();
      document.getElementById('mapping-pager').innerHTML = pagerHtml(d.total, d.page, d.size, 'loadMapping');
    }).catch(function(e) { document.getElementById('mapping-table').textContent = 'Error: ' + e.message; });
  };
  window._renderMappingTable = function() {
    var el = document.getElementById('mapping-table');
    if (!_mappingData.length) {
      // PR #89 — A13: actionable empty state. Operator's question
      // 'mapping is leer, wie kann diese befüllen?' was the cue that
      // the previous one-line "No center mappings found. Upload a
      // mapping file to get started." was too terse — it doesn't say
      // WHERE to upload, doesn't mention auto-derivation, and gives
      // the operator no clickable next step. Now they get both paths
      // explained inline with buttons.
      var search = document.getElementById('search-mapping').value;
      var objType = document.getElementById('filter-mapping-type').value;
      // If a filter is active and yields zero rows we shouldn't pretend
      // the whole table is empty — show a different message.
      if (search || objType) {
        el.innerHTML = '<div class="text-gray-400 text-sm py-3">' +
          'No center mappings match the current filter. ' +
          '<button class="text-blue-600 hover:underline text-sm" onclick="document.getElementById(\'search-mapping\').value=\'\';document.getElementById(\'filter-mapping-type\').value=\'\';loadMapping(1);">Clear filters</button>' +
          '</div>';
        return;
      }
      el.innerHTML = '<div class="border-2 border-dashed border-gray-300 rounded-lg p-6 my-4">' +
        '<h4 class="text-base font-semibold mb-2 text-gray-700">No center mappings yet</h4>' +
        '<p class="text-sm text-gray-600 mb-4">Center mappings translate <span class="font-medium">legacy</span> CC/PC codes into their <span class="font-medium">target</span> codes for migration. There are two ways to populate this table:</p>' +
        '<div class="grid grid-cols-1 md:grid-cols-2 gap-4">' +
          // Path A — upload CSV
          '<div class="border rounded-lg p-4 bg-blue-50">' +
            '<div class="flex items-center gap-2 mb-2">' +
