  // PR #89 — Balances hierarchical view (A14). Mirrors the
  // Tabular/Hierarchical pattern from the other tabs. We populate the
  // hierarchy picker on demand (first switch into the tab) and re-fetch
  // an aggregated dataset from /legacy/balances/by-hierarchy.
  var _balView = 'tabular';
  var _balHierLoadedFor = null; // cache by hierarchy_id|year combo

  window.switchBalView = function(view) {
    _balView = view;
    setToggleClasses('bal-view-tabular', 'bal-view-hierarchy', view);
    var picker = document.getElementById('bal-hier-picker');
    if (view === 'hierarchy') {
      picker.classList.remove('hidden');
      showHide('bal-hier-wrap', 'bal-table-wrap');
      // Lazy-populate the picker the first time we enter this view
      if (picker.options.length <= 1) {
        fetch('/api/legacy/hierarchies?size=200', { headers: authHdr })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            var items = d.items || [];
            // Group by setclass so operators see CC/PC/Entity sections clearly.
            var ccHiers = items.filter(function(h) { return _normSc(h.setclass) === '0101'; });
            var pcHiers = items.filter(function(h) { return _normSc(h.setclass) === '0104'; });
