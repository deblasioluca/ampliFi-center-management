      sortTh('mapping','target_center','Target Center','_renderMappingTable') +
      sortTh('mapping','target_name','Target Name','_renderMappingTable') +
      sortTh('mapping','mapping_type','Map Type','_renderMappingTable') +
      sortTh('mapping','notes','Notes','_renderMappingTable') +
      '</tr></thead><tbody>';
    items.forEach(function(m) {
      var typeLabel = m.object_type === 'cost_center' ? 'CC' : 'PC';
      var typeBg = m.object_type === 'cost_center' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800';
      html += '<tr class="border-b hover:bg-gray-50">' +
        '<td class="py-1.5 px-2"><span class="text-[10px] font-medium px-1.5 py-0.5 rounded ' + typeBg + '">' + typeLabel + '</span></td>' +
        '<td class="py-1.5 px-2 font-mono">' + esc(m.legacy_coarea) + '</td>' +
