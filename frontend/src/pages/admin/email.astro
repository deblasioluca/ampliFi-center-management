---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Email Configuration" requireAuth={true} adminOnly={true}>
  <a href="/admin" class="text-sm text-amplifi-600 hover:underline">&larr; Back to Admin</a>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold">Email Configuration</h2>
      <p class="text-sm text-gray-500 mt-1">Configure SMTP for sending review invitations, reminders, and notifications to stakeholders.</p>
    </div>
    <button id="btn-test" class="btn-secondary text-sm">Test Connection</button>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- SMTP Settings -->
    <div class="card">
      <h3 class="text-base font-semibold mb-4">SMTP Settings</h3>
      <form id="smtp-form" class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">SMTP Host</label>
          <input type="text" id="smtp-host" class="input w-full text-sm" placeholder="smtp.example.com" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Port</label>
            <input type="number" id="smtp-port" class="input w-full text-sm" placeholder="587" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Encryption</label>
            <select id="smtp-tls" class="input w-full text-sm">
              <option value="none">None</option>
              <option value="starttls" selected>STARTTLS</option>
              <option value="ssl">SSL/TLS</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Username</label>
          <input type="text" id="smtp-user" class="input w-full text-sm" placeholder="user@example.com" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Password</label>
          <input type="password" id="smtp-pass" class="input w-full text-sm" placeholder="••••••••" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">From Address</label>
          <input type="email" id="smtp-from" class="input w-full text-sm" placeholder="noreply@amplifi.dev" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">From Name</label>
          <input type="text" id="smtp-from-name" class="input w-full text-sm" placeholder="ampliFi Center Management" />
        </div>
        <button type="submit" class="btn-amplifi text-sm w-full">Save SMTP Settings</button>
      </form>
      <div id="smtp-status" class="mt-3 text-sm hidden"></div>
    </div>

    <!-- Test & Templates -->
    <div class="space-y-6">
      <div class="card">
        <h3 class="text-base font-semibold mb-4">Send Test Email</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Recipient</label>
            <input type="email" id="test-email" class="input w-full text-sm" placeholder="admin@example.com" />
          </div>
          <button id="btn-send-test" class="btn-amplifi text-sm w-full">Send Test Email</button>
          <div id="test-result" class="text-sm hidden"></div>
        </div>
      </div>

      <div class="card">
        <h3 class="text-base font-semibold mb-4">Email Templates</h3>
        <div class="space-y-2 text-sm">
          <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
            <div>
              <div class="font-medium">Review Invitation</div>
              <div class="text-xs text-gray-500">Sent when a reviewer is assigned scope</div>
            </div>
            <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Built-in</span>
          </div>
          <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
            <div>
              <div class="font-medium">Review Reminder</div>
              <div class="text-xs text-gray-500">Sent for pending reviews approaching deadline</div>
            </div>
            <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Built-in</span>
          </div>
          <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
            <div>
              <div class="font-medium">Housekeeping Notification</div>
              <div class="text-xs text-gray-500">Sent to cost center owners during housekeeping</div>
            </div>
            <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Built-in</span>
          </div>
          <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
            <div>
              <div class="font-medium">Wave Signed Off</div>
              <div class="text-xs text-gray-500">Sent to admin when all reviewers have signed off</div>
            </div>
            <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Built-in</span>
          </div>
          <div class="flex items-center justify-between p-2 bg-gray-50 rounded">
            <div>
              <div class="font-medium">Password Reset</div>
              <div class="text-xs text-gray-500">Sent for password reset requests</div>
            </div>
            <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Built-in</span>
          </div>
        </div>
      </div>

      <!-- Connection test result -->
      <div id="test-connection-result" class="card hidden">
        <h3 class="text-base font-semibold mb-2">Connection Test Result</h3>
        <div id="test-conn-body" class="text-sm"></div>
      </div>
    </div>
  </div>
</Layout>

<script>
  var token = localStorage.getItem('amplifi_token');
  if (!token) { window.location.href = '/login'; }
  var authHdr = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

  // Load existing config
  fetch('/api/admin/config/email', { headers: authHdr }).then(function(r) {
    if (r.ok) return r.json();
    return null;
  }).then(function(d) {
    if (!d || !d.value) return;
    var v = d.value;
    if (v.host) document.getElementById('smtp-host').value = v.host;
    if (v.port) document.getElementById('smtp-port').value = v.port;
    if (v.tls) document.getElementById('smtp-tls').value = v.tls;
    if (v.username) document.getElementById('smtp-user').value = v.username;
    if (v.from_address) document.getElementById('smtp-from').value = v.from_address;
    if (v.from_name) document.getElementById('smtp-from-name').value = v.from_name;
  });

  // Save SMTP settings
  document.getElementById('smtp-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var data = {
      key: 'email',
      value: {
        host: document.getElementById('smtp-host').value,
        port: parseInt(document.getElementById('smtp-port').value) || 587,
        tls: document.getElementById('smtp-tls').value,
        username: document.getElementById('smtp-user').value,
        password: document.getElementById('smtp-pass').value || undefined,
        from_address: document.getElementById('smtp-from').value,
        from_name: document.getElementById('smtp-from-name').value
      }
    };
    fetch('/api/admin/config/email', { method: 'PUT', headers: authHdr, body: JSON.stringify(data) })
      .then(function(r) { return r.json(); }).then(function(d) {
        var el = document.getElementById('smtp-status');
        el.classList.remove('hidden');
        el.className = 'mt-3 text-sm p-2 rounded bg-green-100 text-green-700';
        el.textContent = 'SMTP settings saved successfully.';
        setTimeout(function() { el.classList.add('hidden'); }, 3000);
      }).catch(function(e) {
        var el = document.getElementById('smtp-status');
        el.classList.remove('hidden');
        el.className = 'mt-3 text-sm p-2 rounded bg-red-100 text-red-700';
        el.textContent = 'Error: ' + e.message;
      });
  });

  // Test connection
  document.getElementById('btn-test').addEventListener('click', function() {
    var el = document.getElementById('test-connection-result');
    el.classList.remove('hidden');
    document.getElementById('test-conn-body').textContent = 'Testing...';
    fetch('/api/admin/config/email/test', { method: 'POST', headers: authHdr })
      .then(function(r) { return r.json(); }).then(function(d) {
        var html = '<div class="flex items-center gap-2">';
        if (d.status === 'ok') {
          html += '<span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs font-medium">Connected</span>';
          html += '<span class="text-gray-500">' + d.host + ':' + d.port + '</span>';
        } else {
          html += '<span class="px-2 py-0.5 bg-red-100 text-red-700 rounded text-xs font-medium">Failed</span>';
          html += '<span class="text-red-600">' + (d.error || 'Unknown error') + '</span>';
        }
        html += '</div>';
        document.getElementById('test-conn-body').innerHTML = html;
      });
  });

  // Send test email
  document.getElementById('btn-send-test').addEventListener('click', function() {
    var email = document.getElementById('test-email').value;
    if (!email) { alert('Enter a recipient email address.'); return; }
    var el = document.getElementById('test-result');
    el.classList.remove('hidden');
    el.className = 'text-sm p-2 rounded bg-blue-100 text-blue-700';
    el.textContent = 'Sending...';
    fetch('/api/admin/config/email/send-test', {
      method: 'POST', headers: authHdr,
      body: JSON.stringify({ to: email })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.sent) {
        el.className = 'text-sm p-2 rounded bg-green-100 text-green-700';
        el.textContent = 'Test email sent to ' + email;
      } else {
        el.className = 'text-sm p-2 rounded bg-red-100 text-red-700';
        el.textContent = 'Failed: ' + (d.error || 'Unknown error');
      }
    });
  });
</script>
