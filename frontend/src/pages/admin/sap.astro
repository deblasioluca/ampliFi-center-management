    ],
    gl_account: [
      { value: 'odata:GLAccountSet',                          label: '[OData] GLAccountSet',              proto: 'odata' },
      { value: 'adt:SKA1',                                    label: '[ADT] Query Table: SKA1 (CoA level)', proto: 'adt' },
      { value: 'rfc:RFC_READ_TABLE:SKA1',                    label: '[RFC] RFC_READ_TABLE on SKA1',      proto: 'soap_rfc' },
    ],
    employee: [
      { value: 'adt:ZUHL_GRD_GPF',                            label: '[ADT] Query Table: ZUHL_GRD_GPF (custom HR)', proto: 'adt' },
      { value: 'rfc:RFC_READ_TABLE:ZUHL_GRD_GPF',            label: '[RFC] RFC_READ_TABLE on ZUHL_GRD_GPF', proto: 'soap_rfc' },
    ],
    entity: [
      { value: 'odata:BusinessCompanyCodeSet',                label: '[OData] BusinessCompanyCodeSet (T001)', proto: 'odata' },
      { value: 'adt:T001',                                    label: '[ADT] Query Table: T001',              proto: 'adt' },
      { value: 'rfc:RFC_READ_TABLE:T001',                    label: '[RFC] RFC_READ_TABLE on T001',         proto: 'soap_rfc' },
    ],
  };

  var _connProtocols = {}; // cache connId -> protocol
  var _connNames = {};     // cache connId -> name

  async function _loadBindings(connId) {
    var el = document.getElementById('bindings-' + connId);
    var connName = _connNames[connId] || '';
    var protocol = _connProtocols[connId] || 'unknown';
    el.classList.remove('hidden');
    el.innerHTML = '<div class="text-gray-500 text-sm">Loading bindings...</div>';
    try {
      var res = await fetch('/api/admin/sap/' + connId + '/bindings', { headers: authHdr });
      var bindings = await res.json();
      var html = '<div class="flex items-center justify-between mb-3">' +
        '<h4 class="text-sm font-semibold text-gray-700">Object Bindings — what to extract from ' + esc(connName) + '</h4>' +
        '<button onclick="addBinding(' + connId + ')" class="btn-sm bg-amber-50 text-amber-700 hover:bg-amber-100">+ Add Binding</button>' +
        '</div>';
      html += '<p class="text-xs text-gray-400 mb-2">Each binding maps an SAP data object to an extraction query. The retrieval method depends on the connection protocol (' + esc(protocol) + ').</p>';
      if (!bindings.length) {
        html += '<p class="text-sm text-gray-400">No bindings yet. Add one to configure data extraction.</p>';
      } else {
        html += '<table class="w-full text-xs"><thead><tr class="bg-gray-50"><th class="px-2 py-1 text-left">Scope</th><th class="px-2 py-1 text-left">Category</th><th class="px-2 py-1 text-left">Object Type</th><th class="px-2 py-1 text-left">Retrieval Method</th><th class="px-2 py-1 text-left">Schedule</th><th class="px-2 py-1 text-left">Status</th><th class="px-2 py-1"></th></tr></thead><tbody>';
        var _scopeLabels = { cleanup: 'CM Cleanup', housekeeping: 'CM HK', explorer: 'Explorer' };
        bindings.forEach(function(b) {
          html += '<tr class="border-t"><td class="px-2 py-1">' + esc(_scopeLabels[b.scope] || b.scope || '-') + '</td>' +
            '<td class="px-2 py-1">' + esc(b.data_category || '-') + '</td>' +
            '<td class="px-2 py-1 font-mono">' + esc(b.object_type) + '</td>' +
            '<td class="px-2 py-1 font-mono text-xs">' + esc(b.entity_set || b.path || '-') + '</td>' +
            '<td class="px-2 py-1">' + esc(b.schedule_cron || 'Manual') + '</td>' +
            '<td class="px-2 py-1">' + (b.enabled ? '<span class="text-green-600">Enabled</span>' : '<span class="text-red-500">Disabled</span>') + '</td>' +
            '<td class="px-2 py-1 flex gap-1">' +
            '<button onclick="testBinding(' + connId + ',' + b.id + ',this)" class="text-xs text-blue-600 hover:text-blue-800" title="Test if this retrieval method works">Test</button>' +
            '<button onclick="deleteBinding(' + connId + ',' + b.id + ')" class="text-xs text-red-500 hover:text-red-700">Delete</button>' +
            '</td></tr>';
        });
        html += '</tbody></table>';
      }
      el.innerHTML = html;
    } catch(err) {
      el.innerHTML = '<div class="text-red-600 text-sm">Error: ' + esc(err.message) + '</div>';
    }
  }

  window.showBindings = async function(connId, connName, protocol) {
    if (connName) _connNames[connId] = connName;
    if (protocol) _connProtocols[connId] = protocol;
    var el = document.getElementById('bindings-' + connId);
    if (!el.classList.contains('hidden')) { el.classList.add('hidden'); return; }
    await _loadBindings(connId);
  };

  window.addBinding = function(connId) {
    var el = document.getElementById('bindings-' + connId);
    if (document.getElementById('add-binding-form-' + connId)) return;
    var protocol = _connProtocols[connId] || 'odata';
    var OBJECT_TYPES = [
      { value: 'cost_center', label: 'Cost Center' },
      { value: 'profit_center', label: 'Profit Center' },
      { value: 'hierarchy', label: 'Hierarchy' },
      { value: 'balance', label: 'Balance' },
      { value: 'gl_account', label: 'GL Account' },
      { value: 'employee', label: 'Employee' },
      { value: 'entity', label: 'Entity (Company Code)' },
    ];

    // Map protocol to matching proto tag for pre-selection
    var protoMap = { 'odata': 'odata', 'adt': 'adt', 'soap_rfc': 'soap_rfc', 'soap': 'soap_rfc' };
    var connProto = protoMap[protocol] || 'odata';

    function getMethodsForType(objType) {
      return RETRIEVAL_METHODS[objType] || [{ value: '', label: 'No known method', proto: '' }];
    }

    var html = '<div id="add-binding-form-' + connId + '" class="mt-3 p-3 bg-gray-50 rounded-lg border">' +
      '<div class="text-sm font-semibold text-gray-700 mb-2">Add New Binding <span class="text-xs text-gray-400 font-normal">Connection protocol: ' + esc(protocol.toUpperCase()) + '</span></div>' +
      '<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-2">' +
      '<div><label class="block text-xs text-gray-500 mb-1">Scope</label>' +
      '<select id="bind-scope-' + connId + '" class="w-full text-sm border rounded px-2 py-1">' +
      '<option value="cleanup">CM Cleanup</option><option value="housekeeping">CM Housekeeping</option><option value="explorer">Data Explorer</option>' +
      '</select></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Category</label>' +
      '<select id="bind-category-' + connId + '" class="w-full text-sm border rounded px-2 py-1">' +
      '<option value="legacy">Legacy</option><option value="target">Target</option>' +
      '</select></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Object Type</label>' +
      '<select id="bind-type-' + connId + '" class="w-full text-sm border rounded px-2 py-1">' +
      OBJECT_TYPES.map(function(t) { return '<option value="' + t.value + '">' + t.label + '</option>'; }).join('') +
      '</select></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Retrieval Method</label>' +
      '<select id="bind-method-' + connId + '" class="w-full text-sm border rounded px-2 py-1"></select>' +
      '<p class="text-[10px] text-gray-400 mt-0.5">All methods shown — matching protocol highlighted with ★</p></div>' +
      '<div><label class="block text-xs text-gray-500 mb-1">Custom Path / Override (optional)</label>' +
      '<input id="bind-entity-' + connId + '" type="text" class="w-full text-sm border rounded px-2 py-1" placeholder="Leave empty to use selected method" /></div>' +
      '<div class="flex items-end gap-2">' +
      '<button onclick="submitBinding(' + connId + ')" class="btn-sm bg-blue-600 text-white hover:bg-blue-700">Save</button>' +
      '<button onclick="document.getElementById(\'add-binding-form-' + connId + '\').remove()" class="btn-sm bg-gray-200 text-gray-700 hover:bg-gray-300">Cancel</button>' +
      '</div></div>' +
      '<div id="bind-balance-params-' + connId + '" class="hidden mt-2 p-2 bg-white rounded border border-gray-200">' +
      '<p class="text-xs font-semibold text-gray-600 mb-2">Balance Selection Parameters</p>' +
      '<div class="grid grid-cols-2 md:grid-cols-4 gap-2">' +
      '<div><label class="block text-[10px] text-gray-500 mb-0.5">Period From</label>' +
      '<input id="bind-period-from-' + connId + '" type="text" class="w-full text-xs border rounded px-2 py-1" placeholder="e.g. 001/2024" /></div>' +
      '<div><label class="block text-[10px] text-gray-500 mb-0.5">Period To</label>' +
      '<input id="bind-period-to-' + connId + '" type="text" class="w-full text-xs border rounded px-2 py-1" placeholder="e.g. 012/2024" /></div>' +
      '<div><label class="block text-[10px] text-gray-500 mb-0.5">Company Code(s)</label>' +
      '<input id="bind-comp-code-' + connId + '" type="text" class="w-full text-xs border rounded px-2 py-1" placeholder="e.g. 1000,2000" /></div>' +
      '<div><label class="block text-[10px] text-gray-500 mb-0.5">Ledger / GAAP</label>' +
      '<input id="bind-ledger-' + connId + '" type="text" class="w-full text-xs border rounded px-2 py-1" placeholder="e.g. 0L, IFRS" /></div>' +
      '</div>' +
      '<p class="text-[10px] text-gray-400 mt-1">These parameters are saved with the binding and applied automatically during extraction.</p>' +
      '</div></div>';
    el.insertAdjacentHTML('beforeend', html);

    var typeSel = document.getElementById('bind-type-' + connId);
    var methodSel = document.getElementById('bind-method-' + connId);

    var balanceParams = document.getElementById('bind-balance-params-' + connId);

    function updateMethods() {
      var methods = getMethodsForType(typeSel.value);
      var firstMatch = -1;
      methodSel.innerHTML = methods.map(function(m, idx) {
        var isMatch = (m.proto === connProto);
        if (isMatch && firstMatch === -1) firstMatch = idx;
        var star = isMatch ? '\u2605 ' : '  ';
        return '<option value="' + esc(m.value) + '"' + (isMatch ? ' class="font-semibold"' : '') + '>' + star + esc(m.label) + '</option>';
      }).join('');
      if (firstMatch >= 0) methodSel.selectedIndex = firstMatch;
      // Show balance selection params when balance is selected
      if (typeSel.value === 'balance') {
        balanceParams.classList.remove('hidden');
      } else {
        balanceParams.classList.add('hidden');
      }
    }
    updateMethods();
    typeSel.addEventListener('change', updateMethods);
  };

  window.submitBinding = async function(connId) {
    var objectType = document.getElementById('bind-type-' + connId).value;
    var methodSel = document.getElementById('bind-method-' + connId);
    var customPath = document.getElementById('bind-entity-' + connId).value.trim();
    var entitySet = customPath || (methodSel ? methodSel.value : null) || null;

    // Collect balance selection params if applicable
    var params = null;
    if (objectType === 'balance') {
      var periodFrom = (document.getElementById('bind-period-from-' + connId) || {}).value || '';
      var periodTo = (document.getElementById('bind-period-to-' + connId) || {}).value || '';
      var compCode = (document.getElementById('bind-comp-code-' + connId) || {}).value || '';
      var ledger = (document.getElementById('bind-ledger-' + connId) || {}).value || '';
      if (periodFrom || periodTo || compCode || ledger) {
        params = {};
        if (periodFrom) params.period_from = periodFrom;
        if (periodTo) params.period_to = periodTo;
        if (compCode) params.company_codes = compCode;
        if (ledger) params.ledger = ledger;
      }
    }

    try {
      var bindScope = (document.getElementById('bind-scope-' + connId) || {}).value || 'cleanup';
      var bindCategory = (document.getElementById('bind-category-' + connId) || {}).value || 'legacy';
      var body = { object_type: objectType, scope: bindScope, data_category: bindCategory, entity_set: entitySet };
      if (params) body.params = params;
      var res = await fetch('/api/admin/sap/' + connId + '/bindings', {
        method: 'POST', headers: jsonHdr,
        body: JSON.stringify(body)
      });
      if (!res.ok) { var err = await res.json(); throw new Error(err.detail || 'Failed'); }
      await _loadBindings(connId);
    } catch(err) { alert('Error: ' + err.message); }
  };

  window.testBinding = async function(connId, bindingId, btn) {
    var origText = btn.textContent;
    btn.textContent = 'Testing...';
    btn.disabled = true;
    try {
      var res = await fetch('/api/admin/sap/' + connId + '/bindings/' + bindingId + '/test', {
        method: 'POST', headers: authHdr
      });
      var data = await res.json();
      if (data.success) {
        btn.textContent = 'OK';
        btn.classList.remove('text-blue-600');
        btn.classList.add('text-green-600');
        setTimeout(function() { btn.textContent = origText; btn.classList.remove('text-green-600'); btn.classList.add('text-blue-600'); btn.disabled = false; }, 3000);
      } else {
        btn.textContent = 'Failed';
        btn.classList.remove('text-blue-600');
        btn.classList.add('text-red-600');
        alert('Test failed: ' + (data.error || 'Unknown error'));
        setTimeout(function() { btn.textContent = origText; btn.classList.remove('text-red-600'); btn.classList.add('text-blue-600'); btn.disabled = false; }, 3000);
      }
    } catch(err) {
      btn.textContent = origText;
      btn.disabled = false;
      alert('Test error: ' + err.message);
    }
  };

  window.deleteBinding = async function(connId, bindingId) {
    if (!confirm('Delete this binding?')) return;
    await fetch('/api/admin/sap/' + connId + '/bindings/' + bindingId, { method: 'DELETE', headers: authHdr });
    await _loadBindings(connId);
  };
})();
</script>
