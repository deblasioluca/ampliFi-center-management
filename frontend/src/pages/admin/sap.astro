---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="SAP Connections" requireAuth={true} adminOnly={true}>
  <a href="/admin" class="text-sm text-amplifi-600 hover:underline">&larr; Back to Admin</a>
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">SAP Connections</h1>
        <p class="text-sm text-gray-500 mt-1">Manage SAP system connections — supports ADT, OData, and SOAP/RFC protocols.
          Use <strong>Connection Trial</strong> to test all endpoints at once and get recommendations.</p>
      </div>
      <button id="btn-new" class="btn-amplifi">+ New Connection</button>
    </div>
  </div>

  <!-- Connections List -->
  <div id="connections-list" class="space-y-4">Loading...</div>

  <!-- Connection Form Modal -->
  <div id="modal-overlay" class="hidden fixed inset-0 bg-black/50 z-40 flex items-start justify-center pt-10">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-[85vh] overflow-y-auto p-6">
      <h2 id="modal-title" class="text-lg font-semibold mb-4">New SAP Connection</h2>
      <form id="sap-form" class="space-y-4">
        <input type="hidden" id="f-id" value="" />
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Connection Name</label>
            <input id="f-name" type="text" class="input" required placeholder="e.g. S4_LEGACY_PROD" />
            <p class="text-xs text-gray-400 mt-0.5">Unique identifier for this SAP system</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">System Type</label>
            <select id="f-system-type" class="input">
              <option value="S/4HANA">S/4HANA</option>
              <option value="ECC">ECC (ERP Central Component)</option>
              <option value="BW">BW/4HANA</option>
              <option value="MDG">MDG Hub</option>
              <option value="CRM">CRM</option>
              <option value="SRM">SRM</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <input id="f-desc" type="text" class="input" placeholder="e.g. Legacy ECC – read-only finance user" />
        </div>
        <div class="grid grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Host</label>
            <input id="f-host" type="text" class="input" placeholder="sap-server.example.com" />
            <p class="text-xs text-gray-400 mt-0.5">DNS hostname or IP</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Port</label>
            <input id="f-port" type="text" class="input" placeholder="443" maxlength="5" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Protocol</label>
            <select id="f-conn-protocol" class="input">
              <option value="https">HTTPS</option>
              <option value="http">HTTP</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Landscape</label>
            <select id="f-landscape" class="input">
              <option value="DEV">Development</option>
              <option value="QAS">Quality</option>
              <option value="PRD">Production</option>
              <option value="SBX">Sandbox</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Base URL (legacy — use Host/Port above instead)</label>
          <input id="f-url" type="text" class="input" placeholder="https://host:port" required />
          <p class="text-xs text-gray-400 mt-0.5">Auto-built from Host/Port if set</p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Client</label>
            <input id="f-client" type="text" class="input" value="100" maxlength="3" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Language</label>
            <input id="f-lang" type="text" class="input" value="EN" maxlength="2" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Primary Protocol</label>
            <select id="f-protocol" class="input">
              <option value="odata">OData (recommended)</option>
              <option value="adt">ADT (ABAP Dev Tools)</option>
              <option value="soap_rfc">SOAP/RFC</option>
            </select>
            <p class="text-xs text-gray-400 mt-0.5">Use "Connection Trial" to test all 3</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
            <input id="f-user" type="text" class="input" required placeholder="SAP user ID" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input id="f-pwd" type="password" class="input" placeholder="Leave blank to keep existing" />
          </div>
        </div>
        <div class="flex items-center gap-6 text-sm">
          <label class="flex items-center gap-2">
            <input id="f-verify-ssl" type="checkbox" checked /> Verify SSL
          </label>
          <label class="flex items-center gap-2">
            <input id="f-use-proxy" type="checkbox" /> Use Proxy
          </label>
          <label class="flex items-center gap-2">
            <input id="f-saml2" type="checkbox" /> Disable SAML2
          </label>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Allowed Tables (for ADT/RFC extraction)</label>
          <input id="f-tables" type="text" class="input" placeholder="T001,CSKS,CEPC,SETHEADER,SETNODE,SETLEAF,FAGLFLEXT" />
          <p class="text-xs text-gray-400 mt-0.5">Comma-separated table names that RFC_READ_TABLE / ADT datapreview may access</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fiori Launchpad URL</label>
            <input id="f-fiori-url" type="text" class="input" placeholder="https://fiori.example.com/sap/bc/ui5_ui5/ui2/ushell/shells/abap/FioriLaunchpad.html" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">WebGUI URL</label>
            <input id="f-webgui-url" type="text" class="input" placeholder="https://host/sap/bc/gui/sap/its/webgui" />
          </div>
        </div>

        <!-- Web Dispatcher -->
        <details class="border rounded-lg">
          <summary class="cursor-pointer px-4 py-2 bg-blue-50 text-sm font-semibold text-blue-700 hover:bg-blue-100">Web Dispatcher (alternative entry point)</summary>
          <div class="p-4 space-y-3">
            <p class="text-xs text-gray-500">Route traffic through a SAP Web Dispatcher instead of directly to the Application Server. Useful when the app server is not directly reachable.</p>
            <div class="grid grid-cols-3 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">WebDisp Host</label>
                <input id="f-wd-host" type="text" class="input text-sm" placeholder="webdisp.example.com" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">WebDisp Port</label>
                <input id="f-wd-port" type="text" class="input text-sm" placeholder="443" maxlength="5" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">WebDisp Protocol</label>
                <select id="f-wd-protocol" class="input text-sm">
                  <option value="https">HTTPS</option>
                  <option value="http">HTTP</option>
                </select>
              </div>
            </div>
            <label class="flex items-center gap-2 text-sm"><input id="f-use-webdisp" type="checkbox" /> Enable Web Dispatcher globally</label>
            <div class="grid grid-cols-3 gap-3 text-xs">
              <label class="block"><span class="text-slate-600">ADT via WebDisp</span>
                <select id="f-adt-use-wd" class="w-full border rounded px-1 py-0.5 text-xs"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select>
              </label>
              <label class="block"><span class="text-slate-600">SOAP via WebDisp</span>
                <select id="f-soap-use-wd" class="w-full border rounded px-1 py-0.5 text-xs"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select>
              </label>
              <label class="block"><span class="text-slate-600">OData via WebDisp</span>
                <select id="f-odata-use-wd" class="w-full border rounded px-1 py-0.5 text-xs"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select>
              </label>
            </div>
          </div>
        </details>

        <!-- Per-Endpoint Overrides -->
        <details class="border rounded-lg">
          <summary class="cursor-pointer px-4 py-2 bg-amber-50 text-sm font-semibold text-amber-700 hover:bg-amber-100">Per-Endpoint Overrides (SSL, Proxy, SAML2)</summary>
          <div class="p-4 space-y-3">
            <p class="text-xs text-gray-500">Override global SSL/Proxy/SAML2 settings per endpoint. Unchecked = inherit from global.</p>
            <table class="w-full text-xs">
              <thead><tr class="bg-gray-50"><th class="px-2 py-1 text-left">Endpoint</th><th class="px-2 py-1">Verify SSL</th><th class="px-2 py-1">Use Proxy</th><th class="px-2 py-1">SAML2 Disabled</th></tr></thead>
              <tbody>
                <tr class="border-t"><td class="px-2 py-1 font-medium">ADT</td>
                  <td class="px-2 py-1 text-center"><select id="f-adt-ssl" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                  <td class="px-2 py-1 text-center"><select id="f-adt-proxy" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                  <td class="px-2 py-1 text-center"><select id="f-adt-saml2" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                </tr>
                <tr class="border-t"><td class="px-2 py-1 font-medium">SOAP/RFC</td>
                  <td class="px-2 py-1 text-center"><select id="f-soap-ssl" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                  <td class="px-2 py-1 text-center"><select id="f-soap-proxy" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                  <td class="px-2 py-1 text-center"><select id="f-soap-saml2" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                </tr>
                <tr class="border-t"><td class="px-2 py-1 font-medium">OData</td>
                  <td class="px-2 py-1 text-center"><select id="f-odata-ssl" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                  <td class="px-2 py-1 text-center"><select id="f-odata-proxy" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                  <td class="px-2 py-1 text-center"><select id="f-odata-saml2" class="text-xs border rounded px-1 py-0.5"><option value="">Inherit</option><option value="true">Yes</option><option value="false">No</option></select></td>
                </tr>
              </tbody>
            </table>
          </div>
        </details>

        <!-- ICF Aliases -->
        <details class="border rounded-lg">
          <summary class="cursor-pointer px-4 py-2 bg-orange-50 text-sm font-semibold text-orange-700 hover:bg-orange-100">ICF Node Aliases (Certificate &amp; Basic Auth paths)</summary>
          <div class="p-4 space-y-3">
            <p class="text-xs text-gray-500">Custom ICF paths for mTLS (certificate) and Basic Auth endpoints. Standard SAP paths are used when not configured.</p>
            <label class="flex items-center gap-2 text-sm"><input id="f-use-icf" type="checkbox" /> Enable ICF Aliases</label>
            <div id="icf-fields" class="space-y-3">
              <table class="w-full text-xs">
                <thead><tr class="bg-gray-50"><th class="px-2 py-1 text-left">Endpoint</th><th class="px-2 py-1 text-left">Source</th><th class="px-2 py-1 text-left">Certificate Path</th><th class="px-2 py-1 text-left">Basic Auth Path</th><th class="px-2 py-1 text-left">Cert Source</th></tr></thead>
                <tbody>
                  <tr class="border-t"><td class="px-2 py-1 font-medium">ADT</td>
                    <td class="px-2 py-1"><select id="f-adt-icf-src" class="text-xs border rounded px-1 py-0.5 w-full"><option value="">Standard</option><option value="global">Global</option><option value="local">Local</option></select></td>
                    <td class="px-2 py-1"><input id="f-adt-icf-cert" type="text" class="text-xs border rounded px-1 py-0.5 w-full" placeholder="/sap/bc/adt_cert" /></td>
                    <td class="px-2 py-1"><input id="f-adt-icf-basic" type="text" class="text-xs border rounded px-1 py-0.5 w-full" placeholder="/sap/bc/adt_basic" /></td>
                    <td class="px-2 py-1"><select id="f-adt-cert-src" class="text-xs border rounded px-1 py-0.5 w-full"><option value="">None</option><option value="global">Global</option><option value="local">Local</option></select></td>
                  </tr>
                  <tr class="border-t"><td class="px-2 py-1 font-medium">SOAP</td>
                    <td class="px-2 py-1"><select id="f-soap-icf-src" class="text-xs border rounded px-1 py-0.5 w-full"><option value="">Standard</option><option value="global">Global</option><option value="local">Local</option></select></td>
                    <td class="px-2 py-1"><input id="f-soap-icf-cert" type="text" class="text-xs border rounded px-1 py-0.5 w-full" placeholder="/sap/bc/soap_cert" /></td>
                    <td class="px-2 py-1"><input id="f-soap-icf-basic" type="text" class="text-xs border rounded px-1 py-0.5 w-full" placeholder="/sap/bc/soap_basic" /></td>
                    <td class="px-2 py-1"><select id="f-soap-cert-src" class="text-xs border rounded px-1 py-0.5 w-full"><option value="">None</option><option value="global">Global</option><option value="local">Local</option></select></td>
                  </tr>
                  <tr class="border-t"><td class="px-2 py-1 font-medium">OData</td>
                    <td class="px-2 py-1"><select id="f-odata-icf-src" class="text-xs border rounded px-1 py-0.5 w-full"><option value="">Standard</option><option value="global">Global</option><option value="local">Local</option></select></td>
                    <td class="px-2 py-1"><input id="f-odata-icf-cert" type="text" class="text-xs border rounded px-1 py-0.5 w-full" placeholder="/sap/opu/odata_cert" /></td>
                    <td class="px-2 py-1"><input id="f-odata-icf-basic" type="text" class="text-xs border rounded px-1 py-0.5 w-full" placeholder="/sap/opu/odata_basic" /></td>
                    <td class="px-2 py-1"><select id="f-odata-cert-src" class="text-xs border rounded px-1 py-0.5 w-full"><option value="">None</option><option value="global">Global</option><option value="local">Local</option></select></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </details>

        <!-- Principal Propagation -->
        <details class="border rounded-lg">
          <summary class="cursor-pointer px-4 py-2 bg-purple-50 text-sm font-semibold text-purple-700 hover:bg-purple-100">Principal Propagation (Entra ID &rarr; SAP)</summary>
          <div class="p-4 space-y-3">
            <p class="text-xs text-gray-500">OAuth2 SAML Bearer token exchange — propagate the Entra ID user identity to SAP for SSO.</p>
            <label class="flex items-center gap-2 text-sm"><input id="f-pp-enabled" type="checkbox" /> Enable Principal Propagation</label>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">SAP OAuth Token URL</label>
                <input id="f-pp-token-url" type="text" class="input text-sm" value="/sap/bc/sec/oauth2/token" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">SAP OAuth Client ID</label>
                <input id="f-pp-client-id" type="text" class="input text-sm" placeholder="OAuth2 client ID in SAP" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">SAP OAuth Client Secret</label>
                <input id="f-pp-client-secret" type="password" class="input text-sm" placeholder="Leave blank to keep existing" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">User Mapping</label>
                <select id="f-pp-user-mapping" class="input text-sm">
                  <option value="email">Email</option>
                  <option value="upn">UPN</option>
                  <option value="sap_user">SAP User</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">SAML Issuer</label>
                <input id="f-pp-saml-issuer" type="text" class="input text-sm" placeholder="e.g. https://sts.windows.net/{tenant-id}/" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">SAML Audience</label>
                <input id="f-pp-saml-audience" type="text" class="input text-sm" placeholder="e.g. https://sap-server/sap/bc/sec/oauth2/token" />
              </div>
            </div>
          </div>
        </details>

        <div class="flex justify-end gap-3 pt-4 border-t">
          <button type="button" id="btn-cancel" class="btn-secondary">Cancel</button>
          <button type="submit" id="btn-save" class="btn-amplifi">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Connection Trial Modal -->
  <div id="trial-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-10">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl max-h-[85vh] overflow-y-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Connection Trial Results</h2>
        <button onclick="document.getElementById('trial-overlay').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <p class="text-xs text-gray-500 mb-4">Tests login credentials, then probes all 3 SAP endpoints (ADT, OData, SOAP/RFC) independently.
        Based on the results, the system recommends the best configuration.</p>
      <div id="trial-results" class="text-sm">Testing...</div>
    </div>
  </div>

  <!-- Service Discovery Modal -->
  <div id="discover-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-10">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl max-h-[85vh] overflow-y-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">OData Service Discovery</h2>
        <button onclick="document.getElementById('discover-overlay').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <p class="text-xs text-gray-500 mb-4">Lists all OData services available on the SAP gateway. Use this to find the right service for each data type.</p>
      <div id="discover-results" class="text-sm">Discovering...</div>
    </div>
  </div>

  <!-- Simple Test Modal (backward compat) -->
  <div id="test-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-20">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Quick Test — <span id="test-proto"></span></h2>
        <button onclick="document.getElementById('test-overlay').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <div id="test-results" class="text-sm">Testing...</div>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  var token = localStorage.getItem('amplifi_token');
  var authHdr = token ? { 'Authorization': 'Bearer ' + token } : {};
  var jsonHdr = token ? { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } : {};
  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }

  function loadConnections() {
    fetch('/api/admin/sap', { headers: authHdr }).then(function(r) { return r.json(); }).then(function(conns) {
      var el = document.getElementById('connections-list');
      if (!conns.length) {
        el.innerHTML = '<div class="card text-center py-8"><p class="text-gray-500">No SAP connections configured.</p>' +
          '<p class="text-xs text-gray-400 mt-2">Click "New Connection" to add your first SAP system. You\'ll configure the host, credentials, and protocol (OData/ADT/SOAP).</p></div>';
        return;
      }
      var html = '';
      conns.forEach(function(c) {
        var protoLabel = { odata: 'OData', adt: 'ADT', soap_rfc: 'SOAP/RFC' }[c.protocol] || c.protocol;
        var protoColor = { odata: 'bg-green-50 text-green-700', adt: 'bg-blue-50 text-blue-700', soap_rfc: 'bg-orange-50 text-orange-700' }[c.protocol] || 'bg-gray-50 text-gray-700';
        html += '<div class="card">' +
          '<div class="flex items-start justify-between">' +
          '<div class="flex-1">' +
          '<div class="flex items-center gap-3">' +
          '<h3 class="font-semibold text-gray-900">' + esc(c.name) + '</h3>' +
          '<span class="text-xs px-2 py-0.5 rounded ' + protoColor + '">' + protoLabel + '</span>' +
          '<span class="text-xs bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded">' + esc(c.system_type) + '</span>' +
          (c.landscape_type ? '<span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">' + esc(c.landscape_type) + '</span>' : '') +
          (c.is_active ? '<span class="text-xs text-green-600">● Active</span>' : '<span class="text-xs text-red-500">● Inactive</span>') +
          '</div>' +
          (c.description ? '<p class="text-sm text-gray-500 mt-1">' + esc(c.description) + '</p>' : '') +
          '<div class="flex items-center gap-4 mt-2 text-xs text-gray-400">' +
          '<span class="font-mono">' + esc(c.host ? (c.conn_protocol || 'https') + '://' + c.host + (c.port ? ':' + c.port : '') : c.base_url) + '</span>' +
          '<span>Client: ' + esc(c.client) + '</span>' +
          '<span>User: ' + esc(c.username) + '</span>' +
          (c.verify_ssl ? '<span title="SSL verified">🔒 SSL</span>' : '<span title="SSL not verified" class="text-yellow-600">⚠ No SSL</span>') +
          (c.use_webdisp ? '<span class="text-blue-500" title="Web Dispatcher enabled">🔀 WD</span>' : '') +
          (c.use_icf_aliases ? '<span class="text-orange-500" title="ICF Aliases configured">🔗 ICF</span>' : '') +
          (c.pp_enabled ? '<span class="text-purple-500" title="Principal Propagation enabled">🔑 PP</span>' : '') +
          '</div>' +
          '</div>' +
          '<div class="flex flex-col gap-1.5 ml-4">' +
