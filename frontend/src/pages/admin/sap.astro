  // --- Quick Test (single protocol) ---
  window.testConn = async function(id) {
    document.getElementById('test-overlay').classList.remove('hidden');
    document.getElementById('test-results').innerHTML = '<div class="text-center py-4"><div class="animate-spin inline-block w-6 h-6 border-2 border-blue-500 border-t-transparent rounded-full"></div><p class="mt-2 text-gray-500">Testing primary protocol...</p></div>';
    try {
      var res = await fetch('/api/admin/sap/' + id + '/test', { method: 'POST', headers: authHdr });
      var d;
      var ct = res.headers.get('content-type') || '';
      if (ct.indexOf('application/json') !== -1) {
        d = await res.json();
      } else {
        var txt = await res.text();
        d = { success: false, error: txt || ('HTTP ' + res.status) };
      }
      document.getElementById('test-proto').textContent = (d.protocol || '').toUpperCase();
      var html = '';
      if (d.success) {
        html = '<div class="bg-green-50 text-green-800 p-3 rounded-lg mb-3"><strong>Connection successful</strong></div>';
      } else {
        html = '<div class="bg-red-50 text-red-800 p-3 rounded-lg mb-3"><strong>Connection failed</strong></div>';
      }
      if (d.detail) html += '<p class="text-sm text-gray-700 mb-2">' + esc(d.detail) + '</p>';
      if (d.latency_ms) html += '<p class="text-xs text-gray-500">Latency: ' + d.latency_ms + ' ms</p>';
      if (d.error) html += '<p class="text-sm text-red-600 mt-2">' + esc(d.error) + '</p>';
      if (d.sso_redirect) html += '<p class="text-sm text-yellow-700 mt-2">⚠ SSO redirect detected. Try enabling "Disable SAML2" on the connection.</p>';
      if (d.services) html += '<p class="text-xs text-gray-500 mt-2">Services: ' + d.services.join(', ') + '</p>';
      html += '<details class="mt-3"><summary class="text-xs cursor-pointer text-gray-400">Raw response</summary><pre class="text-xs mt-2 bg-gray-50 p-3 rounded overflow-x-auto max-h-48">' + esc(JSON.stringify(d, null, 2)) + '</pre></details>';
      document.getElementById('test-results').innerHTML = html;
    } catch(err) {
      document.getElementById('test-results').innerHTML = '<div class="bg-red-50 text-red-800 p-3 rounded">' + esc(err.message) + '</div>';
    }
  };

  // --- Connection Trial (all 3 endpoints) ---
  window.runTrial = async function(id) {
    document.getElementById('trial-overlay').classList.remove('hidden');
    document.getElementById('trial-results').innerHTML = '<div class="text-center py-8"><div class="animate-spin inline-block w-8 h-8 border-3 border-emerald-500 border-t-transparent rounded-full"></div><p class="mt-3 text-gray-500">Running connection trial...</p><p class="text-xs text-gray-400 mt-1">Testing login + ADT + OData + SOAP endpoints</p></div>';
    try {
      var res = await fetch('/api/admin/sap/' + id + '/trial', { method: 'POST', headers: authHdr });
      var d = await res.json();
      var html = '';

      // Login check
      if (d.login_check) {
        var lc = d.login_check;
        var lcClass = lc.success ? 'bg-green-50 border-green-200 text-green-800' : 'bg-red-50 border-red-200 text-red-800';
        html += '<div class="border rounded-lg p-3 mb-4 ' + lcClass + '">' +
          '<div class="flex items-center justify-between">' +
          '<div><strong>Login Check</strong><span class="ml-2 text-xs">(HTTP ' + lc.status_code + ')</span></div>' +
          '<span class="text-xs">' + (lc.latency_ms || 0) + ' ms</span>' +
          '</div>' +
          '<p class="text-sm mt-1">' + esc(lc.detail) + '</p>' +
          (lc.sso_redirect ? '<p class="text-sm mt-1">⚠ SSO redirect — try enabling "Disable SAML2" in connection settings</p>' : '') +
          '</div>';
      }

      // Endpoint probes matrix
      html += '<h3 class="font-semibold text-sm mb-2">Endpoint Probes</h3>';
      html += '<div class="grid grid-cols-3 gap-3 mb-4">';
      var epLabels = { adt: 'ADT', odata: 'OData', soap: 'SOAP/RFC' };
      var epDesc = {
        adt: '/sap/bc/adt/ — ABAP Development Tools REST API. Requires S_DEVELOP authorization.',
        odata: '/sap/opu/odata/ — OData services via SAP Gateway. Requires S_SERVICE authorization.',
        soap: '/sap/bc/soap/rfc — SOAP web services / RFC. Requires S_RFC authorization.'
      };
      (d.probes || []).forEach(function(p) {
        var cls = p.success ? 'border-green-200 bg-green-50' : 'border-red-200 bg-red-50';
        var icon = p.success ? '✓' : '✗';
        var iconCls = p.success ? 'text-green-600' : 'text-red-600';
        html += '<div class="border rounded-lg p-3 ' + cls + '">' +
          '<div class="flex items-center gap-2 mb-1"><span class="text-lg ' + iconCls + '">' + icon + '</span><strong>' + (epLabels[p.endpoint] || p.endpoint) + '</strong></div>' +
          '<p class="text-xs text-gray-600 mb-1">' + esc(epDesc[p.endpoint] || '') + '</p>' +
          '<p class="text-xs">HTTP ' + p.status_code + ' · ' + (p.latency_ms || 0) + ' ms</p>' +
          (p.detail ? '<p class="text-xs mt-1">' + esc(p.detail) + '</p>' : '') +
          (p.error ? '<p class="text-xs text-red-600 mt-1">' + esc(p.error) + '</p>' : '') +
          (p.sso_redirect ? '<p class="text-xs text-yellow-700 mt-1">SSO redirect detected</p>' : '') +
          (p.csrf_token ? '<p class="text-xs text-green-700 mt-1">CSRF token obtained</p>' : '') +
          (p.services_discovered && p.services_discovered.length ? '<p class="text-xs mt-1">Services: ' + p.services_discovered.slice(0,5).join(', ') + (p.services_discovered.length > 5 ? '...' : '') + '</p>' : '') +
          '</div>';
      });
      html += '</div>';

      // Recommendations
      if (d.recommendations && d.recommendations.length) {
        html += '<h3 class="font-semibold text-sm mb-2">Recommendations</h3>';
        html += '<div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-sm">';
        d.recommendations.forEach(function(r) {
          var icon = r.reachable ? '✓' : '✗';
          var cls = r.reachable ? 'text-green-600' : 'text-red-500';
          html += '<div class="flex items-center gap-2 mb-1"><span class="' + cls + '">' + icon + '</span><strong>' + (epLabels[r.endpoint] || r.endpoint) + '</strong>: ' + esc(r.note || (r.reachable ? 'Available' : 'Not available')) + '</div>';
        });
        html += '</div>';
      }

      // Proposed config
      if (d.proposed_config && d.proposed_config.preferred_protocol) {
        html += '<div class="mt-3 bg-emerald-50 border border-emerald-200 rounded-lg p-3 text-sm">' +
          '<strong>Recommended protocol:</strong> ' + esc(d.proposed_config.preferred_protocol.toUpperCase()) +
          '<br/><strong>Available endpoints:</strong> ' + (d.proposed_config.endpoints_available || []).map(function(e) { return e.toUpperCase(); }).join(', ') +
          '</div>';
      }

      document.getElementById('trial-results').innerHTML = html;
    } catch(err) {
      document.getElementById('trial-results').innerHTML = '<div class="bg-red-50 text-red-800 p-3 rounded">' + esc(err.message) + '</div>';
    }
  };

  // --- Service Discovery ---
  window.discoverServices = async function(id) {
    document.getElementById('discover-overlay').classList.remove('hidden');
    document.getElementById('discover-results').innerHTML = '<div class="text-center py-4"><div class="animate-spin inline-block w-6 h-6 border-2 border-purple-500 border-t-transparent rounded-full"></div><p class="mt-2 text-gray-500">Querying OData catalog...</p></div>';
    try {
      var res = await fetch('/api/admin/sap/' + id + '/discover/services', { headers: authHdr });
      if (!res.ok) { var err = await res.json(); throw new Error(err.detail || 'Failed'); }
      var d = await res.json();
      var html = '<p class="text-sm text-gray-700 mb-3"><strong>' + d.count + '</strong> OData services found on ' + esc(d.connection) + '</p>';
      if (d.services && d.services.length) {
        html += '<div class="mb-3"><input id="svc-search" type="text" class="input" placeholder="Search services..." oninput="filterServices()" /></div>';
        html += '<div id="svc-list" class="max-h-96 overflow-y-auto">';
        html += '<table class="w-full text-xs"><thead><tr class="bg-gray-50"><th class="px-2 py-1 text-left">Title</th><th class="px-2 py-1 text-left">ID</th><th class="px-2 py-1 text-left">Version</th><th class="px-2 py-1 text-left">URL</th></tr></thead><tbody>';
        d.services.forEach(function(s) {
          html += '<tr class="svc-row border-t hover:bg-blue-50" data-search="' + esc((s.title + ' ' + s.id + ' ' + s.description).toLowerCase()) + '">' +
            '<td class="px-2 py-1">' + esc(s.title) + '</td>' +
            '<td class="px-2 py-1 font-mono text-gray-500">' + esc(s.id) + '</td>' +
            '<td class="px-2 py-1">' + esc(s.version) + '</td>' +
            '<td class="px-2 py-1 text-gray-400 truncate max-w-[200px]">' + esc(s.url) + '</td></tr>';
        });
        html += '</tbody></table></div>';
      } else {
        html += '<p class="text-gray-500 text-sm">No services found. Check if OData is enabled on the SAP system and the user has S_SERVICE authorization.</p>';
      }
      document.getElementById('discover-results').innerHTML = html;
    } catch(err) {
      document.getElementById('discover-results').innerHTML = '<div class="bg-red-50 text-red-800 p-3 rounded">' + esc(err.message) + '</div>';
    }
  };

