---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Decision Tree Konfiguration" requireAuth={true} adminOnly={true}>
  <div class="flex items-center justify-between mb-4">
    <div>
      <a href="/admin" class="text-sm text-amplifi-600 hover:underline">&larr; Admin</a>
      <h2 class="text-xl font-bold mt-2">Decision Tree Variants</h2>
      <p class="text-sm text-gray-500 mt-1">
        Create and manage decision-tree variants. Pick a preset to start, then
        tweak parameters to your needs.
      </p>
    </div>
    <div class="flex gap-2">
      <button id="btn-ai-assistant" class="btn btn-sm btn-ghost" title="Use the LLM assistant to draft a variant">
        ✨ AI Assistant
      </button>
      <button id="new-from-preset" class="btn btn-primary">+ New variant from preset</button>
    </div>
  </div>

  <!-- Engine selector -->
  <div class="card mb-4 flex items-center gap-3">
    <label class="text-sm text-gray-600">Engine:</label>
    <button id="engine-v1" class="btn btn-sm btn-primary">V1 — Standard Cleansing</button>
    <button id="engine-v2" class="btn btn-sm btn-ghost">V2 — CEMA Migration</button>
    <span class="ml-3 text-xs text-gray-500" id="engine-help">
      V1 is the classic cleansing tree. V2 is CEMA migration with m:1 PC grouping.
    </span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <!-- ── LEFT: Configs list ──────────────────────────────── -->
    <aside class="card lg:col-span-1">
      <h3 class="text-sm font-semibold mb-3">Existing variants</h3>
      <div id="configs-list" class="space-y-1 text-sm max-h-96 overflow-y-auto">
        <div class="text-gray-400 text-xs">Loading…</div>
      </div>
    </aside>

    <!-- ── RIGHT: Editor ────────────────────────────────────── -->
    <main class="card lg:col-span-2">
      <div id="editor-empty" class="text-center py-12 text-gray-400">
        <div class="text-sm">Pick a variant on the left, or create a new one from a preset.</div>
      </div>

      <div id="editor-form" class="hidden space-y-4">
        <div class="flex items-start justify-between border-b pb-3">
          <div>
            <h3 class="font-semibold" id="editor-title">—</h3>
            <p class="text-xs text-gray-500 mt-1" id="editor-subtitle">—</p>
            <span id="preset-badge" class="hidden inline-block mt-1 text-xs bg-amber-100 text-amber-800 px-2 py-0.5 rounded">
              Created from preset
            </span>
          </div>
          <div class="flex gap-2">
            <button id="btn-fork" class="btn btn-sm btn-ghost" title="Fork in neue Version">⎘ Fork</button>
            <button id="btn-amend" class="btn btn-sm btn-primary">Save</button>
          </div>
        </div>

        <!-- Pipeline editor — driven by rule-catalog -->
        <div id="pipeline-editor" class="space-y-3">
          <div class="text-gray-400 text-sm">Loading rule catalog…</div>
        </div>

        <!-- Apply to wave -->
        <div class="border-t pt-4">
          <h4 class="text-sm font-semibold mb-2">Apply this variant to a wave</h4>
          <div class="flex items-center gap-3">
            <select id="apply-wave" class="input text-sm w-64"><option>– select wave –</option></select>
            <select id="apply-mode" class="input text-sm w-40">
              <option value="simulation">Simulation (no save)</option>
              <option value="activated">Activated (commit)</option>
            </select>
            <button id="btn-apply" class="btn btn-sm btn-primary" disabled>▶ Start run</button>
          </div>
          <p class="text-xs text-gray-500 mt-2">
            Tip: Run a <strong>Simulation</strong> first, review the results on the decisions page,
            and only then start <strong>Activated</strong>.
          </p>
        </div>
      </div>
    </main>
  </div>

  <!-- ── Preset picker modal ──────────────────────────────────────── -->
  <div id="preset-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-2xl max-w-2xl w-full m-4 max-h-[80vh] overflow-y-auto">
      <div class="px-5 py-3 border-b flex items-center justify-between">
        <h3 class="font-semibold">New variant from preset</h3>
        <button id="close-modal" class="text-gray-400 hover:text-gray-700">✕</button>
      </div>
      <div class="p-5 space-y-4">
        <p class="text-sm text-gray-600">
          A preset is a pre-configured decision tree. You can adjust it freely after
          creation — the preset itself is not modified.
        </p>
        <div id="presets-list" class="space-y-2"></div>
      </div>
    </div>
  </div>

  <!-- ── LLM Assistant modal ──────────────────────────────────────── -->
  <div id="ai-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-2xl max-w-3xl w-full m-4 max-h-[90vh] overflow-y-auto">
      <div class="px-5 py-3 border-b flex items-center justify-between">
        <h3 class="font-semibold">✨ AI Assistant — draft a variant</h3>
        <button id="ai-close" class="text-gray-400 hover:text-gray-700">✕</button>
      </div>

      <div class="p-5 space-y-4 text-sm">
        <!-- Mode picker -->
        <div class="flex items-center gap-2 text-xs">
          <span class="text-gray-600">Mode:</span>
          <div class="inline-flex rounded-md border border-gray-300 overflow-hidden">
            <button id="ai-mode-quick" type="button"
                    class="px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium">
              Quick draft
            </button>
            <button id="ai-mode-guided" type="button"
                    class="px-3 py-1.5 text-gray-600 hover:bg-gray-50">
              Guided (clarify → propose → refine)
            </button>
          </div>
          <span class="ml-auto text-xs text-gray-500" id="ai-engine-label">Engine: V1</span>
        </div>

        <p class="text-xs text-gray-500">
          Read-only — the assistant proposes an editable draft. Nothing is saved
          until you load it into the editor and hit Save.
        </p>

        <!-- Step 1: description (always visible) -->
        <div>
          <label class="block text-xs text-gray-600 mb-1">Describe the goal of the variant</label>
          <textarea id="ai-description" rows="3" class="input text-sm w-full resize-y"
                    placeholder="e.g. A conservative cleansing config that flags only clearly unused centers — keeps everything else."></textarea>
        </div>

        <!-- Step 2: clarifying questions (guided mode only, after Ask) -->
        <div id="ai-clarify-block" class="hidden border-t pt-3">
          <h4 class="text-sm font-semibold mb-2">Clarifying questions</h4>
          <div id="ai-clarify-questions" class="space-y-3"></div>
        </div>

        <!-- Step 3: draft preview -->
        <div id="ai-draft-block" class="hidden border-t pt-3">
          <h4 class="text-sm font-semibold mb-2">Proposed draft</h4>
          <div id="ai-rationale" class="text-xs text-gray-700 italic mb-2"></div>
          <div id="ai-warnings" class="hidden text-xs bg-amber-50 border border-amber-200 text-amber-800 rounded px-2 py-1.5 mb-2"></div>
          <div id="ai-validation" class="hidden text-xs bg-red-50 border border-red-200 text-red-800 rounded px-2 py-1.5 mb-2"></div>
          <div id="ai-pipeline-preview" class="space-y-1 text-xs"></div>

          <!-- Refine controls (guided mode) -->
          <div id="ai-refine-block" class="hidden mt-3 pt-3 border-t border-dashed">
            <label class="block text-xs text-gray-600 mb-1">Refine — what should change?</label>
            <textarea id="ai-refine-feedback" rows="2" class="input text-sm w-full resize-y"
                      placeholder="e.g. Drop the redundancy rule. Use a tighter inactivity threshold."></textarea>
            <button id="ai-refine-btn" type="button" class="btn btn-sm btn-ghost mt-2">Refine draft</button>
          </div>
        </div>

        <!-- Save -->
        <div id="ai-save-block" class="hidden border-t pt-3">
          <h4 class="text-sm font-semibold mb-2">Save as new variant</h4>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-gray-600 mb-1">Code (unique)</label>
              <input id="ai-save-code" type="text" class="input text-sm w-full"
                     placeholder="e.g. v1-conservative-ai" />
            </div>
            <div>
              <label class="block text-xs text-gray-600 mb-1">Display name</label>
              <input id="ai-save-name" type="text" class="input text-sm w-full"
                     placeholder="e.g. Conservative cleansing (AI-drafted)" />
            </div>
          </div>
          <button id="ai-save-btn" type="button" class="btn btn-sm btn-primary mt-2">
            Save variant
          </button>
          <span id="ai-save-status" class="ml-2 text-xs text-gray-500"></span>
        </div>

        <!-- Action bar (varies by mode + step) -->
        <div class="flex items-center justify-between border-t pt-3">
          <div id="ai-status" class="text-xs text-gray-500 min-h-[1em]"></div>
          <div class="flex gap-2">
            <button id="ai-reset" type="button" class="btn btn-sm btn-ghost">Reset</button>
            <button id="ai-go-btn" type="button" class="btn btn-sm btn-primary">Ask the assistant</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script src="/ui-prompts.js" is:inline></script>
<script>
  const state = {
    engine: 'v1',
    catalog: null,
    presets: null,
    configs: [],
    currentConfigId: null,
    currentConfig: null,
    waves: [],
  };

  // ── API helper — JWT bearer auth via localStorage 'amplifi_token' ─
  const TOKEN = localStorage.getItem('amplifi_token');
  if (!TOKEN) {
    window.location.href = '/login';
  }

  async function api(path, opts = {}) {
    const headers = {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + TOKEN,
      ...(opts.headers || {}),
    };
    const r = await fetch(path, { ...opts, headers });
    if (r.status === 401) {
      // token expired/invalid → bounce to login
      window.location.href = '/login';
      throw new Error('Not authenticated — redirecting to login');
    }
    if (!r.ok) {
      const err = await r.json().catch(() => ({}));
      throw new Error(err.detail || `HTTP ${r.status}`);
    }
    return r.json();
  }

  // ── Boot: fetch catalog + presets + configs + waves ───────────────
  async function boot() {
    const [cat, pre, cfgs, waves] = await Promise.all([
      api(`/api/configs/rule-catalog`),
      api(`/api/configs/presets?engine=${state.engine}`),
      api(`/api/configs?status=active`),
      api(`/api/waves?status=draft,analysing,proposed`).catch(() => ({ items: [] })),
    ]);
    state.catalog = cat.entries;
    state.presets = pre.presets;
    // /api/configs returns a plain list[ConfigOut] (not wrapped in {items}).
    // /api/waves returns {items: [...], total, page, size}. Be defensive about both.
    state.configs = Array.isArray(cfgs) ? cfgs : (cfgs.items || []);
    state.waves = Array.isArray(waves) ? waves : (waves.items || []);
    renderConfigsList();
    renderPresetsList();
    renderWaveDropdown();
  }

  function renderConfigsList() {
    const container = document.getElementById('configs-list');
    if (!state.configs.length) {
      container.innerHTML = `<div class="text-gray-400 text-xs italic py-3">No variants — create a new one.</div>`;
      return;
    }
    container.innerHTML = state.configs.map(c => `
      <div class="px-2 py-2 hover:bg-gray-50 rounded cursor-pointer config-item" data-config-id="${c.id}">
        <div class="font-medium text-sm">${c.name}</div>
        <div class="text-xs text-gray-500">${c.code} · v${c.version}</div>
      </div>
    `).join('');
    container.querySelectorAll('.config-item').forEach(el => {
      el.addEventListener('click', () => loadConfig(el.getAttribute('data-config-id')));
    });
  }

  function renderPresetsList() {
    const list = document.getElementById('presets-list');
    list.innerHTML = state.presets.map(p => `
      <div class="border rounded-lg p-3 hover:bg-amplifi-50 cursor-pointer preset-card" data-preset="${p.name}">
        <div class="flex items-start justify-between">
          <div>
            <div class="font-medium text-sm">${p.label}</div>
            <div class="text-xs text-gray-500 mt-1">${p.description}</div>
          </div>
          <button class="btn btn-sm btn-primary use-preset" data-preset="${p.name}">Choose</button>
        </div>
      </div>
    `).join('');
    list.querySelectorAll('.use-preset').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        instantiatePreset(btn.getAttribute('data-preset'));
      });
    });
  }

  function renderWaveDropdown() {
    const sel = document.getElementById('apply-wave');
    sel.innerHTML = '<option value="">– select wave –</option>' +
      state.waves.map(w => `<option value="${w.id}">${w.name} (${w.status})</option>`).join('');
    sel.addEventListener('change', () => {
      document.getElementById('btn-apply').disabled = !sel.value || !state.currentConfigId;
    });
  }

  // ── Preset instantiation ─────────────────────────────────────────
  async function instantiatePreset(presetName) {
    let friendlyName;
    try {
      friendlyName = await uiPrompt({
        title: 'New variant from preset',
        label: `Name for the new variant (based on '${presetName}'):`,
        defaultValue: `${presetName} ${new Date().toISOString().slice(0, 10)}`,
        helpText: 'You can rename later. The variant is independent — editing it does not change the preset.',
      });
    } catch {
      return; // user cancelled
    }
    try {
      const result = await api(
        `/api/configs/presets/${state.engine}/${presetName}/instantiate`,
        {
          method: 'POST',
          body: JSON.stringify({ name: friendlyName }),
        }
      );
      document.getElementById('preset-modal').classList.add('hidden');
      document.getElementById('preset-modal').classList.remove('flex');
      // Reload list and select the new config.
      // /api/configs returns a plain list, not wrapped in {items}.
      const cfgs = await api(`/api/configs?status=active`);
      state.configs = Array.isArray(cfgs) ? cfgs : (cfgs.items || []);
      renderConfigsList();
      // Pass the CODE, not the numeric id — /api/configs/{code} expects a code string.
      loadConfig(result.code);
    } catch (err) {
      uiAlert('Error: ' + err.message);
    }
  }

  // ── Config editor ────────────────────────────────────────────────
  async function loadConfig(configIdOrCode) {
    // Accept either a numeric id (from list-click data-config-id) or a code
    // string (from instantiatePreset). Resolve to code via the in-memory
    // list, then GET /api/configs/{code}.
    let code = String(configIdOrCode);
    if (/^\d+$/.test(code)) {
      const fromList = state.configs.find(c => String(c.id) === code);
      if (fromList) {
        code = fromList.code;
      } else {
        // The list might be stale (just-instantiated config). Refresh once.
        const cfgs = await api(`/api/configs`);
        state.configs = Array.isArray(cfgs) ? cfgs : (cfgs.items || []);
        const found = state.configs.find(c => String(c.id) === String(configIdOrCode));
        if (!found) {
          alert(`Config not found (id=${configIdOrCode})`);
          return;
        }
        code = found.code;
      }
    }
    const cfg = await api(`/api/configs/${encodeURIComponent(code)}`);
    if (!cfg || !cfg.code) {
      alert('Config could not be loaded.');
      return;
    }
    state.currentConfig = cfg;
    state.currentConfigId = cfg.id;
    document.getElementById('editor-empty').classList.add('hidden');
    document.getElementById('editor-form').classList.remove('hidden');
    document.getElementById('editor-title').textContent = cfg.name || cfg.code;
    document.getElementById('editor-subtitle').textContent =
      `${cfg.code} · Version ${cfg.version} · ${cfg.description || ''}`;
    const presetBadge = document.getElementById('preset-badge');
    if (cfg.config?._preset_origin) {
      presetBadge.textContent = `From preset: ${cfg.config._preset_origin}`;
      presetBadge.classList.remove('hidden');
    } else {
      presetBadge.classList.add('hidden');
    }
    renderPipelineEditor(cfg.config);
    document.getElementById('btn-apply').disabled =
      !document.getElementById('apply-wave').value;
  }

  function renderPipelineEditor(configData) {
    const container = document.getElementById('pipeline-editor');
    const pipeline = configData?.pipeline || [];
    if (!pipeline.length) {
      container.innerHTML = `<div class="text-gray-400 text-sm">Pipeline is empty.</div>`;
      return;
    }
    container.innerHTML = pipeline.map((step, idx) => {
      const meta = state.catalog?.find(c => c.code === step.routine);
      if (!meta) {
        return `<div class="border rounded p-2 text-xs text-gray-400">${step.routine} (no catalog entry)</div>`;
      }
      return renderPipelineStep(step, meta, idx);
    }).join('');
    bindPipelineHandlers();
  }

  function renderPipelineStep(step, meta, idx) {
    const decidesBadges = (meta.decides || []).map(d => {
      const colors = {
        KEEP: 'green', RETIRE: 'red', MERGE_MAP: 'orange', REDESIGN: 'blue',
        CC: 'indigo', PC_ONLY: 'purple', CC_AND_PC: 'pink',
        WBS_REAL: 'teal', WBS_STAT: 'cyan', '1:1': 'gray', '1:n': 'purple',
        MIGRATE: 'emerald', PASS: 'gray',
      };
      const c = colors[d] || 'gray';
      return `<span class="text-[10px] bg-${c}-100 text-${c}-700 px-1.5 py-0.5 rounded mr-1">${d}</span>`;
    }).join('');

    const paramsHtml = Object.entries(meta.params || {}).map(([pname, pmeta]) => {
      const value = step.params?.[pname] ?? pmeta.default;
      return renderParamControl(idx, pname, pmeta, value);
    }).join('');

    return `
      <div class="border rounded-lg overflow-hidden" data-step-idx="${idx}">
        <div class="bg-gray-50 px-3 py-2 flex items-center gap-2">
          <input type="checkbox" ${step.enabled !== false ? 'checked' : ''}
                 class="step-enabled" data-step-idx="${idx}" />
          <div class="flex-1">
            <div class="font-medium text-sm">${meta.business_label}</div>
            <div class="text-xs text-gray-500 font-mono">${meta.code}</div>
          </div>
          <div>${decidesBadges}</div>
        </div>
        <div class="p-3 text-sm">
          <p class="text-xs text-gray-600 mb-3 leading-relaxed">${meta.description}</p>
          ${paramsHtml ? `<div class="space-y-3">${paramsHtml}</div>` : '<div class="text-xs text-gray-400 italic">No parameters</div>'}
        </div>
      </div>
    `;
  }

  function renderParamControl(stepIdx, pname, pmeta, value) {
    const help = pmeta.help_text || '';
    const label = pmeta.friendly_label || pname;
    const unit = pmeta.unit || '';

    if (pmeta.type === 'boolean') {
      return `
        <label class="flex items-start gap-2">
          <input type="checkbox" class="param-input mt-0.5" data-step="${stepIdx}" data-param="${pname}" data-type="boolean" ${value ? 'checked' : ''} />
          <div class="flex-1">
            <span class="text-sm font-medium">${label}</span>
            <p class="text-xs text-gray-500 mt-0.5">${help}</p>
          </div>
        </label>
      `;
    }

    if (pmeta.type === 'integer' || pmeta.type === 'number') {
      const step = pmeta.step || (pmeta.type === 'integer' ? 1 : 0.01);
      return `
        <div>
          <label class="flex items-center justify-between">
            <span class="text-sm font-medium">${label}</span>
            <span class="text-xs text-gray-500">${value} ${unit}</span>
          </label>
          <input type="range" class="param-input w-full mt-1"
                 min="${pmeta.min}" max="${pmeta.max}" step="${step}" value="${value}"
                 data-step="${stepIdx}" data-param="${pname}" data-type="${pmeta.type}"
                 oninput="this.parentElement.querySelector('span:last-of-type').textContent = this.value + ' ${unit}'" />
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </div>
      `;
    }

    if (pmeta.enum) {
      return `
        <div>
          <label class="text-sm font-medium">${label}</label>
          <select class="param-input input text-sm w-full mt-1"
                  data-step="${stepIdx}" data-param="${pname}" data-type="enum">
            ${pmeta.enum.map(opt => `<option value="${opt}" ${opt === value ? 'selected' : ''}>${opt}</option>`).join('')}
          </select>
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </div>
      `;
    }

    // Default: text input
    return `
      <div>
        <label class="text-sm font-medium">${label}</label>
        <input type="text" class="param-input input text-sm w-full mt-1"
               value="${value || ''}"
               data-step="${stepIdx}" data-param="${pname}" data-type="string" />
        <p class="text-xs text-gray-500 mt-1">${help}</p>
      </div>
    `;
  }

  function bindPipelineHandlers() {
    // Collect changes into state.currentConfig
    document.querySelectorAll('.step-enabled').forEach(el => {
      el.addEventListener('change', e => {
        const idx = parseInt(e.target.getAttribute('data-step-idx'), 10);
        state.currentConfig.config.pipeline[idx].enabled = e.target.checked;
      });
    });
    document.querySelectorAll('.param-input').forEach(el => {
      el.addEventListener('change', e => {
        const t = e.target;
        const stepIdx = parseInt(t.getAttribute('data-step'), 10);
        const pname = t.getAttribute('data-param');
        const ptype = t.getAttribute('data-type');
        const step = state.currentConfig.config.pipeline[stepIdx];
        step.params = step.params || {};
        if (ptype === 'boolean') step.params[pname] = t.checked;
        else if (ptype === 'integer') step.params[pname] = parseInt(t.value, 10);
        else if (ptype === 'number') step.params[pname] = parseFloat(t.value);
        else step.params[pname] = t.value;
      });
    });
  }

  // ── Save / Apply ─────────────────────────────────────────────────
  document.getElementById('btn-amend').addEventListener('click', async () => {
    if (!state.currentConfigId) return;
    try {
      await api(`/api/configs/${state.currentConfig.code}/amend`, {
        method: 'POST',
        body: JSON.stringify({ config: state.currentConfig.config }),
      });
      uiToast('Variant saved (new version created).', { kind: 'success' });
      boot();
    } catch (err) {
      uiAlert('Error: ' + err.message);
    }
  });

  document.getElementById('btn-fork').addEventListener('click', async () => {
    if (!state.currentConfigId) return;
    let newCode;
    try {
      newCode = await uiPrompt({
        title: 'Fork variant',
        label: 'New code for the fork:',
        defaultValue: state.currentConfig.code + '-copy',
        helpText: 'A short identifier — this is what shows up in URLs and logs.',
      });
    } catch {
      return;
    }
    try {
      await api(`/api/configs/${state.currentConfig.code}/fork`, {
        method: 'POST',
        body: JSON.stringify({ new_code: newCode, name: state.currentConfig.name + ' (Fork)' }),
      });
      uiToast('Fork created.', { kind: 'success' });
      boot();
    } catch (err) {
      uiAlert({ message: 'Error: ' + err.message, kind: 'danger' });
    }
  });

  document.getElementById('btn-apply').addEventListener('click', async () => {
    const waveId = document.getElementById('apply-wave').value;
    const mode = document.getElementById('apply-mode').value;
    if (!waveId || !state.currentConfigId) return;
    try {
      const result = await api(`/api/waves/${waveId}/analyse-with-engine`, {
        method: 'POST',
        body: JSON.stringify({
          engine: state.engine,
          config_id: state.currentConfigId,
          mode,
        }),
      });
      const url = `/cockpit/decisions?run_id=${result.run_id || result.id}`;
      uiToast(`Run #${result.run_id || result.id} started.`, { kind: 'success' });
      const goNow = await uiConfirm({
        title: 'Run started',
        message: `Run #${result.run_id || result.id} is now running. Open the results page to watch progress?`,
        okLabel: 'Open results',
        cancelLabel: 'Stay here',
      });
      if (goNow) {
        window.location.href = url;
      }
    } catch (err) {
      uiAlert('Error: ' + err.message);
    }
  });

  // ── UI controls ──────────────────────────────────────────────────
  document.getElementById('engine-v1').addEventListener('click', () => switchEngine('v1'));
  document.getElementById('engine-v2').addEventListener('click', () => switchEngine('v2'));
  document.getElementById('new-from-preset').addEventListener('click', () => {
    document.getElementById('preset-modal').classList.remove('hidden');
    document.getElementById('preset-modal').classList.add('flex');
  });
  document.getElementById('close-modal').addEventListener('click', () => {
    document.getElementById('preset-modal').classList.add('hidden');
    document.getElementById('preset-modal').classList.remove('flex');
  });

  function switchEngine(v) {
    state.engine = v;
    document.getElementById('engine-v1').classList.toggle('btn-primary', v === 'v1');
    document.getElementById('engine-v1').classList.toggle('btn-ghost', v !== 'v1');
    document.getElementById('engine-v2').classList.toggle('btn-primary', v === 'v2');
    document.getElementById('engine-v2').classList.toggle('btn-ghost', v !== 'v2');
    document.getElementById('engine-help').textContent = v === 'v1'
      ? 'V1 is the classic cleansing tree.'
      : 'V2 is CEMA migration with m:1 PC grouping.';
    boot();
  }

  // ── LLM AI Assistant — Drafter (single-shot) + Configurator (guided) ──
  const ai = {
    mode: 'quick',
    currentDraft: null,
    rationale: null,
    clarifications: [],   // [{question, answer}]
    questions: [],        // staged questions from clarify step
  };

  function aiSetMode(mode) {
    ai.mode = mode;
    const quick = document.getElementById('ai-mode-quick');
    const guided = document.getElementById('ai-mode-guided');
    const onCls = 'px-3 py-1.5 bg-amplifi-50 text-amplifi-700 font-medium';
    const offCls = 'px-3 py-1.5 text-gray-600 hover:bg-gray-50';
    quick.className = mode === 'quick' ? onCls : offCls;
    guided.className = mode === 'guided' ? onCls : offCls;
    document.getElementById('ai-go-btn').textContent =
      mode === 'guided' ? 'Ask clarifying questions' : 'Draft variant';
  }

  function aiResetUI() {
    ai.currentDraft = null;
    ai.rationale = null;
    ai.clarifications = [];
    ai.questions = [];
    document.getElementById('ai-clarify-block').classList.add('hidden');
    document.getElementById('ai-clarify-questions').innerHTML = '';
    document.getElementById('ai-draft-block').classList.add('hidden');
    document.getElementById('ai-refine-block').classList.add('hidden');
    document.getElementById('ai-save-block').classList.add('hidden');
    document.getElementById('ai-save-status').textContent = '';
    document.getElementById('ai-save-code').value = '';
    document.getElementById('ai-save-name').value = '';
    document.getElementById('ai-status').textContent = '';
    document.getElementById('ai-go-btn').disabled = false;
  }

  function aiOpenModal() {
    aiResetUI();
    document.getElementById('ai-engine-label').textContent =
      'Engine: ' + (state.engine || 'v1').toUpperCase();
    document.getElementById('ai-modal').classList.remove('hidden');
    document.getElementById('ai-modal').classList.add('flex');
  }

  function aiCloseModal() {
    document.getElementById('ai-modal').classList.add('hidden');
    document.getElementById('ai-modal').classList.remove('flex');
  }

  function aiEscape(s) {
    const d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function aiRenderClarifyQuestions(questions) {
    const wrap = document.getElementById('ai-clarify-questions');
    wrap.innerHTML = '';
    if (!questions || !questions.length) {
      wrap.innerHTML = '<p class="text-xs text-gray-500">The assistant didn\'t need clarification — proposing draft directly.</p>';
      return false;
    }
    questions.forEach((q, idx) => {
      const opts = (q.options || []).map((o, oi) =>
        `<button type="button" data-q="${idx}" data-opt="${aiEscape(o)}"
                 class="ai-clarify-opt btn btn-sm btn-ghost text-xs">${aiEscape(o)}</button>`
      ).join('');
      const div = document.createElement('div');
      div.className = 'border rounded p-2 bg-gray-50';
      div.innerHTML =
        `<div class="text-xs font-medium mb-1">${aiEscape(q.question)}</div>` +
        `<div class="flex flex-wrap gap-1 mb-1">${opts}</div>` +
        `<input type="text" class="ai-clarify-input input text-xs w-full" data-q="${idx}"
                placeholder="Or type your own answer…" />`;
      wrap.appendChild(div);
    });
    // Click handlers for option buttons
    wrap.querySelectorAll('.ai-clarify-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-q');
        const opt = btn.getAttribute('data-opt');
        wrap.querySelector(`input.ai-clarify-input[data-q="${idx}"]`).value = opt;
        // Highlight selection
        wrap.querySelectorAll(`.ai-clarify-opt[data-q="${idx}"]`).forEach(b =>
          b.classList.remove('bg-amplifi-100', 'text-amplifi-800', 'font-medium'));
        btn.classList.add('bg-amplifi-100', 'text-amplifi-800', 'font-medium');
      });
    });
    return true;
  }

  function aiRenderDraft(draft, rationale, warnings, validation) {
    ai.currentDraft = draft;
    ai.rationale = rationale;
    document.getElementById('ai-rationale').textContent = rationale || '';
    const warnEl = document.getElementById('ai-warnings');
    if (warnings && warnings.length) {
      warnEl.innerHTML = '<strong>Caveats:</strong> ' +
        warnings.map(aiEscape).join(' · ');
      warnEl.classList.remove('hidden');
    } else {
      warnEl.classList.add('hidden');
    }
    const valEl = document.getElementById('ai-validation');
    if (validation && !validation.ok && validation.invalid_codes && validation.invalid_codes.length) {
      valEl.innerHTML = '<strong>Validation issues:</strong> the LLM proposed unknown routine codes: ' +
        validation.invalid_codes.map(c => `<code>${aiEscape(c)}</code>`).join(', ') +
        '. These will be ignored on save.';
      valEl.classList.remove('hidden');
    } else {
      valEl.classList.add('hidden');
    }
    const pipeline = (draft && draft.pipeline) || [];
    const rows = pipeline.map((step, i) => {
      const params = step.params || {};
      const paramStr = Object.keys(params).length
        ? ' · ' + Object.entries(params).map(([k, v]) => `${k}=${JSON.stringify(v)}`).join(', ')
        : '';
      return `<div class="border-l-2 ${step.enabled === false ? 'border-gray-300 opacity-60' : 'border-amplifi-400'} pl-2 py-0.5">
        <span class="text-gray-400">${i + 1}.</span>
        <code class="font-mono">${aiEscape(step.routine)}</code>
        ${step.enabled === false ? '<span class="text-[10px] text-gray-400">disabled</span>' : ''}
        <span class="text-[10px] text-gray-500">${aiEscape(paramStr)}</span>
      </div>`;
    }).join('');
    document.getElementById('ai-pipeline-preview').innerHTML = rows ||
      '<div class="text-xs text-gray-400">(empty pipeline)</div>';
    document.getElementById('ai-draft-block').classList.remove('hidden');
    document.getElementById('ai-save-block').classList.remove('hidden');
    if (ai.mode === 'guided') {
      document.getElementById('ai-refine-block').classList.remove('hidden');
    }
    // Default save code based on engine + first routine
    const codeInput = document.getElementById('ai-save-code');
    if (!codeInput.value) {
      codeInput.value = `${state.engine}-ai-${Date.now().toString().slice(-6)}`;
    }
  }

  async function aiHandleGo() {
    const desc = document.getElementById('ai-description').value.trim();
    if (!desc) {
      document.getElementById('ai-status').textContent = 'Please describe the goal first.';
      return;
    }
    const goBtn = document.getElementById('ai-go-btn');
    goBtn.disabled = true;
    document.getElementById('ai-status').textContent = 'Asking the assistant…';
    try {
      if (ai.mode === 'quick') {
        // Single-shot drafter
        const data = await api('/api/admin/configs/draft-from-description', {
          method: 'POST',
          body: JSON.stringify({ description: desc, engine: state.engine }),
        });
        if (!data.available) {
          document.getElementById('ai-status').textContent =
            'Assistant unavailable: ' + (data.reason || 'unknown');
          return;
        }
        aiRenderDraft(data.draft, data.rationale, data.warnings, data.validation);
        document.getElementById('ai-status').textContent =
          `Draft ready · ${data.model || '?'} · ${data.tokens_in || 0} in / ${data.tokens_out || 0} out tokens`;
      } else {
        // Guided — first call: clarify
        if (!ai.questions.length && ai.clarifications.length === 0 &&
            document.getElementById('ai-clarify-block').classList.contains('hidden')) {
          const data = await api('/api/admin/configs/configure-stepwise', {
            method: 'POST',
            body: JSON.stringify({
              step: 'clarify', description: desc, engine: state.engine,
            }),
          });
          if (!data.available) {
            document.getElementById('ai-status').textContent =
              'Assistant unavailable: ' + (data.reason || 'unknown');
            return;
          }
          ai.questions = data.questions || [];
          const hasQuestions = aiRenderClarifyQuestions(ai.questions);
          document.getElementById('ai-clarify-block').classList.remove('hidden');
          if (hasQuestions) {
            document.getElementById('ai-status').textContent =
              'Answer the questions, then click "Propose draft".';
            document.getElementById('ai-go-btn').textContent = 'Propose draft';
          } else {
            // No questions → go straight to propose with empty clarifications
            document.getElementById('ai-go-btn').textContent = 'Propose draft';
            await aiProposeStep(desc);
          }
        } else if (!ai.currentDraft) {
          // We have questions answered → propose
          // Collect answers
          ai.clarifications = ai.questions.map((q, idx) => {
            const inp = document.querySelector(
              `#ai-clarify-questions input.ai-clarify-input[data-q="${idx}"]`);
            return { question: q.question, answer: (inp && inp.value || '').trim() };
          }).filter(c => c.answer);
          await aiProposeStep(desc);
        } else {
          document.getElementById('ai-status').textContent =
            'Use "Refine draft" below to iterate, or save the variant.';
        }
      }
    } catch (err) {
      document.getElementById('ai-status').textContent =
        'Request failed: ' + (err && err.message || err);
    } finally {
      goBtn.disabled = false;
    }
  }

  async function aiProposeStep(desc) {
    const data = await api('/api/admin/configs/configure-stepwise', {
      method: 'POST',
      body: JSON.stringify({
        step: 'propose',
        description: desc,
        engine: state.engine,
        clarifications: ai.clarifications,
      }),
    });
    if (!data.available) {
      document.getElementById('ai-status').textContent =
        'Assistant unavailable: ' + (data.reason || 'unknown');
      return;
    }
    aiRenderDraft(data.draft, data.rationale, data.warnings, data.validation);
    document.getElementById('ai-status').textContent =
      `Draft ready · ${data.model || '?'} · ${data.tokens_in || 0} in / ${data.tokens_out || 0} out tokens`;
    document.getElementById('ai-go-btn').textContent = 'Done — save below';
    document.getElementById('ai-go-btn').disabled = true;
  }

  async function aiHandleRefine() {
    const feedback = document.getElementById('ai-refine-feedback').value.trim();
    if (!feedback) {
      document.getElementById('ai-status').textContent = 'Please describe what to change.';
      return;
    }
    if (!ai.currentDraft) {
      document.getElementById('ai-status').textContent = 'No draft to refine yet.';
      return;
    }
    const btn = document.getElementById('ai-refine-btn');
    btn.disabled = true;
    document.getElementById('ai-status').textContent = 'Refining…';
    try {
      const data = await api('/api/admin/configs/configure-stepwise', {
        method: 'POST',
        body: JSON.stringify({
          step: 'refine',
          engine: state.engine,
          draft: ai.currentDraft,
          user_feedback: feedback,
        }),
      });
      if (!data.available) {
        document.getElementById('ai-status').textContent =
          'Refine failed: ' + (data.reason || 'unknown');
        return;
      }
      aiRenderDraft(data.draft, data.rationale, data.warnings, data.validation);
      document.getElementById('ai-refine-feedback').value = '';
      document.getElementById('ai-status').textContent =
        `Refined · ${data.model || '?'} · ${data.tokens_in || 0} in / ${data.tokens_out || 0} out tokens`;
    } catch (err) {
      document.getElementById('ai-status').textContent =
        'Refine failed: ' + (err && err.message || err);
    } finally {
      btn.disabled = false;
    }
  }

  async function aiHandleSave() {
    const code = document.getElementById('ai-save-code').value.trim();
    const name = document.getElementById('ai-save-name').value.trim();
    if (!code || !name) {
      document.getElementById('ai-save-status').textContent = 'Code and name are required.';
      return;
    }
    if (!ai.currentDraft) {
      document.getElementById('ai-save-status').textContent = 'No draft to save.';
      return;
    }
    const btn = document.getElementById('ai-save-btn');
    btn.disabled = true;
    document.getElementById('ai-save-status').textContent = 'Saving…';
    try {
      await api('/api/configs', {
        method: 'POST',
        body: JSON.stringify({
          code,
          name,
          description: ai.rationale ? `AI-drafted: ${ai.rationale}` : 'AI-drafted variant',
          config: ai.currentDraft,
        }),
      });
      document.getElementById('ai-save-status').textContent = 'Saved! Refreshing list…';
      // Refresh the configs list via existing boot, then close
      await boot();
      setTimeout(aiCloseModal, 600);
    } catch (err) {
      document.getElementById('ai-save-status').textContent =
        'Save failed: ' + (err && err.message || err);
    } finally {
      btn.disabled = false;
    }
  }

  // Wire up AI Assistant
  document.getElementById('btn-ai-assistant').addEventListener('click', aiOpenModal);
  document.getElementById('ai-close').addEventListener('click', aiCloseModal);
  document.getElementById('ai-reset').addEventListener('click', () => {
    document.getElementById('ai-description').value = '';
    aiResetUI();
  });
  document.getElementById('ai-mode-quick').addEventListener('click', () => {
    aiSetMode('quick'); aiResetUI();
  });
  document.getElementById('ai-mode-guided').addEventListener('click', () => {
    aiSetMode('guided'); aiResetUI();
  });
  document.getElementById('ai-go-btn').addEventListener('click', aiHandleGo);
  document.getElementById('ai-refine-btn').addEventListener('click', aiHandleRefine);
  document.getElementById('ai-save-btn').addEventListener('click', aiHandleSave);

  // Boot
  boot().catch(err => {
    document.getElementById('configs-list').innerHTML =
      `<div class="text-red-600 text-xs">Error loading: ${err.message}</div>`;
  });
</script>
