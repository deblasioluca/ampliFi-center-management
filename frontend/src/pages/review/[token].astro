---
import Layout from '../../components/layout/Layout.astro';
export const prerender = false;
---

<Layout title="Review" requireAuth={false}>
  <div id="review-app">
    <div id="review-header" class="mb-6">Loading review scope...</div>
    <!-- View toggle -->
    <div id="review-toolbar" class="hidden flex items-center justify-between mb-4 border-b pb-3">
      <div class="flex gap-2 items-center">
        <select id="review-filter" class="input text-sm w-40" onchange="window._loadItems(1)">
          <option value="">All Items</option>
          <option value="PENDING">Pending</option>
          <option value="APPROVED">Approved</option>
          <option value="NOT_REQUIRED">Not Required</option>
          <option value="COMMENTED">Commented</option>
        </select>
        <select id="review-view" class="input text-sm w-48" onchange="window._switchView(this.value)">
          <option value="comparison">Side-by-Side Comparison</option>
          <option value="flat">Flat List</option>
          <option value="entity">Group by Entity</option>
          <option value="outcome">Group by Outcome</option>
        </select>
        <input type="text" id="review-search" class="input text-sm w-48" placeholder="Search CC / name..."
          oninput="clearTimeout(window._searchT); window._searchT=setTimeout(function(){window._loadItems(1)},300)" />
      </div>
      <div class="flex gap-2">
        <button onclick="bulkApprove()" class="btn-sm bg-green-600 text-white hover:bg-green-700">Approve All Pending</button>
        <button onclick="requestChanges()" class="btn-sm bg-yellow-600 text-white hover:bg-yellow-700">Request Changes</button>
        <button onclick="completeReview()" class="btn-sm bg-amplifi-600 text-white hover:bg-amplifi-700">Complete Review</button>
      </div>
    </div>
    <div id="review-content"></div>
  </div>

  <!-- Comparison Detail Modal -->
  <div id="compare-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-8">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-6xl max-h-[85vh] overflow-y-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold" id="compare-title">Center Comparison</h2>
        <button onclick="document.getElementById('compare-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <div id="compare-body" class="text-sm"></div>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  var pathParts = window.location.pathname.split('/');
  var reviewToken = pathParts[pathParts.length - 1];
  if (!reviewToken) { document.getElementById('review-header').textContent = 'Invalid review URL.'; return; }

  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }
  var currentView = 'comparison';
  var allItems = [];

  // Load scope summary
  fetch('/api/review/' + reviewToken).then(function(r) {
    if (!r.ok) throw new Error(r.status === 410 ? 'This review link has expired or been completed.' : 'Invalid review link.');
    return r.json();
  }).then(function(scope) {
    var pct = scope.total_items ? Math.round(scope.decided_items / scope.total_items * 100) : 0;
    document.getElementById('review-header').innerHTML =
      '<h1 class="text-2xl font-bold text-gray-900">Review: ' + esc(scope.name) + '</h1>' +
      '<p class="text-sm text-gray-500 mt-1">Review the proposed changes below. Compare the <strong>current center</strong> (left) with the <strong>proposed new center</strong> (right). Approve, reject, or add comments to each item.</p>' +
      '<div class="flex items-center gap-4 mt-2">' +
      '<span class="text-sm text-gray-600">' + scope.decided_items + ' / ' + scope.total_items + ' decided (' + pct + '%)</span>' +
      '<div class="flex-1 h-2 bg-gray-200 rounded-full"><div class="h-full bg-amplifi-500 rounded-full transition-all" style="width:' + pct + '%"></div></div>' +
      '</div>';
    document.getElementById('review-toolbar').classList.remove('hidden');
    loadItems(1);
  }).catch(function(e) {
    document.getElementById('review-header').innerHTML = '<div class="text-red-600 text-lg">' + esc(e.message) + '</div>';
  });

  function loadItems(page) {
    var decision = '';
    var filterEl = document.getElementById('review-filter');
    if (filterEl) decision = filterEl.value;
    var search = (document.getElementById('review-search') || {}).value || '';
    var url = '/api/review/' + reviewToken + '/items?page=' + page + '&size=20';
    if (decision) url += '&decision=' + decision;
    if (search) url += '&search=' + encodeURIComponent(search);

    fetch(url).then(function(r) { return r.json(); }).then(function(d) {
      allItems = d.items || [];
      if (currentView === 'comparison') renderComparison(d);
      else if (currentView === 'flat') renderFlat(d);
      else renderGrouped(d, currentView);
    });
  }
  window._loadItems = loadItems;

  window._switchView = function(view) {
    currentView = view;
    loadItems(1);
  };

  // ---- Comparison View (default) ----
  function renderComparison(d) {
    var el = document.getElementById('review-content');
    if (!d.items || !d.items.length) { el.innerHTML = '<p class="text-gray-500 py-8 text-center">No items to review.</p>'; return; }

    var html = '<div class="space-y-4">';
    d.items.forEach(function(item) {
      var bgColor = item.decision === 'APPROVED' ? 'border-green-300 bg-green-50/50' :
                    item.decision === 'NOT_REQUIRED' ? 'border-gray-300 bg-gray-50/50' :
                    item.decision === 'COMMENTED' ? 'border-yellow-300 bg-yellow-50/50' : 'border-gray-200';
      var outColor = { KEEP: 'text-green-700 bg-green-100', RETIRE: 'text-red-700 bg-red-100',
                      MERGE_MAP: 'text-orange-700 bg-orange-100', REDESIGN: 'text-blue-700 bg-blue-100' }[item.cleansing_outcome] || 'bg-gray-100';

      html += '<div class="border-2 rounded-lg ' + bgColor + '" id="item-' + item.id + '">';

      // Header bar
      html += '<div class="flex items-center justify-between px-4 py-2 border-b bg-white/80 rounded-t-lg">' +
        '<div class="flex items-center gap-3">' +
        '<span class="font-mono font-semibold">' + esc(item.cctr || 'CC #' + item.proposal_id) + '</span>' +
        '<span class="px-2 py-0.5 rounded text-xs font-medium ' + outColor + '">' + esc(item.cleansing_outcome || '-') + '</span>' +
        (item.target_object ? '<span class="text-xs text-gray-500 bg-gray-100 px-1.5 py-0.5 rounded">→ ' + esc(item.target_object) + '</span>' : '') +
        (item.entity_code ? '<span class="text-xs text-gray-400">Entity: ' + esc(item.entity_code || item.ccode) + '</span>' : '') +
        '</div>' +
        '<div class="flex gap-1.5">';

      if (item.decision === 'PENDING') {
        html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="btn-sm bg-green-600 text-white hover:bg-green-700 text-xs px-3">Approve</button>' +
          '<button onclick="decide(' + item.id + ',\'NOT_REQUIRED\')" class="btn-sm bg-gray-500 text-white hover:bg-gray-600 text-xs px-3">Not Required</button>' +
          '<button onclick="decide(' + item.id + ',\'COMMENTED\')" class="btn-sm bg-yellow-500 text-white hover:bg-yellow-600 text-xs px-3">Comment</button>';
      } else {
        var decColor = item.decision === 'APPROVED' ? 'bg-green-600' : item.decision === 'COMMENTED' ? 'bg-yellow-500' : 'bg-gray-500';
        html += '<span class="text-xs text-white px-2 py-1 rounded ' + decColor + '">' + item.decision + '</span>' +
          '<button onclick="decide(' + item.id + ',\'PENDING\')" class="btn-sm text-xs text-gray-500 hover:bg-gray-100">Undo</button>';
      }
      html += '</div></div>';

      // Two-column comparison: Old (left) vs New (right)
      html += '<div class="grid grid-cols-2 gap-0 divide-x">';

      // LEFT: Current / Legacy Center
      html += '<div class="p-4">';
      html += '<h4 class="text-xs font-semibold text-gray-500 uppercase mb-2">Current Center (Legacy)</h4>';
      html += '<table class="w-full text-xs">';
      html += '<tr><td class="py-0.5 text-gray-400 w-1/3">Cost Center</td><td class="py-0.5 font-mono">' + esc(item.cctr || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Name</td><td class="py-0.5">' + esc(item.txtsh || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Description</td><td class="py-0.5">' + esc(item.txtmi || item.txtsh || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Company Code</td><td class="py-0.5">' + esc(item.ccode || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Controlling Area</td><td class="py-0.5">' + esc(item.coarea || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Profit Center</td><td class="py-0.5 font-mono">' + esc(item.pctr || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Responsible</td><td class="py-0.5">' + esc(item.responsible || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Category</td><td class="py-0.5">' + esc(item.cctrcgy || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Currency</td><td class="py-0.5">' + esc(item.currency || '-') + '</td></tr>';
      if (item.total_balance !== undefined) html += '<tr><td class="py-0.5 text-gray-400">Total Balance</td><td class="py-0.5 font-mono">' + (item.total_balance || '0') + '</td></tr>';
      if (item.posting_count !== undefined) html += '<tr><td class="py-0.5 text-gray-400">Posting Count</td><td class="py-0.5">' + (item.posting_count || '0') + '</td></tr>';
      html += '</table></div>';

      // RIGHT: Proposed New Center
      html += '<div class="p-4 bg-blue-50/30">';
      html += '<h4 class="text-xs font-semibold text-blue-600 uppercase mb-2">Proposed New Center</h4>';
      html += '<table class="w-full text-xs">';

      if (item.cleansing_outcome === 'RETIRE') {
        html += '<tr><td colspan="2" class="py-4 text-center text-red-600"><span class="text-2xl">×</span><br/>This center will be <strong>retired</strong>.<br/>No new center is proposed.</td></tr>';
      } else if (item.cleansing_outcome === 'MERGE_MAP') {
        html += '<tr><td colspan="2" class="py-4 text-center text-orange-600"><span class="text-2xl">⟶</span><br/>This center will be <strong>merged</strong> into:<br/><span class="font-mono font-semibold">' + esc(item.merge_into_cctr || 'TBD') + '</span></td></tr>';
      } else if (item.cleansing_outcome === 'REDESIGN') {
        html += '<tr><td class="py-0.5 text-gray-400 w-1/3">Cost Center</td><td class="py-0.5 font-mono text-blue-700">' + esc(item.new_cctr || item.cctr || '-') + ' <span class="text-xs text-blue-500">(redesigned)</span></td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Name</td><td class="py-0.5 text-blue-700">' + esc(item.new_txtsh || item.txtsh || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Target Type</td><td class="py-0.5"><span class="bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded text-xs">' + esc(item.target_object || '-') + '</span></td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Responsible</td><td class="py-0.5">' + esc(item.new_responsible || item.responsible || '-') + '</td></tr>';
      } else {
        // KEEP → new center created from old, possibly with new ID
        html += '<tr><td class="py-0.5 text-gray-400 w-1/3">Cost Center</td><td class="py-0.5 font-mono text-green-700">' + esc(item.new_cctr || item.cctr || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Name</td><td class="py-0.5">' + esc(item.new_txtsh || item.txtsh || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Target Type</td><td class="py-0.5"><span class="bg-green-100 text-green-700 px-1.5 py-0.5 rounded text-xs">' + esc(item.target_object || '-') + '</span></td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Profit Center</td><td class="py-0.5 font-mono">' + esc(item.new_pctr || item.pctr || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Responsible</td><td class="py-0.5">' + esc(item.new_responsible || item.responsible || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Company Code</td><td class="py-0.5">' + esc(item.ccode || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Currency</td><td class="py-0.5">' + esc(item.currency || '-') + '</td></tr>';
      }
      html += '</table></div>';
      html += '</div>'; // end grid

      // Decision path + confidence
      if (item.rule_path || item.confidence) {
        html += '<div class="px-4 py-2 border-t bg-gray-50/50 text-xs">';
        if (item.confidence) html += '<span class="text-gray-500">Confidence: <strong>' + Math.round(item.confidence * 100) + '%</strong></span> ';
        if (item.rule_path) {
          var steps = item.rule_path.steps || item.rule_path;
          if (Array.isArray(steps) && steps.length) {
            html += '<details class="inline"><summary class="cursor-pointer text-blue-600">Decision path (' + steps.length + ' steps)</summary>' +
              '<ul class="ml-4 list-disc text-gray-500 mt-1">';
            steps.forEach(function(s) { html += '<li>' + esc(s) + '</li>'; });
            html += '</ul></details>';
          }
        }
        html += '</div>';
      }

      // Comment
      if (item.comment) {
        html += '<div class="px-4 py-2 border-t bg-yellow-50 text-xs"><span class="text-gray-500">Comment:</span> <em>' + esc(item.comment) + '</em></div>';
      }

      html += '</div>'; // end card
    });
    html += '</div>';

    // Pager
    var pages = Math.ceil(d.total / d.size) || 1;
    html += '<div class="flex items-center justify-between mt-4 text-sm">' +
      '<span class="text-gray-500">' + d.total + ' items, page ' + d.page + '/' + pages + '</span>' +
      '<div class="flex gap-1">' +
      (d.page > 1 ? '<button onclick="window._loadItems(' + (d.page-1) + ')" class="btn-sm">← Prev</button>' : '') +
      (d.page < pages ? '<button onclick="window._loadItems(' + (d.page+1) + ')" class="btn-sm">Next →</button>' : '') +
      '</div></div>';

    el.innerHTML = html;
  }

  // ---- Flat List View ----
  function renderFlat(d) {
    var el = document.getElementById('review-content');
    if (!d.items || !d.items.length) { el.innerHTML = '<p class="text-gray-500 py-8 text-center">No items to review.</p>'; return; }

    var html = '<table class="w-full text-sm"><thead><tr class="bg-gray-50 text-xs text-gray-500 uppercase">' +
      '<th class="px-3 py-2 text-left">CC</th><th class="px-3 py-2 text-left">Name</th>' +
      '<th class="px-3 py-2 text-left">Entity</th><th class="px-3 py-2 text-left">Outcome</th>' +
      '<th class="px-3 py-2 text-left">Target</th><th class="px-3 py-2 text-left">Decision</th>' +
      '<th class="px-3 py-2 text-right">Actions</th></tr></thead><tbody>';

    d.items.forEach(function(item) {
      var outColor = { KEEP: 'text-green-700 bg-green-100', RETIRE: 'text-red-700 bg-red-100',
                      MERGE_MAP: 'text-orange-700 bg-orange-100', REDESIGN: 'text-blue-700 bg-blue-100' }[item.cleansing_outcome] || 'bg-gray-100';
      var decColor = { APPROVED: 'text-green-700 bg-green-100', NOT_REQUIRED: 'text-gray-600 bg-gray-100',
                      COMMENTED: 'text-yellow-700 bg-yellow-100', PENDING: 'text-gray-500 bg-gray-50' }[item.decision] || '';
      html += '<tr class="border-t hover:bg-blue-50/50">' +
        '<td class="px-3 py-2 font-mono text-xs">' + esc(item.cctr) + '</td>' +
        '<td class="px-3 py-2 text-xs">' + esc(item.txtsh || '-') + '</td>' +
        '<td class="px-3 py-2 text-xs">' + esc(item.ccode || '-') + '</td>' +
        '<td class="px-3 py-2"><span class="px-1.5 py-0.5 rounded text-xs ' + outColor + '">' + esc(item.cleansing_outcome) + '</span></td>' +
        '<td class="px-3 py-2 text-xs">' + esc(item.target_object || '-') + '</td>' +
        '<td class="px-3 py-2"><span class="px-1.5 py-0.5 rounded text-xs ' + decColor + '">' + esc(item.decision) + '</span></td>' +
        '<td class="px-3 py-2 text-right">';
      if (item.decision === 'PENDING') {
        html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-xs text-green-600 hover:underline mr-2">Approve</button>' +
          '<button onclick="decide(' + item.id + ',\'COMMENTED\')" class="text-xs text-yellow-600 hover:underline">Comment</button>';
      } else {
        html += '<button onclick="decide(' + item.id + ',\'PENDING\')" class="text-xs text-gray-500 hover:underline">Undo</button>';
      }
      html += '</td></tr>';
    });
    html += '</tbody></table>';

    var pages = Math.ceil(d.total / d.size) || 1;
    html += '<div class="flex items-center justify-between mt-4 text-sm">' +
      '<span class="text-gray-500">' + d.total + ' items, page ' + d.page + '/' + pages + '</span>' +
      '<div class="flex gap-1">' +
      (d.page > 1 ? '<button onclick="window._loadItems(' + (d.page-1) + ')" class="btn-sm">← Prev</button>' : '') +
      (d.page < pages ? '<button onclick="window._loadItems(' + (d.page+1) + ')" class="btn-sm">Next →</button>' : '') +
      '</div></div>';
    el.innerHTML = html;
  }

  // ---- Grouped View ----
  function renderGrouped(d, mode) {
    fetch('/api/review/' + reviewToken + '/items?size=500').then(function(r) { return r.json(); }).then(function(dAll) {
      if (!dAll.items) return;
      var groups = {};
      dAll.items.forEach(function(item) {
        var key = mode === 'entity' ? (item.ccode || 'Unknown') : (item.cleansing_outcome || 'Unknown');
        if (!groups[key]) groups[key] = [];
        groups[key].push(item);
      });
      var el = document.getElementById('review-content');
      var html = '<div class="space-y-4">';
      Object.keys(groups).sort().forEach(function(key) {
        var items = groups[key];
        var pending = items.filter(function(i) { return i.decision === 'PENDING'; }).length;
        html += '<details class="card" open>' +
          '<summary class="cursor-pointer font-semibold text-sm">' + esc(key) +
          ' <span class="text-gray-400 font-normal">(' + items.length + ' items, ' + pending + ' pending)</span></summary>' +
          '<div class="mt-2 space-y-1">';
        items.forEach(function(item) {
          var outColor = { KEEP: 'text-green-700', RETIRE: 'text-red-700', MERGE_MAP: 'text-orange-700', REDESIGN: 'text-blue-700' }[item.cleansing_outcome] || '';
          html += '<div class="flex items-center justify-between text-xs py-1 border-t">' +
            '<div class="flex items-center gap-2">' +
            '<span class="font-mono">' + esc(item.cctr) + '</span>' +
            '<span class="' + outColor + '">' + esc(item.cleansing_outcome) + '</span>' +
            '<span class="text-gray-400">' + esc(item.txtsh || '') + '</span></div>' +
            '<div class="flex gap-1">';
          if (item.decision === 'PENDING') {
            html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-green-600 hover:underline">Approve</button>' +
              '<button onclick="decide(' + item.id + ',\'COMMENTED\')" class="text-yellow-600 hover:underline ml-2">Comment</button>';
          } else {
            html += '<span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700">' + item.decision + '</span>';
          }
          html += '</div></div>';
        });
        html += '</div></details>';
      });
      html += '</div>';
      el.innerHTML = html;
    });
  }

  // ---- Decision Handling ----
  window.decide = async function(itemId, decision) {
    var comment = null;
    if (decision === 'COMMENTED') {
      comment = prompt('Enter your comment:');
      if (comment === null) return;
    }
    await fetch('/api/review/' + reviewToken + '/items/' + itemId + '/decide', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ decision: decision, comment: comment })
    });
    loadItems(1);
    fetch('/api/review/' + reviewToken).then(function(r) { return r.json(); }).then(function(scope) {
      var pct = scope.total_items ? Math.round(scope.decided_items / scope.total_items * 100) : 0;
      var bar = document.querySelector('#review-header .bg-amplifi-500');
      if (bar) bar.style.width = pct + '%';
    });
  };

  window.bulkApprove = async function() {
    if (!confirm('Approve all visible pending items?')) return;
    var res = await fetch('/api/review/' + reviewToken + '/items?size=1000&decision=PENDING');
    var d = await res.json();
    var ids = (d.items || []).map(function(i) { return i.id; });
    if (!ids.length) { alert('No pending items.'); return; }
    await fetch('/api/review/' + reviewToken + '/items/bulk-decide', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_ids: ids, decision: 'APPROVED' })
    });
    loadItems(1);
  };

  window.requestChanges = async function() {
    var comment = prompt('Describe the changes you are requesting:');
    if (!comment) return;
    await fetch('/api/review/' + reviewToken + '/request-changes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ comment: comment })
    });
    alert('Change request submitted.');
    loadItems(1);
  };

  window.completeReview = async function() {
    if (!confirm('Submit this review? This marks your review as complete.')) return;
    try {
      var res = await fetch('/api/review/' + reviewToken + '/complete', { method: 'POST' });
      if (res.ok) {
        alert('Review submitted successfully. Thank you!');
        window.location.reload();
      } else {
        var err = await res.json();
        alert('Error: ' + (err.detail || 'Failed to submit'));
      }
    } catch(e) { alert('Error: ' + e.message); }
  };

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'TEXTAREA') return;
    if (e.key === 'ArrowDown' || e.key === 'j') {
      e.preventDefault();
      var items = document.querySelectorAll('[id^="item-"]');
      var current = document.querySelector('[id^="item-"].ring-2');
      if (!current && items.length) { items[0].classList.add('ring-2', 'ring-amplifi-400'); items[0].scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      else if (current) {
        var idx = Array.from(items).indexOf(current);
        current.classList.remove('ring-2', 'ring-amplifi-400');
        if (idx < items.length - 1) { items[idx + 1].classList.add('ring-2', 'ring-amplifi-400'); items[idx + 1].scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      }
    }
    if (e.key === 'ArrowUp' || e.key === 'k') {
      e.preventDefault();
      var items = document.querySelectorAll('[id^="item-"]');
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) {
        var idx = Array.from(items).indexOf(current);
        current.classList.remove('ring-2', 'ring-amplifi-400');
        if (idx > 0) { items[idx - 1].classList.add('ring-2', 'ring-amplifi-400'); items[idx - 1].scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      }
    }
    if (e.key === 'a' || e.key === 'A') {
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) { var id = parseInt(current.id.replace('item-', '')); decide(id, 'APPROVED'); }
    }
    if (e.key === 'n' || e.key === 'N') {
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) { var id = parseInt(current.id.replace('item-', '')); decide(id, 'NOT_REQUIRED'); }
    }
    if (e.key === 'c' || e.key === 'C') {
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) { var id = parseInt(current.id.replace('item-', '')); decide(id, 'COMMENTED'); }
    }
  });
})();
