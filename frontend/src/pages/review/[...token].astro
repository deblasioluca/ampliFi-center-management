---
import Layout from '../../components/layout/Layout.astro';

export function getStaticPaths() {
  return [{ params: { token: undefined } }];
}
---

<Layout title="Review" requireAuth={false}>
  <div id="review-app">
    <div id="review-header" class="mb-6">Loading review scope...</div>
    <!-- View toggle -->
    <div id="review-toolbar" class="hidden flex items-center justify-between mb-4 border-b pb-3">
      <div class="flex gap-2 items-center">
        <select id="review-filter" class="input text-sm w-40" onchange="window._loadItems(1)">
          <option value="">All Items</option>
          <option value="PENDING">Pending</option>
          <option value="APPROVED">Approved</option>
          <option value="NOT_REQUIRED">Not Required</option>
          <option value="COMMENTED">Commented</option>
          <option value="NEW_REQUEST">New Requests</option>
        </select>
        <select id="review-view" class="input text-sm w-48" onchange="window._switchView(this.value)">
          <option value="comparison">Side-by-Side Comparison</option>
          <option value="flat">Flat List</option>
          <option value="hierarchy">Legacy Hierarchy</option>
          <option value="proposed">Proposed (New) Structure</option>
          <option value="entity">Group by Entity</option>
          <option value="outcome">Group by Outcome</option>
        </select>
        <input type="text" id="review-search" class="input text-sm w-48" placeholder="Search CC / name..."
          oninput="clearTimeout(window._searchT); window._searchT=setTimeout(function(){window._loadItems(1)},300)" />
      </div>
      <div class="flex gap-2">
        <button onclick="bulkApprove()" class="btn-sm bg-green-600 text-white hover:bg-green-700">Approve All Pending</button>
        <button onclick="openNewCenterModal()" class="btn-sm bg-blue-600 text-white hover:bg-blue-700">+ Request New Center</button>
        <button onclick="requestChanges()" class="btn-sm bg-yellow-600 text-white hover:bg-yellow-700">Request Changes</button>
        <button onclick="completeReview()" class="btn-sm bg-amplifi-600 text-white hover:bg-amplifi-700">Complete Review</button>
      </div>
    </div>
    <div id="review-content"></div>

    <!-- Center Mapping Reference (collapsible) -->
    <div id="review-mapping-section" class="hidden mt-6 border rounded-lg">
      <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('span').textContent = this.nextElementSibling.classList.contains('hidden') ? '▸' : '▾'" class="w-full text-left px-4 py-2 bg-gray-50 rounded-t-lg text-sm font-medium text-gray-700 hover:bg-gray-100">
        <span>▸</span> Center Mapping Overview
      </button>
      <div class="hidden">
        <div id="review-mapping-view" class="text-xs"></div>
      </div>
    </div>
  </div>

  <!-- Request New / Clone Center Modal -->
  <div id="new-center-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-16">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold" id="nc-modal-title">Request New Center</h2>
        <button onclick="document.getElementById('new-center-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <div id="nc-clone-info" class="hidden bg-blue-50 border border-blue-200 rounded p-3 text-xs text-blue-700 mb-3">
        <strong>Cloning from:</strong> <span id="nc-clone-label"></span>
        <p class="mt-1 text-blue-600">Fields pre-filled. Amend as needed.</p>
      </div>
      <form id="new-center-form" class="space-y-3">
        <input type="hidden" id="nc-clone-from" value="" />
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">Type</label>
            <select id="nc-target" class="input text-sm w-full">
              <option value="CC">Cost Center</option>
              <option value="PC">Profit Center</option>
              <option value="CC_AND_PC">Both CC + PC</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">Responsible</label>
            <input id="nc-responsible" type="text" class="input text-sm w-full" placeholder="Owner name..." />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Proposed Name <span class="text-red-500">*</span></label>
          <input id="nc-name" type="text" class="input text-sm w-full" placeholder="Short text / description..." required />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">Entity (Company Code)</label>
            <input id="nc-ccode" type="text" class="input text-sm w-full" placeholder="e.g. 1000" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">Hierarchy Node</label>
            <select id="nc-hier-node" class="input text-sm w-full">
              <option value="">(none)</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Purpose / Justification <span class="text-red-500">*</span></label>
          <textarea id="nc-purpose" class="input text-sm w-full h-20" placeholder="Why is this center needed?" required></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Balance Sheet Relevance</label>
          <input id="nc-bs" type="text" class="input text-sm w-full" placeholder="e.g. 'Direct revenue posting expected'" />
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" onclick="document.getElementById('new-center-modal').classList.add('hidden')" class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-amplifi">Submit Request</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Comparison Detail Modal -->
  <div id="compare-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-8">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-6xl max-h-[85vh] overflow-y-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold" id="compare-title">Center Comparison</h2>
        <button onclick="document.getElementById('compare-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <div id="compare-body" class="text-sm"></div>
    </div>
  </div>

  <!-- Data Quality Issue Resolution Modal -->
  <div id="dq-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-12">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-[80vh] overflow-y-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Data Quality Issues — <span id="dq-modal-cc" class="font-mono text-amplifi-600"></span></h2>
        <button onclick="document.getElementById('dq-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <div id="dq-modal-body" class="space-y-3 text-sm"></div>
    </div>
  </div>

  <!-- Employee Picker Modal (for DQ resolution) -->
  <div id="emp-picker-modal" class="hidden fixed inset-0 bg-black/50 z-[60] flex items-start justify-center pt-16">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[70vh] overflow-y-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Select Employee</h2>
        <button onclick="document.getElementById('emp-picker-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <input type="text" id="emp-search-input" class="input text-sm w-full mb-3" placeholder="Search by GPN, name, or email..."
        oninput="clearTimeout(window._empST); window._empST=setTimeout(function(){searchEmployees()},300)" />
      <div id="emp-search-results" class="space-y-1 text-sm max-h-96 overflow-y-auto"></div>
    </div>
  </div>
</Layout>

<script is:inline src="/center-mapping-view.js"></script>
<script is:inline>
(function() {
  var pathParts = window.location.pathname.split('/');
  var reviewToken = pathParts[pathParts.length - 1];
  if (!reviewToken) { document.getElementById('review-header').textContent = 'Invalid review URL.'; return; }

  function esc(t) { var d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }
  var currentView = 'comparison';
  var allItems = [];

  // Load scope summary
  fetch('/api/review/' + reviewToken).then(function(r) {
    if (!r.ok) throw new Error(r.status === 410 ? 'This review link has expired or been completed.' : 'Invalid review link.');
    return r.json();
  }).then(function(scope) {
    var pct = scope.total_items ? Math.round(scope.decided_items / scope.total_items * 100) : 0;
    document.getElementById('review-header').innerHTML =
      '<h1 class="text-2xl font-bold text-gray-900">Review: ' + esc(scope.name) + '</h1>' +
      '<p class="text-sm text-gray-500 mt-1">Review the proposed changes below. Compare the <strong>current center</strong> (left) with the <strong>proposed new center</strong> (right). Approve, reject, or add comments to each item.</p>' +
      '<p class="text-xs text-gray-400 mt-1">Keyboard: <kbd class="px-1 bg-gray-100 rounded">j/k</kbd> navigate &middot; <kbd class="px-1 bg-gray-100 rounded">a</kbd> approve &middot; <kbd class="px-1 bg-gray-100 rounded">n</kbd> not required &middot; <kbd class="px-1 bg-gray-100 rounded">c</kbd> comment</p>' +
      '<div class="flex items-center gap-4 mt-2">' +
      '<span class="text-sm text-gray-600">' + scope.decided_items + ' / ' + scope.total_items + ' decided (' + pct + '%)</span>' +
      '<div class="flex-1 h-2 bg-gray-200 rounded-full"><div class="h-full bg-amplifi-500 rounded-full transition-all" style="width:' + pct + '%"></div></div>' +
      '</div>';
    document.getElementById('review-toolbar').classList.remove('hidden');
    // Show center mapping reference section
    document.getElementById('review-mapping-section').classList.remove('hidden');
    if (window.CenterMappingView) {
      var mv = new window.CenterMappingView({
        containerId: 'review-mapping-view',
        scope: scope.scope_name || '',
        authHeaders: {},
      });
      mv.load();
    }
    loadItems(1);
  }).catch(function(e) {
    document.getElementById('review-header').innerHTML = '<div class="text-red-600 text-lg">' + esc(e.message) + '</div>';
  });

  function loadItems(page) {
    var decision = '';
    var filterEl = document.getElementById('review-filter');
    if (filterEl) decision = filterEl.value;
    var search = (document.getElementById('review-search') || {}).value || '';
    var url = '/api/review/' + reviewToken + '/items?page=' + page + '&size=20';
    if (decision) url += '&decision=' + decision;
    if (search) url += '&search=' + encodeURIComponent(search);

    fetch(url).then(function(r) { return r.json(); }).then(function(d) {
      allItems = d.items || [];
      if (currentView === 'comparison') renderComparison(d);
      else if (currentView === 'flat') renderFlat(d);
      else if (currentView === 'hierarchy') renderHierarchy(d);
      else if (currentView === 'proposed') renderProposed(d);
      else renderGrouped(d, currentView);
    });
  }
  window._loadItems = loadItems;

  window._switchView = function(view) {
    currentView = view;
    loadItems(1);
  };

  // ---- Comparison View (default) ----
  function renderComparison(d) {
    var el = document.getElementById('review-content');
    if (!d.items || !d.items.length) { el.innerHTML = '<p class="text-gray-500 py-8 text-center">No items to review.</p>'; return; }

    var html = '<div class="space-y-4">';
    d.items.forEach(function(item) {
      var bgColor = item.decision === 'APPROVED' ? 'border-green-300 bg-green-50/50' :
                    item.decision === 'NOT_REQUIRED' ? 'border-gray-300 bg-gray-50/50' :
                    item.decision === 'COMMENTED' ? 'border-yellow-300 bg-yellow-50/50' : 'border-gray-200';
      var outColor = { KEEP: 'text-green-700 bg-green-100', RETIRE: 'text-red-700 bg-red-100',
                      MERGE_MAP: 'text-orange-700 bg-orange-100', REDESIGN: 'text-blue-700 bg-blue-100' }[item.cleansing_outcome] || 'bg-gray-100';

      html += '<div class="border-2 rounded-lg ' + bgColor + '" id="item-' + item.id + '">';

      // Header bar
      html += '<div class="flex items-center justify-between px-4 py-2 border-b bg-white/80 rounded-t-lg">' +
        '<div class="flex items-center gap-3">' +
        '<span class="font-mono font-semibold">' + esc(item.cctr || 'CC #' + item.proposal_id) + '</span>' +
        '<span class="px-2 py-0.5 rounded text-xs font-medium ' + outColor + '">' + esc(item.cleansing_outcome || '-') + '</span>' +
        (item.target_object ? '<span class="text-xs text-gray-500 bg-gray-100 px-1.5 py-0.5 rounded">→ ' + esc(item.target_object) + '</span>' : '') +
        (item.entity_code ? '<span class="text-xs text-gray-400">Entity: ' + esc(item.entity_code || item.ccode) + '</span>' : '') +
        '</div>' +
        '<div class="flex gap-1.5">';

      if (item.decision === 'PENDING') {
        html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="btn-sm bg-green-600 text-white hover:bg-green-700 text-xs px-3">Approve</button>' +
          '<button onclick="decide(' + item.id + ',\'NOT_REQUIRED\')" class="btn-sm bg-gray-500 text-white hover:bg-gray-600 text-xs px-3">Not Required</button>' +
          '<button onclick="decide(' + item.id + ',\'COMMENTED\')" class="btn-sm bg-yellow-500 text-white hover:bg-yellow-600 text-xs px-3">Comment</button>';
      } else {
        var decColor = item.decision === 'APPROVED' ? 'bg-green-600' : item.decision === 'COMMENTED' ? 'bg-yellow-500' : 'bg-gray-500';
        html += '<span class="text-xs text-white px-2 py-1 rounded ' + decColor + '">' + item.decision + '</span>' +
          '<button onclick="decide(' + item.id + ',\'PENDING\')" class="btn-sm text-xs text-gray-500 hover:bg-gray-100">Undo</button>';
      }
      html += '</div></div>';

      // Two-column comparison: Old (left) vs New (right)
      html += '<div class="grid grid-cols-2 gap-0 divide-x">';

      // LEFT: Current / Legacy Center
      html += '<div class="p-4">';
      html += '<h4 class="text-xs font-semibold text-gray-500 uppercase mb-2">Current Center (Legacy)</h4>';
      html += '<table class="w-full text-xs">';
      html += '<tr><td class="py-0.5 text-gray-400 w-1/3">Cost Center</td><td class="py-0.5 font-mono">' + esc(item.cctr || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Name</td><td class="py-0.5">' + esc(item.txtsh || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Description</td><td class="py-0.5">' + esc(item.txtmi || item.txtsh || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Company Code</td><td class="py-0.5">' + esc(item.ccode || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Controlling Area</td><td class="py-0.5">' + esc(item.coarea || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Profit Center</td><td class="py-0.5 font-mono">' + esc(item.pctr || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Responsible</td><td class="py-0.5">' + esc(item.responsible || '-');
      if (item.dq_issues_open > 0) {
        html += ' <span class="inline-flex items-center gap-1 bg-orange-100 text-orange-700 text-xs px-1.5 py-0.5 rounded cursor-pointer" onclick="openDqModal(' + item.id + ', \'' + esc(item.cctr || '') + '\')" title="Data quality issues">';
        html += '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>';
        html += item.dq_issues_open + ' issue' + (item.dq_issues_open > 1 ? 's' : '') + '</span>';
      }
      html += '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Category</td><td class="py-0.5">' + esc(item.cctrcgy || '-') + '</td></tr>';
      html += '<tr><td class="py-0.5 text-gray-400">Currency</td><td class="py-0.5">' + esc(item.currency || '-') + '</td></tr>';
      if (item.total_balance !== undefined) html += '<tr><td class="py-0.5 text-gray-400">Total Balance</td><td class="py-0.5 font-mono">' + (item.total_balance || '0') + '</td></tr>';
      if (item.posting_count !== undefined) html += '<tr><td class="py-0.5 text-gray-400">Posting Count</td><td class="py-0.5">' + (item.posting_count || '0') + '</td></tr>';
      html += '</table></div>';

      // RIGHT: Proposed New Center
      html += '<div class="p-4 bg-blue-50/30">';
      html += '<h4 class="text-xs font-semibold text-blue-600 uppercase mb-2">Proposed New Center</h4>';
      html += '<table class="w-full text-xs">';

      if (item.cleansing_outcome === 'RETIRE') {
        html += '<tr><td colspan="2" class="py-4 text-center text-red-600"><span class="text-2xl">×</span><br/>This center will be <strong>retired</strong>.<br/>No new center is proposed.</td></tr>';
      } else if (item.cleansing_outcome === 'MERGE_MAP') {
        html += '<tr><td colspan="2" class="py-4 text-center text-orange-600"><span class="text-2xl">⟶</span><br/>This center will be <strong>merged</strong> into:<br/><span class="font-mono font-semibold">' + esc(item.merge_into_cctr || 'TBD') + '</span></td></tr>';
      } else if (item.cleansing_outcome === 'REDESIGN') {
        html += '<tr><td class="py-0.5 text-gray-400 w-1/3">Cost Center</td><td class="py-0.5 font-mono text-blue-700">' + esc(item.new_cctr || item.cctr || '-') + ' <span class="text-xs text-blue-500">(redesigned)</span></td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Name</td><td class="py-0.5 text-blue-700">' + esc(item.new_txtsh || item.txtsh || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Target Type</td><td class="py-0.5"><span class="bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded text-xs">' + esc(item.target_object || '-') + '</span></td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Responsible</td><td class="py-0.5">' + esc(item.new_responsible || item.responsible || '-') + '</td></tr>';
      } else {
        // KEEP → new center created from old, possibly with new ID
        html += '<tr><td class="py-0.5 text-gray-400 w-1/3">Cost Center</td><td class="py-0.5 font-mono text-green-700">' + esc(item.new_cctr || item.cctr || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Name</td><td class="py-0.5">' + esc(item.new_txtsh || item.txtsh || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Target Type</td><td class="py-0.5"><span class="bg-green-100 text-green-700 px-1.5 py-0.5 rounded text-xs">' + esc(item.target_object || '-') + '</span></td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Profit Center</td><td class="py-0.5 font-mono">' + esc(item.new_pctr || item.pctr || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Responsible</td><td class="py-0.5">' + esc(item.new_responsible || item.responsible || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Company Code</td><td class="py-0.5">' + esc(item.ccode || '-') + '</td></tr>';
        html += '<tr><td class="py-0.5 text-gray-400">Currency</td><td class="py-0.5">' + esc(item.currency || '-') + '</td></tr>';
      }
      html += '</table></div>';
      html += '</div>'; // end grid

      // Decision path + confidence
      if (item.rule_path || item.confidence) {
        html += '<div class="px-4 py-2 border-t bg-gray-50/50 text-xs">';
        if (item.confidence) html += '<span class="text-gray-500">Confidence: <strong>' + Math.round(item.confidence * 100) + '%</strong></span> ';
        if (item.rule_path) {
          var steps = item.rule_path.steps || item.rule_path;
          if (Array.isArray(steps) && steps.length) {
            html += '<details class="inline"><summary class="cursor-pointer text-blue-600">Decision path (' + steps.length + ' steps)</summary>' +
              '<ul class="ml-4 list-disc text-gray-500 mt-1">';
            steps.forEach(function(s) { html += '<li>' + esc(s) + '</li>'; });
            html += '</ul></details>';
          }
        }
        html += '</div>';
      }

      // Comment
      if (item.comment) {
        html += '<div class="px-4 py-2 border-t bg-yellow-50 text-xs"><span class="text-gray-500">Comment:</span> <em>' + esc(item.comment) + '</em></div>';
      }

      html += '</div>'; // end card
    });
    html += '</div>';

    // Pager
    var pages = Math.ceil(d.total / d.size) || 1;
    html += '<div class="flex items-center justify-between mt-4 text-sm">' +
      '<span class="text-gray-500">' + d.total + ' items, page ' + d.page + '/' + pages + '</span>' +
      '<div class="flex gap-1">' +
      (d.page > 1 ? '<button onclick="window._loadItems(' + (d.page-1) + ')" class="btn-sm">← Prev</button>' : '') +
      (d.page < pages ? '<button onclick="window._loadItems(' + (d.page+1) + ')" class="btn-sm">Next →</button>' : '') +
      '</div></div>';

    el.innerHTML = html;
  }

  // ---- Flat List View ----
  function renderFlat(d) {
    var el = document.getElementById('review-content');
    if (!d.items || !d.items.length) { el.innerHTML = '<p class="text-gray-500 py-8 text-center">No items to review.</p>'; return; }

    var html = '<table class="w-full text-sm"><thead><tr class="bg-gray-50 text-xs text-gray-500 uppercase">' +
      '<th class="px-3 py-2 text-left">CC</th><th class="px-3 py-2 text-left">Name</th>' +
      '<th class="px-3 py-2 text-left">Entity</th><th class="px-3 py-2 text-left">Outcome</th>' +
      '<th class="px-3 py-2 text-left">Target</th><th class="px-3 py-2 text-left">Decision</th>' +
      '<th class="px-3 py-2 text-right">Actions</th></tr></thead><tbody>';

    d.items.forEach(function(item) {
      var outColor = { KEEP: 'text-green-700 bg-green-100', RETIRE: 'text-red-700 bg-red-100',
                      MERGE_MAP: 'text-orange-700 bg-orange-100', REDESIGN: 'text-blue-700 bg-blue-100' }[item.cleansing_outcome] || 'bg-gray-100';
      var decColor = { APPROVED: 'text-green-700 bg-green-100', NOT_REQUIRED: 'text-gray-600 bg-gray-100',
                      COMMENTED: 'text-yellow-700 bg-yellow-100', PENDING: 'text-gray-500 bg-gray-50' }[item.decision] || '';
      html += '<tr class="border-t hover:bg-blue-50/50">' +
        '<td class="px-3 py-2 font-mono text-xs">' + esc(item.cctr) + '</td>' +
        '<td class="px-3 py-2 text-xs">' + esc(item.txtsh || '-') + '</td>' +
        '<td class="px-3 py-2 text-xs">' + esc(item.ccode || '-') + '</td>' +
        '<td class="px-3 py-2"><span class="px-1.5 py-0.5 rounded text-xs ' + outColor + '">' + esc(item.cleansing_outcome) + '</span></td>' +
        '<td class="px-3 py-2 text-xs">' + esc(item.target_object || '-') + '</td>' +
        '<td class="px-3 py-2"><span class="px-1.5 py-0.5 rounded text-xs ' + decColor + '">' + esc(item.decision) + '</span></td>' +
        '<td class="px-3 py-2 text-right">';
      if (item.decision === 'PENDING') {
        html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-xs text-green-600 hover:underline mr-2">Approve</button>' +
          '<button onclick="decide(' + item.id + ',\'COMMENTED\')" class="text-xs text-yellow-600 hover:underline mr-2">Comment</button>';
      } else {
        html += '<button onclick="decide(' + item.id + ',\'PENDING\')" class="text-xs text-gray-500 hover:underline mr-2">Undo</button>';
      }
      html += '<button onclick="openNewCenterModal({cloneFrom:\'' + esc(item.cctr || '') + '\',name:\'' + esc(item.txtsh || '') + '\',ccode:\'' + esc(item.ccode || '') + '\',responsible:\'' + esc(item.responsible || '') + '\'})" class="text-xs text-gray-500 hover:underline" title="Clone as new center">Clone</button>';
      html += '</td></tr>';
    });
    html += '</tbody></table>';

    var pages = Math.ceil(d.total / d.size) || 1;
    html += '<div class="flex items-center justify-between mt-4 text-sm">' +
      '<span class="text-gray-500">' + d.total + ' items, page ' + d.page + '/' + pages + '</span>' +
      '<div class="flex gap-1">' +
      (d.page > 1 ? '<button onclick="window._loadItems(' + (d.page-1) + ')" class="btn-sm">← Prev</button>' : '') +
      (d.page < pages ? '<button onclick="window._loadItems(' + (d.page+1) + ')" class="btn-sm">Next →</button>' : '') +
      '</div></div>';
    el.innerHTML = html;
  }

  // ---- Grouped View ----
  function renderGrouped(d, mode) {
    fetch('/api/review/' + reviewToken + '/items?size=500').then(function(r) { return r.json(); }).then(function(dAll) {
      if (!dAll.items) return;
      var groups = {};
      dAll.items.forEach(function(item) {
        var key = mode === 'entity' ? (item.ccode || 'Unknown') : (item.cleansing_outcome || 'Unknown');
        if (!groups[key]) groups[key] = [];
        groups[key].push(item);
      });
      var el = document.getElementById('review-content');
      var html = '<div class="space-y-4">';
      Object.keys(groups).sort().forEach(function(key) {
        var items = groups[key];
        var pending = items.filter(function(i) { return i.decision === 'PENDING'; }).length;
        html += '<details class="card" open>' +
          '<summary class="cursor-pointer font-semibold text-sm">' + esc(key) +
          ' <span class="text-gray-400 font-normal">(' + items.length + ' items, ' + pending + ' pending)</span></summary>' +
          '<div class="mt-2 space-y-1">';
        items.forEach(function(item) {
          var outColor = { KEEP: 'text-green-700', RETIRE: 'text-red-700', MERGE_MAP: 'text-orange-700', REDESIGN: 'text-blue-700' }[item.cleansing_outcome] || '';
          html += '<div class="flex items-center justify-between text-xs py-1 border-t">' +
            '<div class="flex items-center gap-2">' +
            '<span class="font-mono">' + esc(item.cctr) + '</span>' +
            '<span class="' + outColor + '">' + esc(item.cleansing_outcome) + '</span>' +
            '<span class="text-gray-400">' + esc(item.txtsh || '') + '</span></div>' +
            '<div class="flex gap-1">';
          if (item.decision === 'PENDING') {
            html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-green-600 hover:underline">Approve</button>' +
              '<button onclick="decide(' + item.id + ',\'COMMENTED\')" class="text-yellow-600 hover:underline ml-2">Comment</button>';
          } else {
            html += '<span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700">' + item.decision + '</span>';
          }
          html += '</div></div>';
        });
        html += '</div></details>';
      });
      html += '</div>';
      el.innerHTML = html;
    });
  }

  // ---- Hierarchy View (Legacy tree with bulk tick) ----
  function renderHierarchy(d) {
    // Fetch all items to build hierarchy
    fetch('/api/review/' + reviewToken + '/items?size=1000').then(function(r) { return r.json(); }).then(function(dAll) {
      if (!dAll.items || !dAll.items.length) { document.getElementById('review-content').innerHTML = '<p class="text-gray-500 py-8 text-center">No items to review.</p>'; return; }

      // Group items by entity, then build a pseudo-hierarchy
      var entities = {};
      dAll.items.forEach(function(item) {
        var entityKey = item.ccode || item.entity_code || 'Unknown';
        if (!entities[entityKey]) entities[entityKey] = [];
        entities[entityKey].push(item);
      });

      var el = document.getElementById('review-content');
      var html = '<div class="text-xs text-gray-500 mb-3">Hierarchy view groups cost centers by entity. Check a node to approve all descendants.</div>';
      html += '<div class="space-y-2">';

      Object.keys(entities).sort().forEach(function(entity) {
        var items = entities[entity];
        var pendingCount = items.filter(function(i) { return i.decision === 'PENDING'; }).length;
        var approvedCount = items.filter(function(i) { return i.decision === 'APPROVED'; }).length;
        var totalCount = items.length;

        html += '<div class="border rounded-lg overflow-hidden">';
        html += '<div class="flex items-center gap-2 px-4 py-2 bg-gray-50 border-b cursor-pointer" onclick="toggleHierChildren(this)">';
        html += '<span class="tree-arrow text-gray-400">&#9660;</span>';
        html += '<input type="checkbox" class="hier-entity-cb" data-entity="' + esc(entity) + '" onchange="hierBulkDecide(this)" ' + (approvedCount === totalCount ? 'checked' : '') + ' />';
        html += '<span class="font-semibold text-sm">Entity: ' + esc(entity) + '</span>';
        html += '<span class="text-xs text-gray-400 ml-2">' + totalCount + ' centers';
        if (pendingCount > 0) html += ', <span class="text-orange-600">' + pendingCount + ' pending</span>';
        html += '</span>';
        html += '</div>';
        html += '<div class="hier-children">';

        items.forEach(function(item) {
          var outColor = { KEEP: 'text-green-700', RETIRE: 'text-red-700', MERGE_MAP: 'text-orange-700', REDESIGN: 'text-blue-700' }[item.cleansing_outcome] || '';
          var decBg = item.decision === 'APPROVED' ? 'bg-green-50' : item.decision === 'NOT_REQUIRED' ? 'bg-gray-50' : '';
          html += '<div class="flex items-center gap-2 px-4 py-1.5 border-t text-xs hover:bg-blue-50/50 ' + decBg + '">';
          html += '<span class="w-4"></span>';
          html += '<input type="checkbox" class="hier-item-cb" data-id="' + item.id + '" ' + (item.decision === 'APPROVED' ? 'checked' : '') + ' onchange="hierItemDecide(this,' + item.id + ')" />';
          html += '<span class="font-mono font-medium w-24">' + esc(item.cctr) + '</span>';
          html += '<span class="' + outColor + ' w-20">' + esc(item.cleansing_outcome || '-') + '</span>';
          html += '<span class="text-gray-600 flex-1">' + esc(item.txtsh || '-') + '</span>';
          if (item.target_object) html += '<span class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">→ ' + esc(item.target_object) + '</span>';
          html += '<span class="w-20 text-right">';
          if (item.decision !== 'PENDING') html += '<span class="px-1.5 py-0.5 rounded text-xs ' + (item.decision === 'APPROVED' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600') + '">' + item.decision + '</span>';
          html += '</span>';
          html += '</div>';
        });

        html += '</div></div>';
      });

      html += '</div>';
      el.innerHTML = html;
    });
  }

  window.toggleHierChildren = function(el) {
    var children = el.closest('.border').querySelector('.hier-children');
    if (children) {
      var hidden = children.classList.toggle('hidden');
      el.querySelector('.tree-arrow').innerHTML = hidden ? '&#9654;' : '&#9660;';
    }
  };

  window.hierBulkDecide = function(cb) {
    var entity = cb.getAttribute('data-entity');
    var decision = cb.checked ? 'APPROVED' : 'PENDING';
    // Find all pending items in this entity
    fetch('/api/review/' + reviewToken + '/items?size=1000').then(function(r) { return r.json(); }).then(function(d) {
      var ids = (d.items || []).filter(function(i) {
        return (i.ccode === entity || i.entity_code === entity) && i.decision === 'PENDING';
      }).map(function(i) { return i.id; });
      if (!ids.length) { loadItems(1); return; }
      fetch('/api/review/' + reviewToken + '/items/bulk-decide', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ item_ids: ids, decision: decision })
      }).then(function() { loadItems(1); });
    });
  };

  window.hierItemDecide = function(cb, itemId) {
    decide(itemId, cb.checked ? 'APPROVED' : 'PENDING');
  };

  // ---- Proposed (New) Structure View ----
  function renderProposed(d) {
    fetch('/api/review/' + reviewToken + '/items?size=1000').then(function(r) { return r.json(); }).then(function(dAll) {
      if (!dAll.items || !dAll.items.length) { document.getElementById('review-content').innerHTML = '<p class="text-gray-500 py-8 text-center">No items.</p>'; return; }

      // Group by target_object type, then by proposed PC
      var keepItems = [];
      var retireItems = [];
      var mergeGroups = {};
      var redesignItems = [];

      dAll.items.forEach(function(item) {
        if (item.cleansing_outcome === 'RETIRE') retireItems.push(item);
        else if (item.cleansing_outcome === 'MERGE_MAP') {
          var target = item.merge_into_cctr || 'TBD';
          if (!mergeGroups[target]) mergeGroups[target] = [];
          mergeGroups[target].push(item);
        }
        else if (item.cleansing_outcome === 'REDESIGN') redesignItems.push(item);
        else keepItems.push(item);
      });

      // Group KEEP items by proposed profit center
      var pcGroups = {};
      keepItems.forEach(function(item) {
        var pc = item.new_pctr || item.pctr || 'Unassigned';
        if (!pcGroups[pc]) pcGroups[pc] = [];
        pcGroups[pc].push(item);
      });

      var el = document.getElementById('review-content');
      var html = '<div class="text-xs text-gray-500 mb-3">Proposed new structure showing how cost centers will be organized after rationalization. Multiple CCs can map to one PC (many-to-one).</div>';

      // KPI summary
      html += '<div class="grid grid-cols-4 gap-3 mb-4">';
      html += '<div class="bg-green-50 rounded-lg p-3 text-center"><div class="text-lg font-bold text-green-700">' + keepItems.length + '</div><div class="text-xs text-green-600">Continue (KEEP)</div></div>';
      html += '<div class="bg-red-50 rounded-lg p-3 text-center"><div class="text-lg font-bold text-red-700">' + retireItems.length + '</div><div class="text-xs text-red-600">Sunset (RETIRE)</div></div>';
      var mergeCount = 0; Object.keys(mergeGroups).forEach(function(k) { mergeCount += mergeGroups[k].length; });
      html += '<div class="bg-orange-50 rounded-lg p-3 text-center"><div class="text-lg font-bold text-orange-700">' + mergeCount + '</div><div class="text-xs text-orange-600">Merged (MERGE_MAP)</div></div>';
      html += '<div class="bg-blue-50 rounded-lg p-3 text-center"><div class="text-lg font-bold text-blue-700">' + redesignItems.length + '</div><div class="text-xs text-blue-600">Redesigned</div></div>';
      html += '</div>';

      html += '<div class="space-y-3">';

      // Proposed PC groups (KEEP items grouped by target PC)
      if (Object.keys(pcGroups).length > 0) {
        html += '<h3 class="text-sm font-semibold text-green-700 mb-2">New Profit Center Structure (Many CC → One PC)</h3>';
        Object.keys(pcGroups).sort().forEach(function(pc) {
          var items = pcGroups[pc];
          html += '<details class="border rounded-lg overflow-hidden" open>';
          html += '<summary class="flex items-center gap-2 px-4 py-2 bg-green-50 cursor-pointer">';
          html += '<span class="font-mono font-semibold text-sm text-green-800">PC ' + esc(pc) + '</span>';
          html += '<span class="text-xs text-green-600">(' + items.length + ' cost centers)</span>';
          html += '</summary>';
          items.forEach(function(item) {
            var decColor = item.decision === 'APPROVED' ? 'bg-green-50' : item.decision === 'PENDING' ? '' : 'bg-gray-50';
            html += '<div class="flex items-center gap-2 px-4 py-1.5 border-t text-xs ' + decColor + '">';
            html += '<span class="w-4 text-green-500">&#9679;</span>';
            html += '<span class="font-mono font-medium w-24">' + esc(item.new_cctr || item.cctr || '-') + '</span>';
            html += '<span class="text-gray-600 flex-1">' + esc(item.new_txtsh || item.txtsh || '-') + '</span>';
            html += '<span class="text-gray-400 text-[10px]">was: ' + esc(item.cctr || '-') + '</span>';
            if (item.decision !== 'PENDING') html += '<span class="px-1.5 py-0.5 rounded text-xs bg-green-100 text-green-700">' + item.decision + '</span>';
            else html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-xs text-green-600 hover:underline">Approve</button>';
            html += '</div>';
          });
          html += '</details>';
        });
      }

      // Merge groups
      if (Object.keys(mergeGroups).length > 0) {
        html += '<h3 class="text-sm font-semibold text-orange-700 mt-4 mb-2">Merge Targets</h3>';
        Object.keys(mergeGroups).sort().forEach(function(target) {
          var items = mergeGroups[target];
          html += '<details class="border rounded-lg overflow-hidden">';
          html += '<summary class="flex items-center gap-2 px-4 py-2 bg-orange-50 cursor-pointer">';
          html += '<span class="font-mono font-semibold text-sm text-orange-800">→ ' + esc(target) + '</span>';
          html += '<span class="text-xs text-orange-600">(' + items.length + ' centers merging into this)</span>';
          html += '</summary>';
          items.forEach(function(item) {
            html += '<div class="flex items-center gap-2 px-4 py-1.5 border-t text-xs">';
            html += '<span class="w-4 text-orange-400">&#8594;</span>';
            html += '<span class="font-mono w-24">' + esc(item.cctr || '-') + '</span>';
            html += '<span class="text-gray-600 flex-1">' + esc(item.txtsh || '-') + '</span>';
            if (item.decision !== 'PENDING') html += '<span class="px-1.5 py-0.5 rounded text-xs bg-orange-100 text-orange-700">' + item.decision + '</span>';
            else html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-xs text-orange-600 hover:underline">Approve</button>';
            html += '</div>';
          });
          html += '</details>';
        });
      }

      // Retire list
      if (retireItems.length > 0) {
        html += '<details class="border rounded-lg overflow-hidden mt-4">';
        html += '<summary class="flex items-center gap-2 px-4 py-2 bg-red-50 cursor-pointer">';
        html += '<span class="font-semibold text-sm text-red-800">Centers to Sunset</span>';
        html += '<span class="text-xs text-red-600">(' + retireItems.length + ' centers)</span>';
        html += '</summary>';
        retireItems.forEach(function(item) {
          html += '<div class="flex items-center gap-2 px-4 py-1.5 border-t text-xs">';
          html += '<span class="w-4 text-red-400">&#10005;</span>';
          html += '<span class="font-mono w-24">' + esc(item.cctr || '-') + '</span>';
          html += '<span class="text-gray-600 flex-1">' + esc(item.txtsh || '-') + '</span>';
          if (item.decision !== 'PENDING') html += '<span class="px-1.5 py-0.5 rounded text-xs bg-red-100 text-red-700">' + item.decision + '</span>';
          else html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-xs text-red-600 hover:underline">Approve</button>';
          html += '</div>';
        });
        html += '</details>';
      }

      // Redesign list
      if (redesignItems.length > 0) {
        html += '<details class="border rounded-lg overflow-hidden mt-4">';
        html += '<summary class="flex items-center gap-2 px-4 py-2 bg-blue-50 cursor-pointer">';
        html += '<span class="font-semibold text-sm text-blue-800">Redesigned Centers</span>';
        html += '<span class="text-xs text-blue-600">(' + redesignItems.length + ' centers)</span>';
        html += '</summary>';
        redesignItems.forEach(function(item) {
          html += '<div class="flex items-center gap-2 px-4 py-1.5 border-t text-xs">';
          html += '<span class="w-4 text-blue-400">&#9733;</span>';
          html += '<span class="font-mono w-24">' + esc(item.new_cctr || item.cctr || '-') + '</span>';
          html += '<span class="text-gray-600 flex-1">' + esc(item.new_txtsh || item.txtsh || '-') + '</span>';
          html += '<span class="text-gray-400 text-[10px]">was: ' + esc(item.cctr || '-') + '</span>';
          if (item.decision !== 'PENDING') html += '<span class="px-1.5 py-0.5 rounded text-xs bg-blue-100 text-blue-700">' + item.decision + '</span>';
          else html += '<button onclick="decide(' + item.id + ',\'APPROVED\')" class="text-xs text-blue-600 hover:underline">Approve</button>';
          html += '</div>';
        });
        html += '</details>';
      }

      html += '</div>';
      el.innerHTML = html;
    });
  }

  // ---- Decision Handling ----
  window.decide = async function(itemId, decision) {
    var comment = null;
    if (decision === 'COMMENTED') {
      comment = prompt('Enter your comment:');
      if (comment === null) return;
    }
    await fetch('/api/review/' + reviewToken + '/items/' + itemId + '/decide', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ decision: decision, comment: comment })
    });
    loadItems(1);
    fetch('/api/review/' + reviewToken).then(function(r) { return r.json(); }).then(function(scope) {
      var pct = scope.total_items ? Math.round(scope.decided_items / scope.total_items * 100) : 0;
      var bar = document.querySelector('#review-header .bg-amplifi-500');
      if (bar) bar.style.width = pct + '%';
    });
  };

  window.bulkApprove = async function() {
    if (!confirm('Approve all visible pending items?')) return;
    var res = await fetch('/api/review/' + reviewToken + '/items?size=1000&decision=PENDING');
    var d = await res.json();
    var ids = (d.items || []).map(function(i) { return i.id; });
    if (!ids.length) { alert('No pending items.'); return; }
    await fetch('/api/review/' + reviewToken + '/items/bulk-decide', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_ids: ids, decision: 'APPROVED' })
    });
    loadItems(1);
  };

  window.requestChanges = async function() {
    var comment = prompt('Describe the changes you are requesting:');
    if (!comment) return;
    await fetch('/api/review/' + reviewToken + '/request-changes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ comment: comment })
    });
    alert('Change request submitted.');
    loadItems(1);
  };

  window.completeReview = async function() {
    if (!confirm('Submit this review? This marks your review as complete.')) return;
    try {
      var res = await fetch('/api/review/' + reviewToken + '/complete', { method: 'POST' });
      if (res.ok) {
        alert('Review submitted successfully. Thank you!');
        window.location.reload();
      } else {
        var err = await res.json();
        alert('Error: ' + (err.detail || 'Failed to submit'));
      }
    } catch(e) { alert('Error: ' + e.message); }
  };

  // Request New Center form
  // Open new-center modal (optionally with clone data)
  window.openNewCenterModal = function(opts) {
    opts = opts || {};
    document.getElementById('nc-clone-from').value = opts.cloneFrom || '';
    document.getElementById('nc-name').value = opts.name || '';
    document.getElementById('nc-ccode').value = opts.ccode || '';
    document.getElementById('nc-responsible').value = opts.responsible || '';
    document.getElementById('nc-hier-node').value = opts.hierNode || '';
    document.getElementById('nc-purpose').value = '';
    document.getElementById('nc-bs').value = '';
    if (opts.cloneFrom) {
      document.getElementById('nc-modal-title').textContent = 'Clone Center: ' + opts.cloneFrom;
      document.getElementById('nc-clone-info').classList.remove('hidden');
      document.getElementById('nc-clone-label').textContent = opts.cloneFrom + (opts.name ? ' — ' + opts.name : '');
    } else {
      document.getElementById('nc-modal-title').textContent = 'Request New Center';
      document.getElementById('nc-clone-info').classList.add('hidden');
    }
    document.getElementById('new-center-modal').classList.remove('hidden');
  };

  document.getElementById('new-center-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var purpose = document.getElementById('nc-purpose').value.trim();
    if (!purpose) return;
    try {
      var res = await fetch('/api/review/' + reviewToken + '/items/request-new', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          purpose: purpose,
          target_object: document.getElementById('nc-target').value,
          responsible: document.getElementById('nc-responsible').value || null,
          bs_relevance: document.getElementById('nc-bs').value || null,
          proposed_name: document.getElementById('nc-name').value || null,
          proposed_ccode: document.getElementById('nc-ccode').value || null,
          hierarchy_node: document.getElementById('nc-hier-node').value || null,
          clone_from: document.getElementById('nc-clone-from').value || null
        })
      });
      if (res.ok) {
        document.getElementById('new-center-modal').classList.add('hidden');
        document.getElementById('nc-purpose').value = '';
        document.getElementById('nc-responsible').value = '';
        document.getElementById('nc-bs').value = '';
        document.getElementById('nc-name').value = '';
        document.getElementById('nc-ccode').value = '';
        document.getElementById('nc-hier-node').value = '';
        document.getElementById('nc-clone-from').value = '';
        document.getElementById('nc-clone-info').classList.add('hidden');
        alert('Request submitted. The data manager will review it.');
        loadItems(1);
      } else {
        var err = await res.json();
        alert('Error: ' + (err.detail || 'Failed'));
      }
    } catch(ex) { alert('Error: ' + ex.message); }
  });

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'TEXTAREA') return;
    if (e.key === 'ArrowDown' || e.key === 'j') {
      e.preventDefault();
      var items = document.querySelectorAll('[id^="item-"]');
      var current = document.querySelector('[id^="item-"].ring-2');
      if (!current && items.length) { items[0].classList.add('ring-2', 'ring-amplifi-400'); items[0].scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      else if (current) {
        var idx = Array.from(items).indexOf(current);
        current.classList.remove('ring-2', 'ring-amplifi-400');
        if (idx < items.length - 1) { items[idx + 1].classList.add('ring-2', 'ring-amplifi-400'); items[idx + 1].scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      }
    }
    if (e.key === 'ArrowUp' || e.key === 'k') {
      e.preventDefault();
      var items = document.querySelectorAll('[id^="item-"]');
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) {
        var idx = Array.from(items).indexOf(current);
        current.classList.remove('ring-2', 'ring-amplifi-400');
        if (idx > 0) { items[idx - 1].classList.add('ring-2', 'ring-amplifi-400'); items[idx - 1].scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      }
    }
    if (e.key === 'a' || e.key === 'A') {
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) { var id = parseInt(current.id.replace('item-', '')); decide(id, 'APPROVED'); }
    }
    if (e.key === 'n' || e.key === 'N') {
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) { var id = parseInt(current.id.replace('item-', '')); decide(id, 'NOT_REQUIRED'); }
    }
    if (e.key === 'c' || e.key === 'C') {
      var current = document.querySelector('[id^="item-"].ring-2');
      if (current) { var id = parseInt(current.id.replace('item-', '')); decide(id, 'COMMENTED'); }
    }
  });

  // Load hierarchy nodes into the picker
  (async function() {
    function flattenTree(nodes, result) {
      (nodes || []).forEach(function(n) {
        if (n.type === 'node' || (n.children && n.children.length)) {
          result.push({ setname: n.setname, leaf_count: n.leaf_count || 0 });
        }
        if (n.children) flattenTree(n.children, result);
      });
    }
    try {
      var res = await fetch('/api/legacy/hierarchies?size=200&scope=cleanup');
      if (!res.ok) return;
      var data = await res.json();
      var hiers = data.items || data || [];
      if (!hiers.length) return;
      var select = document.getElementById('nc-hier-node');
      for (var h = 0; h < hiers.length; h++) {
        var hier = hiers[h];
        var hierId = hier.id;
        var hierName = hier.description || hier.setname || hier.name || ('Hierarchy ' + hierId);
        try {
          var treeRes = await fetch('/api/legacy/hierarchies/' + hierId + '/tree');
          if (!treeRes.ok) continue;
          var treeData = await treeRes.json();
          var flatNodes = [];
          flattenTree(treeData.tree || [], flatNodes);
          if (flatNodes.length) {
            var optgroup = document.createElement('optgroup');
            optgroup.label = hierName;
            flatNodes.forEach(function(n) {
              var opt = document.createElement('option');
              opt.value = n.setname;
              opt.textContent = n.setname + ' (' + n.leaf_count + ' items)';
              optgroup.appendChild(opt);
            });
            select.appendChild(optgroup);
          }
        } catch(e) {}
      }
    } catch(e) {}
  })();

  // ===== Data Quality Issue Resolution =====
  window._dqResolvingIssueId = null;

  window.openDqModal = async function(itemId, cctr) {
    document.getElementById('dq-modal-cc').textContent = cctr;
    document.getElementById('dq-modal-body').innerHTML = '<div class="text-gray-400">Loading...</div>';
    document.getElementById('dq-modal').classList.remove('hidden');
    try {
      var res = await fetch('/api/dq/issues?object_type=cost_center&status=open&size=50');
      if (!res.ok) throw new Error('Failed to fetch DQ issues');
      var data = await res.json();
      var issues = data.items.filter(function(i) { return i.cctr === cctr; });
      if (!issues.length) {
        document.getElementById('dq-modal-body').innerHTML = '<div class="text-green-600">No open issues for this center.</div>';
        return;
      }
      var html = '';
      issues.forEach(function(iss) {
        html += '<div class="border rounded p-3 bg-gray-50">';
        html += '<div class="flex items-center justify-between mb-1">';
        html += '<span class="font-medium">' + esc(iss.field_name) + '</span>';
        html += '<span class="text-xs px-2 py-0.5 rounded ' +
          (iss.severity === 'error' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700') +
          '">' + esc(iss.severity) + '</span>';
        html += '</div>';
        html += '<div class="text-xs text-gray-500 mb-2">' + esc(iss.message || '') + '</div>';
        html += '<div class="text-xs mb-2"><span class="text-gray-400">Current:</span> <code class="bg-gray-200 px-1 rounded">' + esc(iss.current_value || '-') + '</code></div>';
        if (iss.suggested_value) {
          html += '<div class="text-xs mb-2"><span class="text-gray-400">Suggested:</span> <code class="bg-green-100 px-1 rounded">' + esc(iss.suggested_value) + '</code></div>';
        }
        html += '<div class="flex gap-2 mt-2">';
        html += '<button onclick="openEmpPicker(' + iss.id + ')" class="btn-sm bg-amplifi-600 text-white hover:bg-amplifi-700 text-xs">Assign Employee</button>';
        if (iss.suggested_employee_id) {
          html += '<button onclick="resolveDqWithSuggested(' + iss.id + ', ' + iss.suggested_employee_id + ')" class="btn-sm bg-green-600 text-white hover:bg-green-700 text-xs">Accept Suggested</button>';
        }
        html += '<button onclick="suppressDq(' + iss.id + ')" class="btn-sm bg-gray-400 text-white hover:bg-gray-500 text-xs">Suppress</button>';
        html += '</div></div>';
      });
      document.getElementById('dq-modal-body').innerHTML = html;
    } catch(e) {
      document.getElementById('dq-modal-body').innerHTML = '<div class="text-red-600">Error loading issues: ' + esc(e.message) + '</div>';
    }
  };

  window.openEmpPicker = function(issueId) {
    window._dqResolvingIssueId = issueId;
    document.getElementById('emp-search-input').value = '';
    document.getElementById('emp-search-results').innerHTML = '<div class="text-gray-400 text-xs">Type to search employees...</div>';
    document.getElementById('emp-picker-modal').classList.remove('hidden');
    document.getElementById('emp-search-input').focus();
  };

  window.searchEmployees = async function() {
    var q = document.getElementById('emp-search-input').value.trim();
    var container = document.getElementById('emp-search-results');
    if (!q || q.length < 2) {
      container.innerHTML = '<div class="text-gray-400 text-xs">Type at least 2 characters...</div>';
      return;
    }
    container.innerHTML = '<div class="text-gray-400 text-xs">Searching...</div>';
    try {
      var res = await fetch('/api/employees?search=' + encodeURIComponent(q) + '&size=20');
      if (!res.ok) throw new Error('Search failed');
      var data = await res.json();
      if (!data.items.length) {
        container.innerHTML = '<div class="text-gray-400 text-xs">No employees found.</div>';
        return;
      }
      var html = '';
      data.items.forEach(function(emp) {
        var active = emp.is_active !== false;
        html += '<div class="flex items-center justify-between p-2 hover:bg-gray-50 rounded cursor-pointer border' + (!active ? ' opacity-50' : '') + '" onclick="selectEmployee(' + emp.id + ')">';
        html += '<div>';
        html += '<div class="font-medium">' + esc(emp.gpn) + ' — ' + esc(emp.display_name || '') + '</div>';
        html += '<div class="text-xs text-gray-400">' + esc(emp.verak_display || '') + (emp.email_address ? ' | ' + esc(emp.email_address) : '') + '</div>';
        html += '</div>';
        if (!active) html += '<span class="text-xs text-red-500">Inactive</span>';
        html += '</div>';
      });
      container.innerHTML = html;
    } catch(e) {
      container.innerHTML = '<div class="text-red-500 text-xs">Error: ' + esc(e.message) + '</div>';
    }
  };

  window.selectEmployee = async function(empId) {
    var issueId = window._dqResolvingIssueId;
    if (!issueId) return;
    try {
      var res = await fetch('/api/review/' + reviewToken + '/dq-resolve/' + issueId, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({employee_id: empId, action: 'resolve'})
      });
      if (!res.ok) throw new Error('Failed to resolve');
      document.getElementById('emp-picker-modal').classList.add('hidden');
      // Refresh DQ modal
      var cc = document.getElementById('dq-modal-cc').textContent;
      openDqModal(0, cc);
      // Refresh review items
      window._loadItems && window._loadItems(1);
    } catch(e) {
      alert('Error resolving: ' + e.message);
    }
  };

  window.resolveDqWithSuggested = async function(issueId, empId) {
    try {
      var res = await fetch('/api/review/' + reviewToken + '/dq-resolve/' + issueId, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({employee_id: empId, action: 'resolve'})
      });
      if (!res.ok) throw new Error('Failed to resolve');
      var cc = document.getElementById('dq-modal-cc').textContent;
      openDqModal(0, cc);
      window._loadItems && window._loadItems(1);
    } catch(e) {
      alert('Error: ' + e.message);
    }
  };

  window.suppressDq = async function(issueId) {
    if (!confirm('Suppress this data quality issue?')) return;
    try {
      var res = await fetch('/api/review/' + reviewToken + '/dq-resolve/' + issueId, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({action: 'suppress'})
      });
      if (!res.ok) throw new Error('Failed to suppress');
      var cc = document.getElementById('dq-modal-cc').textContent;
      openDqModal(0, cc);
      window._loadItems && window._loadItems(1);
    } catch(e) {
      alert('Error: ' + e.message);
    }
  };
})();
</script>
