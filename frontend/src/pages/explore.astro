---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ampliFi Data Explorer — public data visualization" />
  <title>Data Explorer | ampliFi</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-gray-50 h-screen flex flex-col overflow-hidden font-[Inter,system-ui,sans-serif]">

  <!-- Slim standalone header -->
  <header class="bg-[#1a1a2e] text-white px-4 py-2 flex items-center justify-between flex-shrink-0">
    <div class="flex items-center gap-2">
      <img src="/ubs-logo.svg" alt="UBS" class="h-5" />
      <span class="font-semibold text-sm"><span style="color:#E60000">a</span>mpliF<span style="color:#E60000">i</span> Data Explorer</span>
    </div>
    <span id="explore-status" class="text-xs text-gray-400">Ready</span>
  </header>

  <!-- Main tabs: Legacy | ampliFi -->
  <div class="flex gap-1 border-b bg-white px-4 flex-shrink-0">
    <button id="main-tab-legacy" class="px-5 py-1.5 text-sm font-semibold border-b-2 border-blue-600 text-blue-700" data-main-tab="legacy">Legacy</button>
    <button id="main-tab-amplifi" class="px-5 py-1.5 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700" data-main-tab="amplifi">ampliFi</button>
  </div>

  <!-- ===== LEGACY PANEL ===== -->
  <div id="panel-legacy" class="flex-1 flex flex-col min-h-0 px-4 pt-2">
    <!-- Object sub-tabs -->
    <div class="bg-white border rounded-t-lg px-2 py-0.5 flex items-center gap-0 overflow-x-auto flex-shrink-0" id="legacy-tabs">
      <button class="explore-tab explore-tab-active" data-explore-tab="cost-centers">Cost Centers</button>
      <button class="explore-tab" data-explore-tab="profit-centers">Profit Centers</button>
      <button class="explore-tab" data-explore-tab="entities">Entities</button>
      <button class="explore-tab" data-explore-tab="gl-accounts-ska1">GL Accts (CoA)</button>
      <button class="explore-tab" data-explore-tab="gl-accounts-skb1">GL Accts (CoCd)</button>
      <button class="explore-tab" data-explore-tab="hierarchies">Hierarchies</button>
      <button class="explore-tab" data-explore-tab="employees">Employees</button>
    </div>

    <!-- DOD container -->
    <div id="explore-dod-container" class="flex-1 min-h-0 bg-white border-x border-b rounded-b-lg overflow-hidden">
      <div id="explore-dod" class="text-xs h-full"></div>
    </div>
  </div>

  <!-- ===== AMPLIFI PANEL ===== -->
  <div id="panel-amplifi" class="hidden flex-1 flex flex-col min-h-0 px-4 pt-2">
    <!-- Run selector -->
    <div class="bg-white border rounded-t-lg px-3 py-1.5 flex items-center gap-2 flex-shrink-0">
      <label class="text-xs text-gray-500">Analysis Run:</label>
      <select id="amplifi-run-select" class="border rounded px-2 py-1 text-xs"></select>
    </div>
    <!-- DOD container for mapping -->
    <div id="amplifi-dod-container" class="flex-1 min-h-0 bg-white border-x border-b rounded-b-lg overflow-hidden">
      <div id="amplifi-dod" class="text-xs h-full"></div>
    </div>
  </div>

<style is:global>
  .explore-tab {
    padding: 4px 12px; font-size: 12px; font-weight: 500;
    color: #6b7280; white-space: nowrap; border-bottom: 2px solid transparent;
    cursor: pointer; transition: all 0.15s;
  }
  .explore-tab:hover { color: #374151; }
  .explore-tab-active { color: #1d4ed8; border-bottom-color: #2563eb; font-weight: 600; }
</style>

<script is:inline src="/data-object-display.js"></script>
<script is:inline>
(function() {
  // ── Config ────────────────────────────────────────────────────────────
  var TABS = {
    'cost-centers':     { label: 'Cost Centers',    endpoint: '/api/explore/legacy/cost-centers',     identity: 'cctr',  hierTypes: ['0101'] },
    'profit-centers':   { label: 'Profit Centers',  endpoint: '/api/explore/legacy/profit-centers',   identity: 'pctr',  hierTypes: ['0104'] },
    'entities':         { label: 'Entities',        endpoint: '/api/explore/legacy/entities',         identity: 'ccode', hierTypes: ['0106'] },
    'gl-accounts-ska1': { label: 'GL Accts (CoA)',  endpoint: '/api/explore/legacy/gl-accounts-ska1', identity: 'saknr', hierTypes: [], glMode: true },
    'gl-accounts-skb1': { label: 'GL Accts (CoCd)', endpoint: '/api/explore/legacy/gl-accounts-skb1', identity: 'saknr', hierTypes: [], glMode: true },
    'hierarchies':      { label: 'Hierarchies',     endpoint: '/api/explore/legacy/hierarchies',      identity: 'setname', hierTypes: [] },
    'employees':        { label: 'Employees',       endpoint: '/api/explore/legacy/employees',        identity: 'pernr', hierTypes: [] }
  };

  var currentTab = 'cost-centers';
  var dodInstance = null;

  // ── Main tab switching ────────────────────────────────────────────────
  document.querySelectorAll('[data-main-tab]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.dataset.mainTab;
      document.getElementById('panel-legacy').classList.toggle('hidden', tab !== 'legacy');
      document.getElementById('panel-amplifi').classList.toggle('hidden', tab !== 'amplifi');
      document.querySelectorAll('[data-main-tab]').forEach(function(b) {
        var active = b.dataset.mainTab === tab;
        b.classList.toggle('border-blue-600', active);
        b.classList.toggle('text-blue-700', active);
        b.classList.toggle('border-transparent', !active);
        b.classList.toggle('text-gray-500', !active);
      });
      if (tab === 'amplifi') loadAmplifiRuns();
    });
  });

  // ── Legacy sub-tab switching ──────────────────────────────────────────
  document.querySelectorAll('[data-explore-tab]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.dataset.exploreTab;
      selectLegacyTab(tab);
    });
  });

  function selectLegacyTab(tab) {
    currentTab = tab;
    document.querySelectorAll('[data-explore-tab]').forEach(function(b) {
      b.classList.toggle('explore-tab-active', b.dataset.exploreTab === tab);
    });
    document.getElementById('explore-status').textContent = TABS[tab].label;
    initDOD(tab);
  }

  // ── Initialize DOD instance for a tab ─────────────────────────────────
  function initDOD(tab) {
    var cfg = TABS[tab];
    if (!cfg) return;

    dodInstance = new window.DataObjectDisplay({
      containerId: 'explore-dod',
      objectType: tab,
      dataEndpoint: cfg.endpoint,
      hierarchyEndpoint: '/api/legacy/hierarchies',
      identityField: cfg.identity,
      showViewToggle: cfg.hierTypes.length > 0,
      showHierarchyPicker: cfg.hierTypes.length > 0,
      hierarchyTypes: cfg.hierTypes,
      glHierarchyMode: cfg.glMode || false,
      showSearch: true,
      showCSV: true,
      showPagination: true,
      pageSize: 200,
      hierPageSize: 2000,
      authHeaders: {},
      excludeColumns: ['id', 'scope', 'data_category', 'mandt']
    });

    dodInstance.loadDisplayConfig(function() {
      dodInstance.loadHierarchyOptions(function() {
        dodInstance.loadData(function() {
          dodInstance.render();
        });
      });
    });
  }

  // ── ampliFi panel ─────────────────────────────────────────────────────
  var amplifiDod = null;

  async function loadAmplifiRuns() {
    try {
      var resp = await fetch('/api/explore/amplifi/runs');
      var data = await resp.json();
      var sel = document.getElementById('amplifi-run-select');
      sel.innerHTML = '<option value="">Select run...</option>';
      (data.runs || []).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = (r.label || 'Run ' + r.id) + ' (' + (r.finished_at || 'N/A') + ')';
        sel.appendChild(opt);
      });
    } catch(e) {}
  }

  document.getElementById('amplifi-run-select').addEventListener('change', function() {
    var runId = this.value;
    if (!runId) {
      document.getElementById('amplifi-dod').innerHTML = '<span class="p-4 text-sm text-gray-400 block">Select an analysis run above.</span>';
      return;
    }
    amplifiDod = new window.DataObjectDisplay({
      containerId: 'amplifi-dod',
      objectType: 'amplifi-mapping',
      dataEndpoint: '/api/explore/amplifi/mapping',
      identityField: 'legacy_cctr',
      showViewToggle: false,
      showHierarchyPicker: false,
      showSearch: true,
      showCSV: true,
      showPagination: true,
      pageSize: 200,
      extraQueryParams: { run_id: runId },
      authHeaders: {},
      columns: [
        { key: 'legacy_cctr', label: 'Legacy CC' },
        { key: 'legacy_txtsh', label: 'Description' },
        { key: 'legacy_ccode', label: 'Company' },
        { key: 'outcome', label: 'Outcome' },
        { key: 'target_object', label: 'Target' },
        { key: 'merge_into_cctr', label: 'Merge Into' },
        { key: 'confidence', label: 'Confidence' }
      ]
    });
    amplifiDod.loadData(function() { amplifiDod.render(); });
  });

  // ── Boot ──────────────────────────────────────────────────────────────
  selectLegacyTab('cost-centers');
})();
</script>

</body>
</html>
