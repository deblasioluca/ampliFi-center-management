---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ampliFi Reference Data Explorer — public data visualization" />
  <title>Reference Data Explorer | ampliFi</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-gray-50 h-screen flex flex-col overflow-hidden font-[Inter,system-ui,sans-serif]">

  <!-- Slim standalone header -->
  <header class="bg-[#1a1a2e] text-white px-4 py-2 flex items-center justify-between flex-shrink-0">
    <div class="flex items-center gap-2">
      <img src="/ubs-logo.svg" alt="UBS" class="h-5" />
      <span class="font-semibold text-sm"><span style="color:#E60000">a</span>mpliF<span style="color:#E60000">i</span> Reference Data Explorer</span>
    </div>
    <span id="explore-status" class="text-xs text-gray-400">Ready</span>
  </header>

  <!-- Main tabs: Legacy | Target (ampliFi) -->
  <div class="flex gap-1 border-b bg-white px-4 flex-shrink-0">
    <button id="main-tab-legacy" class="px-5 py-1.5 text-sm font-semibold border-b-2 border-blue-600 text-blue-700" data-main-tab="legacy">Legacy</button>
    <button id="main-tab-target" class="px-5 py-1.5 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700" data-main-tab="target">Target (<span style="color:#E60000">a</span>mpliF<span style="color:#E60000">i</span>)</button>
  </div>

  <!-- ===== LEGACY PANEL ===== -->
  <div id="panel-legacy" class="flex-1 flex flex-col min-h-0 px-4 pt-2">
    <!-- Object sub-tabs -->
    <div class="bg-white border rounded-t-lg px-2 py-0.5 flex items-center gap-0 overflow-x-auto flex-shrink-0" id="legacy-tabs">
      <button class="explore-tab explore-tab-active" data-explore-tab="cost-centers" data-panel="legacy">Cost Centers</button>
      <button class="explore-tab" data-explore-tab="profit-centers" data-panel="legacy">Profit Centers</button>
      <button class="explore-tab" data-explore-tab="entities" data-panel="legacy">Entities</button>
      <button class="explore-tab" data-explore-tab="gl-accounts-ska1" data-panel="legacy">GL Accts (General Ledger)</button>
      <button class="explore-tab" data-explore-tab="gl-accounts-skb1" data-panel="legacy">GL Accts (CoCd)</button>
      <button class="explore-tab" data-explore-tab="gl-accounts-group" data-panel="legacy">GL Accts (Group Reporting)</button>
      <button class="explore-tab" data-explore-tab="gl-accounts-fpsl" data-panel="legacy" title="Coming soon — table structure TBD">GL Accts (FPSL) ⏳</button>
      <button class="explore-tab" data-explore-tab="gl-account-mapping" data-panel="legacy" title="Coming soon — legacy to target GL account mapping">GL Mapping ⏳</button>
      <button class="explore-tab" data-explore-tab="center-mapping-overview" data-panel="legacy">Center Mapping</button>
      <button class="explore-tab" data-explore-tab="hierarchies" data-panel="legacy">Hierarchies</button>
    </div>

    <!-- DOD container -->
    <div id="explore-dod-container" class="flex-1 min-h-0 bg-white border-x border-b rounded-b-lg overflow-hidden">
      <div id="explore-dod" class="text-xs h-full"></div>
    </div>
  </div>

  <!-- ===== TARGET (ampliFi) PANEL ===== -->
  <div id="panel-target" class="hidden flex-1 flex flex-col min-h-0 px-4 pt-2">
    <!-- Object sub-tabs (mirrors legacy minus employees) -->
    <div class="bg-white border rounded-t-lg px-2 py-0.5 flex items-center gap-0 overflow-x-auto flex-shrink-0" id="target-tabs">
      <button class="explore-tab explore-tab-active" data-explore-tab="target-cost-centers" data-panel="target">Cost Centers</button>
      <button class="explore-tab" data-explore-tab="target-profit-centers" data-panel="target">Profit Centers</button>
      <button class="explore-tab" data-explore-tab="target-entities" data-panel="target">Entities</button>
      <button class="explore-tab" data-explore-tab="target-gl-accounts-ska1" data-panel="target">GL Accts (General Ledger)</button>
      <button class="explore-tab" data-explore-tab="target-gl-accounts-skb1" data-panel="target">GL Accts (CoCd)</button>
      <button class="explore-tab" data-explore-tab="target-gl-accounts-group" data-panel="target">GL Accts (Group Reporting)</button>
      <button class="explore-tab" data-explore-tab="target-gl-accounts-fpsl" data-panel="target" title="Coming soon — table structure TBD">GL Accts (FPSL) ⏳</button>
      <button class="explore-tab" data-explore-tab="target-gl-account-mapping" data-panel="target" title="Coming soon — legacy to target GL account mapping">GL Mapping ⏳</button>
      <button class="explore-tab" data-explore-tab="target-center-mapping-overview" data-panel="target">Center Mapping</button>
      <button class="explore-tab" data-explore-tab="target-hierarchies" data-panel="target">Hierarchies</button>
    </div>

    <!-- DOD container for target -->
    <div id="target-dod-container" class="flex-1 min-h-0 bg-white border-x border-b rounded-b-lg overflow-hidden">
      <div id="target-dod" class="text-xs h-full"></div>
    </div>
  </div>

<style is:global>
  .explore-tab {
    padding: 4px 12px; font-size: 12px; font-weight: 500;
    color: #6b7280; white-space: nowrap; border-bottom: 2px solid transparent;
    cursor: pointer; transition: all 0.15s;
  }
  .explore-tab:hover { color: #374151; }
  .explore-tab-active { color: #1d4ed8; border-bottom-color: #2563eb; font-weight: 600; }
  .explore-tab .data-dot {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: #22c55e; margin-left: 4px; vertical-align: middle;
  }
</style>

<script is:inline src="/data-object-display.js"></script>
<script is:inline src="/center-mapping-view.js"></script>
<script is:inline>
(function() {
  // ── Tab configs ────────────────────────────────────────────────────────
  // Legacy tabs — same objects as before, minus employees
  // Cache for last-loaded timestamps (fetched once)
  var _lastLoadedCache = null;
  function fetchLastLoaded(cb) {
    if (_lastLoadedCache) { cb(_lastLoadedCache); return; }
    fetch('/api/data/last-loaded?scope=explorer').then(function(r) { return r.json(); }).then(function(d) {
      _lastLoadedCache = d;
      cb(d);
    }).catch(function() { cb({}); });
  }

  var LEGACY_TABS = {
    'cost-centers':       { label: 'Cost Centers',    endpoint: '/api/explore/legacy/cost-centers',     identity: 'cctr',  hierTypes: ['0101'], uploadKind: 'cost_centers', countKey: 'cost_centers' },
    'profit-centers':     { label: 'Profit Centers',  endpoint: '/api/explore/legacy/profit-centers',   identity: 'pctr',  hierTypes: ['0104'], uploadKind: 'profit_centers', countKey: 'profit_centers' },
    'entities':           { label: 'Entities',        endpoint: '/api/explore/legacy/entities',         identity: 'ccode', hierTypes: ['0106'], category: 'legacy', uploadKind: 'entities', countKey: 'entities' },
    'gl-accounts-ska1':   { label: 'GL Accts (General Ledger)',  endpoint: '/api/explore/legacy/gl-accounts-ska1', identity: 'saknr', hierTypes: [], glMode: true, category: 'legacy', uploadKind: 'gl_accounts_ska1', countKey: 'gl_accounts_ska1' },
    'gl-accounts-skb1':   { label: 'GL Accts (CoCd)', endpoint: '/api/explore/legacy/gl-accounts-skb1', identity: 'saknr', hierTypes: [], glMode: true, category: 'legacy', uploadKind: 'gl_accounts_skb1', countKey: 'gl_accounts_skb1' },
    'gl-accounts-group':  { label: 'GL Accts (Group Reporting)', endpoint: '/api/explore/legacy/gl-accounts-group', identity: 'saknr', hierTypes: [], glMode: 'type_a_only', category: 'legacy', uploadKind: 'gl_accounts_group', countKey: 'gl_accounts_group' },
    'gl-accounts-fpsl':   { label: 'GL Accts (Subledger FPSL)', placeholder: true },
    'gl-account-mapping': { label: 'GL Account Mapping', placeholder: true },
    'center-mapping-overview': { label: 'Center Mapping', useMappingView: true, countKey: 'center_mappings' },
    'hierarchies':        { label: 'Hierarchies',     endpoint: '/api/explore/legacy/hierarchies',      identity: 'setname', hierTypes: [], category: 'legacy', uploadKind: 'hierarchies', countKey: 'hierarchies' }
  };

  // Target tabs — mirror legacy structure using target tables / data_category=target
  var TARGET_TABS = {
    'target-cost-centers':       { label: 'Cost Centers',    endpoint: '/api/explore/legacy/target-cost-centers',     identity: 'cctr',  hierTypes: ['0101'], uploadKind: 'target_cost_centers', countKey: 'target_cost_centers' },
    'target-profit-centers':     { label: 'Profit Centers',  endpoint: '/api/explore/legacy/target-profit-centers',   identity: 'pctr',  hierTypes: ['0104'], uploadKind: 'target_profit_centers', countKey: 'target_profit_centers' },
    'target-entities':           { label: 'Entities',        endpoint: '/api/explore/legacy/entities',                identity: 'ccode', hierTypes: ['0106'], category: 'target', uploadKind: 'entities', countKey: 'target_entities' },
    'target-gl-accounts-ska1':   { label: 'GL Accts (General Ledger)',  endpoint: '/api/explore/legacy/gl-accounts-ska1',        identity: 'saknr', hierTypes: [], glMode: true, category: 'target', uploadKind: 'gl_accounts_ska1', countKey: 'target_gl_accounts_ska1' },
    'target-gl-accounts-skb1':   { label: 'GL Accts (CoCd)', endpoint: '/api/explore/legacy/gl-accounts-skb1',       identity: 'saknr', hierTypes: [], glMode: true, category: 'target', uploadKind: 'gl_accounts_skb1', countKey: 'target_gl_accounts_skb1' },
    'target-gl-accounts-group':  { label: 'GL Accts (Group Reporting)', endpoint: '/api/explore/legacy/gl-accounts-group', identity: 'saknr', hierTypes: [], glMode: 'type_a_only', category: 'target', uploadKind: 'gl_accounts_group', countKey: 'target_gl_accounts_group' },
    'target-gl-accounts-fpsl':   { label: 'GL Accts (Subledger FPSL)', placeholder: true },
    'target-gl-account-mapping': { label: 'GL Account Mapping', placeholder: true },
    'target-center-mapping-overview': { label: 'Center Mapping', useMappingView: true, countKey: 'center_mappings' },
    'target-hierarchies':        { label: 'Hierarchies',     endpoint: '/api/explore/legacy/hierarchies',             identity: 'setname', hierTypes: [], category: 'target', countKey: 'target_hierarchies' }
  };

  var currentPanel = 'legacy';
  var currentLegacyTab = 'cost-centers';
  var currentTargetTab = 'target-cost-centers';
  var dodLegacy = null;
  var dodTarget = null;

  // ── Main tab switching ────────────────────────────────────────────────
  document.querySelectorAll('[data-main-tab]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.dataset.mainTab;
      currentPanel = tab;
      document.getElementById('panel-legacy').classList.toggle('hidden', tab !== 'legacy');
      document.getElementById('panel-target').classList.toggle('hidden', tab !== 'target');
      document.querySelectorAll('[data-main-tab]').forEach(function(b) {
        var active = b.dataset.mainTab === tab;
        b.classList.toggle('border-blue-600', active);
        b.classList.toggle('text-blue-700', active);
        b.classList.toggle('border-transparent', !active);
        b.classList.toggle('text-gray-500', !active);
      });
      if (tab === 'target') {
        initDOD('target', currentTargetTab);
      }
    });
  });

  // ── Sub-tab switching ─────────────────────────────────────────────────
  document.querySelectorAll('[data-explore-tab]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.dataset.exploreTab;
      var panel = this.dataset.panel;
      var tabContainer = document.getElementById(panel + '-tabs');
      tabContainer.querySelectorAll('[data-explore-tab]').forEach(function(b) {
        b.classList.toggle('explore-tab-active', b.dataset.exploreTab === tab);
      });
      if (panel === 'legacy') {
        currentLegacyTab = tab;
      } else {
        currentTargetTab = tab;
      }
      var tabCfg = panel === 'legacy' ? LEGACY_TABS[tab] : TARGET_TABS[tab];
      document.getElementById('explore-status').textContent = tabCfg ? tabCfg.label : '';
      initDOD(panel, tab);
    });
  });

  // ── Initialize DOD instance for a tab ─────────────────────────────────
  function initDOD(panel, tab) {
    var tabs = panel === 'legacy' ? LEGACY_TABS : TARGET_TABS;
    var cfg = tabs[tab];
    if (!cfg) return;

    var containerId = panel === 'legacy' ? 'explore-dod' : 'target-dod';

    // Placeholder tabs — show coming soon message
    if (cfg.placeholder) {
      document.getElementById(containerId).innerHTML =
        '<div class="flex items-center justify-center h-full text-gray-400">' +
        '<div class="text-center"><p class="text-lg font-medium mb-2">' + cfg.label + '</p>' +
        '<p class="text-sm">Coming soon — table structure to be defined</p></div></div>';
      return;
    }

    // Center Mapping Overview — uses dedicated component with rowspan grouping
    if (cfg.useMappingView) {
      var mv = new window.CenterMappingView({
        containerId: containerId,
        scope: '',
        authHeaders: {},
      });
      mv.load();
      return;
    }

    var extraParams = {};
    if (cfg.category) {
      extraParams.data_category = cfg.category;
    }

    var hasHier = cfg.hierTypes.length > 0 || cfg.glMode;
    var dod = new window.DataObjectDisplay({
      containerId: containerId,
      objectType: tab,
      dataEndpoint: cfg.endpoint,
      hierarchyEndpoint: '/api/legacy/hierarchies',
      identityField: cfg.identity,
      showViewToggle: hasHier,
      showHierarchyPicker: hasHier,
      hierarchyTypes: cfg.hierTypes,
      glHierarchyMode: cfg.glMode || false,
      showSearch: true,
      showCSV: true,
      showPagination: true,
      pageSize: 200,
      hierPageSize: 2000,
      authHeaders: {},
      extraQueryParams: extraParams,
      excludeColumns: ['id', 'scope', 'data_category', 'mandt']
    });

    // Apply last-loaded timestamp
    if (cfg.uploadKind) {
      fetchLastLoaded(function(timestamps) {
        if (timestamps[cfg.uploadKind]) {
          dod.lastLoadedAt = timestamps[cfg.uploadKind];
        }
      });
    }

    dod.loadDisplayConfig(function() {
      dod.loadHierarchyOptions(function() {
        dod.loadData(function() {
          dod.render();
        });
      });
    });

    if (panel === 'legacy') {
      dodLegacy = dod;
    } else {
      dodTarget = dod;
    }
  }

  // ── Green dot indicators for tabs with loaded data ──────────────────
  function updateTabDots(counts) {
    var allTabs = { legacy: LEGACY_TABS, target: TARGET_TABS };
    Object.keys(allTabs).forEach(function(panel) {
      var tabs = allTabs[panel];
      Object.keys(tabs).forEach(function(tabKey) {
        var cfg = tabs[tabKey];
        if (!cfg.countKey) return;
        var count = counts[cfg.countKey] || 0;
        var btn = document.querySelector(
          '[data-explore-tab="' + tabKey + '"][data-panel="' + panel + '"]'
        );
        if (!btn) return;
        // Remove existing dot if any
        var existing = btn.querySelector('.data-dot');
        if (existing) existing.remove();
        if (count > 0) {
          var dot = document.createElement('span');
          dot.className = 'data-dot';
          dot.title = count.toLocaleString() + ' records';
          btn.appendChild(dot);
        }
      });
    });
  }

  // Fetch counts and render dots
  fetch('/api/explore/counts').then(function(r) { return r.json(); })
    .then(updateTabDots).catch(function() {});

  // ── Boot ──────────────────────────────────────────────────────────────
  document.getElementById('explore-status').textContent = LEGACY_TABS['cost-centers'].label;
  initDOD('legacy', 'cost-centers');
})();
</script>

</body>
</html>
