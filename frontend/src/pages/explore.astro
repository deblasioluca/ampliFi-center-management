---
import Layout from '../components/layout/Layout.astro';
export const prerender = false;
---

<Layout title="Explore Data" requireAuth={false}>
  <!-- Header -->
  <div class="flex items-center justify-between mb-2">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Explore Data</h1>
      <p class="text-xs text-gray-500">Browse legacy and target data — cost centers, profit centers, hierarchies, entities, and more</p>
    </div>
    <div class="flex items-center gap-2 text-xs">
      <span id="explore-status" class="text-gray-400">Loading...</span>
    </div>
  </div>

  <!-- Top-level tabs: Legacy | ampliFi -->
  <div class="flex gap-1 border-b mb-2">
    <button id="main-tab-legacy" class="px-5 py-2 text-sm font-semibold border-b-2 border-blue-600 text-blue-700" onclick="switchMainTab('legacy')">Legacy</button>
    <button id="main-tab-amplifi" class="px-5 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700" onclick="switchMainTab('amplifi')">ampliFi</button>
    <button id="main-tab-sources" class="px-5 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700" onclick="switchMainTab('sources')">Data Sources</button>
  </div>

  <!-- ===== LEGACY PANEL ===== -->
  <div id="panel-legacy">
    <!-- Object sub-tabs -->
    <div class="bg-white border rounded-t-lg px-2 py-1 flex items-center gap-0 overflow-x-auto">
      <button class="explore-sub active px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-blue-600 text-blue-700" data-obj="cost-centers" onclick="switchLegacyObj('cost-centers')">Cost Centers</button>
      <button class="explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="profit-centers" onclick="switchLegacyObj('profit-centers')">Profit Centers</button>
      <button class="explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="entities" onclick="switchLegacyObj('entities')">Entities</button>
      <button class="explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="hierarchies" onclick="switchLegacyObj('hierarchies')">Hierarchies</button>
      <button class="explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="balances" onclick="switchLegacyObj('balances')">Balances</button>
      <button class="explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="employees" onclick="switchLegacyObj('employees')">Employees</button>
      <button class="explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="gl-accounts" onclick="switchLegacyObj('gl-accounts')">GL Accounts</button>
    </div>

    <!-- Toolbar -->
    <div class="bg-white border-x border-b rounded-b-lg px-3 py-2 flex items-center justify-between gap-2 mb-2">
      <div class="flex items-center gap-2">
        <button id="view-tabular" class="btn-sm bg-blue-600 text-white text-xs" onclick="switchView('tabular')">Tabular</button>
        <button id="view-hierarchical" class="btn-sm bg-gray-200 text-gray-700 text-xs hidden" onclick="switchView('hierarchical')">Hierarchical</button>
        <input id="explore-search" type="text" placeholder="Search..." class="border rounded px-2 py-1 text-xs w-48" oninput="applySearch()" />
      </div>
      <div class="flex items-center gap-2">
        <span id="explore-count" class="text-xs text-gray-500"></span>
        <button onclick="exportCSV()" class="btn-secondary text-xs">CSV</button>
      </div>
    </div>

    <!-- Content area (scrollable within viewport) -->
    <div id="legacy-content" class="overflow-x-auto overflow-y-auto bg-white border rounded-lg" style="max-height:calc(100vh - 300px)">
      <span class="p-4 text-sm text-gray-400 block">Loading data...</span>
    </div>
  </div>

  <!-- ===== AMPLIFI PANEL ===== -->
  <div id="panel-amplifi" class="hidden">
    <!-- Sub-tabs -->
    <div class="bg-white border rounded-t-lg px-2 py-1 flex items-center gap-0 overflow-x-auto">
      <button class="amplifi-sub active px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-indigo-600 text-indigo-700" data-obj="mapping" onclick="switchAmplifiObj('mapping')">Legacy → Target Mapping</button>
      <button class="amplifi-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="summary" onclick="switchAmplifiObj('summary')">Summary</button>
      <button class="amplifi-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700" data-obj="cc-pc-map" onclick="switchAmplifiObj('cc-pc-map')">CC → PC (n:1)</button>
    </div>

    <!-- Toolbar -->
    <div class="bg-white border-x border-b rounded-b-lg px-3 py-2 flex items-center justify-between gap-2 mb-2">
      <div class="flex items-center gap-2">
        <label class="text-xs text-gray-500">Run:</label>
        <select id="amplifi-run-sel" class="input text-xs py-1 w-56" onchange="loadAmplifiData()">
          <option value="">Latest completed run</option>
        </select>
        <input id="amplifi-search" type="text" placeholder="Search..." class="border rounded px-2 py-1 text-xs w-48" oninput="applyAmplifiSearch()" />
      </div>
      <span id="amplifi-count" class="text-xs text-gray-500"></span>
    </div>

    <!-- Content area -->
    <div id="amplifi-content" class="overflow-x-auto overflow-y-auto bg-white border rounded-lg" style="max-height:calc(100vh - 300px)">
      <span class="p-4 text-sm text-gray-400 block">Loading analysis results...</span>
    </div>
  </div>

  <!-- ===== DATA SOURCES PANEL ===== -->
  <div id="panel-sources" class="hidden">
    <div class="bg-white border rounded-lg p-4">
      <h3 class="text-sm font-semibold mb-3">Data Source Configuration</h3>
      <p class="text-xs text-gray-500 mb-4">Shows where each data object is sourced from and current record counts.</p>
      <div id="sources-content" class="overflow-x-auto">
        <span class="text-sm text-gray-400">Loading...</span>
      </div>
    </div>
  </div>
</Layout>

<style>
  #legacy-content thead th,
  #amplifi-content thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #f9fafb;
  }
</style>

<script>
(function() {
  var BASE = '/api/explore';
  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  var _currentLegacyObj = 'cost-centers';
  var _currentView = 'tabular';
  var _legacyData = {};
  var _amplifiData = null;
  var _amplifiObj = 'mapping';

  // ── Main tab switching ────────────────────────────────────────────────
  window.switchMainTab = function(tab) {
    ['legacy', 'amplifi', 'sources'].forEach(function(t) {
      var panel = document.getElementById('panel-' + t);
      var btn = document.getElementById('main-tab-' + t);
      if (t === tab) {
        panel.classList.remove('hidden');
        btn.className = 'px-5 py-2 text-sm font-semibold border-b-2 border-blue-600 text-blue-700';
      } else {
        panel.classList.add('hidden');
        btn.className = 'px-5 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700';
      }
    });
    if (tab === 'amplifi' && !_amplifiData) loadAmplifiData();
    if (tab === 'sources') loadSources();
  };

  // ── Legacy object switching ───────────────────────────────────────────
  window.switchLegacyObj = function(obj) {
    _currentLegacyObj = obj;
    document.querySelectorAll('.explore-sub').forEach(function(b) {
      if (b.getAttribute('data-obj') === obj) {
        b.className = 'explore-sub active px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-blue-600 text-blue-700';
      } else {
        b.className = 'explore-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700';
      }
    });
    // Show/hide hierarchical button
    var hierBtn = document.getElementById('view-hierarchical');
    if (obj === 'cost-centers' || obj === 'profit-centers' || obj === 'hierarchies') {
      hierBtn.classList.remove('hidden');
    } else {
      hierBtn.classList.add('hidden');
      _currentView = 'tabular';
    }
    loadLegacyObj(obj);
  };

  window.switchView = function(view) {
    _currentView = view;
    var tabBtn = document.getElementById('view-tabular');
    var hierBtn = document.getElementById('view-hierarchical');
    if (view === 'tabular') {
      tabBtn.className = 'btn-sm bg-blue-600 text-white text-xs';
      hierBtn.className = 'btn-sm bg-gray-200 text-gray-700 text-xs';
    } else {
      tabBtn.className = 'btn-sm bg-gray-200 text-gray-700 text-xs';
      hierBtn.className = 'btn-sm bg-blue-600 text-white text-xs';
    }
    renderLegacy();
  };

  // ── Load legacy data ──────────────────────────────────────────────────
  function loadLegacyObj(obj) {
    var el = document.getElementById('legacy-content');
    el.innerHTML = '<span class="p-4 text-sm text-gray-400 block">Loading...</span>';
    var url = BASE + '/legacy/' + obj + '?size=2000';
    fetch(url).then(function(r) { return r.json(); }).then(function(d) {
      _legacyData[obj] = d;
      document.getElementById('explore-count').textContent = (d.total || (d.items || []).length) + ' records';
      renderLegacy();
    }).catch(function(e) { el.innerHTML = '<span class="p-4 text-red-500 block">Error: ' + esc(e.message) + '</span>'; });
  }

  function renderLegacy() {
    var el = document.getElementById('legacy-content');
    var d = _legacyData[_currentLegacyObj];
    if (!d) return;
    var search = (document.getElementById('explore-search').value || '').toLowerCase();

    if (_currentLegacyObj === 'cost-centers') renderCostCenters(el, d, search);
    else if (_currentLegacyObj === 'profit-centers') renderProfitCenters(el, d, search);
    else if (_currentLegacyObj === 'entities') renderEntities(el, d, search);
    else if (_currentLegacyObj === 'hierarchies') renderHierarchies(el, d, search);
    else if (_currentLegacyObj === 'balances') renderBalances(el, d, search);
    else if (_currentLegacyObj === 'employees') renderEmployees(el, d, search);
    else if (_currentLegacyObj === 'gl-accounts') renderGLAccounts(el, d, search);
  }

  window.applySearch = function() { renderLegacy(); };

  // ── Cost Centers ──────────────────────────────────────────────────────
  function renderCostCenters(el, d, search) {
    var items = (d.items || []).filter(function(c) {
      if (!search) return true;
      return (c.cctr || '').toLowerCase().indexOf(search) >= 0 || (c.txtsh || '').toLowerCase().indexOf(search) >= 0 ||
             (c.ccode || '').toLowerCase().indexOf(search) >= 0 || (c.responsible || '').toLowerCase().indexOf(search) >= 0;
    });
    if (_currentView === 'hierarchical') { renderHierTree(el, items, 'cctr'); return; }
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">CC</th><th class="py-2 px-2 text-left">Short Text</th><th class="py-2 px-2 text-left">Entity</th>';
    html += '<th class="py-2 px-2 text-left">CO Area</th><th class="py-2 px-2 text-left">Profit Ctr</th><th class="py-2 px-2 text-left">Responsible</th>';
    html += '<th class="py-2 px-2 text-left">Category</th><th class="py-2 px-2 text-left">Currency</th><th class="py-2 px-2 text-center">Active</th>';
    html += '</tr></thead><tbody>';
    items.forEach(function(c) {
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(c.cctr) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(c.txtsh) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(c.ccode) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(c.coarea) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(c.pctr) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(c.responsible) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(c.cctrcgy) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(c.currency) + '</td>';
      html += '<td class="py-1.5 px-2 text-center">' + (c.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('explore-count').textContent = items.length + ' records';
  }

  // ── Profit Centers ────────────────────────────────────────────────────
  function renderProfitCenters(el, d, search) {
    var items = (d.items || []).filter(function(p) {
      if (!search) return true;
      return (p.pctr || '').toLowerCase().indexOf(search) >= 0 || (p.txtsh || '').toLowerCase().indexOf(search) >= 0 ||
             (p.ccode || '').toLowerCase().indexOf(search) >= 0;
    });
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">PC</th><th class="py-2 px-2 text-left">Short Text</th><th class="py-2 px-2 text-left">Entity</th>';
    html += '<th class="py-2 px-2 text-left">CO Area</th><th class="py-2 px-2 text-left">Responsible</th><th class="py-2 px-2 text-left">Department</th>';
    html += '<th class="py-2 px-2 text-left">Currency</th><th class="py-2 px-2 text-center">Active</th>';
    html += '</tr></thead><tbody>';
    items.forEach(function(p) {
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(p.pctr) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(p.txtsh) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(p.ccode) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(p.coarea) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(p.responsible) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(p.department) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(p.currency) + '</td>';
      html += '<td class="py-1.5 px-2 text-center">' + (p.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('explore-count').textContent = items.length + ' records';
  }

  // ── Entities ──────────────────────────────────────────────────────────
  function renderEntities(el, d, search) {
    var items = (d.items || []).filter(function(e) {
      if (!search) return true;
      return (e.ccode || '').toLowerCase().indexOf(search) >= 0 || (e.name || '').toLowerCase().indexOf(search) >= 0;
    });
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">Code</th><th class="py-2 px-2 text-left">Name</th><th class="py-2 px-2 text-left">Country</th>';
    html += '<th class="py-2 px-2 text-left">Region</th><th class="py-2 px-2 text-left">Currency</th><th class="py-2 px-2 text-center">Active</th>';
    html += '</tr></thead><tbody>';
    items.forEach(function(e) {
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(e.ccode) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.name) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.country) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.region) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(e.currency) + '</td>';
      html += '<td class="py-1.5 px-2 text-center">' + (e.is_active ? '<span class="text-green-600">Yes</span>' : '<span class="text-red-500">No</span>') + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('explore-count').textContent = items.length + ' records';
  }

  // ── GL Accounts ───────────────────────────────────────────────────────
  function renderGLAccounts(el, d, search) {
    var items = (d.items || []).filter(function(r) {
      if (!search) return true;
      return (r.class_code || '').toLowerCase().indexOf(search) >= 0 || (r.class_label || '').toLowerCase().indexOf(search) >= 0;
    });
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">Class Code</th><th class="py-2 px-2 text-left">Label</th>';
    html += '<th class="py-2 px-2 text-left">From Account</th><th class="py-2 px-2 text-left">To Account</th><th class="py-2 px-2 text-left">Category</th>';
    html += '</tr></thead><tbody>';
    items.forEach(function(r) {
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(r.class_code) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(r.class_label) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(r.from_account) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(r.to_account) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(r.category) + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('explore-count').textContent = items.length + ' records';
  }

  // ── Balances ──────────────────────────────────────────────────────────
  function renderBalances(el, d, search) {
    var bals = d.balances || {};
    var keys = Object.keys(bals).filter(function(k) { return !search || k.toLowerCase().indexOf(search) >= 0; }).sort();
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">CO Area : CC</th><th class="py-2 px-2 text-right">Periods</th><th class="py-2 px-2 text-right">Total Amount</th><th class="py-2 px-2 text-right">Total Postings</th><th class="py-2 px-2 text-left">Currency</th>';
    html += '</tr></thead><tbody>';
    keys.forEach(function(k) {
      var periods = bals[k];
      var totalAmt = 0, totalPost = 0, curr = '';
      periods.forEach(function(p) { totalAmt += p.amount; totalPost += p.postings; curr = p.currency || curr; });
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(k) + '</td>';
      html += '<td class="py-1.5 px-2 text-right">' + periods.length + '</td>';
      html += '<td class="py-1.5 px-2 text-right font-mono' + (totalAmt < 0 ? ' text-red-600' : '') + '">' + totalAmt.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0}) + '</td>';
      html += '<td class="py-1.5 px-2 text-right font-mono">' + totalPost.toLocaleString() + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(curr) + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('explore-count').textContent = keys.length + ' cost center keys';
  }

  // ── Employees ─────────────────────────────────────────────────────────
  function renderEmployees(el, d, search) {
    var items = (d.items || []).filter(function(e) {
      if (!search) return true;
      return (e.gpn || '').toLowerCase().indexOf(search) >= 0 || (e.bs_name || '').toLowerCase().indexOf(search) >= 0 ||
             (e.email_address || '').toLowerCase().indexOf(search) >= 0;
    });
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">GPN</th><th class="py-2 px-2 text-left">Name</th><th class="py-2 px-2 text-left">First</th><th class="py-2 px-2 text-left">Last</th>';
    html += '<th class="py-2 px-2 text-left">OU Code</th><th class="py-2 px-2 text-left">OU Desc</th><th class="py-2 px-2 text-left">Local CC</th>';
    html += '<th class="py-2 px-2 text-left">Job</th><th class="py-2 px-2 text-left">Email</th>';
    html += '</tr></thead><tbody>';
    items.forEach(function(e) {
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(e.gpn) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.bs_name) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.bs_firstname) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.bs_lastname) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(e.ou_cd) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.ou_desc) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(e.local_cc_cd) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.job_desc) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(e.email_address) + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('explore-count').textContent = items.length + ' of ' + (d.total || items.length) + ' records';
  }

  // ── Hierarchies (tree view) ───────────────────────────────────────────
  function renderHierarchies(el, d, search) {
    var hiers = d.hierarchies || [];
    if (!hiers.length) { el.innerHTML = '<span class="p-4 text-gray-400 block">No hierarchies loaded</span>'; return; }
    var html = '<div class="p-3">';
    hiers.forEach(function(h, idx) {
      html += '<div class="mb-4 border rounded-lg overflow-hidden">';
      html += '<div class="bg-gray-50 px-3 py-2 flex items-center gap-2 cursor-pointer" onclick="toggleHierTree(' + idx + ')">';
      html += '<span class="text-xs font-semibold text-gray-700">' + esc(h.label) + '</span>';
      html += '<span class="text-[10px] px-1.5 py-0.5 rounded bg-blue-100 text-blue-700">' + esc(h.type_label) + '</span>';
      html += '<span class="text-[10px] text-gray-400">' + (h.leaves || []).length + ' leaves, ' + (h.nodes || []).length + ' nodes</span>';
      html += '</div>';
      html += '<div id="hier-tree-' + idx + '" class="hidden p-2 text-xs font-mono max-h-64 overflow-auto"></div>';
      html += '</div>';
    });
    html += '</div>';
    el.innerHTML = html;
    document.getElementById('explore-count').textContent = hiers.length + ' hierarchies';
  }

  window.toggleHierTree = function(idx) {
    var el = document.getElementById('hier-tree-' + idx);
    if (!el) return;
    if (!el.classList.contains('hidden')) { el.classList.add('hidden'); return; }
    el.classList.remove('hidden');
    if (el.innerHTML) return;
    var d = _legacyData['hierarchies'];
    var h = (d.hierarchies || [])[idx];
    if (!h) return;
    var childMap = {};
    (h.nodes || []).forEach(function(n) {
      if (!childMap[n.parent]) childMap[n.parent] = [];
      childMap[n.parent].push(n.child);
    });
    var leafMap = {};
    (h.leaves || []).forEach(function(lf) {
      if (!leafMap[lf.setname]) leafMap[lf.setname] = [];
      leafMap[lf.setname].push(lf.value);
    });
    function buildTree(node, depth) {
      var indent = '';
      for (var i = 0; i < depth; i++) indent += '  ';
      var html = '<div style="padding-left:' + (depth * 16) + 'px" class="py-0.5">';
      html += '<span class="text-blue-700 font-semibold">' + esc(node) + '</span>';
      var leaves = leafMap[node] || [];
      if (leaves.length) html += ' <span class="text-gray-400">(' + leaves.length + ' items)</span>';
      html += '</div>';
      leaves.forEach(function(v) {
        html += '<div style="padding-left:' + ((depth + 1) * 16) + 'px" class="py-0.5 text-gray-600">' + esc(v) + '</div>';
      });
      (childMap[node] || []).forEach(function(child) { html += buildTree(child, depth + 1); });
      return html;
    }
    el.innerHTML = buildTree(h.setname, 0);
  };

  // ── Hierarchical tree view for CC/PC ──────────────────────────────────
  function renderHierTree(el, items, keyField) {
    var hierData = _legacyData['hierarchies'];
    if (!hierData || !(hierData.hierarchies || []).length) {
      el.innerHTML = '<span class="p-4 text-gray-400 block">No hierarchies loaded. Load hierarchies first to use hierarchical view.</span>';
      return;
    }
    var hiers = hierData.hierarchies;
    var html = '<div class="p-3"><div class="mb-2"><label class="text-xs font-medium mr-2">Hierarchy:</label>';
    html += '<select id="explore-hier-sel" class="input text-xs w-64" onchange="reloadHierView()">';
    hiers.forEach(function(h, i) { html += '<option value="' + i + '">' + esc(h.label) + '</option>'; });
    html += '</select></div>';

    var h = hiers[0];
    var itemMap = {};
    items.forEach(function(it) { if (it[keyField]) itemMap[it[keyField]] = it; });
    var leafMap = {};
    (h.leaves || []).forEach(function(lf) {
      if (!leafMap[lf.setname]) leafMap[lf.setname] = [];
      leafMap[lf.setname].push(lf.value);
    });
    var childMap = {};
    (h.nodes || []).forEach(function(n) {
      if (!childMap[n.parent]) childMap[n.parent] = [];
      childMap[n.parent].push(n.child);
    });

    function buildNode(node, depth) {
      var leaves = leafMap[node] || [];
      var children = childMap[node] || [];
      var count = leaves.length;
      children.forEach(function(c) { count += countLeaves(c); });
      var r = '<div style="padding-left:' + (depth * 16) + 'px" class="py-1 border-b border-gray-100">';
      r += '<span class="font-semibold text-blue-800 text-xs">' + esc(node) + '</span>';
      r += '<span class="text-[10px] text-gray-400 ml-1">(' + count + ')</span></div>';
      leaves.forEach(function(v) {
        var it = itemMap[v];
        r += '<div style="padding-left:' + ((depth + 1) * 16) + 'px" class="py-0.5 text-[11px] border-b border-gray-50">';
        r += '<span class="font-mono">' + esc(v) + '</span>';
        if (it) r += ' <span class="text-gray-500">' + esc(it.txtsh || it.txtmi || '') + '</span>';
        r += '</div>';
      });
      children.forEach(function(c) { r += buildNode(c, depth + 1); });
      return r;
    }
    function countLeaves(node) {
      var n = (leafMap[node] || []).length;
      (childMap[node] || []).forEach(function(c) { n += countLeaves(c); });
      return n;
    }
    html += buildNode(h.setname, 0) + '</div>';
    el.innerHTML = html;
  }

  // ── ampliFi tab ───────────────────────────────────────────────────────
  window.switchAmplifiObj = function(obj) {
    _amplifiObj = obj;
    document.querySelectorAll('.amplifi-sub').forEach(function(b) {
      if (b.getAttribute('data-obj') === obj) {
        b.className = 'amplifi-sub active px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-indigo-600 text-indigo-700';
      } else {
        b.className = 'amplifi-sub px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-700';
      }
    });
    renderAmplifi();
  };

  window.loadAmplifiData = function() {
    var el = document.getElementById('amplifi-content');
    el.innerHTML = '<span class="p-4 text-sm text-gray-400 block">Loading...</span>';
    var runId = document.getElementById('amplifi-run-sel').value;
    var url = BASE + '/amplifi/mapping' + (runId ? '?run_id=' + runId : '');
    fetch(url).then(function(r) { return r.json(); }).then(function(d) {
      _amplifiData = d;
      document.getElementById('amplifi-count').textContent = (d.total || 0) + ' proposals';
      renderAmplifi();
    }).catch(function(e) { el.innerHTML = '<span class="p-4 text-red-500 block">Error: ' + esc(e.message) + '</span>'; });

    // Load run list
    fetch(BASE + '/amplifi/runs').then(function(r) { return r.json(); }).then(function(d) {
      var sel = document.getElementById('amplifi-run-sel');
      var val = sel.value;
      sel.innerHTML = '<option value="">Latest completed run</option>';
      (d.runs || []).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = (r.label || 'Run #' + r.id) + (r.finished_at ? ' (' + r.finished_at.split('T')[0] + ')' : '');
        sel.appendChild(opt);
      });
      if (val) sel.value = val;
    });
  };

  window.applyAmplifiSearch = function() { renderAmplifi(); };

  function renderAmplifi() {
    var el = document.getElementById('amplifi-content');
    if (!_amplifiData) { el.innerHTML = '<span class="p-4 text-gray-400 block">No analysis data available. Run an analysis first.</span>'; return; }
    if (_amplifiObj === 'mapping') renderMapping(el);
    else if (_amplifiObj === 'summary') renderSummary(el);
    else if (_amplifiObj === 'cc-pc-map') renderCCPCMap(el);
  }

  function renderMapping(el) {
    var search = (document.getElementById('amplifi-search').value || '').toLowerCase();
    var items = (_amplifiData.items || []).filter(function(it) {
      if (!search) return true;
      return (it.legacy_cctr || '').toLowerCase().indexOf(search) >= 0 || (it.legacy_txtsh || '').toLowerCase().indexOf(search) >= 0 ||
             (it.outcome || '').toLowerCase().indexOf(search) >= 0 || (it.merge_into_cctr || '').toLowerCase().indexOf(search) >= 0;
    });
    var COLORS = { KEEP: '#22c55e', RETIRE: '#ef4444', MERGE_MAP: '#f59e0b', REDESIGN: '#3b82f6' };
    var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
    html += '<th class="py-2 px-2 text-left">Legacy CC</th><th class="py-2 px-2 text-left">Name</th><th class="py-2 px-2 text-left">Entity</th>';
    html += '<th class="py-2 px-2 text-left">CO Area</th><th class="py-2 px-2 text-left">Legacy PC</th>';
    html += '<th class="py-2 px-2 text-center">Outcome</th><th class="py-2 px-2 text-left">Target Object</th><th class="py-2 px-2 text-left">Target CC</th>';
    html += '<th class="py-2 px-2 text-center">Confidence</th>';
    html += '</tr></thead><tbody>';
    items.forEach(function(it) {
      var color = COLORS[it.outcome] || '#9ca3af';
      html += '<tr class="border-b hover:bg-gray-50">';
      html += '<td class="py-1.5 px-2 font-mono font-medium">' + esc(it.legacy_cctr) + '</td>';
      html += '<td class="py-1.5 px-2">' + esc(it.legacy_txtsh) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(it.legacy_ccode) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(it.legacy_coarea) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(it.legacy_pctr) + '</td>';
      html += '<td class="py-1.5 px-2 text-center"><span class="px-1.5 py-0.5 rounded text-[10px] font-semibold text-white" style="background:' + color + '">' + esc(it.outcome) + '</span></td>';
      html += '<td class="py-1.5 px-2">' + esc(it.target_object) + '</td>';
      html += '<td class="py-1.5 px-2 font-mono">' + esc(it.merge_into_cctr) + '</td>';
      html += '<td class="py-1.5 px-2 text-center font-mono">' + (it.confidence ? parseFloat(it.confidence).toFixed(2) : '-') + '</td>';
      html += '</tr>';
    });
    el.innerHTML = html + '</tbody></table>';
    document.getElementById('amplifi-count').textContent = items.length + ' proposals';
  }

  function renderSummary(el) {
    var d = _amplifiData;
    var s = d.summary || {};
    var total = d.total || 0;
    var html = '<div class="p-4 space-y-4">';
    html += '<div class="text-sm"><strong>Run:</strong> ' + esc(d.run_label || 'Run #' + d.run_id) + ' (' + esc(d.run_status) + ')</div>';
    html += '<div class="text-sm"><strong>Total Proposals:</strong> ' + total + '</div>';
    html += '<div class="grid grid-cols-2 lg:grid-cols-4 gap-3">';
    var COLORS = { KEEP: '#22c55e', RETIRE: '#ef4444', MERGE_MAP: '#f59e0b', REDESIGN: '#3b82f6' };
    ['KEEP', 'RETIRE', 'MERGE_MAP', 'REDESIGN'].forEach(function(o) {
      var cnt = s[o] || 0;
      var pct = total ? Math.round(cnt / total * 100) : 0;
      html += '<div class="border rounded-lg p-3 text-center">';
      html += '<div class="text-lg font-bold" style="color:' + (COLORS[o] || '#666') + '">' + cnt + '</div>';
      html += '<div class="text-xs text-gray-500">' + o + ' (' + pct + '%)</div></div>';
    });
    html += '</div>';
    // Reduction
    var kept = (s.KEEP || 0);
    var reduced = total - kept;
    var reductionPct = total ? Math.round(reduced / total * 100) : 0;
    html += '<div class="bg-blue-50 border border-blue-200 rounded-lg p-3">';
    html += '<div class="text-sm font-semibold text-blue-800">Reduction: ' + reductionPct + '% (' + reduced + ' of ' + total + ' centers)</div>';
    html += '</div></div>';
    el.innerHTML = html;
  }

  function renderCCPCMap(el) {
    var items = _amplifiData.items || [];
    var pcGroups = {};
    items.forEach(function(it) {
      if (it.outcome === 'MERGE_MAP' || it.outcome === 'REDESIGN') {
        var tgt = it.merge_into_cctr || it.legacy_pctr || 'Unassigned';
        if (!pcGroups[tgt]) pcGroups[tgt] = [];
        pcGroups[tgt].push(it);
      }
    });
    var keys = Object.keys(pcGroups).sort(function(a, b) { return pcGroups[b].length - pcGroups[a].length; });
    var html = '<div class="p-3 space-y-3">';
    html += '<div class="text-xs text-gray-500 mb-2">' + keys.length + ' target groups from ' + items.filter(function(it) { return it.outcome === 'MERGE_MAP' || it.outcome === 'REDESIGN'; }).length + ' proposals (MERGE_MAP + REDESIGN only)</div>';
    keys.forEach(function(k) {
      var group = pcGroups[k];
      html += '<div class="border rounded-lg overflow-hidden">';
      html += '<div class="bg-indigo-50 px-3 py-1.5 flex items-center justify-between">';
      html += '<span class="text-xs font-semibold text-indigo-800">Target: ' + esc(k) + '</span>';
      html += '<span class="text-[10px] bg-indigo-200 text-indigo-700 px-1.5 py-0.5 rounded">' + group.length + ' CC' + (group.length > 1 ? 's' : '') + '</span>';
      html += '</div>';
      html += '<div class="px-3 py-1">';
      group.forEach(function(it) {
        html += '<div class="text-[11px] py-0.5 border-b border-gray-50">';
        html += '<span class="font-mono">' + esc(it.legacy_cctr) + '</span> <span class="text-gray-500">' + esc(it.legacy_txtsh) + '</span>';
        html += ' <span class="text-gray-300">(' + esc(it.legacy_ccode) + ')</span>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    if (!keys.length) html += '<span class="text-gray-400">No MERGE_MAP or REDESIGN proposals found</span>';
    html += '</div>';
    el.innerHTML = html;
  }

  // ── Data Sources ──────────────────────────────────────────────────────
  function loadSources() {
    var el = document.getElementById('sources-content');
    fetch(BASE + '/data-sources').then(function(r) { return r.json(); }).then(function(d) {
      var items = d.sources || [];
      var html = '<table class="w-full text-xs border-collapse"><thead><tr class="border-b bg-gray-50">';
      html += '<th class="py-2 px-3 text-left">Object</th><th class="py-2 px-3 text-left">Source</th><th class="py-2 px-3 text-right">Records</th>';
      html += '</tr></thead><tbody>';
      items.forEach(function(s) {
        html += '<tr class="border-b hover:bg-gray-50">';
        html += '<td class="py-2 px-3 font-medium">' + esc(s.label) + '</td>';
        html += '<td class="py-2 px-3"><span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700 text-[10px]">' + esc(s.source) + '</span></td>';
        html += '<td class="py-2 px-3 text-right font-mono font-bold">' + (s.count || 0).toLocaleString() + '</td>';
        html += '</tr>';
      });
      el.innerHTML = html + '</tbody></table>';
    });
  }

  // ── CSV Export ─────────────────────────────────────────────────────────
  window.exportCSV = function() {
    var el = document.getElementById('legacy-content');
    var table = el.querySelector('table');
    if (!table) return;
    var rows = [];
    table.querySelectorAll('tr').forEach(function(tr) {
      var cols = [];
      tr.querySelectorAll('th, td').forEach(function(td) { cols.push('"' + (td.textContent || '').replace(/"/g, '""') + '"'); });
      rows.push(cols.join(','));
    });
    var blob = new Blob([rows.join('\n')], { type: 'text/csv' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = _currentLegacyObj + '.csv';
    a.click();
  };

  // ── Init ──────────────────────────────────────────────────────────────
  fetch(BASE + '/counts').then(function(r) { return r.json(); }).then(function(d) {
    var parts = [];
    if (d.cost_centers) parts.push(d.cost_centers + ' CC');
    if (d.profit_centers) parts.push(d.profit_centers + ' PC');
    if (d.entities) parts.push(d.entities + ' entities');
    if (d.employees) parts.push(d.employees + ' employees');
    document.getElementById('explore-status').textContent = parts.join(' | ') || 'No data loaded';
  });

  // Load hierarchies in background for tree views
  fetch(BASE + '/legacy/hierarchies').then(function(r) { return r.json(); }).then(function(d) {
    _legacyData['hierarchies'] = d;
  });

  // Load initial view
  loadLegacyObj('cost-centers');

})();
</script>
