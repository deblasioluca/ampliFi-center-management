---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="My Tasks" requireAuth={true}>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">My Tasks</h1>
    <p class="text-sm text-gray-500 mt-1">Review your assigned cost centers, request changes, and approve proposals</p>
  </div>

  <!-- Assigned review scopes (auto-loaded for logged-in user) -->
  <div id="assigned-scopes" class="hidden mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Your Assigned Review Scopes</h2>
    <div id="assigned-scopes-list" class="space-y-3"></div>
  </div>

  <!-- Info banner when no review token -->
  <div id="no-review" class="card mb-6">
    <div class="flex items-start gap-4">
      <svg class="w-8 h-8 text-amplifi-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="text-base font-semibold text-gray-900">No Active Review Scope</h3>
        <p class="text-sm text-gray-500 mt-1">
          You don't have an active review assignment right now. When a wave is in the review phase,
          you'll receive a review link with a personal token. Enter it below to access your scope.
        </p>
        <div class="mt-4 flex gap-3 items-end">
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">Review Token</label>
            <input type="text" id="review-token" class="input" placeholder="Paste your review token here..." />
          </div>
          <button id="load-review-btn" class="btn-amplifi whitespace-nowrap">Load Review</button>
        </div>
        <div id="token-error" class="text-sm text-red-600 mt-2 hidden"></div>
      </div>
    </div>
  </div>

  <!-- Review scope (shown when token loaded) -->
  <div id="review-scope" class="hidden">
    <!-- Scope summary -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Wave</h4>
        <p id="scope-wave" class="text-lg font-bold text-gray-900 mt-1">--</p>
      </div>
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Total Items</h4>
        <p id="scope-total" class="text-lg font-bold text-gray-900 mt-1">--</p>
      </div>
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Decided</h4>
        <p id="scope-decided" class="text-lg font-bold text-green-600 mt-1">--</p>
      </div>
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Pending</h4>
        <p id="scope-pending" class="text-lg font-bold text-amber-600 mt-1">--</p>
      </div>
    </div>

    <!-- DOD-powered review items table (same as all other data tabs) -->
    <div id="review-dod-container" class="card"></div>

    <!-- Why Panel (hidden, shown on row click) -->
    <div id="why-panel" class="card mt-4 hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold text-gray-900">Analysis Reasoning</h3>
        <button onclick="document.getElementById('why-panel').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-sm">Close</button>
      </div>
      <div id="why-content" class="text-sm space-y-2">Loading...</div>
    </div>
  </div>

  <!-- Request New CC/PC Modal -->
  <div id="new-center-modal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg mx-4 p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-gray-900" id="new-center-title">Request New Center</h3>
        <button id="close-new-modal" class="text-gray-400 hover:text-gray-600">&times;</button>
      </div>
      <form id="new-center-form" class="space-y-4">
        <input type="hidden" id="nc-clone-from" value="" />
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
            <select id="nc-target-object" class="input text-sm">
              <option value="CC">Cost Center</option>
              <option value="PC">Profit Center</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Responsible</label>
            <input type="text" id="nc-responsible" class="input text-sm" placeholder="Owner name..." />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Proposed Name / Short Text</label>
          <input type="text" id="nc-name" class="input text-sm" placeholder="Short description..." required />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Entity (Company Code)</label>
            <input type="text" id="nc-ccode" class="input text-sm" placeholder="e.g. 1000" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Controlling Area</label>
            <input type="text" id="nc-coarea" class="input text-sm" placeholder="e.g. 1000" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hierarchy Node</label>
          <div class="relative">
            <select id="nc-hier-node" class="input text-sm">
              <option value="">(none — no hierarchy placement)</option>
            </select>
            <p class="text-[10px] text-gray-400 mt-0.5">Select a node under which this center should be placed</p>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Purpose / Justification</label>
          <textarea id="nc-purpose" class="input text-sm" rows="3" placeholder="Why is this center needed?" required></textarea>
        </div>
        <div id="nc-clone-info" class="hidden bg-blue-50 border border-blue-200 rounded p-3 text-xs text-blue-700">
          <strong>Cloning from:</strong> <span id="nc-clone-label"></span>
          <p class="mt-1 text-blue-600">Fields have been pre-filled from the source center. Amend as needed.</p>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="cancel-new-center" class="btn-secondary text-sm">Cancel</button>
          <button type="submit" class="btn-amplifi text-sm">Submit Request</button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script is:inline src="/data-object-display.js"></script>
<script is:inline>
  (function() {
    var currentToken = localStorage.getItem('amplifi_review_token') || '';
    var reviewDod = null;

    function authHeaders() {
      var t = localStorage.getItem('amplifi_token');
      return t ? { 'Authorization': 'Bearer ' + t, 'Content-Type': 'application/json' } : { 'Content-Type': 'application/json' };
    }

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text || '';
      return div.innerHTML;
    }

    // ── Scope loading ───────────────────────────────────────────────────
    async function loadScope(token) {
      try {
        var res = await fetch('/api/review/' + token, { headers: authHeaders() });
        if (!res.ok) throw new Error((await res.json().catch(function(){return {};})).detail || 'Invalid token');
        var data = await res.json();
        document.getElementById('no-review').classList.add('hidden');
        document.getElementById('review-scope').classList.remove('hidden');
        document.getElementById('scope-wave').textContent = data.wave_name || data.wave_code || data.wave_id || '--';
        document.getElementById('scope-total').textContent = (data.total_items || 0).toLocaleString();
        document.getElementById('scope-decided').textContent = (data.decided_items || 0).toLocaleString();
        document.getElementById('scope-pending').textContent = ((data.total_items || 0) - (data.decided_items || 0)).toLocaleString();
        localStorage.setItem('amplifi_review_token', token);
        currentToken = token;
        initReviewDOD(token);
      } catch(err) {
        document.getElementById('token-error').textContent = err.message;
        document.getElementById('token-error').classList.remove('hidden');
      }
    }

    // ── Initialize DataObjectDisplay for review items ────────────────────
    function initReviewDOD(token) {
      if (reviewDod) {
        // Update data endpoint if token changed
        reviewDod.dataEndpoint = '/api/review/' + token + '/items';
        reviewDod._page = 1;
        reviewDod.loadData(function() { reviewDod.render(); });
        return;
      }

      reviewDod = new window.DataObjectDisplay({
        objectType: 'review-items',
        containerId: 'review-dod-container',
        dataEndpoint: '/api/review/' + token + '/items',
        hierarchyEndpoint: '/api/legacy/hierarchies',
        authHeaders: authHeaders(),
        identityField: 'cctr',
        showHierarchyPicker: true,
        showViewToggle: true,
        showSearch: true,
        showPagination: true,
        showCSV: true,
        pageSize: 50,
        hierPageSize: 5000,
        columns: [
          { key: 'cctr', label: 'Cost Center' },
          { key: 'txtsh', label: 'Description' },
          { key: 'ccode', label: 'Entity' },
          { key: 'cleansing_outcome', label: 'Proposal' },
          { key: 'target_object', label: 'Target' },
          { key: 'decision', label: 'Status' },
          { key: 'responsible', label: 'Responsible' },
          { key: 'coarea', label: 'Co. Area' }
        ],
        excludeColumns: ['id', 'proposal_id', 'comment', 'confidence', 'rule_path', 'merge_into_cctr', 'txtmi', 'cctrcgy', 'currency', 'pctr', 'entity_code', 'routine_outputs'],
        toolbarButtons: [
          { label: '+ Request New CC/PC', className: 'text-xs px-3 py-1.5 rounded border border-blue-400 bg-blue-50 text-blue-700 hover:bg-blue-100 font-medium', title: 'Request a new center', onclick: function() { openNewCenterModal(); } },
          { label: 'Approve All Pending', className: 'text-xs px-3 py-1.5 rounded bg-green-600 text-white hover:bg-green-700 font-medium', title: 'Approve all pending items', onclick: function() { approveAll(); } },
          { label: 'Complete Review', className: 'text-xs px-3 py-1.5 rounded bg-amplifi-600 text-white hover:bg-amplifi-700 font-medium', title: 'Complete this review', onclick: function() { completeReview(); } }
        ],
        rowActions: [
          { label: 'Approve', className: 'text-xs px-2 py-0.5 rounded bg-green-50 text-green-700 border border-green-200 hover:bg-green-100 mr-1', title: 'Approve', onclick: function(row) { decideItem(row.id, 'APPROVED'); } },
          { label: 'Reject', className: 'text-xs px-2 py-0.5 rounded bg-red-50 text-red-700 border border-red-200 hover:bg-red-100 mr-1', title: 'Reject', onclick: function(row) { decideItem(row.id, 'NOT_REQUIRED'); } },
          { label: 'Clone', className: 'text-xs px-2 py-0.5 rounded bg-gray-50 text-gray-600 border border-gray-200 hover:bg-gray-100', title: 'Clone as new center', onclick: function(row) {
            if (row._hierNode) {
              openNewCenterModal({ hierNode: row._hierNode });
            } else {
              openNewCenterModal({ cloneFrom: row.cctr, name: row.txtsh, ccode: row.ccode, responsible: row.responsible });
            }
          }}
        ],
        onRowClick: function(row) { showWhyPanel(row); }
      });

      reviewDod.loadDisplayConfig(function() {
        reviewDod.loadHierarchyOptions(function() {
          reviewDod.loadData(function() {
            reviewDod.render();
          });
        });
      });
    }

    // ── Actions ─────────────────────────────────────────────────────────
    async function decideItem(itemId, decision) {
      try {
        await fetch('/api/review/' + currentToken + '/items/' + itemId + '/decide', {
          method: 'POST', headers: authHeaders(),
          body: JSON.stringify({ decision: decision })
        });
        reviewDod.loadData(function() { reviewDod.render(); });
        refreshScopeSummary();
      } catch(e) { alert('Failed: ' + e.message); }
    }

    async function approveAll() {
      if (!confirm('Approve all pending items?')) return;
      try {
        var res = await fetch('/api/review/' + currentToken + '/items?page=1&size=9999', { headers: authHeaders() });
        var data = await res.json();
        var pendingIds = (data.items || []).filter(function(i) { return !i.decision || i.decision === 'PENDING'; }).map(function(i) { return i.id; });
        if (pendingIds.length === 0) { alert('No pending items'); return; }
        await fetch('/api/review/' + currentToken + '/items/bulk-decide', {
          method: 'POST', headers: authHeaders(),
          body: JSON.stringify({ item_ids: pendingIds, decision: 'APPROVE' })
        });
        reviewDod.loadData(function() { reviewDod.render(); });
        refreshScopeSummary();
      } catch(e) { alert('Failed: ' + e.message); }
    }

    async function completeReview() {
      if (!confirm('Complete this review? This cannot be undone.')) return;
      try {
        await fetch('/api/review/' + currentToken + '/complete', { method: 'POST', headers: authHeaders() });
        alert('Review completed successfully!');
        localStorage.removeItem('amplifi_review_token');
        window.location.reload();
      } catch(e) { alert('Failed: ' + e.message); }
    }

    async function refreshScopeSummary() {
      try {
        var res = await fetch('/api/review/' + currentToken, { headers: authHeaders() });
        if (!res.ok) return;
        var data = await res.json();
        document.getElementById('scope-total').textContent = (data.total_items || 0).toLocaleString();
        document.getElementById('scope-decided').textContent = (data.decided_items || 0).toLocaleString();
        document.getElementById('scope-pending').textContent = ((data.total_items || 0) - (data.decided_items || 0)).toLocaleString();
      } catch(e) {}
    }

    // ── Why panel ───────────────────────────────────────────────────────
    function showWhyPanel(item) {
      var panel = document.getElementById('why-panel');
      var content = document.getElementById('why-content');
      panel.classList.remove('hidden');
      var html = '<div class="grid grid-cols-2 gap-3">';
      html += '<div><span class="text-gray-500">Cost Center:</span> <span class="font-mono font-medium">' + escapeHtml(item.cctr || '--') + '</span></div>';
      html += '<div><span class="text-gray-500">Description:</span> ' + escapeHtml(item.txtsh || item.txtmi || '--') + '</div>';
      html += '<div><span class="text-gray-500">Entity:</span> ' + escapeHtml(item.entity_code || item.ccode || '--') + '</div>';
      html += '<div><span class="text-gray-500">Proposal:</span> <span class="font-medium">' + escapeHtml(item.cleansing_outcome || '--') + '</span></div>';
      html += '<div><span class="text-gray-500">Target:</span> ' + escapeHtml(item.target_object || item.merge_into_cctr || 'N/A') + '</div>';
      html += '<div><span class="text-gray-500">Confidence:</span> ' + ((parseFloat(item.confidence) || 0) * 100).toFixed(0) + '%</div>';
      html += '</div>';
      if (item.rule_path) {
        html += '<div class="mt-3 p-3 bg-gray-50 rounded"><h4 class="text-xs font-medium text-gray-600 mb-1">Rule Path</h4><p class="text-xs text-gray-700">' + escapeHtml(item.rule_path) + '</p></div>';
      }
      content.innerHTML = html;
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── Load review button ──────────────────────────────────────────────
    document.getElementById('load-review-btn').addEventListener('click', function() {
      var token = document.getElementById('review-token').value.trim();
      if (!token) return;
      document.getElementById('token-error').classList.add('hidden');
      loadScope(token);
    });

    // ── Auto-load assigned review scopes ────────────────────────────────
    (async function() {
      try {
        var res = await fetch('/api/waves/review-scopes', { headers: authHeaders() });
        if (!res.ok) return;
        var scopes = await res.json();
        if (!scopes || !scopes.length) return;

        var container = document.getElementById('assigned-scopes');
        var list = document.getElementById('assigned-scopes-list');
        container.classList.remove('hidden');

        var html = '';
        scopes.forEach(function(s) {
          var statusColor = s.status === 'completed' ? 'bg-green-100 text-green-700' :
                            s.status === 'in_progress' ? 'bg-blue-100 text-blue-700' :
                            'bg-gray-100 text-gray-700';
          var pct = s.total_items ? Math.round((s.decided_items || 0) / s.total_items * 100) : 0;
          html += '<div class="card hover:shadow-md transition-shadow cursor-pointer border-l-4 border-amplifi-500" data-scope-token="' + escapeHtml(s.token || '') + '">' +
            '<div class="flex items-center justify-between mb-2">' +
            '<h3 class="font-semibold text-gray-900">' + escapeHtml(s.name || 'Review Scope') + '</h3>' +
            '<span class="px-2 py-0.5 rounded-full text-xs font-medium ' + statusColor + '">' + escapeHtml(s.status || 'pending') + '</span>' +
            '</div>' +
            '<div class="flex items-center gap-4 text-xs text-gray-500">' +
            '<span>Wave: ' + escapeHtml(s.wave_name || '-') + '</span>' +
            '<span>Type: ' + escapeHtml(s.scope_type || '-') + '</span>' +
            '<span>' + (s.decided_items || 0) + ' / ' + (s.total_items || 0) + ' decided (' + pct + '%)</span>' +
            '</div>' +
            '<div class="mt-2 h-1.5 bg-gray-200 rounded-full"><div class="h-full bg-amplifi-500 rounded-full" style="width:' + pct + '%"></div></div>' +
            '</div>';
        });
        list.innerHTML = html;

        list.querySelectorAll('[data-scope-token]').forEach(function(card) {
          card.addEventListener('click', function() {
            var token = this.getAttribute('data-scope-token');
            if (token) loadScope(token);
          });
        });

        if (scopes.length === 1 && !currentToken && scopes[0].token) {
          loadScope(scopes[0].token);
        }
      } catch(e) { /* ignore */ }
    })();

    // Auto-load if token saved
    if (currentToken) {
      document.getElementById('review-token').value = currentToken;
      loadScope(currentToken);
    }

    // ── Request New / Clone Modal ──────────────────────────────────────
    var modal = document.getElementById('new-center-modal');
    function openNewCenterModal(opts) {
      opts = opts || {};
      document.getElementById('nc-clone-from').value = opts.cloneFrom || '';
      document.getElementById('nc-name').value = opts.name || '';
      document.getElementById('nc-ccode').value = opts.ccode || '';
      document.getElementById('nc-responsible').value = opts.responsible || '';
      document.getElementById('nc-coarea').value = '';
      document.getElementById('nc-purpose').value = '';
      // Set hierarchy picker
      var hierSelect = document.getElementById('nc-hier-node');
      if (opts.hierNode) {
        // Try to select the matching option
        for (var i = 0; i < hierSelect.options.length; i++) {
          if (hierSelect.options[i].value === opts.hierNode) { hierSelect.selectedIndex = i; break; }
        }
      } else {
        hierSelect.selectedIndex = 0;
      }
      if (opts.cloneFrom) {
        document.getElementById('new-center-title').textContent = 'Clone Center: ' + opts.cloneFrom;
        document.getElementById('nc-clone-info').classList.remove('hidden');
        document.getElementById('nc-clone-label').textContent = opts.cloneFrom + (opts.name ? ' — ' + opts.name : '');
      } else {
        document.getElementById('new-center-title').textContent = 'Request New Center';
        document.getElementById('nc-clone-info').classList.add('hidden');
      }
      modal.classList.remove('hidden');
    }
    window.openNewCenterModal = openNewCenterModal;

    function closeModal() { modal.classList.add('hidden'); }
    document.getElementById('close-new-modal').addEventListener('click', closeModal);
    document.getElementById('cancel-new-center').addEventListener('click', closeModal);

    // Submit new center request
    document.getElementById('new-center-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!currentToken) return alert('No active review scope');
      var body = {
        purpose: document.getElementById('nc-purpose').value.trim(),
        target_object: document.getElementById('nc-target-object').value,
        responsible: document.getElementById('nc-responsible').value.trim() || null,
        proposed_name: document.getElementById('nc-name').value.trim() || null,
        proposed_ccode: document.getElementById('nc-ccode').value.trim() || null,
        proposed_coarea: document.getElementById('nc-coarea').value.trim() || null,
        hierarchy_node: document.getElementById('nc-hier-node').value || null,
        clone_from: document.getElementById('nc-clone-from').value.trim() || null,
      };
      if (!body.purpose) return alert('Please provide a purpose/justification');
      try {
        var res = await fetch('/api/review/' + currentToken + '/items/request-new', {
          method: 'POST',
          headers: authHeaders(),
          body: JSON.stringify(body)
        });
        if (!res.ok) { var err = await res.json().catch(function(){return {};}); throw new Error(err.detail || 'Request failed'); }
        closeModal();
        if (reviewDod) { reviewDod.loadData(function() { reviewDod.render(); }); }
        refreshScopeSummary();
        alert('Request submitted! The admin will review it.');
      } catch(err) {
        alert('Error: ' + err.message);
      }
    });

    // ── Load hierarchy nodes for the picker ─────────────────────────────
    (async function loadHierNodePicker() {
      function flattenTree(nodes, result) {
        (nodes || []).forEach(function(n) {
          if (n.type === 'node' || (n.children && n.children.length)) {
            result.push({ setname: n.setname, leaf_count: n.leaf_count || 0 });
          }
          if (n.children) flattenTree(n.children, result);
        });
      }
      try {
        var res = await fetch('/api/legacy/hierarchies?size=200', { headers: authHeaders() });
        if (!res.ok) return;
        var data = await res.json();
        var hiers = data.items || data || [];
        if (!hiers.length) return;
        var select = document.getElementById('nc-hier-node');
        for (var h = 0; h < hiers.length; h++) {
          var hier = hiers[h];
          var hierId = hier.id;
          var hierName = hier.description || hier.setname || hier.name || ('Hierarchy ' + hierId);
          try {
            var treeRes = await fetch('/api/legacy/hierarchies/' + hierId + '/tree', { headers: authHeaders() });
            if (!treeRes.ok) continue;
            var treeData = await treeRes.json();
            var flatNodes = [];
            flattenTree(treeData.tree || [], flatNodes);
            if (flatNodes.length) {
              var optgroup = document.createElement('optgroup');
              optgroup.label = hierName;
              flatNodes.forEach(function(n) {
                var opt = document.createElement('option');
                opt.value = n.setname;
                opt.textContent = n.setname + ' (' + n.leaf_count + ' items)';
                optgroup.appendChild(opt);
              });
              select.appendChild(optgroup);
            }
          } catch(e) { /* skip */ }
        }
      } catch(e) { /* ignore */ }
    })();
  })();
</script>
