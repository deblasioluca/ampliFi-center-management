---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="My Tasks" requireAuth={true}>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">My Tasks</h1>
    <p class="text-sm text-gray-500 mt-1">Review your assigned cost centers, request changes, and approve proposals</p>
  </div>

  <!-- Info banner when no review token -->
  <div id="no-review" class="card mb-6">
    <div class="flex items-start gap-4">
      <svg class="w-8 h-8 text-amplifi-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="text-base font-semibold text-gray-900">No Active Review Scope</h3>
        <p class="text-sm text-gray-500 mt-1">
          You don't have an active review assignment right now. When a wave is in the review phase,
          you'll receive a review link with a personal token. Enter it below to access your scope.
        </p>
        <div class="mt-4 flex gap-3 items-end">
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">Review Token</label>
            <input type="text" id="review-token" class="input" placeholder="Paste your review token here..." />
          </div>
          <button id="load-review-btn" class="btn-amplifi whitespace-nowrap">Load Review</button>
        </div>
        <div id="token-error" class="text-sm text-red-600 mt-2 hidden"></div>
      </div>
    </div>
  </div>

  <!-- Review scope (shown when token loaded) -->
  <div id="review-scope" class="hidden">
    <!-- Scope summary -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Wave</h4>
        <p id="scope-wave" class="text-lg font-bold text-gray-900 mt-1">--</p>
      </div>
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Total Items</h4>
        <p id="scope-total" class="text-lg font-bold text-gray-900 mt-1">--</p>
      </div>
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Decided</h4>
        <p id="scope-decided" class="text-lg font-bold text-green-600 mt-1">--</p>
      </div>
      <div class="card">
        <h4 class="text-sm font-medium text-gray-500">Pending</h4>
        <p id="scope-pending" class="text-lg font-bold text-amber-600 mt-1">--</p>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="card mb-4">
      <div class="flex flex-wrap items-center gap-3">
        <input type="text" id="review-search" class="input text-sm flex-1 min-w-[200px]" placeholder="Search by cost center, entity, or proposal..." />
        <select id="review-filter-status" class="input text-sm w-40">
          <option value="">All statuses</option>
          <option value="pending">Pending only</option>
          <option value="decided">Decided only</option>
        </select>
        <select id="review-filter-action" class="input text-sm w-40">
          <option value="">All proposals</option>
          <option value="KEEP">KEEP</option>
          <option value="RETIRE">RETIRE</option>
          <option value="MERGE_MAP">MERGE/MAP</option>
          <option value="REDESIGN">REDESIGN</option>
        </select>
      </div>
    </div>

    <!-- Review items table -->
    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Review Items</h2>
        <div class="flex gap-2">
          <button id="approve-all-btn" class="btn-success text-xs">Approve All Pending</button>
          <button id="complete-review-btn" class="btn-primary text-xs">Complete Review</button>
        </div>
      </div>

      <p class="text-xs text-gray-500 mb-3">Click a row to see the analysis reasoning (why this proposal was made).</p>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left py-2 px-3 font-medium text-gray-500">Cost Center</th>
              <th class="text-left py-2 px-3 font-medium text-gray-500">Description</th>
              <th class="text-left py-2 px-3 font-medium text-gray-500">Entity</th>
              <th class="text-left py-2 px-3 font-medium text-gray-500">Proposal</th>
              <th class="text-left py-2 px-3 font-medium text-gray-500">Target</th>
              <th class="text-left py-2 px-3 font-medium text-gray-500">Status</th>
              <th class="text-left py-2 px-3 font-medium text-gray-500">Actions</th>
            </tr>
          </thead>
          <tbody id="review-items">
            <tr><td colspan="7" class="py-8 text-center text-gray-400">Loading...</td></tr>
          </tbody>
        </table>
      </div>

      <div id="review-pagination" class="mt-4 flex justify-center gap-2"></div>
    </div>

    <!-- Why Panel (hidden, shown on row click) -->
    <div id="why-panel" class="card mt-4 hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-base font-semibold text-gray-900">Analysis Reasoning</h3>
        <button onclick="document.getElementById('why-panel').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-sm">Close</button>
      </div>
      <div id="why-content" class="text-sm space-y-2">Loading...</div>
    </div>
  </div>
</Layout>

<script is:inline>
  (function() {
    var currentToken = localStorage.getItem('amplifi_review_token') || '';
    var currentPage = 1;

    function authHeaders() {
      var t = localStorage.getItem('amplifi_token');
      return t ? { 'Authorization': 'Bearer ' + t, 'Content-Type': 'application/json' } : { 'Content-Type': 'application/json' };
    }

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text || '';
      return div.innerHTML;
    }

    async function loadScope(token) {
      try {
        var res = await fetch('/api/review/' + token, { headers: authHeaders() });
        if (!res.ok) throw new Error((await res.json().catch(function(){return {};})).detail || 'Invalid token');
        var data = await res.json();
        document.getElementById('no-review').classList.add('hidden');
        document.getElementById('review-scope').classList.remove('hidden');
        document.getElementById('scope-wave').textContent = data.wave_code || data.wave_id || '--';
        document.getElementById('scope-total').textContent = (data.total_items || 0).toLocaleString();
        document.getElementById('scope-decided').textContent = (data.decided_items || 0).toLocaleString();
        document.getElementById('scope-pending').textContent = ((data.total_items || 0) - (data.decided_items || 0)).toLocaleString();
        localStorage.setItem('amplifi_review_token', token);
        currentToken = token;
        loadItems(token, 1);
      } catch(err) {
        document.getElementById('token-error').textContent = err.message;
        document.getElementById('token-error').classList.remove('hidden');
      }
    }

    async function loadItems(token, page) {
      currentPage = page;
      var tbody = document.getElementById('review-items');
      tbody.innerHTML = '<tr><td colspan="7" class="py-8 text-center text-gray-400">Loading...</td></tr>';
      try {
        var res = await fetch('/api/review/' + token + '/items?page=' + page + '&size=20', { headers: authHeaders() });
        if (!res.ok) throw new Error('Failed to load items');
        var data = await res.json();
        tbody.innerHTML = '';
        if (!data.items || data.items.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" class="py-8 text-center text-gray-400">No items found</td></tr>';
          return;
        }
        // Apply client-side search/filter
        var searchVal = (document.getElementById('review-search').value || '').toLowerCase();
        var statusFilter = document.getElementById('review-filter-status').value;
        var actionFilter = document.getElementById('review-filter-action').value;
        var filtered = data.items.filter(function(item) {
          if (searchVal) {
            var text = ((item.legacy_cc_code || '') + ' ' + (item.cc_code || '') + ' ' + (item.entity_name || '') + ' ' + (item.cleansing_action || '') + ' ' + (item.cc_description || '')).toLowerCase();
            if (text.indexOf(searchVal) === -1) return false;
          }
          if (statusFilter === 'pending' && item.stakeholder_decision && item.stakeholder_decision !== 'pending') return false;
          if (statusFilter === 'decided' && (!item.stakeholder_decision || item.stakeholder_decision === 'pending')) return false;
          if (actionFilter && (item.cleansing_action || '').toUpperCase() !== actionFilter) return false;
          return true;
        });
        if (filtered.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" class="py-8 text-center text-gray-400">No items match your filters</td></tr>';
          return;
        }
        var actionColors = { KEEP: 'bg-green-50 text-green-700', RETIRE: 'bg-red-50 text-red-700', MERGE_MAP: 'bg-purple-50 text-purple-700', REDESIGN: 'bg-blue-50 text-blue-700' };
        filtered.forEach(function(item) {
          var tr = document.createElement('tr');
          tr.className = 'border-b border-gray-100 hover:bg-blue-50 cursor-pointer';
          tr.setAttribute('data-item-id', item.id);
          var decided = item.stakeholder_decision && item.stakeholder_decision !== 'pending';
          var actionCls = actionColors[(item.cleansing_action || '').toUpperCase()] || 'bg-amplifi-50 text-amplifi-700';
          tr.innerHTML =
            '<td class="py-2 px-3 font-mono text-xs">' + escapeHtml(item.legacy_cc_code || item.cc_code || '--') + '</td>' +
            '<td class="py-2 px-3 text-xs max-w-[200px] truncate">' + escapeHtml(item.cc_description || item.cc_name || '--') + '</td>' +
            '<td class="py-2 px-3 text-xs">' + escapeHtml(item.entity_name || '--') + '</td>' +
            '<td class="py-2 px-3"><span class="text-xs px-2 py-0.5 rounded ' + actionCls + '">' + escapeHtml(item.cleansing_action || '--') + '</span></td>' +
            '<td class="py-2 px-3 text-xs">' + escapeHtml(item.target_cc_code || item.mapping_target || '--') + '</td>' +
            '<td class="py-2 px-3">' + (decided
              ? '<span class="text-xs px-2 py-0.5 rounded bg-green-50 text-green-700">' + escapeHtml(item.stakeholder_decision) + '</span>'
              : '<span class="text-xs px-2 py-0.5 rounded bg-amber-50 text-amber-700">pending</span>') + '</td>' +
            '<td class="py-2 px-3">' + (decided ? '<span class="text-xs text-gray-400">Done</span>' :
              '<button data-id="' + item.id + '" data-action="APPROVE" class="decide-btn text-xs px-2 py-1 bg-green-50 text-green-700 rounded hover:bg-green-100 mr-1">Approve</button>' +
              '<button data-id="' + item.id + '" data-action="REJECT" class="decide-btn text-xs px-2 py-1 bg-red-50 text-red-700 rounded hover:bg-red-100">Reject</button>') + '</td>';
          // Row click to show why panel
          tr.addEventListener('click', function(e) {
            if (e.target.tagName === 'BUTTON') return;
            showWhyPanel(item);
          });
          tbody.appendChild(tr);
        });

        // Click handlers
        tbody.querySelectorAll('.decide-btn').forEach(function(btn) {
          btn.addEventListener('click', async function() {
            var itemId = this.getAttribute('data-id');
            var decision = this.getAttribute('data-action');
            try {
              await fetch('/api/review/' + currentToken + '/items/' + itemId + '/decide', {
                method: 'POST', headers: authHeaders(),
                body: JSON.stringify({ decision: decision })
              });
              loadItems(currentToken, currentPage);
              loadScope(currentToken);
            } catch(e) { alert('Failed: ' + e.message); }
          });
        });

        // Pagination
        var pag = document.getElementById('review-pagination');
        pag.innerHTML = '';
        var totalPages = Math.ceil((data.total || 0) / 20);
        for (var p = 1; p <= totalPages; p++) {
          var btn = document.createElement('button');
          btn.textContent = p;
          btn.className = p === page ? 'btn-amplifi text-xs px-3 py-1' : 'btn-secondary text-xs px-3 py-1';
          btn.setAttribute('data-page', p);
          btn.addEventListener('click', function() { loadItems(currentToken, parseInt(this.getAttribute('data-page'))); });
          pag.appendChild(btn);
        }
      } catch(e) {
        tbody.innerHTML = '<tr><td colspan="7" class="py-8 text-center text-red-500">' + escapeHtml(e.message) + '</td></tr>';
      }
    }

    // Load review button
    document.getElementById('load-review-btn').addEventListener('click', function() {
      var token = document.getElementById('review-token').value.trim();
      if (!token) return;
      document.getElementById('token-error').classList.add('hidden');
      loadScope(token);
    });

    // Approve all pending
    document.getElementById('approve-all-btn').addEventListener('click', async function() {
      if (!confirm('Approve all pending items?')) return;
      try {
        var res = await fetch('/api/review/' + currentToken + '/items?page=1&size=9999', { headers: authHeaders() });
        var data = await res.json();
        var pendingIds = (data.items || []).filter(function(i) { return !i.stakeholder_decision || i.stakeholder_decision === 'pending'; }).map(function(i) { return i.id; });
        if (pendingIds.length === 0) { alert('No pending items'); return; }
        await fetch('/api/review/' + currentToken + '/items/bulk-decide', {
          method: 'POST', headers: authHeaders(),
          body: JSON.stringify({ item_ids: pendingIds, decision: 'APPROVE' })
        });
        loadScope(currentToken);
      } catch(e) { alert('Failed: ' + e.message); }
    });

    // Complete review
    document.getElementById('complete-review-btn').addEventListener('click', async function() {
      if (!confirm('Complete this review? This cannot be undone.')) return;
      try {
        await fetch('/api/review/' + currentToken + '/complete', { method: 'POST', headers: authHeaders() });
        alert('Review completed successfully!');
        localStorage.removeItem('amplifi_review_token');
        window.location.reload();
      } catch(e) { alert('Failed: ' + e.message); }
    });

    // Why panel
    function showWhyPanel(item) {
      var panel = document.getElementById('why-panel');
      var content = document.getElementById('why-content');
      panel.classList.remove('hidden');
      var html = '<div class="grid grid-cols-2 gap-3">';
      html += '<div><span class="text-gray-500">Cost Center:</span> <span class="font-mono font-medium">' + escapeHtml(item.legacy_cc_code || item.cc_code || '--') + '</span></div>';
      html += '<div><span class="text-gray-500">Description:</span> ' + escapeHtml(item.cc_description || item.cc_name || '--') + '</div>';
      html += '<div><span class="text-gray-500">Entity:</span> ' + escapeHtml(item.entity_name || '--') + '</div>';
      html += '<div><span class="text-gray-500">Proposal:</span> <span class="font-medium">' + escapeHtml(item.cleansing_action || '--') + '</span></div>';
      html += '<div><span class="text-gray-500">Target:</span> ' + escapeHtml(item.target_cc_code || item.mapping_target || 'N/A') + '</div>';
      html += '<div><span class="text-gray-500">Confidence:</span> ' + ((item.confidence || 0) * 100).toFixed(0) + '%</div>';
      html += '</div>';
      if (item.reasoning || item.why) {
        html += '<div class="mt-3 p-3 bg-gray-50 rounded"><h4 class="text-xs font-medium text-gray-600 mb-1">Reasoning</h4><p class="text-xs text-gray-700">' + escapeHtml(item.reasoning || item.why) + '</p></div>';
      }
      if (item.routine_outputs && item.routine_outputs.length) {
        html += '<div class="mt-3"><h4 class="text-xs font-medium text-gray-600 mb-1">Routine Outputs</h4><div class="space-y-1">';
        item.routine_outputs.forEach(function(r) {
          html += '<div class="text-xs p-2 bg-gray-50 rounded"><span class="font-medium">' + escapeHtml(r.routine_code || r.code) + ':</span> ' + escapeHtml(r.verdict || r.outcome) + ' — ' + escapeHtml(r.reason || '') + '</div>';
        });
        html += '</div></div>';
      }
      content.innerHTML = html;
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // Search/filter handlers
    document.getElementById('review-search').addEventListener('input', function() {
      clearTimeout(this._t);
      var self = this;
      this._t = setTimeout(function() { if (currentToken) loadItems(currentToken, currentPage); }, 300);
    });
    document.getElementById('review-filter-status').addEventListener('change', function() { if (currentToken) loadItems(currentToken, currentPage); });
    document.getElementById('review-filter-action').addEventListener('change', function() { if (currentToken) loadItems(currentToken, currentPage); });

    // Auto-load if token saved
    if (currentToken) {
      document.getElementById('review-token').value = currentToken;
      loadScope(currentToken);
    }

    // Keyboard navigation for review items table
    var selectedRow = -1;
    document.addEventListener('keydown', function(e) {
      var table = document.querySelector('#review-items-table tbody');
      if (!table) return;
      var rows = table.querySelectorAll('tr');
      if (!rows.length) return;

      if (e.key === 'ArrowDown' || e.key === 'j') {
        e.preventDefault();
        selectedRow = Math.min(selectedRow + 1, rows.length - 1);
        highlightRow(rows);
      } else if (e.key === 'ArrowUp' || e.key === 'k') {
        e.preventDefault();
        selectedRow = Math.max(selectedRow - 1, 0);
        highlightRow(rows);
      } else if (e.key === 'Enter' && selectedRow >= 0) {
        e.preventDefault();
        var btn = rows[selectedRow].querySelector('button');
        if (btn) btn.click();
      } else if (e.key === 'a' && selectedRow >= 0) {
        // Quick approve
        var approveBtn = rows[selectedRow].querySelector('.btn-approve');
        if (approveBtn) approveBtn.click();
      } else if (e.key === 'r' && selectedRow >= 0) {
        // Quick reject
        var rejectBtn = rows[selectedRow].querySelector('.btn-reject');
        if (rejectBtn) rejectBtn.click();
      }
    });

    function highlightRow(rows) {
      rows.forEach(function(r, i) {
        r.classList.toggle('bg-amplifi-50', i === selectedRow);
        r.classList.toggle('ring-2', i === selectedRow);
        r.classList.toggle('ring-amplifi-300', i === selectedRow);
      });
      if (selectedRow >= 0 && rows[selectedRow]) {
        rows[selectedRow].scrollIntoView({ block: 'nearest' });
      }
    }
  })();
</script>
